# Analytics — public variables (safe to expose in browser)
PUBLIC_GA_ID=your-google-analytics-measurement-id   # Format: G-XXXXXXXXXX
PUBLIC_CF_BEACON=your-cloudflare-beacon-token        # From Cloudflare Web Analytics

# Cloudflare Functions — server-side secrets (set in Cloudflare Pages dashboard)
ANTHROPIC_API_KEY=your-anthropic-api-key             # From console.anthropic.com

# Build-time only — raises GitHub API rate limit from 60 to 5000 req/hr (public_repo scope, read-only)
GITHUB_TOKEN=your-github-personal-access-token
