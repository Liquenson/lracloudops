{
	"compatibility_date": "2026-05-06",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "lracloudops",
	"pages_build_output_dir": "./dist",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}