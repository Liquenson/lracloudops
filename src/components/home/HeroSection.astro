---
import FlowDiagram from '../FlowDiagram.astro'

interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props

const contactHref = lang === 'es' ? '/contacto' : '/contact'
const projectsHref = lang === 'es' ? '/proyectos' : '/projects'
const assessmentHref = '/assessment'

const industries =
  lang === 'es'
    ? [
        {
          label: 'Salud',
          path: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
        },
        {
          label: 'Fintech',
          path: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z',
        },
        {
          label: 'SaaS',
          path: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
        },
        {
          label: 'Enterprise',
          path: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z',
        },
      ]
    : [
        {
          label: 'Healthcare',
          path: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
        },
        {
          label: 'Fintech',
          path: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z',
        },
        {
          label: 'SaaS',
          path: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
        },
        {
          label: 'Enterprise',
          path: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z',
        },
      ]

const terminalLabel =
  lang === 'es'
    ? 'Terminal mostrando comandos de Terraform y Kubernetes'
    : 'Terminal output showing Terraform and Kubernetes commands'
const ciLabel =
  lang === 'es'
    ? 'Todas las etapas CI/CD completadas'
    : 'All CI/CD stages passed'
const industriesLabel =
  lang === 'es' ? 'Industrias atendidas' : 'Industries served'
const deployBadge = lang === 'es' ? 'Despliegue exitoso' : 'Deploy successful'
const deployTime =
  lang === 'es' ? 'aws-production · hace 2m' : 'aws-production · 2m ago'
const nodesHealthy =
  lang === 'es' ? '3/3 nodos saludables' : '3/3 nodes healthy'
const trustItems =
  lang === 'es'
    ? ['Respuesta en 24h', 'Sin contratos de permanencia']
    : ['Response within 24h', 'No lock-in contracts']
const assessmentText =
  lang === 'es' ? 'Assessment DevOps gratuito' : 'Free DevOps assessment'
const sectorText =
  lang === 'es'
    ? 'Infraestructura AWS, Azure y Google Cloud — diseñada para producción en salud, fintech y plataformas cloud'
    : 'AWS, Azure and Google Cloud infrastructure — built for production across healthcare, fintech and cloud-native platforms'
const flowLabel =
  lang === 'es' ? 'Flujo de plataforma típico' : 'Typical platform flow'
const flowChecks =
  lang === 'es'
    ? [
        '✅ Infraestructura como código',
        '✅ Despliegues automáticos',
        '✅ Observabilidad integrada',
        '✅ Seguridad por diseño',
      ]
    : [
        '✅ Infrastructure as Code',
        '✅ Automated deployments',
        '✅ Built-in observability',
        '✅ Security by design',
      ]
const flowSteps =
  lang === 'es'
    ? [
        { label: 'GitHub', sublabel: 'Código', icon: 'github' },
        { label: 'Terraform', sublabel: 'IaC', icon: 'terraform' },
        { label: 'Amazon EKS', sublabel: 'Kubernetes' },
        { label: 'ArgoCD', sublabel: 'GitOps', icon: 'argo' },
        { label: 'Production', sublabel: 'Workloads' },
      ]
    : [
        { label: 'GitHub', sublabel: 'Code', icon: 'github' },
        { label: 'Terraform', sublabel: 'IaC', icon: 'terraform' },
        { label: 'Amazon EKS', sublabel: 'Kubernetes' },
        { label: 'ArgoCD', sublabel: 'GitOps', icon: 'argo' },
        { label: 'Production', sublabel: 'Workloads' },
      ]
const h1FontSize =
  lang === 'es'
    ? 'text-[34px] sm:text-[52px] lg:text-[68px]'
    : 'text-[34px] sm:text-[52px] lg:text-[62px]'
---

<section
  class="relative overflow-hidden hero-gradient"
  aria-labelledby="hero-heading"
>
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.06) 1px, transparent 0); background-size: 32px 32px;"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 80% 50% at 50% 100%, rgba(30,111,255,0.15) 0%, transparent 60%);"
  >
  </div>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-px pointer-events-none"
    aria-hidden="true"
    style="background: linear-gradient(90deg, transparent, rgba(96,165,250,0.4), transparent);"
  >
  </div>

  <div
    class="relative max-w-7xl mx-auto px-5 sm:px-6 py-14 sm:py-24 lg:py-32 grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-14 lg:gap-20 items-center"
  >
    <div class="animate-fade-left">
      <div
        class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full mb-8 text-xs font-semibold"
        style="background: rgba(37,99,235,0.15); border: 1px solid rgba(96,165,250,0.3); color: #93C5FD;"
      >
        <span
          class="w-2 h-2 rounded-full flex-shrink-0 animate-pulse-soft"
          style="background: #60A5FA;"
          aria-hidden="true"></span>
        Platform Engineering &middot; AWS &middot; Azure &middot; GCP &middot; Kubernetes
      </div>

      <h1
        id="hero-heading"
        class={`${h1FontSize} font-extrabold text-white leading-[1.04] mb-7`}
        style="letter-spacing: -0.035em;"
      >
        {
          lang === 'es' ? (
            <Fragment>
              Ingeniería de plataformas
              <br />
              para infraestructuras
              <>
                <br />
                <span style="color: #60A5FA;">que deben funcionar.</span>
              </>
            </Fragment>
          ) : (
            <Fragment>
              Platform Engineering
              <br />
              for Infrastructure
              <>
                <br />
                <span style="color: #60A5FA;">That Must Work.</span>
              </>
            </Fragment>
          )
        }
      </h1>

      <p
        class="text-lg sm:text-xl leading-relaxed mb-5 max-w-[520px]"
        style="color: var(--color-navy-muted);"
      >
        {
          lang === 'es'
            ? 'Infraestructura reproducible. Entrega automatizada. Resiliencia operacional desde el primer día. Sin aprovisionamiento manual, sin arquitectura improvisada, sin cambios sin trazabilidad.'
            : 'Reproducible infrastructure. Automated delivery. Operational resilience from day one. No manual provisioning, no improvised architecture, no untracked changes.'
        }
      </p>

      <div
        class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full mb-7 text-xs font-semibold"
        style="background: rgba(30,111,255,0.15); border: 1px solid rgba(96,165,250,0.25); color: #93C5FD;"
      >
        <span
          class="w-1.5 h-1.5 rounded-full flex-shrink-0"
          style="background: #34D399;"
          aria-hidden="true"></span>
        {
          lang === 'es'
            ? '✦ Potenciado por Claude Sonnet · IA aplicada a DevOps'
            : '✦ Powered by Claude Sonnet · AI applied to DevOps'
        }
      </div>

      <div class="flex flex-wrap gap-4 mb-6">
        <a href={contactHref} class="btn btn-primary btn-lg btn-pill">
          {
            lang === 'es'
              ? 'Solicitar revisión de infraestructura'
              : 'Request an Infrastructure Review'
          }
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a href={projectsHref} class="btn btn-outline-white btn-lg btn-pill">
          {lang === 'es' ? 'Ver casos de estudio' : 'View Case Studies'}
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <p
        style="font-size: 0.875rem; color: rgba(255,255,255,0.7); margin-top: 1rem;"
      >
        {sectorText}
      </p>

      <div
        style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:1.25rem;"
        role="list"
        aria-label={industriesLabel}
      >
        {
          industries.map(({ label, path }) => (
            <span
              role="listitem"
              style="display:inline-flex; align-items:center; gap:0.375rem; font-size:0.7rem; font-weight:500; color:rgba(148,163,184,0.8); background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-radius:100px; padding:0.3rem 0.75rem;"
            >
              <svg
                style="width:0.875rem; height:0.875rem; flex-shrink:0; color:rgba(96,165,250,0.8);"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={path}
                />
              </svg>
              {label}
            </span>
          ))
        }
      </div>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        {
          trustItems.map((item) => (
            <span
              class="flex items-center gap-1.5 text-xs font-medium"
              style="color: rgba(148,163,184,0.65);"
            >
              <svg
                class="w-3.5 h-3.5 flex-shrink-0"
                style="color: #60A5FA;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              {item}
            </span>
          ))
        }
        <a
          href={assessmentHref}
          class="flex items-center gap-1.5 text-xs font-medium transition-colors hover:opacity-80"
          style="color: rgba(148,163,184,0.65);"
        >
          <svg
            class="w-3.5 h-3.5 flex-shrink-0"
            style="color: #60A5FA;"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M5 13l4 4L19 7"></path>
          </svg>
          {assessmentText}
        </a>
      </div>
    </div>

    <div
      class="relative flex justify-center lg:justify-end animate-fade-up delay-200"
    >
      <div class="relative w-full max-w-[510px]">
        <div
          class="absolute -inset-6 rounded-3xl pointer-events-none"
          aria-hidden="true"
          style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.25) 0%, transparent 70%); filter: blur(24px);"
        >
        </div>

        <div
          class="relative rounded-2xl overflow-hidden"
          style="background: #0d1117; border: 1px solid rgba(255,255,255,0.09); box-shadow: 0 40px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.04);"
        >
          <div
            class="flex items-center gap-2 px-4 py-3.5"
            style="background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.07);"
          >
            <div
              class="w-3 h-3 rounded-full"
              style="background: #FF5F57;"
              aria-hidden="true"
            >
            </div>
            <div
              class="w-3 h-3 rounded-full"
              style="background: #FEBC2E;"
              aria-hidden="true"
            >
            </div>
            <div
              class="w-3 h-3 rounded-full"
              style="background: #28C840;"
              aria-hidden="true"
            >
            </div>
            <div class="flex-1 text-center">
              <span
                class="text-xs font-mono"
                style="color: rgba(255,255,255,0.25);"
                >aws-production &middot; main</span
              >
            </div>
            <span
              class="w-1.5 h-1.5 rounded-full bg-emerald-400"
              aria-hidden="true"></span>
            <span
              class="text-xs font-mono"
              style="color: rgba(255,255,255,0.25);">live</span
            >
          </div>

          <div
            class="p-5 font-mono text-xs sm:text-sm leading-relaxed space-y-1"
            aria-label={terminalLabel}
          >
            <div class="flex items-center gap-2">
              <span style="color: #79C0FF;">❯</span>
              <span class="text-white">terraform apply --auto-approve</span>
            </div>
            <div
              class="mt-2 text-[0.68rem]"
              style="color: rgba(255,255,255,0.35);"
            >
              Plan: 14 to add, 0 to change, 0 to destroy.
            </div>
            <div class="space-y-0.5 mt-2">
              {
                [
                  ['aws_vpc.main', '6s'],
                  ['aws_eks_cluster.main', '2m 18s'],
                  ['aws_rds_cluster.db', '1m 44s'],
                  ['aws_cloudfront_distribution.cdn', '47s'],
                  ['module.alb.aws_lb.main', '52s'],
                ].map(([res, time]) => (
                  <div class="text-xs">
                    <span style="color: #3FB950;">✓</span>{' '}
                    <span style="color: rgba(255,255,255,0.5);">{res}</span>{' '}
                    <span style="color: rgba(255,255,255,0.22); font-size: 0.65rem;">
                      ({time})
                    </span>
                  </div>
                ))
              }
            </div>
            <div class="mt-2.5 text-xs font-semibold" style="color: #3FB950;">
              Apply complete! Resources: 14 added.
            </div>

            <div class="mt-5 flex items-center gap-2">
              <span style="color: #79C0FF;">❯</span>
              <span class="text-white">kubectl get pods -n production</span>
            </div>
            <div class="space-y-0.5 mt-1">
              {
                [
                  'webapp-7d4b9f-x2k9p',
                  'webapp-7d4b9f-m8n3q',
                  'webapp-7d4b9f-p9l1w',
                ].map((pod) => (
                  <div style="font-size: 0.68rem;">
                    <span style="color: rgba(255,255,255,0.5);">
                      {pod}&nbsp;&nbsp;
                    </span>
                    <span style="color: rgba(255,255,255,0.4);">
                      2/2&nbsp;&nbsp;
                    </span>
                    <span style="color: #3FB950;">Running</span>
                  </div>
                ))
              }
            </div>
            <div class="mt-4 flex items-center gap-1.5">
              <span style="color: #79C0FF;">❯</span>
              <span
                class="terminal-cursor w-1.5 h-4 inline-block rounded-sm"
                style="background: rgba(255,255,255,0.6);"
                aria-hidden="true"></span>
            </div>
          </div>

          <div
            class="px-5 pb-4 pt-2.5"
            style="border-top: 1px solid rgba(255,255,255,0.06);"
          >
            <div class="flex items-center gap-0.5" aria-label={ciLabel}>
              {
                ['Build', 'Test', 'Security', 'Docker', 'Deploy'].map(
                  (step, i) => (
                    <div class="flex items-center">
                      <div class="flex items-center gap-1 text-xs font-mono">
                        <span style="color: #3FB950;" aria-hidden="true">
                          ✓
                        </span>
                        <span style="color: rgba(255,255,255,0.4); font-size: 0.62rem;">
                          {step}
                        </span>
                      </div>
                      {i < 4 && (
                        <div
                          class="w-4 h-px mx-1"
                          style="background: rgba(63,185,80,0.3);"
                          aria-hidden="true"
                        />
                      )}
                    </div>
                  )
                )
              }
            </div>
          </div>
        </div>

        <div
          class="absolute -top-5 -right-2 sm:-right-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-400"
          style="border: 1px solid rgba(15,23,42,0.07);"
        >
          <div class="flex items-center gap-2 mb-0.5">
            <span class="w-2 h-2 rounded-full bg-emerald-400" aria-hidden="true"
            ></span>
            <span class="text-xs font-bold text-gray-800">{deployBadge}</span>
          </div>
          <p class="text-[10px]" style="color: #64748B;">{deployTime}</p>
        </div>

        <div
          class="absolute -bottom-5 -left-2 sm:-left-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-500"
          style="border: 1px solid rgba(15,23,42,0.07);"
        >
          <div class="flex items-center gap-2 mb-1">
            <svg
              class="w-3.5 h-3.5"
              style="color: #2563EB;"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"
              ></path>
            </svg>
            <span class="text-xs font-bold text-gray-800">EKS Cluster</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span
              class="w-1.5 h-1.5 rounded-full bg-emerald-400"
              aria-hidden="true"></span>
            <span class="text-[10px]" style="color: #64748B;"
              >{nodesHealthy}</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="relative max-w-5xl mx-auto px-5 sm:px-6 pb-14 mt-0">
    <div
      style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 2.5rem;"
    >
      <p
        class="text-center text-[10px] font-bold uppercase tracking-widest mb-8"
        style="color: rgba(148,163,184,0.45);"
      >
        {flowLabel}
      </p>
      <FlowDiagram steps={flowSteps} />
      <div
        class="flex flex-wrap gap-4 justify-center mt-8 text-xs sm:text-sm"
        style="color: rgba(148,163,184,0.7);"
      >
        {
          flowChecks.map((check) => (
            <span class="flex items-center gap-1.5">{check}</span>
          ))
        }
      </div>
    </div>
  </div>
</section>
