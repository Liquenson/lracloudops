---
import TechIcon from '../TechIcon.astro'

interface Props { lang: 'es' | 'en' }
const { lang } = Astro.props

const ariaLabel = lang === 'es' ? 'Tecnologías que operamos en producción' : 'Technologies we operate in production'
const barLabel = lang === 'es' ? 'Tecnologías de producción en las que confiamos' : 'Trusted technologies we operate in production'

const techs = [
  { name: 'AWS', path: 'M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z' },
  { name: 'Microsoft Azure', slug: 'microsoftazure' },
  { name: 'Google Cloud', slug: 'googlecloud' },
  { name: 'Terraform', slug: 'terraform' },
  { name: 'Kubernetes', slug: 'kubernetes' },
  { name: 'Docker', slug: 'docker' },
  { name: 'GitHub Actions', slug: 'githubactions' },
  { name: 'ArgoCD', slug: 'argo' },
  { name: 'Helm', slug: 'helm' },
  { name: 'Jenkins', slug: 'jenkins' },
  { name: 'Ansible', slug: 'ansible' },
  { name: 'KinD', path: 'M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 004.5 9v.878m13.5-3A2.25 2.25 0 0119.5 9v.878m0 0a2.246 2.246 0 00-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0121 12v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6c0-.98.626-1.813 1.5-2.122' },
  { name: 'CloudWatch', path: 'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605' },
  { name: 'Prometheus', slug: 'prometheus' },
  { name: 'Grafana', slug: 'grafana' },
  { name: 'Alertmanager', path: 'M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0M10.5 8.25h3l-3 4.5h3' },
  { name: 'CloudTrail', path: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { name: 'SonarCloud', slug: 'sonarcloud' },
  { name: 'ShellCheck', slug: 'gnubash' },
  { name: 'containerd', slug: 'containerd' },
  { name: 'Vagrant', slug: 'vagrant' },
  { name: 'Linux', slug: 'linux' },
]
---

<section style="background: #F8FAFC; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB;" aria-label={ariaLabel}>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <p class="text-center text-[11px] font-bold uppercase tracking-widest mb-12" style="color: #94A3B8;">{barLabel}</p>
    <div class="grid grid-cols-4 sm:grid-cols-5 lg:grid-cols-10 gap-5">
      {techs.map(({ name, slug, path }: { name: string; slug?: string; path?: string }) => (
        <div class="flex flex-col items-center gap-3 group cursor-default" title={name}>
          <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-white transition-all group-hover:shadow-md group-hover:border-blue-200" style="border: 1px solid #E5E7EB;">
            {slug && <TechIcon slug={slug} class="w-7 h-7" style="color: #1E6FFF;" />}
            {path && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7" style="color: #1E6FFF;" aria-hidden="true">
                <path d={path} />
              </svg>
            )}
          </div>
          <span class="text-[11px] font-semibold text-center leading-tight" style="color: #64748B;">{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
