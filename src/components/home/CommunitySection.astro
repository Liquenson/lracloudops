---
interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props

const badge = lang === 'es' ? 'Comunidad' : 'Community'
const heading =
  lang === 'es'
    ? 'Sigue nuestro recorrido de ingeniería'
    : 'Follow our engineering journey'
const subtext =
  lang === 'es'
    ? 'Proyectos reales. Infraestructura real. Resultados reales.'
    : 'Real projects. Real infrastructure. Real results.'
const liConnections = lang === 'es' ? '518 conexiones' : '518 connections'
const liDesc =
  lang === 'es'
    ? 'Novedades DevOps y actualizaciones de infraestructura cloud'
    : 'DevOps insights and cloud infrastructure updates'
const liCta = lang === 'es' ? 'Conectar en LinkedIn' : 'Connect on LinkedIn'
const ghRepos = lang === 'es' ? '10+ repositorios' : '10+ repositories'
const ghDesc =
  lang === 'es'
    ? 'Herramientas DevOps open source y plantillas de infraestructura'
    : 'Open source DevOps tools and infrastructure templates'
const ghCta = lang === 'es' ? 'Ver en GitHub' : 'View on GitHub'
---

<section
  style="background: #F8FAFC; border-top: 1px solid #E5E7EB;"
  aria-labelledby="social-heading"
>
  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="text-center mb-12 animate-fade-up">
      <span class="section-label">{badge}</span>
      <h2
        id="social-heading"
        class="text-3xl sm:text-4xl font-bold mt-5 mb-4"
        style="color: #0F172A; letter-spacing: -0.025em;"
      >
        {heading}
      </h2>
      <p class="text-lg max-w-xl mx-auto" style="color: #64748B;">{subtext}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <a
        href="https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white rounded-2xl p-7 flex flex-col card-lift animate-fade-up delay-200"
        style="border-left: 4px solid #0A66C2; border-top: 1px solid #E5E7EB; border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06); text-decoration: none;"
      >
        <div class="flex items-center gap-4 mb-5">
          <div
            class="w-12 h-12 flex items-center justify-center rounded-xl flex-shrink-0"
            style="background: #EFF6FF;"
            aria-hidden="true"
          >
            <svg
              class="w-6 h-6"
              style="color: #0A66C2;"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold" style="color: #0F172A;">
              Ruben Liquenson
            </div>
            <div class="text-xs" style="color: #94A3B8;">{liConnections}</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed flex-1 mb-5" style="color: #64748B;">
          {liDesc}
        </p>
        <span
          class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
          style="color: #0A66C2;"
        >
          {liCta}
          <svg
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </span>
      </a>

      <a
        href="https://github.com/lra-cloud-ops"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white rounded-2xl p-7 flex flex-col card-lift animate-fade-up delay-300"
        style="border-left: 4px solid #0A2540; border-top: 1px solid #E5E7EB; border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06); text-decoration: none;"
      >
        <div class="flex items-center gap-4 mb-5">
          <div
            class="w-12 h-12 flex items-center justify-center rounded-xl flex-shrink-0"
            style="background: #F1F5F9;"
            aria-hidden="true"
          >
            <svg
              class="w-6 h-6"
              style="color: #0A2540;"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold" style="color: #0F172A;">
              github.com/lra-cloud-ops
            </div>
            <div class="text-xs" style="color: #94A3B8;">{ghRepos}</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed flex-1 mb-5" style="color: #64748B;">
          {ghDesc}
        </p>
        <span
          class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
          style="color: #0A2540;"
        >
          {ghCta}
          <svg
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </span>
      </a>
    </div>
  </div>
</section>
