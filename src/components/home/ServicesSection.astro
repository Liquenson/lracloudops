---
interface Props { lang: 'es' | 'en' }
const { lang } = Astro.props

const esServices = [
  { icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6', title: 'Infraestructura Cloud', href: '/cloud-infrastructure', desc: 'Entornos AWS codificados con networking definido, límites de seguridad y políticas de acceso. Módulos Terraform auditables, versionados y reproducibles en múltiples cuentas.' },
  { icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2', title: 'Plataformas Kubernetes', href: '/kubernetes-platforms', desc: 'Clusters EKS de producción operados como plataformas internas. Entrega GitOps vía ArgoCD. Los equipos de desarrollo despliegan sin abrir tickets de infraestructura.' },
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'DevOps Automation', href: '/devops-automation', desc: 'Pipelines end-to-end que aplican tests, escaneos de seguridad y quality gates antes de llegar al cluster. Cada release es trazable. Cada rollback requiere un solo comando.' },
  { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', title: 'Platform Engineering', href: '/platform-engineering', desc: 'Construcción de plataformas internas de desarrollo que reducen la carga cognitiva y aceleran la entrega de los equipos de ingeniería, desde golden paths hasta portales de autoservicio.' },
  { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Observability & SRE', href: '/observability', desc: 'Métricas Prometheus, dashboards Grafana y alertas configuradas antes del go-live. SLOs definidos. Sabes qué está fallando antes de que se abra un ticket.' },
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Seguridad y Cumplimiento', href: '/servicios', desc: 'Autenticación OIDC, IAM de mínimo privilegio, aislamiento de red y límites de cumplimiento aplicados a nivel de infraestructura — no añadidos después del despliegue.' },
]

const enServices = [
  { icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6', title: 'Cloud Infrastructure', href: '/cloud-infrastructure', desc: 'Codified AWS environments with defined networking, security boundaries and access policies. Terraform modules that can be audited, version-controlled and reproduced across accounts.' },
  { icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2', title: 'Kubernetes Platforms', href: '/platform-engineering', desc: 'Production EKS clusters operated as internal platforms. GitOps delivery via ArgoCD. Development teams deploy without raising infrastructure tickets.' },
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'DevOps Automation', href: '/devops-automation', desc: 'End-to-end pipelines that enforce tests, security scans and policy gates before reaching a cluster. Every release is traceable. Every rollback takes one command.' },
  { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', title: 'Platform Engineering', href: '/platform-engineering', desc: 'Building internal developer platforms that reduce cognitive load and accelerate delivery for engineering teams, from golden paths to self-service portals.' },
  { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Observability & SRE', href: '/observability', desc: 'Prometheus metrics, Grafana dashboards and alerting configured before go-live. SLOs defined. You know what is failing before a ticket is filed.' },
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Security & Compliance', href: '/services', desc: 'OIDC authentication, least-privilege IAM, network isolation and compliance boundaries enforced at the infrastructure layer — not retrofitted after launch.' },
]

const services = lang === 'es' ? esServices : enServices
const badge = lang === 'es' ? 'Servicios' : 'Services'
const heading = lang === 'es' ? 'Lo que construimos y operamos' : 'What we build and operate'
const subtext = lang === 'es'
  ? 'Seis disciplinas de ingeniería. Un modelo operativo de plataforma unificado, diseñado para fiabilidad en producción.'
  : 'Six engineering disciplines. One unified platform operating model designed for production reliability.'
const learnMore = lang === 'es' ? 'Saber más' : 'Learn more'
const allSolutions = lang === 'es' ? 'Ver todas las soluciones' : 'View all solutions'
const allHref = lang === 'es' ? '/servicios' : '/services'
const delays = ['delay-100', 'delay-200', 'delay-300', 'delay-100', 'delay-200', 'delay-300']
---

<section style="background: #F8FAFC; border-top: 1px solid #E5E7EB;" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 py-24">
    <div class="text-center mb-16 animate-fade-up">
      <span class="section-label">{badge}</span>
      <h2 id="services-heading" class="text-4xl sm:text-5xl font-bold mt-5 mb-5" style="color: #0F172A; letter-spacing: -0.025em;">{heading}</h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">{subtext}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(({ icon, title, desc, href }, i) => (
        <div class={`bg-white rounded-2xl p-8 flex flex-col card-lift animate-fade-up ${delays[i]}`} style="border-left: 4px solid #1E6FFF; border-top: 1px solid #E5E7EB; border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06);">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-6 flex-shrink-0" style="background: #EFF6FF;" aria-hidden="true">
            <svg class="w-5 h-5" style="color: #2563EB;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">{title}</h3>
          <p class="text-sm leading-relaxed flex-1 mb-6" style="color: #64748B;">{desc}</p>
          <a href={href} class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors mt-auto" style="color: #2563EB;">
            {learnMore}
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href={allHref} class="inline-flex items-center gap-2 text-sm font-semibold px-7 py-3.5 rounded-xl border transition-all hover:bg-white" style="color: #0F172A; border-color: #D1D5DB; background: white;">
        {allSolutions}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
