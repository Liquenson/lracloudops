---
interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props

const esIndustries = [
  {
    title: 'Salud',
    desc: 'Infraestructura con conciencia HIPAA y trazabilidad completa',
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
    chips: ['HIPAA', 'Multi-AZ', 'Zero-trust', 'IAM'],
  },
  {
    title: 'Servicios Financieros',
    desc: 'Despliegues sin tiempo de inactividad en entornos financieros regulados',
    icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    chips: ['PCI-DSS', 'OIDC', 'GitOps', 'Immutable Infra'],
  },
  {
    title: 'Cloud Native SaaS',
    desc: 'Plataformas escalables que crecen con tu producto',
    icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
    chips: ['Kubernetes', 'GitOps', 'AWS', 'GCP'],
  },
  {
    title: 'Consultoría IT y PYME',
    desc: 'Consultoría IT integral y gestión de infraestructura',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    chips: ['Terraform', 'AWS', 'Azure', 'Cisco'],
  },
]

const enIndustries = [
  {
    title: 'Healthcare',
    desc: 'HIPAA-aware infrastructure with full audit trails',
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
    chips: ['HIPAA', 'Multi-AZ', 'Zero-trust', 'IAM'],
  },
  {
    title: 'Financial Services',
    desc: 'Zero-downtime deployments in regulated financial environments',
    icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    chips: ['PCI-DSS', 'OIDC', 'GitOps', 'Immutable Infra'],
  },
  {
    title: 'Cloud Native SaaS',
    desc: 'Scalable platforms that grow with your product',
    icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
    chips: ['Kubernetes', 'GitOps', 'AWS', 'GCP'],
  },
  {
    title: 'IT Consulting & SMB',
    desc: 'Comprehensive IT consulting and infrastructure management',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    chips: ['Terraform', 'AWS', 'Azure', 'Cisco'],
  },
]

const industries = lang === 'es' ? esIndustries : enIndustries
const badge = lang === 'es' ? 'Industrias' : 'Industries'
const heading =
  lang === 'es' ? 'Industrias a las que servimos' : 'Industries we serve'
const subtext =
  lang === 'es'
    ? 'Experiencia probada en entornos regulados y de alta disponibilidad'
    : 'Proven experience in regulated and high-availability environments'
---

<section
  style="background: var(--surface-1); border-top: 1px solid var(--color-gray-200);"
  aria-labelledby="sectors-heading"
>
  <div class="max-w-7xl mx-auto px-6" style="padding-block: var(--section-gap);">
    <div class="text-center mb-14 animate-fade-up">
      <span class="ds-eyebrow">{badge}</span>
      <h2
        id="sectors-heading"
        style="margin-top: var(--gap-sm); font-family: var(--font-display); font-size: var(--type-h2); font-weight: 800; color: var(--color-gray-900); letter-spacing: -0.025em; margin-bottom: var(--gap-sm);"
      >
        {heading}
      </h2>
      <p
        style="font-size: var(--type-body-lg); color: var(--color-gray-600); max-width: 40rem; margin-inline: auto;"
      >
        {subtext}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        industries.map(({ title, desc, icon, chips }, i) => (
          <div
            class={`card p-6 animate-fade-up delay-${(i + 1) * 100}`}
          >
            <div
              class="w-10 h-10 flex items-center justify-center rounded-lg mb-4 flex-shrink-0"
              style="background: var(--color-primary-light);"
              aria-hidden="true"
            >
              <svg
                class="w-5 h-5"
                style="color: var(--color-primary);"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={icon}
                />
              </svg>
            </div>
            <h3
              class="text-base font-bold mb-1"
              style="color: var(--color-gray-900);"
            >
              {title}
            </h3>
            <p
              class="text-sm font-medium mb-4"
              style="color: var(--color-gray-600);"
            >
              {desc}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {chips.map((chip) => (
                <span class="chip">{chip}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
