---
interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props

const badge = lang === 'es' ? 'Empezar' : 'Get started'
const heading =
  lang === 'es'
    ? '¿Listo para modernizar\ntu infraestructura?'
    : 'Ready to modernize\nyour infrastructure?'
const subtext =
  lang === 'es'
    ? 'Agenda una consulta gratuita de 30 minutos. Revisaremos tu configuración actual y propondremos una hoja de ruta concreta.'
    : "Schedule a free 30-minute consultation. We'll review your current setup and propose a concrete roadmap."
const ctaPrimary = lang === 'es' ? 'Agendar Consulta' : 'Schedule Consultation'
const ctaSecondary = lang === 'es' ? 'Ver nuestro trabajo' : 'View Our Work'
const ctaHref = lang === 'es' ? '/contacto' : '/contact'
const projectsHref = lang === 'es' ? '/proyectos' : '/projects'
const linkedinText =
  lang === 'es'
    ? 'Síguenos en LinkedIn para actualizaciones de ingeniería'
    : 'Follow our engineering updates on LinkedIn'
const trustItems =
  lang === 'es'
    ? [
        '30 minutos. Sin presentación comercial.',
        'Respuesta en 24 horas.',
        'Evaluación de arquitectura incluida.',
      ]
    : [
        '30 minutes. No sales deck.',
        'Response within 24 hours.',
        'Architecture assessment included.',
      ]
---

<section class="relative overflow-hidden" aria-labelledby="cta-heading">
  <div class="py-28 px-6 relative" style="background: #0D1B2E;">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.07) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 100%, rgba(37,99,235,0.25) 0%, transparent 60%);"
    >
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-px pointer-events-none"
      aria-hidden="true"
      style="background: linear-gradient(90deg, transparent, rgba(96,165,250,0.35), transparent);"
    >
    </div>

    <div class="relative max-w-3xl mx-auto text-center animate-fade-up">
      <span
        class="inline-flex items-center text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-8"
        style="background: rgba(30,111,255,0.18); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
        >{badge}</span
      >

      <h2
        id="cta-heading"
        class="text-4xl sm:text-5xl lg:text-[56px] font-extrabold text-white mb-6"
        style="letter-spacing: -0.03em; line-height: 1.06;"
      >
        {
          lang === 'es' ? (
            <Fragment>
              ¿Listo para modernizar
              <br />
              tu infraestructura?
            </Fragment>
          ) : (
            <Fragment>
              Ready to modernize
              <br />
              your infrastructure?
            </Fragment>
          )
        }
      </h2>

      <p
        class="text-xl mb-10 max-w-xl mx-auto leading-relaxed"
        style="color: rgba(148,163,184,0.8);"
      >
        {subtext}
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2.5 text-base font-bold px-8 py-4 rounded-xl transition-all hover:-translate-y-px active:scale-[0.98]"
          style="display:inline-flex; align-items:center; gap:8px; padding:14px 28px; background:#1E6FFF; color:#FFFFFF; font-weight:700; font-size:1rem; border-radius:6px; text-decoration:none; transition:all 150ms ease; border:none; cursor:pointer;"
        >
          {ctaPrimary}
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a
          href={projectsHref}
          class="inline-flex items-center gap-2 text-base font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(255,255,255,0.85); border-color: rgba(255,255,255,0.25);"
        >
          {ctaSecondary}
        </a>
      </div>

      <a
        href="https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium transition-colors hover:opacity-80 mb-8"
        style="color: #94A3B8;"
      >
        <svg
          class="w-4 h-4"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
        {linkedinText}
      </a>

      <div
        class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3"
        style="color: #94A3B8;"
      >
        {
          trustItems.map((item) => (
            <span class="flex items-center gap-2 text-sm">
              <svg
                class="w-4 h-4 flex-shrink-0"
                style="color: #60A5FA;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              {item}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
