---
interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props

const esPrinciples = [
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Mentalidad production-first.',
    desc: 'Cada decisión de arquitectura se evalúa bajo condiciones de producción reales — no en entornos de laboratorio. Los 6 proyectos del portfolio están diseñados para fallar de forma controlada, no para impresionar en demos.',
  },
  {
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    title: 'Infraestructura como código por defecto.',
    desc: 'Los 6 proyectos open source son 100% Terraform, Helm y Ansible. Sin consolas de nube, sin provisioning manual, sin conocimiento implícito. Cada recurso tiene un dueño, cada cambio tiene un commit.',
  },
  {
    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
    title: 'Operaciones GitOps-first.',
    desc: 'ArgoCD como controlador de entrega en todos los entornos Kubernetes. El estado deseado vive en Git. Ningún cambio llega al cluster sin pasar por control de versiones y aprobación de pipeline.',
  },
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Fiabilidad por diseño.',
    desc: 'Topología Multi-AZ, failover automatizado y circuit breakers desde el primer despliegue. Los fallos de componentes permanecen aislados. Los usuarios no los perciben.',
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Automatización sobre procesos manuales.',
    desc: 'Cada pipeline aplica tests, escaneos de seguridad y quality gates antes de que un contenedor llegue al cluster. El equipo despliega más rápido precisamente porque la plataforma gestiona el control.',
  },
  {
    icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    title: 'Entrega basada en documentación.',
    desc: 'Runbooks, diagramas de arquitectura y decisiones de ingeniería documentadas son parte de la entrega — no un afterthought. Métricas Prometheus y dashboards Grafana configurados antes del primer usuario.',
  },
]

const enPrinciples = [
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Production-first mindset.',
    desc: 'Every architecture decision is evaluated under real production conditions — not lab environments. All 6 portfolio projects are designed to fail gracefully, not impress in demos.',
  },
  {
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    title: 'Infrastructure as Code by default.',
    desc: 'All 6 open source projects are 100% Terraform, Helm and Ansible. No cloud consoles, no manual provisioning, no implicit knowledge. Every resource has an owner, every change has a commit.',
  },
  {
    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
    title: 'GitOps-first operations.',
    desc: 'ArgoCD as delivery controller in all Kubernetes environments. Desired state lives in Git. No change reaches the cluster without version control and pipeline approval.',
  },
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Reliability by design.',
    desc: "Multi-AZ topology, automated failover and circuit breakers from the first deployment. Component failures stay isolated. Users don't see them.",
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Automation over manual processes.',
    desc: 'Every pipeline enforces tests, security scans and quality gates before a container reaches the cluster. Teams release faster precisely because the platform handles the gatekeeping.',
  },
  {
    icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    title: 'Documentation-driven delivery.',
    desc: 'Runbooks, architecture diagrams and engineering decisions are part of the delivery — not an afterthought. Prometheus metrics and Grafana dashboards configured before the first user hits production.',
  },
]

const principles = lang === 'es' ? esPrinciples : enPrinciples
const badge = lang === 'es' ? 'Por qué elegirnos' : 'Why choose us'
const heading =
  lang === 'es'
    ? 'Platform engineering\nreduce el riesgo operacional.'
    : 'Platform engineering\nreduces operational risk.'
const subtext =
  lang === 'es'
    ? 'La fiabilidad, la velocidad de entrega y la observabilidad son propiedades de la plataforma — no soluciones de emergencia aplicadas durante incidentes.'
    : 'Reliability, delivery velocity and observability are properties of the platform — not afterthoughts added during incidents.'
const delays = [
  'delay-100',
  'delay-200',
  'delay-300',
  'delay-100',
  'delay-200',
  'delay-300',
]
---

<section
  class="py-24 border-t border-gray-100"
  style="background: #F8FAFC;"
  aria-labelledby="why-heading"
>
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 animate-fade-up">
      <span class="section-label">{badge}</span>
      <h2
        id="why-heading"
        class="text-4xl sm:text-5xl font-bold mt-5 mb-5"
        style="color: #0F172A; letter-spacing: -0.025em;"
      >
        {
          lang === 'es' ? (
            <Fragment>
              Platform engineering
              <br />
              reduce el riesgo operacional.
            </Fragment>
          ) : (
            <Fragment>
              Platform engineering
              <br />
              reduces operational risk.
            </Fragment>
          )
        }
      </h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">{subtext}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        principles.map(({ icon, title, desc }, i) => (
          <div
            class={`bg-white rounded-2xl p-8 animate-fade-up border card-lift ${delays[i]}`}
            style="border-color: #E5E7EB; border-left: 3px solid #2563EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06);"
          >
            <div
              class="w-12 h-12 flex items-center justify-center rounded-xl mb-6"
              style="background: #EFF6FF;"
              aria-hidden="true"
            >
              <svg
                class="w-5 h-5"
                style="color: #2563EB;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={icon}
                />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">
              {title}
            </h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">
              {desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
