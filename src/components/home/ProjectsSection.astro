---
import ProjectsGrid from '../ProjectsGrid.astro'

interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props
---

{
  lang === 'es' ? (
    <section
      class="py-24 bg-white border-t border-gray-100"
      aria-labelledby="engagements-heading"
    >
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16 animate-fade-up">
          <span class="section-label">Proyectos Seleccionados</span>
          <h2
            id="engagements-heading"
            class="text-4xl sm:text-5xl font-bold mt-5 mb-5"
            style="color: #0F172A; letter-spacing: -0.025em;"
          >
            Resultados en producción.
          </h2>
          <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
            Implementaciones de plataforma en sectores regulados. Las métricas
            reflejan entornos de producción, no benchmarks.
          </p>
        </div>
        <ProjectsGrid lang="es" />
        <div class="text-center mt-12">
          <a
            href="/proyectos"
            class="inline-flex items-center gap-2 text-sm font-semibold transition-colors"
            style="color: #2563EB;"
          >
            Ver todas las implementaciones
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>
      </div>
    </section>
  ) : (
    <section
      class="py-24 bg-white border-t border-gray-100"
      aria-labelledby="case-studies-heading"
    >
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14">
          <div class="animate-fade-up">
            <span class="section-label">Case Studies</span>
            <h2
              id="case-studies-heading"
              class="text-4xl sm:text-5xl font-bold mt-5"
              style="color: #0F172A; letter-spacing: -0.025em;"
            >
              Production workloads.
              <br />
              Documented outcomes.
            </h2>
          </div>
          <a
            href="/projects"
            class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold transition-colors animate-fade"
            style="color: #2563EB;"
          >
            View all projects
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>
        <ProjectsGrid lang="en" />
        <div class="text-center mt-12">
          <a
            href="/projects"
            class="inline-flex items-center gap-2 text-sm font-semibold px-7 py-3.5 rounded-xl border transition-all hover:bg-gray-50"
            style="color: #0F172A; border-color: #E5E7EB;"
          >
            View all case studies
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )
}
