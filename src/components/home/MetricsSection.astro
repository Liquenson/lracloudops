---
interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props

const metrics =
  lang === 'es'
    ? [
        { value: '4+', label: 'Años en Producción', sub: 'Entornos reales' },
        { value: '3', label: 'Clouds Soportados', sub: 'AWS · Azure · GCP' },
        {
          value: '4+',
          label: 'Proyectos Open Source',
          sub: 'github.com/lra-cloud-ops',
        },
        {
          value: '100%',
          label: 'Infraestructura como código',
          sub: 'Cero cambios manuales',
        },
        { value: '0', label: 'Deploys manuales', sub: 'GitOps con ArgoCD' },
        {
          value: '45min',
          label: 'Tiempo de despliegue',
          sub: 'Antes: 3 semanas',
        },
        {
          value: '24/7',
          label: 'DevOps Advisor IA',
          sub: 'Powered by Claude Sonnet',
        },
      ]
    : [
        { value: '4+', label: 'Years in Production', sub: 'Real environments' },
        { value: '3', label: 'Clouds Supported', sub: 'AWS · Azure · GCP' },
        {
          value: '4+',
          label: 'Open Source Projects',
          sub: 'github.com/lra-cloud-ops',
        },
        {
          value: '100%',
          label: 'Infrastructure as Code',
          sub: 'Zero manual changes',
        },
        { value: '0', label: 'Manual deploys', sub: 'GitOps with ArgoCD' },
        { value: '45min', label: 'Deploy time', sub: 'Before: 3 weeks' },
        {
          value: '24/7',
          label: 'DevOps Advisor AI',
          sub: 'Powered by Claude Sonnet',
        },
      ]

const badge = lang === 'es' ? 'Por los números' : 'By the numbers'
const heading =
  lang === 'es'
    ? 'Fiabilidad de la plataforma a escala'
    : 'Platform reliability at scale'
const subtext =
  lang === 'es'
    ? 'Métricas reales de producción de la infraestructura que diseñamos, construimos y operamos.'
    : 'Real production metrics from infrastructure we design, build and operate.'
---

<section
  style="background: var(--surface-2); border-top: 1px solid var(--color-gray-200); border-bottom: 1px solid var(--color-gray-200);"
  aria-labelledby="metrics-heading"
>
  <div class="max-w-7xl mx-auto px-6" style="padding-block: var(--gap-xl);">
    <div class="text-center mb-8 animate-fade-up">
      <span class="ds-eyebrow">{badge}</span>
      <h2
        id="metrics-heading"
        style="margin-top: var(--gap-sm); font-family: var(--font-display); font-size: var(--type-h2); font-weight: 800; color: var(--color-gray-900); letter-spacing: -0.025em; margin-bottom: var(--gap-xs);"
      >
        {heading}
      </h2>
      <p
        style="font-size: var(--type-body-lg); color: var(--color-gray-600); max-width: 36rem; margin-inline: auto;"
      >
        {subtext}
      </p>
    </div>

    <div class="stat-strip animate-fade-up">
      {
        metrics.map(({ value, label, sub }) => (
          <div class="stat-strip-item">
            <div class="metric-value">{value}</div>
            <div style="font-size: var(--type-sm); font-weight: 600; color: var(--color-gray-800); font-family: var(--font-display); margin-top: 0.25rem;">
              {label}
            </div>
            <div class="metric-label">{sub}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
