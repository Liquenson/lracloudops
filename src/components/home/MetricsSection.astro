---
interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props

const metrics =
  lang === 'es'
    ? [
        { value: '4+', label: 'Años en Producción', sub: 'Entornos reales' },
        { value: '3', label: 'Clouds Soportados', sub: 'AWS · Azure · GCP' },
        {
          value: '4+',
          label: 'Proyectos Open Source',
          sub: 'github.com/lra-cloud-ops',
        },
        {
          value: '100%',
          label: 'Infraestructura como código',
          sub: 'Cero cambios manuales',
        },
        { value: '0', label: 'Deploys manuales', sub: 'GitOps con ArgoCD' },
        {
          value: '45min',
          label: 'Tiempo de despliegue',
          sub: 'Antes: 3 semanas',
        },
        {
          value: '24/7',
          label: 'DevOps Advisor IA',
          sub: 'Powered by Claude Sonnet',
        },
      ]
    : [
        { value: '4+', label: 'Years in Production', sub: 'Real environments' },
        { value: '3', label: 'Clouds Supported', sub: 'AWS · Azure · GCP' },
        {
          value: '4+',
          label: 'Open Source Projects',
          sub: 'github.com/lra-cloud-ops',
        },
        {
          value: '100%',
          label: 'Infrastructure as Code',
          sub: 'Zero manual changes',
        },
        { value: '0', label: 'Manual deploys', sub: 'GitOps with ArgoCD' },
        { value: '45min', label: 'Deploy time', sub: 'Before: 3 weeks' },
        {
          value: '24/7',
          label: 'DevOps Advisor AI',
          sub: 'Powered by Claude Sonnet',
        },
      ]

const badge = lang === 'es' ? 'Por los números' : 'By the numbers'
const heading =
  lang === 'es'
    ? 'Fiabilidad de la plataforma a escala'
    : 'Platform reliability at scale'
const subtext =
  lang === 'es'
    ? 'Métricas reales de producción de la infraestructura que diseñamos, construimos y operamos.'
    : 'Real production metrics from infrastructure we design, build and operate.'
---

<section
  style="background: var(--color-gray-50); border-top: 1px solid var(--color-gray-200); border-bottom: 1px solid var(--color-gray-200);"
  aria-labelledby="metrics-heading"
>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center mb-10 animate-fade-up">
      <span class="section-eyebrow">{badge}</span>
      <h2
        id="metrics-heading"
        class="text-4xl sm:text-5xl font-bold mt-4 mb-3"
        style="color: var(--color-gray-900); letter-spacing: -0.025em; font-family: var(--font-display);"
      >
        {heading}
      </h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-gray-600);">
        {subtext}
      </p>
    </div>

    <div
      class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 animate-fade-up"
      style="border: 1px solid var(--color-gray-200); border-radius: var(--radius-md); overflow: hidden; background: var(--color-white);"
    >
      {
        metrics.map(({ value, label, sub }, idx) => (
          <div
            class="flex flex-col items-center justify-center text-center px-5 py-10 cursor-default transition-colors hover:bg-gray-50"
            style={
              idx < metrics.length - 1
                ? 'border-right: 1px solid var(--color-gray-200);'
                : ''
            }
          >
            <div class="metric-value mb-1.5">{value}</div>
            <div
              class="text-sm font-semibold mb-1"
              style="color: var(--color-gray-800); font-family: var(--font-display);"
            >
              {label}
            </div>
            <div class="metric-label">{sub}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
