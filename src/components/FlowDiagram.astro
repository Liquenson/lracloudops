---
import TechIcon from './TechIcon.astro';

interface Step {
  label: string;
  sublabel?: string;
  icon?: string;
}
interface Props {
  steps: Step[];
  class?: string;
}
const { steps, class: className = '' } = Astro.props;
---

<div class={`flex items-center gap-2 sm:gap-3 flex-wrap justify-center ${className}`}>
  {steps.map((step, i) => (
    <>
      <div class="flex flex-col items-center gap-1.5 px-4 py-3 rounded-xl bg-white border border-[#E2E8F0] shadow-sm min-w-[90px] sm:min-w-[100px]">
        {step.icon && <TechIcon slug={step.icon} class="w-7 h-7" style="color: #1E6FFF;" />}
        {!step.icon && (
          <div class="w-7 h-7 flex items-center justify-center rounded-lg" style="background: #EEF4FF;">
            <svg class="w-4 h-4" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
            </svg>
          </div>
        )}
        <span class="text-xs font-semibold text-[#0A2540] text-center leading-tight">{step.label}</span>
        {step.sublabel && <span class="text-[10px] text-[#94A3B8] text-center">{step.sublabel}</span>}
      </div>
      {i < steps.length - 1 && (
        <svg class="w-4 h-4 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      )}
    </>
  ))}
</div>
