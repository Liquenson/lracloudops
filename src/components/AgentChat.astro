---
// AI Chat Widget — DevOps Advisor powered by Cloudflare Worker
---

<div
  id="lra-chat-root"
  style="position:fixed;bottom:24px;right:24px;z-index:9999;font-family:Inter,system-ui,sans-serif;"
>
  <!-- Floating toggle button -->
  <button
    id="lra-chat-toggle"
    aria-label="Open DevOps Advisor chat"
    aria-expanded="false"
    aria-haspopup="dialog"
    aria-controls="lra-chat-panel"
    style="width:56px;height:56px;border-radius:50%;background:#1E6FFF;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 24px rgba(30,111,255,0.45),0 2px 8px rgba(30,111,255,0.3);transition:transform 0.2s ease,box-shadow 0.2s ease;"
  >
    <!-- Chat icon (visible when closed) -->
    <svg
      id="lra-icon-chat"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
      ></path>
    </svg>
    <!-- X icon (visible when open) -->
    <svg
      id="lra-icon-x"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="2.5"
      stroke-linecap="round"
      aria-hidden="true"
      style="display:none;"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Chat panel -->
  <div
    id="lra-chat-panel"
    role="dialog"
    aria-label="LRA DevOps Advisor"
    aria-hidden="true"
    style="position:absolute;bottom:68px;right:0;width:380px;height:520px;background:white;border-radius:16px;box-shadow:0 8px 40px rgba(10,37,64,0.2),0 2px 12px rgba(10,37,64,0.1);display:flex;flex-direction:column;overflow:hidden;opacity:0;pointer-events:none;transform:translateY(16px) scale(0.96);transition:opacity 0.22s ease,transform 0.22s ease;"
  >
    <!-- Header -->
    <div
      style="background:#0A2540;padding:14px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0;"
    >
      <div
        style="width:38px;height:38px;border-radius:50%;background:rgba(30,111,255,0.22);display:flex;align-items:center;justify-content:center;flex-shrink:0;"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#60A5FA"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"
          ></path>
          <circle cx="9" cy="14" r="1" fill="#60A5FA" stroke="none"></circle>
          <circle cx="15" cy="14" r="1" fill="#60A5FA" stroke="none"></circle>
        </svg>
      </div>
      <div style="flex:1;min-width:0;">
        <div
          style="font-size:14px;font-weight:700;color:white;line-height:1.2;letter-spacing:-0.01em;"
        >
          DevOps Advisor
        </div>
        <div
          style="font-size:11px;color:rgba(148,163,184,0.85);display:flex;align-items:center;gap:5px;margin-top:2px;"
        >
          <span
            style="width:6px;height:6px;border-radius:50%;background:#34D399;display:inline-block;flex-shrink:0;"
            aria-hidden="true"></span>
          LRA Cloud Ops &middot; Online
        </div>
      </div>
      <button
        id="lra-chat-close"
        aria-label="Close chat"
        style="width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.1);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.65);flex-shrink:0;transition:background 0.15s,color 0.15s;"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Messages area -->
    <div
      id="lra-chat-messages"
      role="log"
      aria-live="polite"
      aria-label="Chat conversation"
      style="flex:1;overflow-y:auto;padding:16px;background:white;"
    >
    </div>

    <!-- Input area -->
    <div
      style="padding:12px 16px;border-top:1px solid #F1F5F9;display:flex;align-items:center;gap:8px;flex-shrink:0;background:white;"
    >
      <input
        id="lra-chat-input"
        type="text"
        placeholder="Ask about infrastructure..."
        maxlength="500"
        aria-label="Type your message"
        autocomplete="off"
        style="flex:1;padding:10px 14px;border:1.5px solid #E2E8F0;border-radius:10px;font-size:14px;color:#0A2540;background:#F8FAFC;outline:none;font-family:inherit;transition:border-color 0.15s,background 0.15s;"
      />
      <button
        id="lra-chat-send"
        aria-label="Send message"
        style="width:40px;height:40px;border-radius:10px;background:#1E6FFF;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background 0.15s,transform 0.1s;"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="white"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2" fill="white" stroke="none"
          ></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  @keyframes lra-dot-bounce {
    0%,
    60%,
    100% {
      transform: translateY(0);
      opacity: 0.35;
    }
    30% {
      transform: translateY(-5px);
      opacity: 1;
    }
  }
  .lra-typing-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #94a3b8;
    display: inline-block;
    animation: lra-dot-bounce 1.3s infinite ease-in-out;
  }
  .lra-typing-dot:nth-child(2) {
    animation-delay: 0.18s;
  }
  .lra-typing-dot:nth-child(3) {
    animation-delay: 0.36s;
  }

  #lra-chat-toggle:hover {
    transform: scale(1.08) !important;
    box-shadow:
      0 6px 32px rgba(30, 111, 255, 0.6),
      0 2px 8px rgba(30, 111, 255, 0.3) !important;
  }
  #lra-chat-toggle:active {
    transform: scale(0.96) !important;
  }

  #lra-chat-close:hover {
    background: rgba(255, 255, 255, 0.18) !important;
    color: white !important;
  }

  #lra-chat-input:focus {
    border-color: #1e6fff !important;
    background: white !important;
    box-shadow: 0 0 0 3px rgba(30, 111, 255, 0.12);
  }

  #lra-chat-send:hover {
    background: #1557d4 !important;
  }
  #lra-chat-send:active {
    transform: scale(0.93);
  }
  #lra-chat-send:disabled {
    background: #94a3b8 !important;
    cursor: not-allowed;
  }

  #lra-chat-messages::-webkit-scrollbar {
    width: 4px;
  }
  #lra-chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  #lra-chat-messages::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 2px;
  }

  /* Mobile: full screen */
  @media (max-width: 480px) {
    #lra-chat-root {
      bottom: 16px !important;
      right: 16px !important;
    }
    #lra-chat-panel {
      position: fixed !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      border-radius: 0 !important;
    }
  }
</style>

<script>
  ;(function () {
    const WORKER = 'https://lracloudops-agent.liquenson-cloud.workers.dev'
    const CAL = 'https://cal.com/ruben-alexis-h6qkjk/30min'
    const MAX = 20

    const WELCOME = [
      "Hi! I'm LRA's DevOps Advisor. I can help you with:",
      '- AWS infrastructure design',
      '- Kubernetes platform setup',
      '- CI/CD automation',
      '- Cost optimization',
      '',
      'What infrastructure challenge can I help you with?',
    ].join('\n')

    interface Msg {
      role: 'user' | 'assistant'
      content: string
      ts: string
    }

    let history: { role: string; content: string }[] = []
    let displayMsgs: Msg[] = []
    let agentCount = 0
    let isOpen = false
    let loading = false
    let welcomed = false

    const el = (id: string) => document.getElementById(id)

    const toggleBtn = el('lra-chat-toggle')
    const panel = el('lra-chat-panel')
    const closeBtn = el('lra-chat-close')
    const messagesEl = el('lra-chat-messages')
    const inputEl = el('lra-chat-input') as HTMLInputElement | null
    const sendBtn = el('lra-chat-send') as HTMLButtonElement | null
    const iconChat = el('lra-icon-chat')
    const iconX = el('lra-icon-x')

    if (!toggleBtn || !panel || !messagesEl || !inputEl || !sendBtn) return

    function sanitize(s: string) {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
    }

    function toHtml(text: string) {
      return sanitize(text)
        .replace(/\n- /g, '\n• ')
        .replace(/^- /g, '• ')
        .replace(/\n/g, '<br>')
    }

    function nowStr() {
      return new Date().toLocaleTimeString([], {
        hour: '2-digit',
        minute: '2-digit',
      })
    }

    function render() {
      messagesEl!.innerHTML = ''
      displayMsgs.forEach((m, i) => {
        const user = m.role === 'user'
        const isLastAgent = !user && i === displayMsgs.length - 1

        const wrap = document.createElement('div')
        wrap.style.cssText = `display:flex;flex-direction:column;align-items:${user ? 'flex-end' : 'flex-start'};margin-bottom:14px;`

        const bubble = document.createElement('div')
        bubble.innerHTML = toHtml(m.content)
        bubble.style.cssText = user
          ? 'background:#1E6FFF;color:white;padding:10px 14px;border-radius:12px 12px 2px 12px;max-width:82%;font-size:14px;line-height:1.55;word-break:break-word;'
          : 'background:#F8FAFC;color:#0A2540;padding:10px 14px;border-radius:12px 12px 12px 2px;max-width:82%;font-size:14px;line-height:1.55;word-break:break-word;border:1px solid #E2E8F0;'

        const time = document.createElement('span')
        time.style.cssText =
          'font-size:11px;color:#94A3B8;margin-top:3px;padding:0 2px;'
        time.textContent = m.ts

        wrap.appendChild(bubble)
        wrap.appendChild(time)
        messagesEl!.appendChild(wrap)

        // CTA from the 3rd agent message onwards
        if (isLastAgent && agentCount >= 3) {
          const ctaWrap = document.createElement('div')
          ctaWrap.style.cssText = 'margin-top:10px;'
          const cta = document.createElement('a')
          cta.href = CAL
          cta.target = '_blank'
          cta.rel = 'noopener noreferrer'
          cta.textContent = 'Schedule free consultation →'
          cta.style.cssText =
            'display:inline-block;background:#0A2540;color:white;font-size:12px;font-weight:600;padding:8px 14px;border-radius:8px;text-decoration:none;letter-spacing:0.01em;transition:background 0.2s;'
          cta.addEventListener('mouseenter', () => {
            cta.style.background = '#1E6FFF'
          })
          cta.addEventListener('mouseleave', () => {
            cta.style.background = '#0A2540'
          })
          ctaWrap.appendChild(cta)
          messagesEl!.appendChild(ctaWrap)
        }
      })

      messagesEl!.scrollTop = messagesEl!.scrollHeight
    }

    function addMsg(role: 'user' | 'assistant', content: string) {
      displayMsgs.push({ role, content, ts: nowStr() })
      history.push({ role, content })
      if (displayMsgs.length > MAX) displayMsgs.shift()
      if (history.length > MAX) history.shift()
      render()
    }

    function showTyping() {
      const bubble = document.createElement('div')
      bubble.id = 'lra-typing-anim'
      bubble.setAttribute('aria-label', 'Advisor is typing')
      bubble.style.cssText =
        'display:flex;flex-direction:column;align-items:flex-start;margin-bottom:14px;'
      bubble.innerHTML = `
        <div style="background:#F8FAFC;border:1px solid #E2E8F0;padding:10px 14px;border-radius:12px 12px 12px 2px;display:inline-flex;align-items:center;gap:5px;">
          <span class="lra-typing-dot"></span>
          <span class="lra-typing-dot"></span>
          <span class="lra-typing-dot"></span>
        </div>
      `
      messagesEl!.appendChild(bubble)
      messagesEl!.scrollTop = messagesEl!.scrollHeight
    }

    function hideTyping() {
      el('lra-typing-anim')?.remove()
    }

    function openChat() {
      isOpen = true
      panel!.removeAttribute('aria-hidden')
      panel!.setAttribute('aria-modal', 'true')
      panel!.style.opacity = '1'
      panel!.style.pointerEvents = 'auto'
      panel!.style.transform = 'translateY(0) scale(1)'
      toggleBtn!.setAttribute('aria-expanded', 'true')
      if (iconChat) iconChat.style.display = 'none'
      if (iconX) iconX.style.display = 'block'

      if (!welcomed) {
        welcomed = true
        setTimeout(() => {
          agentCount++
          addMsg('assistant', WELCOME)
        }, 350)
      }

      setTimeout(() => inputEl!.focus(), 400)
    }

    function closeChat() {
      isOpen = false
      panel!.setAttribute('aria-hidden', 'true')
      panel!.removeAttribute('aria-modal')
      panel!.style.opacity = '0'
      panel!.style.pointerEvents = 'none'
      panel!.style.transform = 'translateY(16px) scale(0.96)'
      toggleBtn!.setAttribute('aria-expanded', 'false')
      if (iconChat) iconChat.style.display = 'block'
      if (iconX) iconX.style.display = 'none'
    }

    async function sendMsg() {
      if (loading) return
      const text = inputEl!.value.trim()
      if (!text) return

      inputEl!.value = ''
      addMsg('user', text)

      loading = true
      sendBtn!.disabled = true
      showTyping()

      const controller = new AbortController()
      const timeout = setTimeout(() => controller.abort(), 30000)

      try {
        const messages = history.map((m) => ({
          role: m.role,
          content: m.content,
        }))
        const res = await fetch(WORKER, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages }),
          signal: controller.signal,
        })

        clearTimeout(timeout)
        console.log('Status:', res.status)

        if (!res.ok) {
          hideTyping()
          agentCount++
          addMsg(
            'assistant',
            `Service error (HTTP ${res.status}). Please try again in a moment.`
          )
          return
        }

        let data: any
        try {
          data = await res.json()
        } catch {
          hideTyping()
          agentCount++
          addMsg(
            'assistant',
            'Service temporarily unavailable. Please try again.'
          )
          return
        }

        console.log('Data:', data)
        const reply: string =
          data.text ??
          "Sorry, I couldn't process your request. Please try again."
        hideTyping()
        agentCount++
        addMsg('assistant', reply)
      } catch (err: any) {
        clearTimeout(timeout)
        console.error('Worker error:', err)
        hideTyping()
        agentCount++
        if (err?.name === 'AbortError') {
          addMsg('assistant', 'Request timed out. Please try again.')
        } else {
          addMsg(
            'assistant',
            'Connection error. Please check your network and try again.'
          )
        }
      } finally {
        loading = false
        sendBtn!.disabled = false
        inputEl!.focus()
      }
    }

    // Event bindings
    toggleBtn.addEventListener('click', () =>
      isOpen ? closeChat() : openChat()
    )
    closeBtn?.addEventListener('click', closeChat)
    sendBtn.addEventListener('click', sendMsg)

    inputEl.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault()
        sendMsg()
      }
    })
    inputEl.addEventListener('focus', () => {
      inputEl!.style.borderColor = '#1E6FFF'
      inputEl!.style.background = 'white'
    })
    inputEl.addEventListener('blur', () => {
      inputEl!.style.borderColor = '#E2E8F0'
      inputEl!.style.background = '#F8FAFC'
    })
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && isOpen) closeChat()
    })
  })()
</script>
