---
import Logo from '../ui/Logo.astro'

interface NavItem {
  label: string
  href: string
}

const navItems: NavItem[] = [
  { label: 'Product', href: '#' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Docs', href: '#' },
  { label: 'Blog', href: '#' },
]
---

<header class="saas-header">
  <div class="saas-header-inner">
    <Logo href="/" />

    <nav class="saas-nav" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a href={item.href} class="saas-nav-link">
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="saas-header-actions">
      <a href="/login" class="btn-ghost">Sign in</a>
      <a href="/signup" class="btn-primary">Start free</a>
    </div>

    <button
      class="saas-mobile-toggle"
      id="saas-mobile-toggle"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="saas-mobile-menu"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <div class="saas-mobile-menu" id="saas-mobile-menu">
    <nav aria-label="Mobile navigation">
      {
        navItems.map((item) => (
          <a href={item.href} class="saas-mobile-link">
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="saas-mobile-actions">
      <a
        href="/login"
        class="btn-ghost"
        style="width: 100%; justify-content: center;">Sign in</a
      >
      <a
        href="/signup"
        class="btn-primary"
        style="width: 100%; justify-content: center;">Start free</a
      >
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('saas-mobile-toggle')
  const menu = document.getElementById('saas-mobile-menu')

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open')
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)))
  })
</script>

<style>
  .saas-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid #edebe9;
  }
  .saas-header-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 5vw, 2rem);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .saas-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-inline: auto;
  }
  .saas-nav-link {
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .saas-nav-link:hover {
    color: #0078d4;
  }
  .saas-header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .btn-ghost {
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111827;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    transition: background 150ms ease;
    display: inline-flex;
    align-items: center;
  }
  .btn-ghost:hover {
    background: #faf9f8;
  }
  .btn-primary {
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #ffffff;
    background: #0078d4;
    text-decoration: none;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    transition: background 150ms ease;
    display: inline-flex;
    align-items: center;
  }
  .btn-primary:hover {
    background: #106ebe;
  }
  .saas-mobile-toggle {
    display: none;
    color: #111827;
    padding: 0.5rem;
  }
  .saas-mobile-menu {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem clamp(1rem, 5vw, 2rem) 1.5rem;
    border-top: 1px solid #edebe9;
  }
  .saas-mobile-menu.open {
    display: flex;
  }
  .saas-mobile-menu nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .saas-mobile-link {
    font-family: 'Red Hat Text', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #111827;
    text-decoration: none;
    padding: 0.625rem 0;
  }
  .saas-mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 860px) {
    .saas-nav,
    .saas-header-actions {
      display: none;
    }
    .saas-mobile-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>
