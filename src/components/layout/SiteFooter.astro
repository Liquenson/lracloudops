---
import { getLangFromUrl, languages, regions, getAlternateUrl } from '../../i18n'

const lang = getLangFromUrl(Astro.url)
const localeUrls = Object.fromEntries(
  Object.keys(languages).map((locale) => [
    locale,
    'https://lracloudops.com' + getAlternateUrl(Astro.url, locale as keyof typeof languages),
  ])
) as Record<keyof typeof languages, string>
const currentLangInfo = languages[lang] ?? languages['en']
---

<footer style="background-color:#0B1220;" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-10 mb-14">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href={lang === 'en' ? '/en/' : '/'} class="inline-block mb-5" aria-label="LRA Cloud Ops — Home">
          <img src="/logo.svg" alt="LRA Cloud Ops" class="h-9 w-auto" style="filter:brightness(0) invert(1) opacity(0.9);" />
        </a>
        <p class="text-sm leading-relaxed mb-6 max-w-xs" style="color:rgba(148,163,184,0.8);">
          {lang === 'es' ? 'Infraestructura cloud, plataformas Kubernetes y automatización DevOps.' : 'Cloud infrastructure, Kubernetes platforms and DevOps automation.'}
        </p>
        <div class="flex gap-2.5 mb-5">
          <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-lg transition-all hover:scale-110 hover:bg-white/15" style="background:rgba(255,255,255,0.08);" aria-label="GitHub">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path></svg>
          </a>
          <a href="https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-lg transition-all hover:scale-110 hover:bg-white/15" style="background:rgba(255,255,255,0.08);" aria-label="LinkedIn">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
          </a>
          <a href="https://www.instagram.com/lracloudops/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-lg transition-all hover:scale-110 hover:bg-white/15" style="background:rgba(255,255,255,0.08);" aria-label="Instagram @lracloudops">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
        <div class="flex items-center gap-2 text-sm mb-4" style="color:rgba(52,211,153,0.9);">
          <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0" aria-hidden="true"></span>
          <span>{lang === 'es' ? 'Disponible para nuevos proyectos' : 'Accepting new engagements'}</span>
        </div>
        <div class="flex flex-wrap gap-1.5">
          <span class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 rounded-full" style="background: rgba(123,66,188,0.15); color: #A78BFA; border: 1px solid rgba(123,66,188,0.3);">HashiCorp</span>
          <span class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 rounded-full" style="background: rgba(4,159,217,0.15); color: #7DD3FC; border: 1px solid rgba(4,159,217,0.3);">Cisco</span>
          <span class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 rounded-full" style="background: rgba(238,49,36,0.15); color: #FCA5A5; border: 1px solid rgba(238,49,36,0.3);">Fortinet ×2</span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-5 text-white">{lang === 'es' ? 'Servicios' : 'Services'}</h3>
        <ul class="space-y-3">
          {(lang === 'es' ? [
            { label: 'Infraestructura Cloud', href: '/cloud-infrastructure' },
            { label: 'Plataformas Kubernetes', href: '/kubernetes-platforms' },
            { label: 'Automatización DevOps', href: '/devops-automation' },
            { label: 'Ingeniería de Plataforma', href: '/platform-engineering' },
            { label: 'Observabilidad & SRE', href: '/observability' },
            { label: 'Modelos de engagement', href: '/pricing' },
          ] : [
            { label: 'Cloud Infrastructure', href: '/en/cloud-infrastructure' },
            { label: 'Kubernetes Platforms', href: '/en/kubernetes-platforms' },
            { label: 'DevOps Automation', href: '/en/devops-automation' },
            { label: 'Platform Engineering', href: '/en/platform-engineering' },
            { label: 'Observability & SRE', href: '/en/observability' },
            { label: 'Engagement Models', href: '/en/pricing' },
          ]).map(({ label, href }) => (
            <li><a href={href} class="text-sm transition-colors hover:text-white" style="color:rgba(148,163,184,0.7);">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-5 text-white">{lang === 'es' ? 'Recursos' : 'Resources'}</h3>
        <ul class="space-y-3">
          {(lang === 'es' ? [
            { label: 'Blog', href: '/blog' },
            { label: 'Documentación', href: '/en/docs' },
            { label: 'Centro de Arquitectura', href: '/en/architectures' },
            { label: 'Herramientas de evaluación', href: '/assessment' },
            { label: 'Casos de uso', href: '/proyectos' },
            { label: 'Open Source', href: '/open-source' },
            { label: 'Seguridad', href: '/security' },
          ] : [
            { label: 'Blog', href: '/en/blog' },
            { label: 'Documentation', href: '/en/docs' },
            { label: 'Architecture Center', href: '/en/architectures' },
            { label: 'Assessment Tools', href: '/en/assessments' },
            { label: 'Case Studies', href: '/en/projects' },
            { label: 'Open Source', href: '/en/open-source' },
            { label: 'Security', href: '/en/security' },
          ]).map(({ label, href }) => (
            <li><a href={href} class="text-sm transition-colors hover:text-white" style="color:rgba(148,163,184,0.7);">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-5 text-white">{lang === 'es' ? 'Empresa' : 'Company'}</h3>
        <ul class="space-y-3">
          {(lang === 'es' ? [
            { label: 'Nosotros', href: '/nosotros' },
            { label: 'Certificaciones', href: '/certifications' },
            { label: '¿Por qué LRA?', href: '/why-lra' },
            { label: 'Contacto', href: '/contacto' },
            { label: 'Privacidad', href: '/privacy' },
            { label: 'GitHub', href: 'https://github.com/lra-cloud-ops', external: true },
          ] : ([
            { label: 'About', href: '/en/about' },
            { label: 'Certifications', href: '/en/certifications' },
            { label: 'Why LRA', href: '/en/why-lra' },
            { label: 'Contact', href: '/en/contact' },
            { label: 'Privacy', href: '/en/privacy' },
            { label: 'GitHub', href: 'https://github.com/lra-cloud-ops', external: true },
          ] as { label: string; href: string; external?: boolean }[])).map(({ label, href, external }) => (
            <li>
              <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined} class="text-sm transition-colors hover:text-white" style="color:rgba(148,163,184,0.7);">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Footer bottom -->
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-6" style="border-top:1px solid rgba(255,255,255,0.06);">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <span class="text-xs" style="color:rgba(148,163,184,0.4);">
          {lang === 'es'
            ? '© 2026 LRA Cloud Operations · Licencia MIT · Hecho con Astro + Cloudflare · Consultora con sede en la UE'
            : '© 2026 LRA Cloud Operations · MIT License · Built with Astro + Cloudflare · EU-based consultancy'}
        </span>
        <a href={lang === 'en' ? '/en/privacy' : '/privacy'} class="text-xs transition-colors hover:text-white" style="color:rgba(148,163,184,0.35);">{lang === 'es' ? 'Privacidad' : 'Privacy Policy'}</a>
        <a href={lang === 'en' ? '/en/terms' : '/terms'} class="text-xs transition-colors hover:text-white" style="color:rgba(148,163,184,0.35);">{lang === 'es' ? 'Términos' : 'Terms of Service'}</a>
      </div>
      <div class="flex items-center gap-4">
        <!-- Footer language selector -->
        <div data-lang-dropdown data-lang-style="footer" class="relative">
          <button data-lang-dropdown-btn class="inline-flex items-center gap-1 text-xs transition-colors hover:text-white" style="color:rgba(148,163,184,0.55);" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            <span>{lang === 'es' ? 'Español' : 'English'}</span>
            <svg data-lang-chevron class="w-3 h-3 ml-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div data-lang-dropdown-menu role="listbox"
            class="absolute bottom-full right-0 mb-2 w-36 rounded-xl overflow-hidden opacity-0 pointer-events-none"
            style="background:#0F1E33; border:1px solid rgba(255,255,255,0.1); box-shadow:0 -4px 20px rgba(0,0,0,0.4); transform:translateY(6px); transition:opacity 0.15s ease,transform 0.15s ease; z-index:200;">
            <div class="py-2">
              {Object.entries(regions).map(([region, locales], regionIdx) => (
                <div>
                  {locales.map((locale) => {
                    const info = languages[locale as keyof typeof languages]
                    const href = localeUrls[locale as keyof typeof languages]
                    const isActive = locale === lang
                    return (
                      <a href={href} role="option" aria-selected={isActive ? 'true' : 'false'} data-lang-option={locale}
                        class={`flex items-center gap-2 px-3 py-2 text-xs transition-colors ${isActive ? 'font-semibold' : 'hover:bg-white/5'}`}
                        style={isActive ? 'color:white; background:rgba(30,111,255,0.2);' : 'color:rgba(148,163,184,0.7);'}>
                        <span>{info.name}</span>
                        {isActive && <svg class="w-3 h-3 ml-auto flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#1E6FFF;" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>}
                      </a>
                    )
                  })}
                  {regionIdx < Object.keys(regions).length - 1 && <div class="border-t mx-3 my-1.5" style="border-color:rgba(255,255,255,0.07);" />}
                </div>
              ))}
            </div>
          </div>
        </div>
        <span style="color:rgba(255,255,255,0.05);" aria-hidden="true">|</span>
        <div class="flex items-center gap-1.5 text-xs" style="color:rgba(148,163,184,0.4);">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block" aria-hidden="true"></span>
          Cloudflare Edge Network
        </div>
        <span style="color:rgba(255,255,255,0.05);" aria-hidden="true">|</span>
        <span class="text-xs font-mono" style="color:rgba(148,163,184,0.25);">v5.0</span>
      </div>
    </div>
  </div>
</footer>
