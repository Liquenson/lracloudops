---
interface Props {
  active?: string
}

const { active = 'overview' } = Astro.props

const navItems = [
  { key: 'overview', label: 'Overview', href: '/dashboard' },
  { key: 'agents', label: 'Agents', href: '#' },
  { key: 'usage', label: 'Usage', href: '#' },
  { key: 'api-keys', label: 'API Keys', href: '#' },
  { key: 'billing', label: 'Billing', href: '#' },
  { key: 'settings', label: 'Settings', href: '#' },
]

const icons: Record<string, string> = {
  overview: 'M3 12l2-2m0 0l7-7 7 7m-9-9v18h9V12',
  agents:
    'M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-4.13a4 4 0 10-4-4 4 4 0 004 4z',
  usage: 'M3 3v18h18M7 15l4-4 4 4 5-6',
  'api-keys': 'M15 7a2 2 0 012 2m4 0a6 6 0 11-12 0 6 6 0 0112 0zM3 21l6-6',
  billing: 'M3 5h18M3 12h18M3 19h18',
  settings: 'M12 15a3 3 0 100-6 3 3 0 000 6z',
}
---

<div class="dashboard-shell">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <img src="/lracloudops-icon.svg" alt="" width="28" height="28" />
      <span>Platform</span>
    </div>

    <nav class="sidebar-nav">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`sidebar-nav-item ${active === item.key ? 'active' : ''}`}
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d={icons[item.key]}
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>

    <div class="sidebar-user">
      <div class="sidebar-avatar">U</div>
      <div class="sidebar-user-info">
        <p class="sidebar-user-name">User Name</p>
        <p class="sidebar-user-email">user@placeholder.com</p>
      </div>
    </div>
  </aside>

  <main class="dashboard-main">
    <slot />
  </main>
</div>

<style>
  .dashboard-shell {
    display: flex;
    min-height: 100vh;
    background: #faf9f8;
  }
  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0 1.5rem 1.5rem;
    font-family: 'Red Hat Display', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #ffffff;
  }
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
  }
  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem 0;
    margin-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .sidebar-avatar {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    background: #0078d4;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Red Hat Display', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    flex-shrink: 0;
  }
  .sidebar-user-name {
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
  }
  .sidebar-user-email {
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.75rem;
    color: #a19f9d;
  }
  .dashboard-main {
    flex: 1;
    min-width: 0;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (max-width: 860px) {
    .sidebar {
      display: none;
    }
  }
</style>
