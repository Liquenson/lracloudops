const activeServicesItems = lang === 'es' ? esServicesItems : servicesItems
const activeSolutionsItems = lang === 'es' ? esSolutionsItems : solutionsItems
const activeIndustriesItems =
  lang === 'es' ? esIndustriesItems : industriesItems
const activeResourcesItems = lang === 'es' ? esResourcesItems : resourcesItems
const activeAboutItems = lang === 'es' ? esAboutItems : aboutItems

const isServicesActive =
  servicesItems.some(
    (i) => currentPath === i.href || currentPath.startsWith(i.href + '/')
  ) ||
  esServicesItems.some(
    (i) => currentPath === i.href || currentPath.startsWith(i.href + '/')
  ) ||
  currentPath.startsWith('/en/services') ||
  currentPath.startsWith('/servicios')
const isSolutionsActive =
  solutionsItems.some(
    (i) => currentPath === i.href || currentPath.startsWith(i.href + '/')
  ) ||
  esSolutionsItems.some(
    (i) => currentPath === i.href || currentPath.startsWith(i.href + '/')
  )
const isIndustriesActive =
  industriesItems.some(
    (i) => currentPath === i.href || currentPath.startsWith(i.href + '/')
  ) ||
  esIndustriesItems.some(
    (i) => currentPath === i.href || currentPath.startsWith(i.href + '/')
  )
const isResourcesActive = [...resourcesItems, ...esResourcesItems].some(
  (i) => currentPath === i.href || currentPath.startsWith(i.href + '/')
)
const isAboutActive =
  currentPath === '/nosotros' ||
  currentPath === '/en/about' ||
  currentPath === '/certifications' ||
  currentPath === '/en/certifications' ||
  currentPath === '/open-source' ||
  currentPath === '/en/open-source' ||
  currentPath === '/why-lra' ||
  currentPath === '/en/why-lra' ||
  currentPath === '/metodologia' ||
  currentPath === '/en/methodology' ||
  currentPath === '/lra-ai' ||
  currentPath === '/en/lra-ai'
const isHomeActive = currentPath === '/' || currentPath === '/en/'
---

<!-- Skip navigation -->
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded-lg focus:font-semibold"
  >{skipLabel}</a
>

<!-- ── STICKY NAVBAR ── -->
<header
  id="site-header"
  class="sticky top-0 z-50 transition-all duration-300"
  style="background: rgba(255,255,255,0.97); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(15,23,42,0.06);"
>
  <nav
    class="max-w-7xl mx-auto px-5 sm:px-6 h-[66px] flex items-center justify-between gap-4"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href={lang === 'en' ? '/en/' : '/'}
      class="flex items-center gap-2 flex-shrink-0 z-50"
      aria-label="LRA Cloud Ops — Home"
    >
      <img
        src="/lracloudops-icon.svg"
        alt="LRA Cloud Ops"
        width="36"
        height="36"
        style="width:36px; height:36px; flex-shrink:0;"
        loading="eager"
        aria-hidden="true"
      />
      <span class="logo-text-full" aria-hidden="true">LRA CloudOps</span>
      <span class="logo-text-short" aria-hidden="true">LRA</span>
    </a>

    <!-- ── Desktop Nav ── -->
    <div class="hidden lg:flex items-center gap-0.5">
      <!-- Home -->
      <a
        href={lang === 'en' ? '/en/' : '/'}
        class={`relative text-sm font-medium px-3 py-2 rounded-lg transition-all duration-200 ${isHomeActive ? 'text-[#0F172A] font-semibold' : 'text-[#64748B] hover:text-[#0F172A] hover:bg-gray-50'}`}
        aria-current={isHomeActive ? 'page' : undefined}
      >
        {lang === 'es' ? 'Inicio' : 'Home'}
        {
          isHomeActive && (
            <span
              class="absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 w-5 rounded-full"
              style="background:#2563EB;"
            />
          )
        }
      </a>

      <!-- Services dropdown -->
      <div class="relative" data-dropdown="services">
        <button
          data-dropdown-btn
          aria-haspopup="true"
          aria-expanded="false"
          class={`relative inline-flex items-center gap-1 text-sm font-medium px-3 py-2 rounded-lg transition-all duration-200 cursor-pointer ${isServicesActive ? 'text-[#0F172A] font-semibold' : 'text-[#64748B] hover:text-[#0F172A] hover:bg-gray-50'}`}
        >
          {lang === 'es' ? 'Servicios' : 'Services'}
          <svg
            data-dropdown-chevron
            class="w-3.5 h-3.5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M19 9l-7 7-7-7"></path></svg
          >
          {
            isServicesActive && (
              <span
                class="absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 w-5 rounded-full"
                style="background:#2563EB;"
              />
            )
          }
        </button>
        <div
          data-dropdown-menu
          role="menu"
          aria-label="Services submenu"
          class="absolute top-full left-0 mt-2 w-80 rounded-2xl overflow-hidden opacity-0 pointer-events-none"
          style="background:white; border:1px solid rgba(15,23,42,0.08); box-shadow:0 4px 6px rgba(15,23,42,0.04),0 20px 50px rgba(15,23,42,0.14); transform:translateY(-8px); transition:opacity 0.2s ease,transform 0.2s ease;"
        >
          <div class="p-2">
            {
              activeServicesItems.map(({ href, label, desc, iconPath }) => {
                const active =
                  currentPath === href || currentPath.startsWith(href + '/')
                return (
                  <a
                    href={href}
                    role="menuitem"
                    class={`flex items-center gap-3 px-3 py-2.5 rounded-xl transition-colors group ${active ? '' : 'hover:bg-gray-50'}`}
                    style={active ? 'background:#EFF6FF;' : ''}
                  >
                    <div
                      class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
                      style={
                        active ? 'background:#DBEAFE;' : 'background:#F1F5F9;'
                      }
                    >
                      <svg
                        class="w-4 h-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        style={active ? 'color:#2563EB;' : 'color:#64748B;'}
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d={iconPath}
                        />
                      </svg>
                    </div>
                    <div>
                      <div
                        class="text-sm font-medium"
                        style={active ? 'color:#1D4ED8;' : 'color:#0F172A;'}
                      >
                        {label}
                      </div>
                      <div class="text-xs mt-0.5" style="color:#94A3B8;">
                        {desc}
                      </div>
                    </div>
                  </a>
                )
              })
            }
          </div>
        </div>
      </div>

      <!-- Solutions dropdown -->
      <div class="relative" data-dropdown="solutions">
        <button
          data-dropdown-btn
          aria-haspopup="true"
          aria-expanded="false"
          class={`relative inline-flex items-center gap-1 text-sm font-medium px-3 py-2 rounded-lg transition-all duration-200 cursor-pointer ${isSolutionsActive ? 'text-[#0F172A] font-semibold' : 'text-[#64748B] hover:text-[#0F172A] hover:bg-gray-50'}`}
        >
          {lang === 'es' ? 'Soluciones' : 'Solutions'}
          <svg
            data-dropdown-chevron
            class="w-3.5 h-3.5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M19 9l-7 7-7-7"></path></svg
          >
          {
            isSolutionsActive && (
              <span
                class="absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 w-5 rounded-full"
                style="background:#2563EB;"
              />
            )
          }
        </button>
        <div
          data-dropdown-menu
          role="menu"
          aria-label="Solutions submenu"
          class="absolute top-full left-0 mt-2 w-72 rounded-2xl overflow-hidden opacity-0 pointer-events-none"
          style="background:white; border:1px solid rgba(15,23,42,0.08); box-shadow:0 4px 6px rgba(15,23,42,0.04),0 20px 50px rgba(15,23,42,0.14); transform:translateY(-8px); transition:opacity 0.2s ease,transform 0.2s ease;"
        >
          <div class="p-2">
            {
              activeSolutionsItems.map(({ href, label, desc, iconPath }) => {
                const active =
                  currentPath === href || currentPath.startsWith(href + '/')
                return (
                  <a
                    href={href}
                    role="menuitem"
                    class={`flex items-center gap-3 px-3 py-2.5 rounded-xl transition-colors ${active ? '' : 'hover:bg-gray-50'}`}
                    style={active ? 'background:#EFF6FF;' : ''}
                  >
                    <div
                      class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
                      style={
                        active ? 'background:#DBEAFE;' : 'background:#F1F5F9;'
                      }
                    >
                      <svg
                        class="w-4 h-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        style={active ? 'color:#2563EB;' : 'color:#64748B;'}
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d={iconPath}
                        />
                      </svg>
                    </div>
                    <div>
                      <div
                        class="text-sm font-medium"
                        style={active ? 'color:#1D4ED8;' : 'color:#0F172A;'}
                      >
