<script>
  // Generic dropdown handler (desktop)
  const dropdownWrappers = Array.from(
    document.querySelectorAll('[data-dropdown]')
  )
  function closeAllDropdowns() {
    dropdownWrappers.forEach((w) => {
      const m = w.querySelector<HTMLElement>('[data-dropdown-menu]')
      const b = w.querySelector<HTMLElement>('[data-dropdown-btn]')
      const c = w.querySelector<HTMLElement>('[data-dropdown-chevron]')
      if (m) {
        m.style.opacity = '0'
        m.style.pointerEvents = 'none'
        m.style.transform = 'translateY(-8px)'
      }
      if (b) b.setAttribute('aria-expanded', 'false')
      if (c) c.style.transform = ''
    })
  }
  dropdownWrappers.forEach((wrapper) => {
    const btn = wrapper.querySelector<HTMLElement>('[data-dropdown-btn]')
    const menu = wrapper.querySelector<HTMLElement>('[data-dropdown-menu]')
    const chevron = wrapper.querySelector<HTMLElement>(
      '[data-dropdown-chevron]'
    )
    if (!btn || !menu) return
    let closeTimer: ReturnType<typeof setTimeout> | null = null
    function openThis() {
      if (closeTimer) clearTimeout(closeTimer)
      dropdownWrappers.forEach((w) => {
        if (w !== wrapper) {
          const m = w.querySelector<HTMLElement>('[data-dropdown-menu]')
          const b = w.querySelector<HTMLElement>('[data-dropdown-btn]')
          const c = w.querySelector<HTMLElement>('[data-dropdown-chevron]')
          if (m) {
            m.style.opacity = '0'
            m.style.pointerEvents = 'none'
            m.style.transform = 'translateY(-8px)'
          }
          if (b) b.setAttribute('aria-expanded', 'false')
          if (c) c.style.transform = ''
        }
      })
      menu!.style.opacity = '1'
      menu!.style.pointerEvents = 'auto'
      menu!.style.transform = 'translateY(0)'
      btn!.setAttribute('aria-expanded', 'true')
      if (chevron) chevron.style.transform = 'rotate(180deg)'
    }
    function closeThis() {
      menu!.style.opacity = '0'
      menu!.style.pointerEvents = 'none'
      menu!.style.transform = 'translateY(-8px)'
      btn!.setAttribute('aria-expanded', 'false')
      if (chevron) chevron.style.transform = ''
    }
    wrapper.addEventListener('mouseenter', openThis)
    wrapper.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(closeThis, 120)
    })
    btn.addEventListener('click', () => {
      btn.getAttribute('aria-expanded') === 'true' ? closeThis() : openThis()
    })
    btn.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        btn.getAttribute('aria-expanded') === 'true' ? closeThis() : openThis()
      }
      if (e.key === 'Escape') closeThis()
    })
    menu.addEventListener('mouseenter', () => {
      if (closeTimer) clearTimeout(closeTimer)
    })
    menu.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(closeThis, 120)
    })
  })
  document.addEventListener('click', (e: MouseEvent) => {
    if (!dropdownWrappers.some((w) => w.contains(e.target as Node)))
      closeAllDropdowns()
  })
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') closeAllDropdowns()
  })
</script>

<script>
  // Mobile menu
  const menuBtn = document.getElementById('menu-btn')
  const drawer = document.getElementById('mobile-drawer')
  const overlay = document.getElementById('mobile-overlay')
  const bar1 = document.getElementById('bar1')
  const bar2 = document.getElementById('bar2')
  const bar3 = document.getElementById('bar3')
  let isOpen = false
  function openMenu() {
    isOpen = true
    if (drawer) drawer.style.transform = 'translateX(0)'
    if (overlay) {
      overlay.style.opacity = '1'
      overlay.style.pointerEvents = 'auto'
    }
    document.body.style.overflow = 'hidden'
    if (bar1) bar1.style.transform = 'translateY(6px) rotate(45deg)'
    if (bar2) bar2.style.opacity = '0'
    if (bar3) bar3.style.transform = 'translateY(-6px) rotate(-45deg)'
    menuBtn?.setAttribute('aria-expanded', 'true')
  }
  function closeMenu() {
    isOpen = false
    if (drawer) drawer.style.transform = 'translateX(100%)'
    if (overlay) {
      overlay.style.opacity = '0'
      overlay.style.pointerEvents = 'none'
    }
    document.body.style.overflow = ''
    if (bar1) bar1.style.transform = ''
    if (bar2) bar2.style.opacity = '1'
    if (bar3) bar3.style.transform = ''
    menuBtn?.setAttribute('aria-expanded', 'false')
  }
  menuBtn?.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()))
  overlay?.addEventListener('click', closeMenu)
  document
    .querySelectorAll('#mobile-drawer a')
    .forEach((l) => l.addEventListener('click', closeMenu))
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && isOpen) closeMenu()
  })

  // Mobile accordion
  const accordions = Array.from(document.querySelectorAll('[data-accordion]'))
  accordions.forEach((section) => {
    const trigger = section.querySelector<HTMLElement>(
      '[data-accordion-trigger]'
    )
    const content = section.querySelector<HTMLElement>(
      '[data-accordion-content]'
    )
    const chevron = section.querySelector<HTMLElement>(
      '[data-accordion-chevron]'
    )
    if (!trigger || !content) return
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true'
      accordions.forEach((other) => {
        if (other !== section) {
          const ot = other.querySelector<HTMLElement>(
            '[data-accordion-trigger]'
          )
          const oc = other.querySelector<HTMLElement>(
            '[data-accordion-content]'
          )
          const ov = other.querySelector<HTMLElement>(
            '[data-accordion-chevron]'
          )
          if (ot) ot.setAttribute('aria-expanded', 'false')
          if (oc) {
            oc.style.maxHeight = '0'
            oc.style.opacity = '0'
          }
          if (ov) ov.style.transform = ''
        }
      })
      if (expanded) {
        trigger.setAttribute('aria-expanded', 'false')
        content.style.maxHeight = '0'
        content.style.opacity = '0'
        if (chevron) chevron.style.transform = ''
      } else {
        trigger.setAttribute('aria-expanded', 'true')
        content.style.maxHeight = content.scrollHeight + 'px'
        content.style.opacity = '1'
        if (chevron) chevron.style.transform = 'rotate(180deg)'
      }
    })
  })

  // Navbar scroll shadow
  const header = document.getElementById('site-header')
  let scrolled = false
  window.addEventListener(
    'scroll',
    () => {
      const s = window.scrollY > 10
      if (s !== scrolled) {
        scrolled = s
        if (header)
          header.style.boxShadow = scrolled
            ? '0 1px 0 rgba(15,23,42,0.05),0 4px 20px rgba(15,23,42,0.07)'
            : 'none'
      }
    },
    { passive: true }
  )
</script>

<script>
  // Language dropdown + localStorage preference
  const LANG_PREF_KEY = 'lang-preference'
  document.querySelectorAll('[data-lang-option]').forEach((el) => {
    el.addEventListener('click', () => {
      const v = (el as HTMLElement).dataset.langOption
      if (v) localStorage.setItem(LANG_PREF_KEY, v)
    })
  })
  const langDropdowns = Array.from(
    document.querySelectorAll('[data-lang-dropdown]')
  )
  function closeLangDropdown(wrapper: Element) {
    const m = wrapper.querySelector<HTMLElement>('[data-lang-dropdown-menu]')
    const b = wrapper.querySelector<HTMLElement>('[data-lang-dropdown-btn]')
    const c = wrapper.querySelector<HTMLElement>('[data-lang-chevron]')
    const style = (wrapper as HTMLElement).dataset.langStyle
    if (m) {
      if (style === 'mobile') {
        m.style.maxHeight = '0'
        m.style.opacity = '0'
      } else {
        m.style.opacity = '0'
        m.style.pointerEvents = 'none'
        m.style.transform =
          style === 'footer' ? 'translateY(6px)' : 'translateY(-6px)'
      }
    }
    if (b) b.setAttribute('aria-expanded', 'false')
    if (c) c.style.transform = ''
  }
  function closeAllLangDropdowns() {
    langDropdowns.forEach((w) => closeLangDropdown(w))
  }
  langDropdowns.forEach((wrapper) => {
    const btn = wrapper.querySelector<HTMLElement>('[data-lang-dropdown-btn]')
    const menu = wrapper.querySelector<HTMLElement>('[data-lang-dropdown-menu]')
    const chevron = wrapper.querySelector<HTMLElement>('[data-lang-chevron]')
    const style = (wrapper as HTMLElement).dataset.langStyle
    if (!btn || !menu) return
    function openLang() {
      closeAllLangDropdowns()
      if (style === 'mobile') {
        menu!.style.maxHeight = menu!.scrollHeight + 'px'
        menu!.style.opacity = '1'
      } else {
        menu!.style.opacity = '1'
        menu!.style.pointerEvents = 'auto'
        menu!.style.transform = 'translateY(0)'
      }
      btn!.setAttribute('aria-expanded', 'true')
      if (chevron) chevron.style.transform = 'rotate(180deg)'
    }
    btn.addEventListener('click', (e) => {
      e.stopPropagation()
      btn!.getAttribute('aria-expanded') === 'true'
        ? closeLangDropdown(wrapper)
        : openLang()
    })
    btn.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        btn!.getAttribute('aria-expanded') === 'true'
          ? closeLangDropdown(wrapper)
          : openLang()
      }
      if (e.key === 'Escape') closeLangDropdown(wrapper)
    })
  })
  document.addEventListener('click', (e: MouseEvent) => {
    if (!langDropdowns.some((w) => w.contains(e.target as Node)))
      closeAllLangDropdowns()
  })
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') closeAllLangDropdowns()
  })
</script>
