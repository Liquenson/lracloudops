---
interface Props {
  lang?: string
}
const { lang = 'en' } = Astro.props
const isES = lang === 'es'
const currentYear = new Date().getFullYear()

const brandBlurb = isES
  ? 'Ingeniería DevOps open source. Patrones de nivel producción. Código público.'
  : 'Open source DevOps engineering. Production-grade patterns. Public codebase.'

const projectsLabel = isES ? 'Proyectos' : 'Projects'
const contactLabel = isES ? 'Contacto' : 'Contact'

const certifications = ['ITLA — IT Essentials', 'INFOTEP — HP Information Technology', 'Cisco Networking Academy']

const projects: [string, string][] = [
  ['lra-ai-platform', 'https://github.com/lra-cloud-ops/lra-ai-platform'],
  ['aws-devops-agent', 'https://github.com/lra-cloud-ops/aws-devops-agent'],
  [
    'aws-terraform-devops',
    'https://github.com/lra-cloud-ops/aws-terraform-devops',
  ],
  ['k8s-on-premise', 'https://github.com/lra-cloud-ops/k8s-on-premise'],
]
---

<footer
  style="background: #202124; padding: 3rem 1.5rem 2rem; border-top: 1px solid #3C4043;"
>
  <div style="max-width: 1280px; margin: 0 auto;">
    <div
      style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; padding-bottom: 2.5rem; border-bottom: 1px solid #3C4043; margin-bottom: 1.5rem;"
      class="footer-grid"
    >
      <!-- Brand -->
      <div>
        <div
          style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;"
        >
          <img src="/lracloudops-logo-dark.png" alt="LRA CloudOps" style="height: 28px; width: auto;" />
          <span
            style="font-family: 'Red Hat Display', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #FFFFFF;"
          >
            LRA CloudOps
          </span>
        </div>
        <p
          style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #9AA0A6; line-height: 1.6; margin-bottom: 1.25rem; max-width: 280px;"
        >
          {brandBlurb}
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.875rem;">
          {certifications.map(cert => (
            <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.6875rem; color: #5F6368; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); padding: 0.125rem 0.5rem; border-radius: 3px;">{cert}</span>
          ))}
        </div>
        <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
          <a
            href="https://github.com/lra-cloud-ops"
            target="_blank"
            rel="noopener"
            style="width: 36px; height: 36px; border-radius: 50%; background: #3C4043; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: background 150ms;"
            onmouseover="this.style.background='#5F6368'"
            onmouseout="this.style.background='#3C4043'"
            title="GitHub Organization"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#9AA0A6">
              <path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/ruben-liquenson-490961269/"
            target="_blank"
            rel="noopener"
            style="width: 36px; height: 36px; border-radius: 50%; background: #3C4043; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: background 150ms;"
            onmouseover="this.style.background='#5F6368'"
            onmouseout="this.style.background='#3C4043'"
            title="LinkedIn"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#9AA0A6">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Projects -->
      <div>
        <p
          style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #9AA0A6; margin-bottom: 1rem;"
        >
          {projectsLabel}
        </p>
        {
          projects.map(([name, href]) => (
            <a
              href={href}
              target="_blank"
              rel="noopener"
              style="display: block; font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; color: #9AA0A6; text-decoration: none; margin-bottom: 0.625rem; transition: color 150ms ease;"
              onmouseover="this.style.color='#FFFFFF'"
              onmouseout="this.style.color='#9AA0A6'"
            >
              {name}
            </a>
          ))
        }
      </div>

      <!-- Contact -->
      <div>
        <p
          style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #9AA0A6; margin-bottom: 1rem;"
        >
          {contactLabel}
        </p>
        <a
          href="mailto:info@lracloudops.com"
          style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #9AA0A6; text-decoration: none; margin-bottom: 0.625rem; transition: color 150ms ease;"
          onmouseover="this.style.color='#FFFFFF'"
          onmouseout="this.style.color='#9AA0A6'"
        >
          info@lracloudops.com
        </a>
        <a
          href="https://www.linkedin.com/in/ruben-liquenson-490961269/"
          target="_blank"
          rel="noopener"
          style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #9AA0A6; text-decoration: none; margin-bottom: 0.625rem; transition: color 150ms ease;"
          onmouseover="this.style.color='#FFFFFF'"
          onmouseout="this.style.color='#9AA0A6'"
        >
          LinkedIn
        </a>
        <a
          href="https://github.com/lra-cloud-ops"
          target="_blank"
          rel="noopener"
          style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #9AA0A6; text-decoration: none; margin-bottom: 0.625rem; transition: color 150ms ease;"
          onmouseover="this.style.color='#FFFFFF'"
          onmouseout="this.style.color='#9AA0A6'"
        >
          GitHub Organization
        </a>
        <p
          style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368; margin-top: 1rem; line-height: 1.5;"
        >
          📍 Las Palmas de Gran Canaria<br />Canarias, España
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="footer-bottom"
      style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;"
    >
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368;"
      >
        © {currentYear} LRA CloudOps · Ruben Liquenson · Las Palmas de Gran
        Canaria, España
      </p>
      <div
        style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;"
      >
        <a
          href="https://www.linkedin.com/company/nibble-tech-llc/"
          target="_blank"
          rel="noopener"
        >
          <img
            src="/nibble-logo.jpg"
            alt="Nibble Tech LLC"
            style="height: 20px; width: auto; border-radius: 3px; opacity: 0.5; transition: opacity 150ms;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.5'"
          />
        </a>
        <a
          href="https://www.linkedin.com/school/itla/"
          target="_blank"
          rel="noopener"
        >
          <img
            src="/itla-logo.jpg"
            alt="ITLA"
            style="height: 20px; width: auto; border-radius: 3px; opacity: 0.5; transition: opacity 150ms;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.5'"
          />
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Tablet (768–1199px): brand + 2 link columns */
  @media (max-width: 1199px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  /* Mobile (< 768px): single column, compact — Red Hat pattern */
  @media (max-width: 767px) {
    footer {
      padding: 2.5rem 1.5rem 1.5rem !important;
    }
    .footer-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
      padding-bottom: 2rem !important;
    }
    .footer-bottom {
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 1.25rem !important;
    }
  }
</style>
