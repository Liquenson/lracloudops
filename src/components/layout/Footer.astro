---
const currentPath = Astro.url.pathname
const isES = currentPath.startsWith('/es')

const year = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="footer-name">Ruben Liquenson</p>
        <p class="footer-role">
          {
            isES
              ? 'Ingeniero DevOps & Especialista AWS'
              : 'DevOps Engineer & AWS Specialist'
          }
        </p>
        <p class="footer-location">📍 Las Palmas de Gran Canaria, España</p>
        <div class="footer-status">
          <span class="status-dot"></span>
          {
            isES
              ? 'Disponible para nuevos proyectos'
              : 'Available for new projects'
          }
        </div>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <p class="footer-col-title">{isES ? 'Navegación' : 'Navigation'}</p>
          <a href={isES ? '/es/' : '/'}>{isES ? 'Inicio' : 'Home'}</a>
          <a href={isES ? '/es/sobre-mi' : '/about'}
            >{isES ? 'Sobre mí' : 'About'}</a
          >
          <a href={isES ? '/es/proyectos' : '/projects'}
            >{isES ? 'Proyectos' : 'Projects'}</a
          >
          <a href={isES ? '/es/blog' : '/blog'}>Blog</a>
          <a href={isES ? '/es/contacto' : '/contact'}
            >{isES ? 'Contacto' : 'Contact'}</a
          >
        </div>
        <div class="footer-col">
          <p class="footer-col-title">{isES ? 'Conectar' : 'Connect'}</p>
          <a
            href="https://www.linkedin.com/in/rubenliquenson-490961269"
            target="_blank"
            rel="noopener">LinkedIn</a
          >
          <a href="https://github.com/Liquenson" target="_blank" rel="noopener"
            >GitHub</a
          >
          <a
            href="https://github.com/lra-cloud-ops"
            target="_blank"
            rel="noopener">LRA GitHub</a
          >
          <a href="mailto:liquenson.cloud@gmail.com">Email</a>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">Stack</p>
          <a href={isES ? '/es/proyectos' : '/projects'}>AWS · EKS</a>
          <a href={isES ? '/es/proyectos' : '/projects'}>Terraform</a>
          <a href={isES ? '/es/proyectos' : '/projects'}>Kubernetes</a>
          <a href={isES ? '/es/proyectos' : '/projects'}>ArgoCD · GitOps</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        © {year} Ruben Liquenson · {isES ? 'Hecho con' : 'Built with'} Astro · Cloudflare
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-dark);
    color: var(--text-inverse);
    padding-block: 4rem 2rem;
    border-top: 1px solid var(--border-dark);
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border-dark);
    margin-bottom: 2rem;
  }
  .footer-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.25rem;
  }
  .footer-role {
    font-size: 0.875rem;
    color: var(--text-inverse-muted);
    margin-bottom: 0.5rem;
  }
  .footer-location {
    font-size: 0.875rem;
    color: var(--text-inverse-muted);
    margin-bottom: 1rem;
  }
  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #4ade80;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .footer-col-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-inverse-muted);
    margin-bottom: 0.25rem;
  }
  .footer-col a {
    font-size: 0.9375rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-col a:hover {
    color: #fff;
  }
  .footer-bottom {
    text-align: center;
    font-size: 0.8125rem;
    color: #4b5563;
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
