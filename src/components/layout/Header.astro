---
interface Props {
  lang?: string
  currentPath?: string
}
const { lang = 'en', currentPath = Astro.url.pathname } = Astro.props
const isES = lang === 'es'
const base = isES ? '/es' : ''

const navItems = isES
  ? [
      { label: 'Proyectos', href: `${base}/proyectos` },
      { label: 'Servicios', href: `${base}/servicios` },
      { label: 'Precios', href: `${base}/precios` },
      { label: 'Sobre nosotros', href: `${base}/sobre-nosotros` },
      { label: 'Contacto', href: `${base}/contacto` },
    ]
  : [
      { label: 'Projects', href: '/projects' },
      { label: 'Services', href: '/services' },
      { label: 'Pricing', href: '/pricing' },
      { label: 'About', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ]

const ctaLabel = isES ? 'Contactar' : 'Get in touch'
const ctaHref = isES ? '/es/contacto' : '/contact'

const isActive = (href: string) =>
  currentPath === href || currentPath === href + '/'
---

<header
  style="position: sticky; top: 0; z-index: 100; background: #FFFFFF; border-bottom: 1px solid #DADCE0; height: 64px;"
>
  <div
    style="max-width: 1280px; margin: 0 auto; padding-inline: clamp(1rem, 5vw, 2rem); display: flex; align-items: center; justify-content: space-between; height: 100%; gap: 1.5rem;"
  >
    <a
      href={isES ? '/es/' : '/'}
      style="display: flex; align-items: center; gap: 0.625rem; text-decoration: none; flex-shrink: 0;"
    >
      <img
        src="/lracloudops-icon.svg"
        alt="LRA CloudOps"
        width="28"
        height="28"
      />
      <span
        style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; letter-spacing: -0.01em;"
        >LRA CloudOps</span
      >
    </a>

    <nav
      style="display: flex; align-items: center; gap: 0; margin-left: auto;"
      class="gc-nav"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            style={`padding: 0 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; font-weight: ${isActive(item.href) ? '600' : '500'}; color: ${isActive(item.href) ? '#1A73E8' : '#5F6368'}; text-decoration: none; height: 64px; display: flex; align-items: center; border-bottom: 3px solid ${isActive(item.href) ? '#1A73E8' : 'transparent'}; transition: all 150ms ease; white-space: nowrap;`}
            onmouseover="this.style.borderBottomColor='#1A73E8'; this.style.color='#1A73E8'"
            onmouseout={`this.style.borderBottomColor='${isActive(item.href) ? '#1A73E8' : 'transparent'}'; this.style.color='${isActive(item.href) ? '#1A73E8' : '#5F6368'}'`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <button
      id="mobile-menu-btn"
      style="display: none; width: 44px; height: 44px; align-items: center; justify-content: center; background: transparent; border: none; cursor: pointer; color: #202124; flex-shrink: 0;"
      aria-label="Toggle menu"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a
      href={ctaHref}
      style="display: inline-flex; align-items: center; background: #1A73E8; color: #FFFFFF; padding: 0.5rem 1.25rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 500; text-decoration: none; white-space: nowrap; flex-shrink: 0;"
      class="header-cta"
    >
      {ctaLabel}
    </a>
  </div>
</header>

<div
  id="mobile-overlay"
  style="display: none; position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.5);"
>
  <div
    style="position: absolute; top: 0; right: 0; width: 280px; height: 100%; background: #FFFFFF; padding: 1.5rem; box-shadow: -4px 0 24px rgba(0,0,0,0.15); display: flex; flex-direction: column;"
  >
    <div
      style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;"
    >
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <img src="/lracloudops-icon.svg" alt="" width="22" height="22" />
        <span
          style="font-family: 'Red Hat Display', sans-serif; font-weight: 700; color: #202124; font-size: 0.9375rem;"
          >LRA CloudOps</span
        >
      </div>
      <button
        id="mobile-close"
        style="background: transparent; border: none; cursor: pointer; color: #5F6368; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; margin: -0.5rem -0.5rem -0.5rem 0;"
        aria-label="Close menu"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <nav style="display: flex; flex-direction: column; gap: 0.25rem; flex: 1;">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            style={`padding: 0.75rem; font-family: 'Red Hat Text', sans-serif; font-size: 1rem; font-weight: ${isActive(item.href) ? '600' : '500'}; color: ${isActive(item.href) ? '#1A73E8' : '#202124'}; border-radius: 6px; text-decoration: none; display: block; background: ${isActive(item.href) ? '#E8F0FE' : 'transparent'};`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a
      href={ctaHref}
      style="display: block; text-align: center; padding: 0.75rem; font-family: 'Red Hat Text', sans-serif; font-weight: 600; color: #FFFFFF; background: #1A73E8; border-radius: 6px; text-decoration: none; margin-top: 1rem;"
    >
      {ctaLabel}
    </a>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const overlay = document.getElementById('mobile-overlay')
  const close = document.getElementById('mobile-close')

  btn?.addEventListener('click', () => {
    if (overlay) overlay.style.display = 'block'
    document.body.style.overflow = 'hidden'
  })

  const closeFn = () => {
    if (overlay) overlay.style.display = 'none'
    document.body.style.overflow = ''
  }

  close?.addEventListener('click', closeFn)
  overlay?.addEventListener('click', (event) => {
    if (event.target === overlay) closeFn()
  })
</script>

<style>
  /* Full inline nav only fits on true desktop (>= 1024px) — collapsing it
     earlier on tablets risks the nav + CTA overflowing the header width. */
  @media (max-width: 1023px) {
    .gc-nav {
      display: none !important;
    }
    .header-cta {
      display: none !important;
    }
    #mobile-menu-btn {
      display: flex !important;
      margin-left: auto;
      order: 3;
    }
  }
</style>
