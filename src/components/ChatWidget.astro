---
// Chat widget — connects to lracloudops-agent Cloudflare Worker
---

<!-- Chat button. #lang-switcher is now bottom-left, so this stays bottom-right without overlap. -->
<div id="chat-widget" style="position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 1000;">

  <!-- Toggle button -->
  <button
    id="chat-toggle"
    aria-label="Open chat"
    style="
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: #1A73E8;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(26,115,232,0.35);
      transition: transform 150ms ease, box-shadow 150ms ease;
    "
    class="chat-toggle-hover"
  >
    <!-- Chat icon -->
    <svg id="chat-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <!-- Close icon (hidden) -->
    <svg id="chat-icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- Chat window -->
  <div
    id="chat-window"
    style="
      display: none;
      position: absolute;
      bottom: 64px;
      right: 0;
      width: 340px;
      height: 480px;
      background: #FFFFFF;
      border: 1px solid #DADCE0;
      border-radius: 12px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.14);
      flex-direction: column;
      overflow: hidden;
    "
  >
    <!-- Header -->
    <div style="
      background: #1A73E8;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-shrink: 0;
    ">
      <div style="
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      ">
        <img src="/asesor2.png" alt="" width="20" height="20" />
      </div>
      <div>
        <p style="font-family: 'Red Hat Display', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #FFFFFF; margin: 0;">LRA CloudOps</p>
        <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; color: rgba(255,255,255,0.8); margin: 0;" id="chat-status">DevOps advisor · online</p>
      </div>
    </div>

    <!-- Messages -->
    <div
      id="chat-messages"
      style="
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        background: #F8F9FA;
      "
    >
      <!-- Welcome message -->
      <div style="display: flex; gap: 0.5rem; align-items: start;">
        <div style="
          width: 28px;
          height: 28px;
          border-radius: 50%;
          background: #1A73E8;
          display: flex;
          align-items: center;
          justify-content: center;
          flex-shrink: 0;
          margin-top: 2px;
        ">
          <img src="/asesor2.png" alt="" width="16" height="16" />
        </div>
        <div style="
          background: #FFFFFF;
          border: 1px solid #DADCE0;
          border-radius: 0 8px 8px 8px;
          padding: 0.625rem 0.875rem;
          max-width: 240px;
        ">
          <p id="welcome-msg" style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #202124; margin: 0; line-height: 1.5;">
            Hi! I'm the LRA CloudOps advisor. Ask me about DevOps, AWS, Kubernetes or our services.
          </p>
        </div>
      </div>
    </div>

    <!-- Suggested questions -->
    <div id="suggestions" style="
      padding: 0.75rem 1rem;
      background: #FFFFFF;
      border-top: 1px solid #DADCE0;
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      flex-shrink: 0;
    ">
      <button class="suggestion-btn" style="
        font-family: 'Red Hat Text', sans-serif;
        font-size: 0.75rem;
        color: #1A73E8;
        background: #E8F0FE;
        border: 1px solid #C5D8F8;
        border-radius: 12px;
        padding: 0.25rem 0.625rem;
        cursor: pointer;
        white-space: nowrap;
      ">What is lra scan?</button>
      <button class="suggestion-btn" style="
        font-family: 'Red Hat Text', sans-serif;
        font-size: 0.75rem;
        color: #1A73E8;
        background: #E8F0FE;
        border: 1px solid #C5D8F8;
        border-radius: 12px;
        padding: 0.25rem 0.625rem;
        cursor: pointer;
        white-space: nowrap;
      ">Pricing?</button>
      <button class="suggestion-btn" style="
        font-family: 'Red Hat Text', sans-serif;
        font-size: 0.75rem;
        color: #1A73E8;
        background: #E8F0FE;
        border: 1px solid #C5D8F8;
        border-radius: 12px;
        padding: 0.25rem 0.625rem;
        cursor: pointer;
        white-space: nowrap;
      ">Free audit?</button>
    </div>

    <!-- Input -->
    <div style="
      padding: 0.75rem 1rem;
      background: #FFFFFF;
      border-top: 1px solid #DADCE0;
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-shrink: 0;
    ">
      <input
        id="chat-input"
        type="text"
        placeholder="Ask about DevOps..."
        style="
          flex: 1;
          padding: 0.5rem 0.75rem;
          font-family: 'Red Hat Text', sans-serif;
          font-size: 0.875rem;
          color: #202124;
          background: #F8F9FA;
          border: 1px solid #DADCE0;
          border-radius: 6px;
          outline: none;
        "
      />
      <button
        id="chat-send"
        style="
          width: 36px;
          height: 36px;
          border-radius: 6px;
          background: #1A73E8;
          border: none;
          cursor: pointer;
          display: flex;
          align-items: center;
          justify-content: center;
          flex-shrink: 0;
          transition: background 150ms ease;
        "
        class="chat-send-hover"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  const WORKER_URL = 'https://lracloudops-agent.liquenson-cloud.workers.dev'
  const lang = document.documentElement.lang || 'en'
  const isES = lang === 'es'

  // Localize welcome message and placeholder
  const welcomeMsg = document.getElementById('welcome-msg')
  const chatInput = document.getElementById('chat-input') as HTMLInputElement
  const chatStatus = document.getElementById('chat-status')

  if (isES) {
    if (welcomeMsg) welcomeMsg.textContent = '¡Hola! Soy el asesor de LRA CloudOps. Pregúntame sobre DevOps, AWS, Kubernetes o nuestros servicios.'
    if (chatInput) chatInput.placeholder = 'Pregunta sobre DevOps...'
    if (chatStatus) chatStatus.textContent = 'Asesor DevOps · en línea'
  }

  // Localize suggestion buttons
  const suggestions = document.querySelectorAll('.suggestion-btn')
  if (isES && suggestions.length >= 3) {
    suggestions[0].textContent = '¿Qué es lra scan?'
    suggestions[1].textContent = '¿Precios?'
    suggestions[2].textContent = '¿Auditoría gratis?'
  }

  // State
  const messages: { role: string; content: string }[] = []
  let isOpen = false
  let isLoading = false

  // Elements
  const toggle = document.getElementById('chat-toggle')
  const window_ = document.getElementById('chat-window')
  const messagesDiv = document.getElementById('chat-messages')
  const input = document.getElementById('chat-input') as HTMLInputElement
  const sendBtn = document.getElementById('chat-send')
  const iconOpen = document.getElementById('chat-icon-open')
  const iconClose = document.getElementById('chat-icon-close')
  const suggestionsDiv = document.getElementById('suggestions')

  function openChat() {
    isOpen = true
    if (window_) window_.style.display = 'flex'
    if (iconOpen) iconOpen.style.display = 'none'
    if (iconClose) iconClose.style.display = 'block'
    if (input) input.focus()
  }

  function closeChat() {
    isOpen = false
    if (window_) window_.style.display = 'none'
    if (iconOpen) iconOpen.style.display = 'block'
    if (iconClose) iconClose.style.display = 'none'
  }

  toggle?.addEventListener('click', () => {
    isOpen ? closeChat() : openChat()
  })

  function addMessage(role: 'user' | 'assistant', text: string) {
    const isUser = role === 'user'
    const div = document.createElement('div')
    div.style.cssText = `display: flex; gap: 0.5rem; align-items: start; ${isUser ? 'flex-direction: row-reverse;' : ''}`

    const avatar = document.createElement('div')
    avatar.style.cssText = `
      width: 28px; height: 28px; border-radius: 50%;
      background: ${isUser ? '#E8F0FE' : '#1A73E8'};
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 2px;
      font-family: 'Red Hat Text', sans-serif; font-size: 0.6875rem;
      font-weight: 700; color: ${isUser ? '#1A73E8' : '#FFFFFF'};
    `
    avatar.textContent = isUser ? 'You' : 'LRA'

    const bubble = document.createElement('div')
    bubble.style.cssText = `
      background: ${isUser ? '#1A73E8' : '#FFFFFF'};
      border: 1px solid ${isUser ? '#1A73E8' : '#DADCE0'};
      border-radius: ${isUser ? '8px 0 8px 8px' : '0 8px 8px 8px'};
      padding: 0.625rem 0.875rem;
      max-width: 240px;
      font-family: 'Red Hat Text', sans-serif;
      font-size: 0.875rem;
      color: ${isUser ? '#FFFFFF' : '#202124'};
      line-height: 1.5;
      white-space: pre-wrap;
    `
    bubble.textContent = text

    div.appendChild(avatar)
    div.appendChild(bubble)
    messagesDiv?.appendChild(div)
    messagesDiv?.scrollTo({ top: messagesDiv.scrollHeight, behavior: 'smooth' })
  }

  function addTypingIndicator() {
    const div = document.createElement('div')
    div.id = 'typing-indicator'
    div.style.cssText = 'display: flex; gap: 0.5rem; align-items: center;'

    const avatar = document.createElement('div')
    avatar.style.cssText = `
      width: 28px; height: 28px; border-radius: 50%;
      background: #1A73E8; display: flex; align-items: center;
      justify-content: center; flex-shrink: 0;
      font-family: 'Red Hat Text', sans-serif; font-size: 0.6875rem;
      font-weight: 700; color: #FFFFFF;
    `
    avatar.textContent = 'LRA'

    const dots = document.createElement('div')
    dots.style.cssText = `
      background: #FFFFFF; border: 1px solid #DADCE0;
      border-radius: 0 8px 8px 8px; padding: 0.75rem 1rem;
      display: flex; gap: 0.25rem; align-items: center;
    `
    dots.innerHTML = `
      <span style="width:6px;height:6px;border-radius:50%;background:#9AA0A6;animation:typing 1.2s infinite 0s"></span>
      <span style="width:6px;height:6px;border-radius:50%;background:#9AA0A6;animation:typing 1.2s infinite 0.2s"></span>
      <span style="width:6px;height:6px;border-radius:50%;background:#9AA0A6;animation:typing 1.2s infinite 0.4s"></span>
    `

    div.appendChild(avatar)
    div.appendChild(dots)
    messagesDiv?.appendChild(div)
    messagesDiv?.scrollTo({ top: messagesDiv.scrollHeight, behavior: 'smooth' })
  }

  function removeTypingIndicator() {
    document.getElementById('typing-indicator')?.remove()
  }

  async function sendMessage(text: string) {
    if (!text.trim() || isLoading) return

    // Hide suggestions after first message
    if (suggestionsDiv) suggestionsDiv.style.display = 'none'

    isLoading = true
    if (sendBtn) (sendBtn as HTMLButtonElement).disabled = true
    if (input) input.value = ''

    messages.push({ role: 'user', content: text })
    addMessage('user', text)
    addTypingIndicator()

    try {
      const res = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages }),
      })

      const data = await res.json()
      const reply = data.text || (isES ? 'Error al procesar tu mensaje.' : 'Error processing your message.')

      removeTypingIndicator()
      messages.push({ role: 'assistant', content: reply })
      addMessage('assistant', reply)

    } catch {
      removeTypingIndicator()
      const errorMsg = isES
        ? 'Error de conexión. Inténtalo de nuevo.'
        : 'Connection error. Please try again.'
      addMessage('assistant', errorMsg)
    }

    isLoading = false
    if (sendBtn) (sendBtn as HTMLButtonElement).disabled = false
    if (input) input.focus()
  }

  // Send on button click
  sendBtn?.addEventListener('click', () => {
    sendMessage(input?.value || '')
  })

  // Send on Enter
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault()
      sendMessage(input.value)
    }
  })

  // Suggestion buttons
  document.querySelectorAll('.suggestion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      sendMessage(btn.textContent || '')
    })
  })
</script>

<style>
  @keyframes typing {
    0%, 60%, 100% { opacity: 0.3; transform: scale(0.8); }
    30% { opacity: 1; transform: scale(1); }
  }

  #chat-window {
    animation: slideUp 200ms ease-out;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    #chat-window {
      width: calc(100vw - 2rem) !important;
      right: -0.5rem !important;
      height: 420px !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #chat-window { animation: none !important; }
    .suggestion-btn { transition: none !important; }
  }

  .chat-toggle-hover:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(26, 115, 232, 0.45) !important;
  }

  .chat-send-hover:hover {
    background: #1557b0 !important;
  }
</style>
