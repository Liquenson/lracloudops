---
import { getLangFromUrl } from '../i18n/index'

interface Props {
  title?: string
  subtitle?: string
  darkBackground?: boolean
}

const lang = getLangFromUrl(Astro.url)
const isES = lang === 'es'

const {
  title = isES
    ? 'Newsletter de Ingeniería DevOps'
    : 'DevOps Engineering Newsletter',
  subtitle = isES
    ? 'Artículos mensuales sobre infraestructura cloud, Kubernetes e ingeniería de plataforma. Sin spam, cancela cuando quieras.'
    : 'Monthly insights on cloud infrastructure, Kubernetes and platform engineering. No spam, unsubscribe anytime.',
  darkBackground = false,
} = Astro.props

const placeholder = isES ? 'tu@empresa.com' : 'you@company.com'
const subscribeBtn = isES ? 'Suscribirse →' : 'Subscribe →'
const subscribingTx = isES ? 'Suscribiendo...' : 'Subscribing...'
const subscribedMsg = isES
  ? '¡Suscrito! Recibirás nuestro próximo número.'
  : 'Subscribed! You will receive our next issue.'
const subscribedBtn = isES ? 'Suscrito ✓' : 'Subscribed ✓'
const errorMsg = isES
  ? 'Error al suscribirse. Por favor intenta de nuevo.'
  : 'Error subscribing. Please try again.'
const connErrorMsg = isES
  ? 'Error de conexión. Por favor intenta de nuevo.'
  : 'Connection error. Please try again.'

const bgStyle = darkBackground
  ? 'background: #0A2540;'
  : 'background: white; border: 1px solid #e2e8f0; box-shadow: 0 4px 24px rgba(10,37,64,0.08);'
const titleColor = darkBackground ? 'color: white;' : 'color: #0A2540;'
const subtitleColor = darkBackground
  ? 'color: rgba(148,163,184,0.8);'
  : 'color: #64748b;'
const badgeStyle = darkBackground
  ? 'background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);'
  : 'background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;'
const inputStyle = darkBackground
  ? 'background: rgba(255,255,255,0.08); color: white; border: 1px solid rgba(255,255,255,0.15); placeholder-color: rgba(255,255,255,0.4);'
  : 'background: #F8FAFC; color: #111827; border: 1px solid #e2e8f0;'
---

<div
  class="newsletter-cta-widget rounded-2xl px-8 py-12 text-center"
  style={bgStyle}
>
  <span
    class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
    style={badgeStyle}
  >
    Newsletter
  </span>
  <h2
    class="text-2xl sm:text-3xl font-bold mb-3"
    style={`letter-spacing: -0.02em; ${titleColor}`}
  >
    {title}
  </h2>
  <p class="text-sm mb-8 max-w-md mx-auto" style={subtitleColor}>
    {subtitle}
  </p>
  <form
    class="newsletter-cta-form flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
  >
    <input
      type="hidden"
      name="access_key"
      value="e8aaab4e-270c-4163-bb76-6a8dfc247485"
    />
    <input
      type="hidden"
      name="subject"
      value="Newsletter Subscription - LRA Cloud Ops"
    />
    <input type="hidden" name="from_name" value="LRA Cloud Ops Newsletter" />
    <input
      type="email"
      name="email"
      required
      placeholder={placeholder}
      class="flex-1 px-4 py-3 text-sm rounded-xl outline-none"
      style={inputStyle}
    />
    <button
      type="submit"
      class="newsletter-cta-btn px-6 py-3 text-sm font-semibold text-white rounded-xl transition-all hover:opacity-90 flex-shrink-0"
      style="background: #1E6FFF; box-shadow: 0 4px 14px rgba(30,111,255,0.4);"
    >
      {subscribeBtn}
    </button>
  </form>
  <div
    class="newsletter-cta-status hidden mt-4 text-sm rounded-xl py-2.5 px-4 max-w-md mx-auto"
  >
  </div>
</div>

<script
  define:vars={{
    subscribingTx,
    subscribedMsg,
    subscribedBtn,
    errorMsg,
    connErrorMsg,
  }}
>
  document.querySelectorAll('.newsletter-cta-widget').forEach((widget) => {
    const form = widget.querySelector('.newsletter-cta-form')
    const btn = widget.querySelector('.newsletter-cta-btn')
    const status = widget.querySelector('.newsletter-cta-status')
    if (!form || !btn || !status) return

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const original = btn.textContent
      btn.textContent = subscribingTx
      btn.disabled = true

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        })
        const data = await res.json()
        if (data.success) {
          status.textContent = subscribedMsg
          status.style.cssText =
            'display:block; background: rgba(16,185,129,0.1); color: #059669; border: 1px solid rgba(16,185,129,0.3); border-radius: 10px; padding: 12px 16px;'
          form.reset()
          btn.textContent = subscribedBtn
        } else {
          status.textContent = errorMsg
          status.style.cssText =
            'display:block; background: rgba(239,68,68,0.1); color: #DC2626; border: 1px solid rgba(239,68,68,0.3); border-radius: 10px; padding: 12px 16px;'
          btn.textContent = original
          btn.disabled = false
        }
      } catch {
        status.textContent = connErrorMsg
        status.style.cssText =
          'display:block; background: rgba(239,68,68,0.1); color: #DC2626; border: 1px solid rgba(239,68,68,0.3); border-radius: 10px; padding: 12px 16px;'
        btn.textContent = original
        btn.disabled = false
      }
      status.classList.remove('hidden')
    })
  })
</script>
