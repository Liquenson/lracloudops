---
interface Props {
  href?: string
  accentColor?: string
  padding?: 'sm' | 'md' | 'lg'
  hover?: boolean
  class?: string
}

const {
  href,
  accentColor,
  padding = 'md',
  hover = true,
  class: className = '',
} = Astro.props

const paddings = {
  sm: 'var(--space-4)',
  md: 'var(--space-6)',
  lg: 'var(--space-8)',
}

const style = `
  background: var(--color-bg-soft);
  border: 1px solid var(--color-border);
  ${accentColor ? `border-top: 3px solid ${accentColor};` : ''}
  border-radius: var(--radius-lg);
  padding: ${paddings[padding]};
  ${href ? 'text-decoration: none; display: block;' : ''}
  transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
`
---

{href ? (
  <a href={href} style={style} class={`lra-card ${hover ? 'lra-card--hover' : ''} ${className}`}>
    <slot />
  </a>
) : (
  <div style={style} class={`lra-card ${hover ? 'lra-card--hover' : ''} ${className}`}>
    <slot />
  </div>
)}

<style>
  @media (hover: hover) {
    .lra-card--hover:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
      border-color: var(--color-primary) !important;
    }
  }
  .lra-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
