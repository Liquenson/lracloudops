---
interface Props {
  href?: string
  class?: string
}
const { href = '/', class: className = '' } = Astro.props
---

<a href={href} class={`logo ${className}`} aria-label="LRA Cloud Ops — Home">
  <img
    src="/lracloudops-icon.svg"
    alt="LRA Cloud Ops"
    width="36"
    height="36"
    style="width:36px; height:36px; flex-shrink:0;"
    loading="eager"
  />
  <span class="logo-text">LRA CloudOps</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
  }
  .logo-text {
    font-family: var(--font-display, 'Red Hat Display', system-ui, sans-serif);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    letter-spacing: -0.01em;
  }
</style>
