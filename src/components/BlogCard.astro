---
interface Props {
  title: string
  description: string
  fecha: Date
  slug: string
  tags: string[]
  lang: 'es' | 'en'
}

const { title, description, fecha, slug, tags, lang } = Astro.props
const href = lang === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`
const dateLabel = fecha.toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
})
const readLabel = lang === 'en' ? 'Read' : 'Leer'
const ariaLabel =
  lang === 'en' ? `Read article: ${title}` : `Leer artículo: ${title}`
---

<a
  href={href}
  aria-label={ariaLabel}
  class="group flex flex-col sm:flex-row sm:items-start justify-between gap-6 p-6 sm:p-7 rounded-2xl transition-all duration-200 block"
  style="background: white; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
  onmouseenter="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 10px 28px rgba(10,37,64,0.09)'; this.style.borderColor='rgba(30,111,255,0.2)';"
  onmouseleave="this.style.transform=''; this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';"
>
  <div class="flex-1">
    <div class="flex flex-wrap gap-2 mb-3">
      {
        tags.map((tag) => (
          <span
            class="text-xs font-medium px-2.5 py-1 rounded-full"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
          >
            {tag}
          </span>
        ))
      }
    </div>
    <h2
      class="text-lg font-bold mb-2 group-hover:text-[#1E6FFF] transition-colors"
      style="color: #0A2540;"
    >
      {title}
    </h2>
    <p class="text-sm leading-relaxed" style="color: #64748b;">{description}</p>
  </div>
  <div class="flex sm:flex-col items-center sm:items-end gap-4 flex-shrink-0">
    <span class="text-xs whitespace-nowrap" style="color: #94a3b8;"
      >{dateLabel}</span
    >
    <span
      class="inline-flex items-center gap-1 text-xs font-semibold group-hover:gap-2 transition-all"
      style="color: #1E6FFF;"
    >
      {readLabel}
      <svg
        class="w-3.5 h-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </span>
  </div>
</a>
