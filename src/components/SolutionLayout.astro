---
import Layout from '../layouts/Layout.astro'
import { getLangFromUrl } from '../i18n/index'

interface Challenge {
  title: string
  desc: string
}

interface ArchLayer {
  layer: string
  tools: string
  desc: string
}

interface Step {
  step: string
  title: string
  desc: string
}

interface Outcome {
  metric: string
  detail: string
}

interface RelatedSolution {
  href: string
  label: string
}

interface Props {
  titulo: string
  descripcion: string
  badgeLabel: string
  h1: string
  heroSubtitle: string
  schema: Record<string, unknown>
  sectionNumber: string
  challenges: Challenge[]
  archTitle: string
  archSubtitle: string
  layers: ArchLayer[]
  steps: Step[]
  outcomes: Outcome[]
  ctaH2: string
  ctaSubtitle: string
  backLabel?: string
  relatedSolutions?: RelatedSolution[]
}

const {
  titulo,
  descripcion,
  badgeLabel,
  h1,
  heroSubtitle,
  schema,
  challenges,
  archTitle,
  archSubtitle,
  layers,
  steps,
  outcomes,
  ctaH2,
  ctaSubtitle,
  relatedSolutions,
} = Astro.props

const lang = getLangFromUrl(Astro.url)
const isES = lang === 'es'

const t = {
  challenge:    isES ? 'El desafío'                         : 'The challenge',
  problemH2:   isES ? 'Lo que le cuesta el problema.'       : 'What the problem costs you.',
  problemDesc: isES
    ? 'La mayoría de los problemas de infraestructura no son causados por las herramientas elegidas. Son causados por cómo se aprovisiona y gestiona la infraestructura a lo largo del tiempo.'
    : 'Most infrastructure problems are not caused by the tools chosen. They are caused by how infrastructure is provisioned and managed over time.',
  archApproach:   isES ? 'Enfoque de arquitectura'           : 'Architecture approach',
  implMethod:     isES ? 'Metodología de implementación'     : 'Implementation methodology',
  howWeImpl:      isES ? 'Cómo lo implementamos.'            : 'How we implement it.',
  outcomes:       isES ? 'Resultados operativos'             : 'Operational outcomes',
  whatChanges:    isES ? 'Qué cambia al completar la entrega.' : 'What changes when this is delivered.',
  bookReview:       isES ? 'Reservar revisión técnica'         : 'Book a technical review',
  allSolutions:     isES ? 'Todas las soluciones'              : 'All solutions',
  contactHref:      isES ? '/contacto'                         : '/contact',
  servicesHref:     isES ? '/servicios'                        : '/services',
  relatedSolLabel:  isES ? 'Soluciones relacionadas'           : 'Related solutions',
}
---

<Layout titulo={titulo} descripcion={descripcion} schema={schema}>
  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none opacity-40"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(30,111,255,0.12) 0%, transparent 65%);"
    >
    </div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-28">
      <div class="max-w-3xl">
        <span
          class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6"
          style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);"
        >
          {badgeLabel}
        </span>
        <h1
          class="text-4xl sm:text-5xl font-extrabold text-white mb-5 animate-fade-left"
          style="letter-spacing: -0.02em;"
        >
          {h1}
        </h1>
        <p
          class="text-lg max-w-2xl animate-fade-up delay-200"
          style="color: rgba(147,184,255,0.8);"
        >
          {heroSubtitle}
        </p>
      </div>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="section-label mb-4">{t.challenge}</span>
        <h2
          class="text-3xl sm:text-4xl font-bold mt-4 mb-4"
          style="color: #0A2540;"
        >
          {t.problemH2}
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: #64748b;">
          {t.problemDesc}
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {
          challenges.map((item) => (
            <div class="card p-6">
              <h3 class="text-base font-bold mb-2" style="color: #0A2540;">
                {item.title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: #64748b;">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE APPROACH -->
  <section class="py-20" style="background: #f8fafc;">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="section-label mb-4">{t.archApproach}</span>
        <h2
          class="text-3xl sm:text-4xl font-bold mt-4 mb-4"
          style="color: #0A2540;"
        >
          {archTitle}
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: #64748b;">
          {archSubtitle}
        </p>
      </div>
      <div class="space-y-4">
        {
          layers.map((item, i) => (
            <div
              class="bg-white rounded-xl p-6 flex flex-col sm:flex-row gap-5 items-start"
              style="border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
            >
              <div
                class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold text-white"
                style="background: #1E6FFF;"
              >
                {String(i + 1).padStart(2, '0')}
              </div>
              <div class="flex-1">
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                  <h3 class="text-base font-bold" style="color: #0A2540;">
                    {item.layer}
                  </h3>
                  <span
                    class="text-xs font-medium px-2.5 py-1 rounded-full"
                    style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
                  >
                    {item.tools}
                  </span>
                </div>
                <p class="text-sm leading-relaxed" style="color: #64748b;">
                  {item.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- IMPLEMENTATION METHODOLOGY -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="section-label mb-4">{t.implMethod}</span>
        <h2
          class="text-3xl sm:text-4xl font-bold mt-4 mb-4"
          style="color: #0A2540;"
        >
          {t.howWeImpl}
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {
          steps.map((item) => (
            <div class="card p-6 text-center">
              <div class="text-3xl font-extrabold mb-3" style="color: #c3d9ff;">
                {item.step}
              </div>
              <h3 class="text-sm font-bold mb-2" style="color: #0A2540;">
                {item.title}
              </h3>
              <p class="text-xs leading-relaxed" style="color: #64748b;">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- OUTCOMES -->
  <section class="py-20" style="background: #EEF4FF;">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="section-label mb-4" style="background: white;"
          >{t.outcomes}</span
        >
        <h2
          class="text-3xl sm:text-4xl font-bold mt-4 mb-4"
          style="color: #0A2540;"
        >
          {t.whatChanges}
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {
          outcomes.map((item) => (
            <div
              class="bg-white rounded-xl p-5 flex items-start gap-4"
              style="border: 1px solid #c3d9ff;"
            >
              <span class="text-green-500 font-bold text-lg flex-shrink-0">
                ✓
              </span>
              <div>
                <p class="text-sm font-bold" style="color: #0A2540;">
                  {item.metric}
                </p>
                <p class="text-xs" style="color: #64748b;">
                  {item.detail}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Injected slot content (flow diagrams, real implementation sections, etc.) -->
  <slot />

  <!-- Related Solutions internal linking -->
  {relatedSolutions && relatedSolutions.length > 0 && (
    <section class="py-12 bg-white border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 p-6 rounded-2xl" style="background: #EEF4FF; border: 1px solid #c3d9ff;">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #1E6FFF;">{t.relatedSolLabel}</p>
            <div class="flex flex-wrap gap-3">
              {relatedSolutions.map(({ href, label }) => (
                <a
                  href={href}
                  class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors hover:opacity-80"
                  style="color: #0A2540;"
                >
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1E6FFF;" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                  {label}
                </a>
              ))}
            </div>
          </div>
          <a
            href={t.servicesHref}
            class="text-xs font-semibold whitespace-nowrap transition-opacity hover:opacity-70"
            style="color: #64748B;"
          >
            {t.allSolutions} →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(30,111,255,0.12) 0%, transparent 70%);"
    >
    </div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2
        class="text-3xl font-bold text-white mb-4"
        style="letter-spacing: -0.02em;"
      >
        {ctaH2}
      </h2>
      <p class="mb-8 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        {ctaSubtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={t.contactHref}
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02]"
          style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 20px rgba(30,111,255,0.4);"
        >
          {t.bookReview}
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
        <a
          href={t.servicesHref}
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);"
        >
          {t.allSolutions}
        </a>
      </div>
    </div>
  </section>
</Layout>
