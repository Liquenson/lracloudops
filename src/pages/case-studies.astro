---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
---
<Layout
  title="Case Studies — LRA CloudOps"
  description="Real infrastructure audit results and Platform Engineering implementations. Verified findings from open source repositories."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <section style="background:#F8F9FA;padding:3rem 1.5rem;border-bottom:1px solid #DADCE0;">
    <div style="max-width:1280px;margin:0 auto;">
      <p style="font-family:'Red Hat Text',sans-serif;font-size:0.75rem;font-weight:600;color:#1A73E8;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.5rem;">Case Studies</p>
      <h1 style="font-family:'Red Hat Display',sans-serif;font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#202124;margin-bottom:0.75rem;">Real results. Verifiable code.</h1>
      <p style="font-family:'Red Hat Text',sans-serif;font-size:1.125rem;color:#5F6368;max-width:640px;line-height:1.7;">Every case study below is backed by open source code you can inspect. No invented metrics, no anonymous claims.</p>
    </div>
  </section>

  <!-- Case Study 1 — aws-terraform-devops audit -->
  <section style="background:#FFFFFF;padding:3rem 1.5rem;border-bottom:1px solid #DADCE0;">
    <div style="max-width:1280px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:4rem;align-items:start;" class="two-col-grid">

        <!-- Left: metadata -->
        <div>
          <span style="font-family:'Red Hat Mono',monospace;font-size:0.6875rem;font-weight:600;color:#137333;background:#E6F4EA;border:1px solid #137333;padding:0.25rem 0.625rem;border-radius:3px;">Infrastructure Audit</span>
          <h2 style="font-family:'Red Hat Display',sans-serif;font-size:1.5rem;font-weight:700;color:#202124;margin:1rem 0 0.5rem;">AWS Terraform infrastructure — security baseline</h2>
          <p style="font-family:'Red Hat Text',sans-serif;font-size:0.9375rem;color:#5F6368;margin-bottom:1.5rem;line-height:1.6;">Real lra scan output — 263 checks passed, 53 misconfigurations identified.</p>

          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            {[
              { label: 'Repository', value: 'lra-cloud-ops/aws-terraform-devops', color: '#202124', weight: 500 },
              { label: 'Stack', value: 'Terraform, AWS, Kubernetes', color: '#202124', weight: 500 },
              { label: 'Scan tools', value: 'Trivy, Checkov', color: '#202124', weight: 500 },
              { label: 'Duration', value: '~60s', color: '#202124', weight: 500 },
              { label: 'Verdict', value: 'FAIL', color: '#F29900', weight: 700 },
            ].map(({ label, value, color, weight }) => (
              <div style="display:flex;flex-direction:column;gap:0.125rem;">
                <span style="font-family:'Red Hat Mono',monospace;font-size:0.75rem;color:#9AA0A6;text-transform:uppercase;letter-spacing:0.04em;">{label}</span>
                <span style={`font-family:'Red Hat Text',sans-serif;font-size:0.9375rem;font-weight:${weight};color:${color};`}>{value}</span>
              </div>
            ))}
          </div>

          <a href="https://github.com/lra-cloud-ops/aws-terraform-devops" target="_blank" rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:0.375rem;margin-top:1.5rem;font-family:'Red Hat Text',sans-serif;font-size:0.875rem;font-weight:600;color:#1A73E8;text-decoration:none;"
            onmouseover="this.style.textDecoration='underline'"
            onmouseout="this.style.textDecoration='none'"
          >
            View repository →
          </a>
        </div>

        <!-- Right: results -->
        <div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem;">
            {[
              { value: '0', label: 'Critical', color: '#137333' },
              { value: '0', label: 'High', color: '#137333' },
              { value: '2', label: 'Medium', color: '#F29900' },
              { value: '263', label: 'Checks passed', color: '#137333' },
              { value: '53', label: 'Failed checks', color: '#F29900' },
            ].map(({ value, label, color }) => (
              <div style="background:#F8F9FA;border:1px solid #DADCE0;border-radius:8px;padding:1rem;text-align:center;">
                <div style={`font-family:'Red Hat Display',sans-serif;font-size:1.75rem;font-weight:900;color:${color};`}>{value}</div>
                <div style="font-family:'Red Hat Text',sans-serif;font-size:0.75rem;color:#5F6368;margin-top:0.25rem;">{label}</div>
              </div>
            ))}
          </div>

          <h3 style="font-family:'Red Hat Display',sans-serif;font-size:1rem;font-weight:700;color:#202124;margin-bottom:1rem;">Key findings</h3>
          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            {[
              { severity: 'WARN', text: '25 Terraform misconfigurations — CloudWatch logging setup and ECR container registry controls.', color: '#F29900', bg: '#FFF8E1' },
              { severity: 'WARN', text: '28 Kubernetes deployment security gaps — pod security policies, resource limits, runtime permissions.', color: '#F29900', bg: '#FFF8E1' },
              { severity: 'PASS', text: 'Dockerfile security: all checks passed.', color: '#137333', bg: '#E6F4EA' },
            ].map(({ severity, text, color, bg }) => (
              <div style="display:flex;align-items:start;gap:0.75rem;padding:0.875rem;background:#F8F9FA;border:1px solid #DADCE0;border-radius:6px;">
                <span style={`font-family:'Red Hat Mono',monospace;font-size:0.6875rem;font-weight:700;padding:0.125rem 0.5rem;border-radius:3px;flex-shrink:0;color:${color};background:${bg};border:1px solid ${color};`}>{severity}</span>
                <p style="font-family:'Red Hat Text',sans-serif;font-size:0.875rem;color:#5F6368;margin:0;line-height:1.6;">{text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#F8F9FA;padding:3rem 1.5rem;">
    <div style="max-width:720px;margin:0 auto;text-align:center;">
      <h2 style="font-family:'Red Hat Display',sans-serif;font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:#202124;margin-bottom:0.75rem;">Run the same analysis on your infrastructure.</h2>
      <p style="font-family:'Red Hat Text',sans-serif;font-size:1rem;color:#5F6368;margin-bottom:2rem;">Free. No commitment. Report within 24 hours.</p>
      <a href="/audit" style="display:inline-flex;align-items:center;gap:0.5rem;background:#1A73E8;color:#FFFFFF;padding:0.875rem 2rem;border-radius:6px;font-family:'Red Hat Text',sans-serif;font-size:1rem;font-weight:600;text-decoration:none;transition:background 150ms ease;"
        onmouseover="this.style.background='#1557B0'"
        onmouseout="this.style.background='#1A73E8'"
      >
        Request free audit →
      </a>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 767px) {
    .two-col-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
