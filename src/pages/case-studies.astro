---
import Layout from '../layouts/Layout.astro'

const caseStudies = [
  {
    id: 'aws-terraform-devops',
    title: 'AWS Terraform DevOps Platform',
    category: 'Cloud Infrastructure',
    status: 'Production',
    summary: 'Production AWS environment with EKS, RDS Multi-AZ and a dual CI/CD pipeline — built entirely from Terraform modules with remote state and SonarCloud quality gates.',
    challenge: 'Provision a reproducible, auditable AWS environment that could be deployed from code, validated with a coverage-gated test suite and deployed through both GitHub Actions and Jenkins in parallel.',
    architecture: [
      'EKS 1.31 with HPA configured at 70% CPU threshold',
      'RDS PostgreSQL 15 Multi-AZ in private subnets',
      '6 modular Terraform modules with S3 remote state and DynamoDB locking',
      'VPC with public/private subnet separation — no backend public IPs',
    ],
    outcomes: [
      '17 automated tests across application and infrastructure layers',
      'SonarCloud coverage gate enforced at ≥80% before any merge',
      'Dual pipeline: GitHub Actions and Jenkins running in parallel',
      'Full environment reproducible from a single terraform apply',
    ],
    stack: ['Terraform 1.9.8', 'AWS EKS 1.31', 'RDS PostgreSQL 15', 'Flask 3.0.3', 'GitHub Actions', 'Jenkins', 'Helm', 'SonarCloud'],
    github: 'https://github.com/Liquenson/aws-terraform-devops',
    iconPath: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
  },
  {
    id: 'tbf-cloud-infrastructure',
    title: 'TBF Cloud Infrastructure',
    category: 'Platform Engineering',
    status: 'Production',
    summary: 'Full-stack SaaS deployment on AWS ECS Fargate with 11 Terraform modules, OIDC-based CI/CD, CloudFront OAC and an automated rollback circuit breaker.',
    challenge: 'Deploy a Spring Boot 4 and React 18 SaaS platform on AWS with no static credentials in CI, differentiated CDN caching for API and static assets, and automated rollback on failed releases.',
    architecture: [
      '11 Terraform modules: vpc, security_group, ecr, rds, ecs_backend, secrets_manager, s3_frontend, s3_documents, cloudfront, alb, nat',
      'CloudFront OAC with differentiated cache policy: API responses bypass cache, static assets cached at edge',
      'ECS Fargate in private subnets behind ALB — no public task IPs',
      'AWS Secrets Manager for runtime secrets — no .env files in production',
    ],
    outcomes: [
      'OIDC authentication in all three CI/CD pipelines — zero long-lived AWS credentials',
      'Automated circuit breaker triggers rollback on failed ECS health checks',
      'Infrastructure applied exclusively through GitHub Actions — no local prod applies',
      'Complete traffic flow: CloudFront → ALB → ECS → RDS → S3 documents',
    ],
    stack: ['Spring Boot 4.0.3', 'Java 17', 'React 18.3.1', 'Terraform 1.9.8', 'AWS ECS Fargate', 'CloudFront', 'RDS PostgreSQL 15', 'GitHub Actions'],
    github: null,
    iconPath: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  },
  {
    id: 'nexoratech',
    title: 'NexoraTech SaaS Platform',
    category: 'Platform Engineering',
    status: 'Production',
    summary: 'Enterprise SaaS platform with JWT + MFA TOTP authentication, Testcontainers integration testing against real PostgreSQL, and three independent OIDC CI/CD pipelines.',
    challenge: 'Build an enterprise SaaS platform with multi-factor authentication, integration tests that run against a real database (not mocks) and a deployment pipeline that required no static AWS credentials.',
    architecture: [
      '10 Terraform modules provisioning the full ECS Fargate stack',
      'JWT + MFA TOTP + BCrypt authentication — no session cookies',
      'Testcontainers: integration tests spin up real PostgreSQL — Flyway validate-on-migrate runs on every test suite',
      'CloudFront OAC with differentiated cache: static assets at edge, API bypasses cache',
    ],
    outcomes: [
      'Three independent OIDC pipelines: backend, frontend and infrastructure',
      'Integration tests hit a real database — no mocked persistence layer',
      'Flyway migration validation runs automatically on every test execution',
      'MFA TOTP enforced at authentication — not optional at the application layer',
    ],
    stack: ['Spring Boot 4.0.3', 'Java 17', 'React 18.3.1', 'Vite 5', 'JJWT 0.12.6', 'Testcontainers', 'Flyway', 'PostgreSQL 15', 'Terraform 1.9.8', 'AWS ECS Fargate'],
    github: null,
    iconPath: 'M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z',
  },
  {
    id: 'linux-fleet-manager',
    title: 'Linux Fleet Management Framework',
    category: 'SRE & Automation',
    status: 'Production',
    summary: 'Bash automation framework for cross-platform fleet inventory collection — structured with set -euo pipefail, TTY detection, SSH BatchMode and ShellCheck CI across three operating systems.',
    challenge: 'Build a fleet management framework that could run reliably across Linux, macOS and Windows Git Bash without external dependencies, with structured output and CI validation on all three platforms.',
    architecture: [
      'Bash 4.0+ with set -euo pipefail and nounset — no silent failures',
      'TTY detection for terminal vs. non-interactive execution context',
      'SSH BatchMode to prevent interactive prompts from blocking automation',
      'Cross-platform detection: Linux, macOS and Windows Git Bash',
    ],
    outcomes: [
      'CSV and JSON inventory exports from a single script invocation',
      'ShellCheck CI validated across Ubuntu, macOS and Windows Git Bash in parallel',
      'Reports written with timestamps — idempotent, non-destructive execution',
      'Library functions shared across scripts via lib/common.sh and lib/logger.sh',
    ],
    stack: ['Bash 4.0+', 'ShellCheck', 'SSH', 'CSV / JSON', 'GitHub Actions', 'Ubuntu', 'macOS', 'Windows Git Bash'],
    github: 'https://github.com/Liquenson/linux-fleet-manager',
    iconPath: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    id: 'k8s-devops-platform',
    title: 'Kubernetes GitOps Reference Architecture',
    category: 'Kubernetes & GitOps',
    status: 'Reference',
    summary: 'Reference GitOps architecture on a local KinD cluster with ArgoCD as the single delivery mechanism — Kubernetes manifests as source of truth, no imperative kubectl.',
    challenge: 'Provide a reference implementation of GitOps adoption that teams could evaluate locally before committing to a production Kubernetes platform.',
    architecture: [
      '3-node KinD cluster: 1 control plane + 2 workers with Ingress port mapping',
      'ArgoCD App of Apps pattern for managing application lifecycle from Git',
      'Kustomize base/overlays for environment-specific configuration',
      'No kubectl apply in production path — all changes via ArgoCD sync',
    ],
    outcomes: [
      'Cluster reproducible from kind create cluster in under 5 minutes',
      'ArgoCD drift detection catches manual changes and self-heals',
      'Reference for teams evaluating GitOps before EKS adoption',
      'Documented in runbook format — not just YAML files',
    ],
    stack: ['Kubernetes 1.29', 'ArgoCD', 'KinD', 'Docker', 'Kustomize', 'GitOps'],
    github: 'https://github.com/Liquenson/k8s-devops-platform',
    iconPath: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
  },
  {
    id: 'aws-devops-agent',
    title: 'AWS DevOps Agent',
    category: 'AI + Cloud Operations',
    status: 'In Development',
    summary: 'Claude Sonnet 4.6 CLI agent with 31 boto3 tools for natural language AWS infrastructure operations — security auditing, cost analysis, IAM key rotation and fleet management.',
    challenge: 'Provide an AI-assisted interface to AWS infrastructure operations that could handle security group auditing, IAM key rotation and cost analysis through natural language without requiring AWS console access.',
    architecture: [
      '31 boto3 tools covering EC2, ECS, EKS, RDS, Lambda, CloudWatch, GuardDuty, Cost Explorer and 20+ additional services',
      'Claude Sonnet 4.6 as the reasoning layer — Anthropic SDK for tool orchestration',
      'Security group auditing: identifies overly permissive rules before they reach production',
      'IAM key rotation workflow: detects aged credentials and executes rotation without manual steps',
    ],
    outcomes: [
      'Natural language interface for routine AWS operations — no console navigation required',
      'GuardDuty integration surfaces active threats within the operational context',
      'Cost analysis identifies rightsizing opportunities from utilization data',
      'Security group audit catches 0.0.0.0/0 rules before infrastructure review cycles',
    ],
    stack: ['Python 3.11', 'Claude Sonnet 4.6', 'boto3', 'Anthropic SDK', 'AWS', 'GuardDuty', 'Cost Explorer'],
    github: 'https://github.com/Liquenson/aws-devops-agent',
    iconPath: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
]

function statusStyle(status: string) {
  const map: Record<string, string> = {
    'Production':     'background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;',
    'In Development': 'background:#fffbeb; color:#b45309; border:1px solid #fde68a;',
    'Reference':      'background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb;',
  }
  return map[status] ?? map['Reference']
}

const production = caseStudies.filter(c => c.status === 'Production')
const inDevelopment = caseStudies.filter(c => c.status === 'In Development')
const reference = caseStudies.filter(c => c.status === 'Reference')

const caseStudiesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': 'https://lracloudops.com/case-studies#list',
  name: 'Cloud Infrastructure & Platform Engineering Case Studies',
  description: 'Production AWS environments, platform engineering implementations and reference architectures.',
  url: 'https://lracloudops.com/case-studies',
  numberOfItems: caseStudies.length,
  itemListElement: caseStudies.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'CreativeWork',
      name: c.title,
      description: c.summary,
      url: c.github ?? `https://lracloudops.com/case-studies#${c.id}`,
      keywords: c.stack.join(', '),
    },
  })),
}
---

<Layout
  titulo="Case Studies · Platform Engineering & Cloud Infrastructure"
  descripcion="Production AWS environments, platform engineering implementations and reference architectures. Architecture decisions, implementation strategies and operational outcomes documented."
  schema={caseStudiesSchema}
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(30,111,255,0.12) 0%, transparent 65%);"></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-28">
      <div class="max-w-3xl">
        <span class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6" style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);">
          {caseStudies.length} implementations documented
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-5 animate-fade-left" style="letter-spacing: -0.02em;">
          Case Studies
        </h1>
        <p class="text-lg max-w-2xl animate-fade-up delay-200" style="color: rgba(147,184,255,0.8);">
          Architecture decisions, implementation strategies and operational outcomes from production AWS environments, platform engineering work and automation frameworks. Not demos — real workloads with documented results.
        </p>
        <div class="flex flex-wrap gap-6 mt-8 text-sm" style="color: rgba(147,184,255,0.7);">
          <span><span class="font-bold text-white">{production.length}</span> production</span>
          <span><span class="font-bold text-white">{inDevelopment.length}</span> in development</span>
          <span><span class="font-bold text-white">{reference.length}</span> reference architectures</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTION CASE STUDIES -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="mb-12">
        <span class="section-label mb-3">Production implementations</span>
        <h2 class="text-2xl sm:text-3xl font-bold mt-3" style="color: #0A2540;">Live workloads with documented outcomes.</h2>
      </div>
      <div class="space-y-8">
        {production.map(cs => (
          <div class="rounded-2xl overflow-hidden" style="border: 1px solid #e2e8f0; box-shadow: 0 2px 8px rgba(10,37,64,0.06);">
            <!-- Header -->
            <div class="p-6 sm:p-8" style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
              <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center" style="background: #EEF4FF;">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1E6FFF;" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={cs.iconPath} />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <h3 class="text-lg font-bold" style="color: #0A2540;">{cs.title}</h3>
                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style={statusStyle(cs.status)}>{cs.status}</span>
                    <span class="text-xs font-medium px-2.5 py-1 rounded-full" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">{cs.category}</span>
                  </div>
                  <p class="text-sm leading-relaxed" style="color: #64748b;">{cs.summary}</p>
                </div>
              </div>
            </div>
            <!-- Body -->
            <div class="p-6 sm:p-8 grid sm:grid-cols-2 gap-8">
              <!-- Challenge + Architecture -->
              <div>
                <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Business challenge</h4>
                <p class="text-sm leading-relaxed mb-6" style="color: #64748b;">{cs.challenge}</p>
                <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Architecture decisions</h4>
                <ul class="space-y-2">
                  {cs.architecture.map(point => (
                    <li class="flex items-start gap-2 text-sm" style="color: #64748b;">
                      <span class="mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full" style="background: #1E6FFF;"></span>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
              <!-- Outcomes + Stack -->
              <div>
                <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Operational outcomes</h4>
                <ul class="space-y-2 mb-6">
                  {cs.outcomes.map(outcome => (
                    <li class="flex items-start gap-2 text-sm" style="color: #64748b;">
                      <span class="text-green-500 font-bold flex-shrink-0">✓</span>
                      {outcome}
                    </li>
                  ))}
                </ul>
                <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Technology stack</h4>
                <div class="flex flex-wrap gap-2 mb-5">
                  {cs.stack.map(tech => (
                    <span class="text-xs px-2.5 py-1 rounded-md font-mono" style="background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0;">{tech}</span>
                  ))}
                </div>
                {cs.github && (
                  <a href={cs.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:underline" style="color: #1E6FFF;">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                    View repository
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IN DEVELOPMENT -->
  {inDevelopment.length > 0 && (
    <section class="py-20" style="background: #f8fafc;">
      <div class="max-w-5xl mx-auto px-6">
        <div class="mb-12">
          <span class="section-label mb-3">In development</span>
          <h2 class="text-2xl sm:text-3xl font-bold mt-3" style="color: #0A2540;">Active platform work.</h2>
        </div>
        <div class="space-y-8">
          {inDevelopment.map(cs => (
            <div class="rounded-2xl overflow-hidden" style="border: 1px solid #e2e8f0; box-shadow: 0 2px 8px rgba(10,37,64,0.06);">
              <div class="p-6 sm:p-8" style="background: #fffbeb; border-bottom: 1px solid #fde68a40;">
                <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center" style="background: #fef3c7;">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #b45309;" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d={cs.iconPath} />
                    </svg>
                  </div>
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-3 mb-2">
                      <h3 class="text-lg font-bold" style="color: #0A2540;">{cs.title}</h3>
                      <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style={statusStyle(cs.status)}>{cs.status}</span>
                      <span class="text-xs font-medium px-2.5 py-1 rounded-full" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">{cs.category}</span>
                    </div>
                    <p class="text-sm leading-relaxed" style="color: #64748b;">{cs.summary}</p>
                  </div>
                </div>
              </div>
              <div class="p-6 sm:p-8 grid sm:grid-cols-2 gap-8">
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Engineering challenge</h4>
                  <p class="text-sm leading-relaxed mb-6" style="color: #64748b;">{cs.challenge}</p>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Architecture approach</h4>
                  <ul class="space-y-2">
                    {cs.architecture.map(point => (
                      <li class="flex items-start gap-2 text-sm" style="color: #64748b;">
                        <span class="mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full" style="background: #1E6FFF;"></span>
                        {point}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Expected outcomes</h4>
                  <ul class="space-y-2 mb-6">
                    {cs.outcomes.map(outcome => (
                      <li class="flex items-start gap-2 text-sm" style="color: #64748b;">
                        <span style="color: #b45309;" class="flex-shrink-0">→</span>
                        {outcome}
                      </li>
                    ))}
                  </ul>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Technology stack</h4>
                  <div class="flex flex-wrap gap-2 mb-5">
                    {cs.stack.map(tech => (
                      <span class="text-xs px-2.5 py-1 rounded-md font-mono" style="background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0;">{tech}</span>
                    ))}
                  </div>
                  {cs.github && (
                    <a href={cs.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:underline" style="color: #1E6FFF;">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                      View repository
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- REFERENCE ARCHITECTURES -->
  {reference.length > 0 && (
    <section class="bg-white py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="mb-12">
          <span class="section-label mb-3">Reference architectures</span>
          <h2 class="text-2xl sm:text-3xl font-bold mt-3" style="color: #0A2540;">Starting points for platform adoption.</h2>
          <p class="text-base mt-2" style="color: #64748b;">Validated implementations that teams can evaluate and adapt — documented for understanding, not just deployment.</p>
        </div>
        <div class="space-y-8">
          {reference.map(cs => (
            <div class="rounded-2xl overflow-hidden" style="border: 1px solid #e2e8f0; box-shadow: 0 2px 8px rgba(10,37,64,0.06);">
              <div class="p-6 sm:p-8" style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center" style="background: #f3f4f6;">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #4b5563;" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d={cs.iconPath} />
                    </svg>
                  </div>
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-3 mb-2">
                      <h3 class="text-lg font-bold" style="color: #0A2540;">{cs.title}</h3>
                      <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style={statusStyle(cs.status)}>{cs.status}</span>
                      <span class="text-xs font-medium px-2.5 py-1 rounded-full" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">{cs.category}</span>
                    </div>
                    <p class="text-sm leading-relaxed" style="color: #64748b;">{cs.summary}</p>
                  </div>
                </div>
              </div>
              <div class="p-6 sm:p-8 grid sm:grid-cols-2 gap-8">
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Design objective</h4>
                  <p class="text-sm leading-relaxed mb-6" style="color: #64748b;">{cs.challenge}</p>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Architecture decisions</h4>
                  <ul class="space-y-2">
                    {cs.architecture.map(point => (
                      <li class="flex items-start gap-2 text-sm" style="color: #64748b;">
                        <span class="mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full" style="background: #1E6FFF;"></span>
                        {point}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Documented outcomes</h4>
                  <ul class="space-y-2 mb-6">
                    {cs.outcomes.map(outcome => (
                      <li class="flex items-start gap-2 text-sm" style="color: #64748b;">
                        <span class="text-green-500 font-bold flex-shrink-0">✓</span>
                        {outcome}
                      </li>
                    ))}
                  </ul>
                  <h4 class="text-xs font-bold uppercase tracking-wider mb-3" style="color: #0A2540;">Technology stack</h4>
                  <div class="flex flex-wrap gap-2 mb-5">
                    {cs.stack.map(tech => (
                      <span class="text-xs px-2.5 py-1 rounded-md font-mono" style="background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0;">{tech}</span>
                    ))}
                  </div>
                  {cs.github && (
                    <a href={cs.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:underline" style="color: #1E6FFF;">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                      View repository
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(30,111,255,0.12) 0%, transparent 70%);"></div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl font-bold text-white mb-4" style="letter-spacing: -0.02em;">Bring your architecture challenge.</h2>
      <p class="mb-8 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        We start with a technical review of your current environment — infrastructure state, deployment process, observability gaps — and outline a concrete path forward.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto" class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02]" style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 20px rgba(30,111,255,0.4);">
          Start a technical review
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href="/servicios" class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10" style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);">
          All solutions
        </a>
      </div>
    </div>
  </section>

</Layout>
