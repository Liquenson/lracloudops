---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'

const auditChecklist = [
  'Trivy — container and IaC vulnerability scan',
  'Checkov — Terraform, Kubernetes, Dockerfile analysis',
  'PASS/FAIL verdict with detailed findings',
  'Concrete recommendations to fix each issue',
  'Delivered by email within 24 hours',
]

const consultingItems = [
  { title: 'Monthly security scan', desc: 'lra scan on all your repos every month' },
  { title: 'Infrastructure review', desc: 'AWS/K8s architecture analysis and recommendations' },
  { title: 'CI/CD pipeline audit', desc: 'GitHub Actions, Jenkins, ArgoCD review' },
  { title: 'Direct access', desc: 'Email and LinkedIn for questions and support' },
]

const techs = [
  'AWS', 'Kubernetes', 'Terraform', 'ArgoCD', 'GitHub Actions', 'Docker',
  'Helm', 'Prometheus', 'Grafana', 'Trivy', 'Checkov', 'Ansible', 'Jenkins',
  'SonarCloud', 'Python', 'Bash',
]
---

<Layout
  title="Platform Engineering Services — LRA CloudOps"
  description="Platform Engineering services backed by open source projects you can inspect — Infrastructure, Kubernetes, GitOps and AI agent automation."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <!-- Page hero -->
  <section
    data-animate="fade-up"
    style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Platform Engineering Services
      </p>
      <h1
        style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;"
      >
        Production-grade infrastructure. Delivered as code.
      </h1>
      <p
        style="font-family: var(--font-body); font-size: 1.0625rem; color: var(--color-text-secondary); max-width: 560px; margin-bottom: 1.5rem;"
      >
        Every engagement is delivered personally by Ruben Liquenson —
        backed by open source projects you can inspect and infrastructure
        patterns proven in 4+ years of production AWS environments.
      </p>

      <div style="background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;">
        <span style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary);">
          Every service is backed by open source code you can inspect:
        </span>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          {['aws-terraform-devops', 'lra-ai-platform', 'k8s-on-premise', 'aws-devops-agent'].map(repo => (
            <a href={`https://github.com/lra-cloud-ops/${repo}`} target="_blank" rel="noopener noreferrer"
              style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-primary); text-decoration: none; background: var(--color-primary-light); border: 1px solid #C5D8F8; padding: 0.125rem 0.5rem; border-radius: 3px;"
              class="tag-hover-blue"
            >{repo} ↗</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Free Audit -->
  <section style="background: var(--color-bg); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="service-grid">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-success-light); color: var(--color-success); padding: 0.25rem 0.875rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 0.8125rem; font-weight: 600; margin-bottom: 1rem;">
            Free · No commitment
          </div>
          <h2 style="font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--color-text); margin-bottom: 1rem; line-height: 1.2;">Infrastructure audit with lra scan</h2>
          <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 1.5rem;">
            Send us your GitHub repository URL. We run lra scan — Trivy for security vulnerabilities, Checkov for IaC misconfigurations — and send you a complete report within 24 hours.
          </p>
          <div style="display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 2rem;">
            {auditChecklist.map(item => (
              <div style="display: flex; align-items: start; gap: 0.75rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: var(--color-primary); flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text-secondary);">{item}</span>
              </div>
            ))}
          </div>
          <a href="/contact" style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-weight: 600; font-size: 0.9375rem; text-decoration: none;" class="btn-premium">
            Request free audit →
          </a>
        </div>

        <!-- Terminal claro -->
        <div style="background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; font-family: var(--font-mono); font-size: 0.8125rem; line-height: 1.9; color: var(--color-text-secondary);">
          <div style="color: var(--color-text-muted); font-style: italic; margin-bottom: 0.75rem;"># Your repository audit</div>
          <div style="margin-bottom: 0.5rem;">
            <span style="color: var(--color-primary); font-weight: 600;">$</span>
            <span style="color: var(--color-text); font-weight: 500;"> lra scan --github your-org/your-repo</span>
          </div>
          <div style="margin-left: 1rem; color: var(--color-text-secondary);">→ Scanning repository...</div>
          <div style="margin-left: 1rem; color: var(--color-text-secondary); margin-bottom: 0.5rem;">→ Running Trivy + Checkov...</div>
          <div style="margin-left: 1rem; color: var(--color-success);">✓ Critical: 0</div>
          <div style="margin-left: 1rem; color: var(--color-success);">✓ High: 0</div>
          <div style="margin-left: 1rem; color: var(--color-warning); margin-bottom: 0.75rem;">⚠ Medium: 2 → recommendations included</div>
          <div style="margin-left: 1rem; color: var(--color-success); font-weight: 600;">✓ Report delivered to your email</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consulting Monthly -->
  <section style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="service-grid">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;" class="consulting-cards">
          {consultingItems.map(item => (
            <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem;" class="card-premium">
              <p style="font-family: var(--font-display); font-size: 0.875rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.25rem;">{item.title}</p>
              <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-text-secondary);">{item.desc}</p>
            </div>
          ))}
        </div>
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-primary-light); color: var(--color-primary); padding: 0.25rem 0.875rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 0.8125rem; font-weight: 600; margin-bottom: 1rem;">
            €699/month
          </div>
          <h2 style="font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--color-text); margin-bottom: 1rem; line-height: 1.2;">Ongoing DevOps consulting</h2>
          <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 1.5rem;">
            Monthly support for teams without a dedicated DevOps engineer. Security scans, infrastructure reviews, pipeline audits and direct access for questions.
          </p>
          <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 2rem;">
            Start with the free audit. If you find it valuable, we set up a monthly engagement. No long-term contracts.
          </p>
          <a href="/contact" style="display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: var(--color-primary); padding: 0.75rem 1.5rem; border-radius: var(--radius-sm); border: 1px solid var(--color-border); font-family: var(--font-body); font-weight: 600; font-size: 0.9375rem; text-decoration: none;" class="btn-premium-outline">
            Get in touch →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Project services -->
  <section style="background: var(--color-bg); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Services</p>
      <h2 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">What we build for you</h2>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); margin-bottom: 2rem;">Fixed-price projects. No hourly surprises.</p>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;" class="services-list-grid" data-animate="stagger">
        {[
          {
            title: 'AWS Infrastructure as Code',
            desc: 'Provision reproducible AWS environments using modular Terraform configurations. Deliverables include VPC with multi-AZ subnets, EKS cluster with managed node groups, RDS with automated backups, ECR with lifecycle policies, IAM roles following least-privilege principles, and CloudWatch monitoring. All infrastructure is version-controlled and deployable via GitHub Actions CI/CD.',
            price: '€1.500 – €3.000',
            time: '1-2 weeks',
            color: '#1A73E8',
            serviceParam: 'aws',
            features: [
              'Multi-AZ VPC with public/private subnets',
              'EKS cluster with auto-scaling node groups',
              'RDS PostgreSQL with backups and failover',
              'ECR, S3, IAM with least-privilege policies',
              'CloudWatch monitoring and alerts',
              'Complete Terraform modules — reproducible',
            ]
          },
          {
            title: 'Kubernetes Platform Engineering',
            desc: 'Deploy production-grade Kubernetes platforms on AWS EKS or bare-metal using kubeadm. Includes Calico CNI, NGINX Ingress Controller, Helm chart management, ArgoCD GitOps delivery with auto-sync and self-healing policies, and Prometheus + Grafana observability stack. Cluster configuration is declarative and stored in Git.',
            price: '€2.000 – €4.000',
            time: '2-3 weeks',
            color: '#137333',
            serviceParam: 'kubernetes',
            features: [
              'EKS on AWS or on-premise with kubeadm',
              'Calico CNI with network policies',
              'NGINX Ingress with TLS termination',
              'ArgoCD GitOps — declarative deployments',
              'Prometheus + Grafana observability stack',
              'Helm charts for your applications',
            ]
          },
          {
            title: 'GitOps Delivery Pipeline',
            desc: 'Implement GitOps delivery using GitHub Actions for CI and ArgoCD for continuous deployment. Every change to application or infrastructure manifests triggers an automated pipeline: lint, test, build, security scan with Trivy, and ArgoCD sync to the target environment. No manual deployments.',
            price: '€800 – €1.200',
            time: '3-5 days',
            color: '#F29900',
            serviceParam: 'cicd',
            features: [
              'GitHub Actions — lint, test, build, deploy',
              'Docker multi-stage build + ECR push',
              'Automated deploy to EKS via Helm/ArgoCD',
              'SonarCloud quality gate integration',
              'Security scan (Trivy + Checkov) on every PR',
              'Environment separation (dev/staging/prod)',
            ]
          },
          {
            title: 'Infrastructure Security Audit',
            desc: 'lra scan executes Trivy against container images and IaC files to identify CVEs and misconfigurations, and Checkov against Terraform, Kubernetes manifests, Dockerfiles and GitHub Actions workflows. Output is a structured PASS/FAIL report with findings classified by severity (CRITICAL, HIGH, MEDIUM, LOW) and remediation guidance generated using Claude.',
            price: '€249 – €499',
            time: '2-3 days',
            color: '#C5221F',
            serviceParam: 'audit',
            payLink: 'https://buy.stripe.com/TU_LINK_REAL_AUDIT',
            features: [
              'lra scan on all your GitHub repositories',
              'Trivy — container and IaC vulnerabilities',
              'Checkov — Terraform, K8s, Dockerfile, Actions',
              'PASS/FAIL report with severity classification',
              'Concrete fix recommendations per finding',
              'Optional: implementation support included',
            ]
          },
        ].map(service => (
          <div style={`background: var(--color-bg-soft); border: 1px solid var(--color-border); border-top: 3px solid ${service.color}; border-radius: var(--radius-lg); padding: 1.5rem;`} class="card-premium" data-animate-child>
            <div style="display: flex; align-items: start; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
              <h3 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--color-text);">{service.title}</h3>
              <div style="text-align: right;">
                <div style={`font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; color: ${service.color};`}>{service.price}</div>
                <div style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted);">{service.time}</div>
              </div>
            </div>
            <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 1rem;">{service.desc}</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              {service.features.map(f => (
                <li style="display: flex; align-items: start; gap: 0.625rem;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style={`color: ${service.color}; flex-shrink: 0; margin-top: 2px;`}><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.5;">{f}</span>
                </li>
              ))}
            </ul>
            {service.payLink ? (
              <div style="display:flex;gap:var(--space-3);flex-wrap:wrap;margin-top:var(--space-5);">
                <a href="/audit"
                  style="display:inline-flex;align-items:center;gap:var(--space-2);background:var(--color-primary);color:#FFFFFF;padding:0.5rem var(--space-4);border-radius:var(--radius-md);font-family:var(--font-body);font-size:var(--text-base);font-weight:600;text-decoration:none;"
                >Free audit first →</a>
                <a href={service.payLink}
                  target="_blank" rel="noopener noreferrer"
                  style="display:inline-flex;align-items:center;gap:var(--space-2);background:transparent;color:var(--color-primary);padding:0.5rem var(--space-4);border-radius:var(--radius-md);border:1px solid var(--color-primary-border);font-family:var(--font-body);font-size:var(--text-base);font-weight:600;text-decoration:none;"
                >Pay €249 now ↗</a>
              </div>
            ) : (
              <div style="margin-top:var(--space-5);">
                <a href={`/contact?service=${service.serviceParam}`}
                  style="display:inline-flex;align-items:center;gap:var(--space-2);background:var(--color-primary);color:#FFFFFF;padding:0.5rem var(--space-4);border-radius:var(--radius-md);font-family:var(--font-body);font-size:var(--text-base);font-weight:600;text-decoration:none;"
                >Get a quote →</a>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-top: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Process</p>
      <h2 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">How we work</h2>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); margin-bottom: 2rem;">From your first message to the delivered report — no surprises.</p>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="process-grid">
        {[
          { step: '01', title: 'You contact us', desc: 'You submit a GitHub repository via the contact form. We confirm receipt within 24 hours.', time: 'Day 1' },
          { step: '02', title: 'We run the audit', desc: 'lra scan runs Trivy and Checkov across your entire codebase — infrastructure, containers, pipelines.', time: 'Day 2' },
          { step: '03', title: 'You get the report', desc: 'Complete PASS/FAIL report delivered by email. Every finding includes severity classification and concrete remediation steps.', time: 'Day 3' },
        ].map(({ step, title, desc, time }) => (
          <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; position: relative;" class="card-premium">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
              <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-primary); background: var(--color-primary-light); padding: 0.25rem 0.625rem; border-radius: var(--radius-sm);">{step}</span>
              <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted);">{time}</span>
            </div>
            <h3 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">{title}</h3>
            <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6;">{desc}</p>
          </div>
        ))}
      </div>
      <div style="margin-top: 1.5rem; padding: 1rem 1.5rem; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: #137333; flex-shrink: 0;"></span>
        <span style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text); font-weight: 500;">We respond to every request within 24 hours.</span>
        <span style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary);">Private repos accepted. No long-term commitment required.</span>
      </div>
    </div>
  </section>

  <!-- What we work with -->
  <section style="background: var(--color-bg); padding: 3rem 1.5rem;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Stack</p>
      <h2 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 2rem;">Technologies we work with</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
        {techs.map(tech => (
          <span style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-text); background: var(--color-bg-soft); border: 1px solid var(--color-border); padding: 0.375rem 0.875rem; border-radius: var(--radius-sm);">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Why trust LRA CloudOps -->
  <section style="background:var(--color-bg-soft);padding:var(--section-py) var(--container-px);border-top:1px solid var(--color-border);">
    <div style="max-width:var(--container-max);margin-inline:auto;">
      <p style="font-family:var(--font-body);font-size:var(--text-sm);font-weight:600;color:var(--color-primary);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:var(--space-2);">Transparency</p>
      <h2 style="font-family:var(--font-display);font-size:clamp(var(--text-2xl),2.5vw,var(--text-4xl));font-weight:700;color:var(--color-text);margin-bottom:var(--space-6);">Why trust LRA CloudOps?</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-6);" class="grid-3">
        {[
          {
            title: 'Open source by default',
            desc: 'Every technique we apply to client infrastructure is demonstrated in public repositories — you can inspect the code before engaging.',
            link: '/open-source',
            linkText: 'View the code →',
          },
          {
            title: 'Real scan output',
            desc: 'The free audit uses the same lra scan tool we run on our own repositories — no black box, no proprietary tooling you cannot verify.',
            link: '/case-studies',
            linkText: 'See real output →',
          },
          {
            title: 'Solo practitioner, clear scope',
            desc: 'One engineer. Fixed-scope engagements. No account managers, no handoffs. You work directly with the person who writes the code.',
            link: '/about',
            linkText: 'Engineering profile →',
          },
        ].map(({ title, desc, link, linkText }) => (
          <div style="background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-6);">
            <h3 style="font-family:var(--font-display);font-size:var(--text-xl);font-weight:700;color:var(--color-text);margin-bottom:var(--space-3);">{title}</h3>
            <p style="font-family:var(--font-body);font-size:var(--text-md);color:var(--color-text-secondary);line-height:1.7;margin-bottom:var(--space-4);">{desc}</p>
            <a href={link} style="font-family:var(--font-body);font-size:var(--text-base);font-weight:600;color:var(--color-primary);text-decoration:none;">{linkText}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 767px) {
    .service-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
    .consulting-cards {
      grid-template-columns: 1fr !important;
    }
    .process-grid {
      grid-template-columns: 1fr !important;
    }
    .services-list-grid {
      grid-template-columns: 1fr !important;
    }
    .grid-3 {
      grid-template-columns: 1fr !important;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .service-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    .services-list-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .consulting-cards { grid-template-columns: repeat(2, 1fr) !important; }
