---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'

const auditChecklist = [
  'Trivy — container and IaC vulnerability scan',
  'Checkov — Terraform, Kubernetes, Dockerfile analysis',
  'PASS/FAIL verdict with detailed findings',
  'Concrete recommendations to fix each issue',
  'Delivered by email within 24 hours',
]

const consultingItems = [
  { title: 'Monthly security scan', desc: 'lra scan on all your repos every month' },
  { title: 'Infrastructure review', desc: 'AWS/K8s architecture analysis and recommendations' },
  { title: 'CI/CD pipeline audit', desc: 'GitHub Actions, Jenkins, ArgoCD review' },
  { title: 'Direct access', desc: 'Email and LinkedIn for questions and support' },
]

const techs = [
  'AWS', 'Kubernetes', 'Terraform', 'ArgoCD', 'GitHub Actions', 'Docker',
  'Helm', 'Prometheus', 'Grafana', 'Trivy', 'Checkov', 'Ansible', 'Jenkins',
  'SonarCloud', 'Python', 'Bash',
]
---

<Layout
  title="Services — LRA CloudOps"
  description="DevOps consulting and infrastructure audit. We analyze your infrastructure, identify problems and help you fix them. Starting with a free lra scan audit."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <!-- Page hero -->
  <section
    data-animate="fade-up"
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Services
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        DevOps consulting and infrastructure audit
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; max-width: 560px;"
      >
        We analyze your infrastructure, identify problems and help you fix
        them. Starting with a free lra scan audit.
      </p>
    </div>
  </section>

  <!-- Free Audit -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="service-grid">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E6F4EA; color: #137333; padding: 0.25rem 0.875rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; font-weight: 600; margin-bottom: 1rem;">
            Free · No commitment
          </div>
          <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;">Infrastructure audit with lra scan</h2>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;">
            Send us your GitHub repository URL. We run lra scan — Trivy for security vulnerabilities, Checkov for IaC misconfigurations — and send you a complete report within 24 hours.
          </p>
          <div style="display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 2rem;">
            {auditChecklist.map(item => (
              <div style="display: flex; align-items: start; gap: 0.75rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">{item}</span>
              </div>
            ))}
          </div>
          <a href="/contact" style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;" class="btn-premium">
            Request free audit →
          </a>
        </div>

        <!-- Terminal claro -->
        <div style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; line-height: 1.9; color: #5F6368;">
          <div style="color: #9AA0A6; font-style: italic; margin-bottom: 0.75rem;"># Your repository audit</div>
          <div style="margin-bottom: 0.5rem;">
            <span style="color: #1A73E8; font-weight: 600;">$</span>
            <span style="color: #202124; font-weight: 500;"> lra scan --github your-org/your-repo</span>
          </div>
          <div style="margin-left: 1rem; color: #5F6368;">→ Scanning repository...</div>
          <div style="margin-left: 1rem; color: #5F6368; margin-bottom: 0.5rem;">→ Running Trivy + Checkov...</div>
          <div style="margin-left: 1rem; color: #137333;">✓ Critical: 0</div>
          <div style="margin-left: 1rem; color: #137333;">✓ High: 0</div>
          <div style="margin-left: 1rem; color: #F29900; margin-bottom: 0.75rem;">⚠ Medium: 2 → recommendations included</div>
          <div style="margin-left: 1rem; color: #137333; font-weight: 600;">✓ Report delivered to your email</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consulting Monthly -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="service-grid">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;" class="consulting-cards">
          {consultingItems.map(item => (
            <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; padding: 1rem;" class="card-premium">
              <p style="font-family: 'Red Hat Display', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;">{item.title}</p>
              <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368;">{item.desc}</p>
            </div>
          ))}
        </div>
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E8F0FE; color: #1A73E8; padding: 0.25rem 0.875rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; font-weight: 600; margin-bottom: 1rem;">
            €499/month
          </div>
          <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;">Ongoing DevOps consulting</h2>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;">
            Monthly support for teams without a dedicated DevOps engineer. Security scans, infrastructure reviews, pipeline audits and direct access for questions.
          </p>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; line-height: 1.7; margin-bottom: 2rem;">
            Start with the free audit. If you find it valuable, we set up a monthly engagement. No long-term contracts.
          </p>
          <a href="/contact" style="display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: #1A73E8; padding: 0.75rem 1.5rem; border-radius: 4px; border: 1px solid #DADCE0; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;" class="btn-premium-outline">
            Get in touch →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Project services -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Services</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 0.5rem;">What we build for you</h2>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;">Fixed-price projects. No hourly surprises.</p>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;" class="services-list-grid" data-animate="stagger">
        {[
          {
            title: 'AWS Infrastructure with Terraform',
            price: '€800 – €2.000',
            time: '1-2 weeks',
            color: '#1A73E8',
            features: [
              'Multi-AZ VPC with public/private subnets',
              'EKS cluster with auto-scaling node groups',
              'RDS PostgreSQL with backups and failover',
              'ECR, S3, IAM with least-privilege policies',
              'CloudWatch monitoring and alerts',
              'Complete Terraform modules — reproducible',
            ]
          },
          {
            title: 'Kubernetes Cluster Setup',
            price: '€1.000 – €2.500',
            time: '2-3 weeks',
            color: '#137333',
            features: [
              'EKS on AWS or on-premise with kubeadm',
              'Calico CNI with network policies',
              'NGINX Ingress with TLS termination',
              'ArgoCD GitOps — declarative deployments',
              'Prometheus + Grafana observability stack',
              'Helm charts for your applications',
            ]
          },
          {
            title: 'CI/CD Pipeline',
            price: '€400 – €800',
            time: '3-5 days',
            color: '#F29900',
            features: [
              'GitHub Actions — lint, test, build, deploy',
              'Docker multi-stage build + ECR push',
              'Automated deploy to EKS via Helm/ArgoCD',
              'SonarCloud quality gate integration',
              'Security scan (Trivy + Checkov) on every PR',
              'Environment separation (dev/staging/prod)',
            ]
          },
          {
            title: 'Security Audit',
            price: '€199 – €299',
            time: '2-3 days',
            color: '#C5221F',
            features: [
              'lra scan on all your GitHub repositories',
              'Trivy — container and IaC vulnerabilities',
              'Checkov — Terraform, K8s, Dockerfile, Actions',
              'PASS/FAIL report with severity classification',
              'Concrete fix recommendations per finding',
              'Optional: implementation support included',
            ]
          },
        ].map(service => (
          <div style={`background: #F8F9FA; border: 1px solid #DADCE0; border-top: 3px solid ${service.color}; border-radius: 8px; padding: 1.5rem;`} class="card-premium" data-animate-child>
            <div style="display: flex; align-items: start; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
              <h3 style="font-family: 'Red Hat Display', sans-serif; font-size: 1rem; font-weight: 700; color: #202124;">{service.title}</h3>
              <div style="text-align: right;">
                <div style={`font-family: 'Red Hat Display', sans-serif; font-size: 1.0625rem; font-weight: 700; color: ${service.color};`}>{service.price}</div>
                <div style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6;">{service.time}</div>
              </div>
            </div>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              {service.features.map(f => (
                <li style="display: flex; align-items: start; gap: 0.625rem;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style={`color: ${service.color}; flex-shrink: 0; margin-top: 2px;`}><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; line-height: 1.5;">{f}</span>
                </li>
              ))}
            </ul>
            <a href="/contact" style="display: inline-flex; align-items: center; gap: 0.375rem; margin-top: 1.25rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #1A73E8; text-decoration: none;"
              onmouseover="this.style.textDecoration='underline'"
              onmouseout="this.style.textDecoration='none'"
            >
              Request quote →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-top: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Process</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 0.5rem;">How we work</h2>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;">From your first message to the delivered report — no surprises.</p>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="process-grid">
        {[
          { step: '01', title: 'You contact us', desc: 'Send your GitHub repo URL via the contact form. We respond within 24 hours to confirm we received it.', time: 'Day 1' },
          { step: '02', title: 'We run the audit', desc: 'We execute lra scan — Trivy for vulnerabilities, Checkov for IaC misconfigurations. Full analysis of your codebase.', time: 'Day 2' },
          { step: '03', title: 'You get the report', desc: 'Complete PASS/FAIL report delivered by email. Includes all findings, severity levels and concrete fix recommendations.', time: 'Day 3' },
        ].map(({ step, title, desc, time }) => (
          <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; position: relative;" class="card-premium">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 700; color: #1A73E8; background: #E8F0FE; padding: 0.25rem 0.625rem; border-radius: 4px;">{step}</span>
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6;">{time}</span>
            </div>
            <h3 style="font-family: 'Red Hat Display', sans-serif; font-size: 1rem; font-weight: 700; color: #202124; margin-bottom: 0.5rem;">{title}</h3>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; line-height: 1.6;">{desc}</p>
          </div>
        ))}
      </div>
      <div style="margin-top: 1.5rem; padding: 1rem 1.5rem; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: #137333; flex-shrink: 0;"></span>
        <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; font-weight: 500;">We respond to every request within 24 hours.</span>
        <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">Private repos accepted. No long-term commitment required.</span>
      </div>
    </div>
  </section>

  <!-- What we work with -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Stack</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 2rem;">Technologies we work with</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
        {techs.map(tech => (
          <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.875rem; color: #202124; background: #F8F9FA; border: 1px solid #DADCE0; padding: 0.375rem 0.875rem; border-radius: 4px;">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 767px) {
    .service-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
    .consulting-cards {
      grid-template-columns: 1fr !important;
    }
    .process-grid {
      grid-template-columns: 1fr !important;
    }
    .services-list-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
