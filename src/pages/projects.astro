---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { getAllRepos, getAllProjectConfigs, formatDate, type RepoData, type ProjectConfig } from '../lib/github'
import { getTagClass } from '../lib/tagColors'

let githubData: Record<string, RepoData> = {}
let projectConfigs: Record<string, ProjectConfig | null> = {}
try {
  ;[githubData, projectConfigs] = await Promise.all([getAllRepos(), getAllProjectConfigs()])
} catch {
  // Build must never fail on a GitHub API hiccup — cards fall back to static data below
}

const MATURITY_BADGES: Record<string, { label: string; color: string; bg: string }> = {
  'lra-ai-platform': { label: 'Core Platform', color: '#137333', bg: '#E6F4EA' },
  'aws-terraform-devops': { label: 'Core Platform', color: '#137333', bg: '#E6F4EA' },
  'k8s-on-premise': { label: 'Supporting', color: '#1A73E8', bg: '#E8F0FE' },
  'aws-devops-agent': { label: 'Lab', color: '#F29900', bg: '#FFF8E1' },
}

const PROJECT_CONNECTIONS = [
  { from: 'lra-ai-platform', arrow: 'runs security scans on', to: 'aws-terraform-devops', desc: 'The SecurityAgent scans Terraform modules for misconfigurations via Checkov.' },
  { from: 'aws-terraform-devops', arrow: 'provisions the cluster for', to: 'k8s-on-premise', desc: 'The EKS module creates the managed Kubernetes layer that complements bare-metal.' },
  { from: 'aws-devops-agent', arrow: 'queries the infrastructure of', to: 'aws-terraform-devops', desc: 'The AI agent reads EC2, RDS and EKS resources provisioned by Terraform.' },
  { from: 'lra-ai-platform', arrow: 'documents and reviews', to: 'all projects', desc: 'DocumentationAgent and ReviewerAgent run across all repositories in the ecosystem.' },
]

const PROJECT_DEFAULTS = [
  {
    name: 'lra-ai-platform',
    slug: 'lra-ai-platform',
    category: 'AI Agents',
    color: '#1A73E8',
    desc: '8 specialized agents orchestrate DevOps operations across AWS, Kubernetes and Terraform with a 5-level Governance Engine.',
    tags: ['Python', 'FastAPI', 'boto3', 'Kubernetes', 'Terraform'],
    status: 'Active',
    statusColor: '#137333',
    githubHref: 'https://github.com/lra-cloud-ops/lra-ai-platform',
    stats: [
      { label: 'Agents', value: '8' },
      { label: 'Integrations', value: '14' },
      { label: 'Workflows', value: '9' },
      { label: 'Tests', value: '33' },
    ],
  },
  {
    name: 'aws-devops-agent',
    slug: 'aws-devops-agent',
    category: 'Cloud AI',
    color: '#137333',
    desc: 'CLI agent using an AI model in a tool-use loop. 31 boto3 functions covering 24 AWS services. Ask in plain language.',
    tags: ['Python', 'Anthropic', 'AI Model', 'boto3', 'AWS'],
    status: 'PoC',
    statusColor: '#F29900',
    githubHref: 'https://github.com/lra-cloud-ops/aws-devops-agent',
    stats: [
      { label: 'AWS Services', value: '24' },
      { label: 'Tools', value: '31' },
      { label: 'Lines', value: '593' },
      { label: 'Model', value: 'AI' },
    ],
  },
  {
    name: 'aws-terraform-devops',
    slug: 'aws-terraform-devops',
    category: 'Infrastructure',
    color: '#F29900',
    desc: 'Complete AWS environment: multi-AZ VPC, EKS 1.31, RDS PostgreSQL 15, ECR. Flask app deployed via Helm. ArgoCD sync. SonarCloud gate.',
    tags: ['Terraform', 'AWS', 'EKS', 'Helm', 'ArgoCD', 'SonarCloud'],
    status: 'Active',
    statusColor: '#137333',
    githubHref: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
    stats: [
      { label: 'TF Modules', value: '7' },
      { label: 'TF Files', value: '26' },
      { label: 'Tests', value: '18' },
      { label: 'Commits', value: '71' },
    ],
  },
  {
    name: 'k8s-on-premise',
    slug: 'k8s-on-premise',
    category: 'Kubernetes',
    color: '#C5221F',
    desc: 'Multi-node Kubernetes cluster from scratch: kubeadm bootstrap, Calico CNI, NGINX Ingress, Helm add-ons and ArgoCD GitOps sync.',
    tags: ['Kubernetes', 'kubeadm', 'Calico', 'Vagrant', 'Helm', 'ArgoCD'],
    status: 'Active',
    statusColor: '#137333',
    githubHref: 'https://github.com/lra-cloud-ops/k8s-on-premise',
    stats: [
      { label: 'Nodes', value: '3' },
      { label: 'Scripts', value: '6' },
      { label: 'Commits', value: '25' },
      { label: 'CNI', value: 'Calico' },
    ],
  },
] as const

const STATUS_COLORS: Record<string, string> = {
  Active: '#137333',
  PoC: '#F29900',
  Lab: '#1A73E8',
  Archive: '#5F6368',
}

function mergeConfigStats(
  defaultStats: readonly { label: string; value: string }[],
  config: ProjectConfig | null | undefined
) {
  if (!config?.stats) return defaultStats
  return defaultStats.map((stat) => {
    const key = Object.keys(config.stats).find((k) => k.toLowerCase() === stat.label.toLowerCase().replace(/\s+/g, ''))
    return key ? { ...stat, value: String(config.stats[key]) } : stat
  })
}

const projects = PROJECT_DEFAULTS.map((project) => {
  const config = projectConfigs[project.slug]
  const github = githubData[project.slug]

  let stats = mergeConfigStats(project.stats, config)
  stats = stats.map((stat) =>
    stat.label === 'Commits' && github?.commits ? { ...stat, value: String(github.commits) } : stat
  )

  return {
    ...project,
    desc: config?.description || project.desc,
    status: config?.status || project.status,
    statusColor: (config?.status && STATUS_COLORS[config.status]) || project.statusColor,
    tags: config?.tags?.length ? config.tags : project.tags,
    stats,
    github,
  }
})

const liveCommitTotal = Object.values(githubData).reduce((sum, repo) => sum + (repo?.commits || 0), 0)
const totalCommitsDisplay = liveCommitTotal > 0 ? `${liveCommitTotal}+` : '121+'
---

<Layout
  title="Open Source Platform — LRA CloudOps"
  description="Four open source projects. Four Platform Engineering capabilities — Infrastructure as Code, Kubernetes, GitOps and AI orchestration."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <!-- Page hero -->
  <section
    data-animate="fade-up"
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Open Source Platform
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        Four capabilities. One platform.
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; max-width: 560px;"
      >
        Production-grade implementations of the Platform Engineering stack —
        inspect the code, run the tools, build on the foundation.
      </p>
    </div>
  </section>

  <!-- Global stats bar -->
  <section style="background: #F8F9FA; border-bottom: 1px solid #DADCE0; padding: 1.25rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
          {[
            { value: '4', label: 'open source projects' },
            { value: totalCommitsDisplay, label: 'commits' },
            { value: '51', label: 'tests' },
          ].map(({ value, label }) => (
            <div style="display: flex; align-items: baseline; gap: 0.375rem;">
              <span style="font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 900; color: #1A73E8; letter-spacing: -0.03em;">{value}</span>
              <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">{label}</span>
            </div>
          ))}
        </div>
        <div style="height: 20px; width: 1px; background: #DADCE0; flex-shrink: 0;"></div>
        <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
          {['Python', 'Terraform', 'Bash', 'HCL', 'YAML'].map(lang => (
            <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.125rem 0.5rem; border-radius: 3px;">{lang}</span>
          ))}
        </div>
        <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener noreferrer"
          style="margin-left: auto; display: inline-flex; align-items: center; gap: 0.375rem; font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; color: #1A73E8; text-decoration: none;"
          onmouseover="this.style.textDecoration='underline'"
          onmouseout="this.style.textDecoration='none'"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          github.com/lra-cloud-ops →
        </a>
      </div>
    </div>
  </section>

  <!-- Projects grid -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        data-animate="stagger"
        style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;"
        class="projects-grid"
      >
        {
          projects.map((project) => (
            <div
              data-animate-child
              class="card-premium"
              style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; overflow: hidden; transition: box-shadow 200ms ease;"
              onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.10)'"
              onmouseout="this.style.boxShadow='none'"
            >
              <div
                style={`background: ${project.color}08; border-bottom: 1px solid #DADCE0; padding: 1.25rem 1.5rem; display: flex; align-items: start; justify-content: space-between;`}
              >
                <div>
                  <p
                    style={`font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: ${project.color}; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.375rem;`}
                  >
                    {project.category}
                  </p>
                  <h2 style="font-family: 'Red Hat Mono', monospace; font-size: 1.0625rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;">
                    {project.name}
                  </h2>
                  <span
                    style={`font-family: 'Red Hat Mono', monospace; font-size: 0.6875rem; font-weight: 600; color: ${MATURITY_BADGES[project.slug].color}; background: ${MATURITY_BADGES[project.slug].bg}; border: 1px solid ${MATURITY_BADGES[project.slug].color}; padding: 0.125rem 0.5rem; border-radius: 3px;`}
                  >
                    {MATURITY_BADGES[project.slug].label}
                  </span>
                </div>
                <span
                  class={project.status === 'Active' ? 'status-active' : undefined}
                  style={`font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: ${project.statusColor}; background: ${project.statusColor}12; padding: 0.25rem 0.625rem; border-radius: 4px; border: 1px solid ${project.statusColor}30; white-space: nowrap;`}
                >
                  {project.status}
                </span>
              </div>

              <div style="display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid #DADCE0;" class="project-stats-grid">
                {project.stats.map(({ label, value }, i) => (
                  <div
                    style={`padding: 0.875rem 1rem; text-align: center; ${i < 3 ? 'border-right: 1px solid #DADCE0;' : ''}`}
                  >
                    <div
                      style={`font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 700; color: ${project.color}; line-height: 1;`}
                      data-count={/^\d+$/.test(value) ? value : undefined}
                    >
                      {value}
                    </div>
                    <div style="font-family: 'Red Hat Text', sans-serif; font-size: 0.6875rem; color: #5F6368; margin-top: 0.25rem;">
                      {label}
                    </div>
                  </div>
                ))}
              </div>

              <div style="padding: 1.25rem 1.5rem;">
                <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; line-height: 1.6; margin-bottom: 1.25rem;">
                  {project.desc}
                </p>

                <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1.25rem;">
                  {project.tags.map((tag) => (
                    <span class={getTagClass(tag)} style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; background: #F8F9FA; border: 1px solid #DADCE0; padding: 0.2rem 0.5rem; border-radius: 3px;">
                      {tag}
                    </span>
                  ))}
                </div>

                {project.github?.pushedAt && (
                  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem; padding-top: 0.875rem; border-top: 1px solid #DADCE0; flex-wrap: wrap;">
                    <span style="display: inline-flex; align-items: center; gap: 0.25rem; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;">
                      ★ {project.github.stars}
                    </span>
                    <span style="display: inline-flex; align-items: center; gap: 0.25rem; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;">
                      ⑂ {project.github.forks}
                    </span>
                    <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;">
                      Updated {formatDate(project.github.pushedAt)}
                    </span>
                  </div>
                )}

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
                  <a
                    href={`/projects/${project.slug}`}
                    style="display: inline-flex; align-items: center; gap: 0.375rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #1A73E8; text-decoration: none;"
                    onmouseover="this.style.textDecoration='underline'"
                    onmouseout="this.style.textDecoration='none'"
                  >
                    View details →
                  </a>
                  <a
                    href={project.githubHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${project.name} on GitHub`}
                    style="display: inline-flex; align-items: center; color: #5F6368; text-decoration: none;"
                    onmouseover="this.style.color='#202124'"
                    onmouseout="this.style.color='#5F6368'"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How these projects connect -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-top: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Ecosystem</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 0.5rem;">Engineering dependencies</h2>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;">How the four repositories interact in production.</p>

      <div style="display: flex; flex-direction: column; gap: 0.75rem; max-width: 720px;">
        {PROJECT_CONNECTIONS.map(({ from, arrow, to, desc }) => (
          <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.25rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; font-weight: 600; color: #1A73E8;">{from}</span>
              <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #9AA0A6;">→ {arrow} →</span>
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; font-weight: 600; color: #202124;">{to}</span>
            </div>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; margin: 0; line-height: 1.6;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 767px) {
    .projects-grid {
      grid-template-columns: 1fr !important;
    }
  }

  @media (max-width: 480px) {
    .project-stats-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

<script>
  // Animated counters — stat values count up from 0 when scrolled into view
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.getAttribute('data-count') || '0')
    const duration = 1200
    const start = performance.now()

    const tick = (now: number) => {
      const elapsed = now - start
      const progress = Math.min(elapsed / duration, 1)
      const eased = 1 - Math.pow(1 - progress, 3)
      el.textContent = Math.round(eased * target).toString()
      if (progress < 1) requestAnimationFrame(tick)
    }
    requestAnimationFrame(tick)
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter(entry.target as HTMLElement)
        observer.unobserve(entry.target)
      }
    })
  }, { threshold: 0.5 })

  document.querySelectorAll('[data-count]').forEach(el => observer.observe(el))
</script>
