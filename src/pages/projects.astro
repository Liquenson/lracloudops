---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'

export const prerender = true

const projects = [
  {
    name: 'aws-terraform-devops',
    longDesc:
      'Production-grade AWS platform built with Terraform modules. Includes VPC with Multi-AZ subnets, EKS cluster with managed node groups, RDS PostgreSQL with automated backups, Application Load Balancer, CloudFront CDN, and full observability stack.',
    tags: ['AWS', 'EKS 1.31', 'Terraform', 'RDS PostgreSQL 15', 'ArgoCD', 'Jenkins', 'Prometheus', 'Grafana'],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
    metrics: [
      { label: 'Deploy time', value: '45min' },
      { label: 'Manual deploys', value: '0' },
      { label: 'Availability', value: '99.9%' },
      { label: 'IaC coverage', value: '100%' },
    ],
  },
  {
    name: 'gitops-stack',
    longDesc:
      'Complete GitOps implementation following the declarative model. ArgoCD watches Git repositories and automatically syncs the cluster state. Drift is detected and reconciled automatically.',
    tags: ['ArgoCD', 'GitOps', 'Kubernetes', 'Helm', 'AWS EKS', 'Ansible', 'CloudWatch'],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/gitops-stack',
    metrics: [
      { label: 'Manual kubectl', value: '0' },
      { label: 'Deploy time', value: '<8min' },
      { label: 'IaC coverage', value: '100%' },
      { label: 'AWS credentials', value: '0 static' },
    ],
  },
  {
    name: 'k8s-devops-platform',
    longDesc:
      'Complete local DevOps platform for development. Uses KinD (Kubernetes in Docker) to replicate the production environment. Includes full GitOps stack, observability, and CI/CD pipelines.',
    tags: ['Kubernetes', 'KinD', 'ArgoCD', 'Helm', 'Prometheus', 'Grafana', 'Alertmanager'],
    status: 'Reference',
    href: 'https://github.com/lra-cloud-ops/k8s-devops-platform',
    metrics: [
      { label: 'Manual kubectl', value: '0' },
      { label: 'GitOps deploys', value: '100%' },
      { label: 'Prod parity', value: 'Exact' },
      { label: 'Auto-heal', value: 'Active' },
    ],
  },
  {
    name: 'linux-fleet-manager',
    longDesc:
      'Production fleet management tool that operates via SSH agents with zero agent requirements on target hosts. All scripts are ShellCheck validated and CI tested across multiple platforms.',
    tags: ['Bash', 'SSH', 'Linux', 'ShellCheck', 'CI/CD', 'Ansible'],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/linux-fleet-manager',
    metrics: [
      { label: 'Agents on hosts', value: '0' },
      { label: 'ShellCheck score', value: '100%' },
      { label: 'Platforms', value: '3 OS' },
      { label: 'Idempotent', value: 'Yes' },
    ],
  },
]
---

<Layout
  title="Projects — Ruben Liquenson"
  description="Open source DevOps projects by Ruben Liquenson. AWS EKS, Terraform, GitOps, Kubernetes — production-grade infrastructure."
  lang="en"
>
  <Header />

  <section class="bg-dark on-dark section-sm">
    <div class="container">
      <div class="eyebrow">Open Source</div>
      <h1 style="color: #FFF; margin-bottom: 1rem;">Projects</h1>
      <p style="color: #94A3B8; max-width: 560px; font-size: 1.125rem;">
        Production-grade infrastructure projects. Real code, real metrics, real environments. Not sandbox demos.
      </p>
    </div>
  </section>

  <section class="bg-light section">
    <div class="container">
      <div style="display: flex; flex-direction: column; gap: 3rem;">
        {
          projects.map((project, i) => (
            <article class={`project-article ${i === 0 ? 'project-article-featured' : ''}`}>
              <div style="display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: start; margin-bottom: 1.5rem;">
                <div>
                  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
                    <a
                      href={project.href}
                      target="_blank"
                      rel="noopener"
                      style="font-family: var(--font-mono); font-size: 1.25rem; font-weight: 700; color: var(--color-primary); text-decoration: none;"
                    >
                      {project.name} ↗
                    </a>
                    <span class={`badge ${project.status === 'Production' ? 'badge-green' : 'badge-blue'}`}>
                      {project.status}
                    </span>
                  </div>
                  <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">{project.longDesc}</p>
                </div>
              </div>

              <div class="metrics-grid">
                {project.metrics.map((m, mi) => (
                  <div class={`metric-item ${mi < project.metrics.length - 1 ? 'metric-border' : ''}`}>
                    <div class="metric-value">{m.value}</div>
                    <div class="metric-label">{m.label}</div>
                  </div>
                ))}
              </div>

              <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
                {project.tags.map((tag) => (
                  <span class="tech-pill" style="font-size: 0.75rem;">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .project-article {
    padding: 2.5rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    background: #fff;
  }
  .project-article-featured {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: var(--surface-subtle);
    border-radius: var(--radius-sm);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .metric-item {
    padding: 1rem;
    text-align: center;
  }
  .metric-border {
    border-right: 1px solid var(--border-light);
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-primary);
  }
  .metric-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
