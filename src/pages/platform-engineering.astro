---
import SolutionLayout from '../components/SolutionLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://lracloudops.com/platform-engineering#service',
  name: 'Platform Engineering',
  serviceType: 'Internal Developer Platform',
  description:
    'Internal developer platforms built on Kubernetes, GitOps and policy-as-code. Self-service infrastructure that reduces deployment friction without reducing operational control.',
  url: 'https://lracloudops.com/platform-engineering',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: ['ES', 'US', 'LATAM'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Platform Engineering Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Kubernetes Platform Design' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'GitOps with ArgoCD' },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Internal Developer Platform',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Policy as Code' },
      },
    ],
  },
}
---

<SolutionLayout
  titulo="Platform Engineering · Internal Developer Platform"
  descripcion="Internal developer platforms built on Kubernetes, GitOps and policy-as-code. Self-service infrastructure that reduces deployment friction without reducing operational control."
  badgeLabel="02 · Platform Engineering"
  h1="A platform your engineers can ship from without asking ops."
  heroSubtitle="Development teams raising infrastructure tickets to deploy software is a bottleneck. Every manual handoff is a delay. We replace that with Kubernetes platforms operated as self-service infrastructure — teams deploy by merging a pull request."
  schema={schema}
  sectionNumber="02"
  challenges={[
    {
      title: 'Deployment bottleneck through ops',
      desc: 'Every deployment requires a ticket to the platform team. Development velocity is constrained by operations capacity, not engineering output.',
    },
    {
      title: 'Inconsistent cluster configuration',
      desc: 'Clusters configured manually diverge from each other. What works in dev fails in production for reasons that take hours to diagnose.',
    },
    {
      title: 'No enforcement of standards',
      desc: 'Without policy, teams apply whatever resource limits and security configurations they prefer. Standards exist only in documentation nobody reads.',
    },
    {
      title: 'Undocumented cluster knowledge',
      desc: 'Critical cluster configuration lives in the memory of the engineers who set it up. Runbooks do not exist. On-call is a guessing game.',
    },
  ]}
  archTitle="The platform components we deliver."
  archSubtitle="Each component reduces the operational surface your teams manage. Together, they form a self-service delivery platform."
  layers={[
    {
      layer: 'Kubernetes Orchestration',
      tools: 'EKS 1.31+ · Node groups · Managed add-ons',
      desc: 'Fully managed EKS clusters with node groups defined in Terraform. Cluster upgrades are tested in dev before production. No manual kubectl apply in production.',
    },
    {
      layer: 'GitOps Delivery',
      tools: 'ArgoCD · ApplicationSets · Auto-sync · Prune + selfHeal',
      desc: 'Git is the single source of truth. ArgoCD syncs cluster state from the repository. Manual changes are overwritten on the next sync cycle.',
    },
    {
      layer: 'Workload Management',
      tools: 'Helm Charts · Kustomize · Per-environment values',
      desc: 'One Helm chart per service, promoted through environments by changing values files. Rollback is a git revert, not a kubectl command.',
    },
    {
      layer: 'Autoscaling',
      tools: 'HPA · VPA · Cluster Autoscaler · KEDA',
      desc: 'Horizontal Pod Autoscaler configured at deployment time. Cluster Autoscaler provisions nodes before the workload needs them, not after.',
    },
    {
      layer: 'Access Control',
      tools: 'RBAC · ServiceAccounts · OPA Gatekeeper · Namespace isolation',
      desc: 'Least-privilege service accounts per workload. OPA Gatekeeper enforces resource limits, image policies and security contexts before admission.',
    },
    {
      layer: 'Local Development',
      tools: 'KinD · Tilt · Skaffold · Local registry',
      desc: 'Local Kubernetes cluster that mirrors the production configuration. Engineers test against real cluster behavior before opening a pull request.',
    },
  ]}
  steps={[
    {
      step: '01',
      title: 'Platform requirements',
      desc: 'Map the deployment workflow, identify bottlenecks and define the self-service contract between platform and product teams.',
    },
    {
      step: '02',
      title: 'Cluster design',
      desc: 'Design the EKS architecture, node group strategy, network policy and RBAC model before provisioning anything.',
    },
    {
      step: '03',
      title: 'GitOps bootstrap',
      desc: 'Deploy ArgoCD, configure ApplicationSets for all environments and migrate existing workloads to GitOps delivery.',
    },
    {
      step: '04',
      title: 'Policy and handover',
      desc: 'Implement admission policies, document the deployment workflow and run a platform walkthrough with the engineering team.',
    },
  ]}
  outcomes={[
    {
      metric: 'Deployments without ops tickets',
      detail: 'teams ship by merging a pull request',
    },
    {
      metric: 'Consistent cluster configuration',
      detail: 'every cluster provisioned from the same Terraform module',
    },
    {
      metric: 'Policy enforced at admission',
      detail: 'not discovered at incident post-mortems',
    },
    {
      metric: 'Rollback in under 2 minutes',
      detail: 'git revert, not manual intervention',
    },
    {
      metric: 'Autoscaling without manual intervention',
      detail: 'HPA and Cluster Autoscaler handle load spikes',
    },
    {
      metric: 'Local development mirrors production',
      detail: 'issues found before they reach a cluster',
    },
  ]}
  ctaH2="Start with a platform review."
  ctaSubtitle="Bring your current Kubernetes setup or deployment workflow. We identify where friction is costing you velocity and outline what a self-service platform would look like for your team."
>
  <!-- Platforms where we operate -->
  <section class="py-12 border-t" style="border-color: rgba(30,111,255,0.2); background: #0A2540;" aria-label="Platforms where we operate">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-xs font-semibold uppercase tracking-widest mb-8" style="color: #64748b;">Platforms where we operate</p>
      <div class="flex items-center gap-10 flex-wrap">
        <div class="flex items-center gap-3 group cursor-default">
          <div class="w-10 h-10 flex items-center justify-center rounded-xl" style="background: rgba(255,153,0,0.12); border: 1px solid rgba(255,153,0,0.25);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #FF9900;" aria-hidden="true"><path d="M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6"/></svg>
          </div>
          <span class="text-sm font-semibold" style="color: rgba(255,255,255,0.75);">AWS</span>
        </div>
        <div class="flex items-center gap-3 group cursor-default">
          <div class="w-10 h-10 flex items-center justify-center rounded-xl" style="background: rgba(50,108,229,0.15); border: 1px solid rgba(50,108,229,0.3);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #326CE5;" aria-hidden="true"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <span class="text-sm font-semibold" style="color: rgba(255,255,255,0.75);">Kubernetes</span>
        </div>
        <div class="flex items-center gap-3 group cursor-default">
          <div class="w-10 h-10 flex items-center justify-center rounded-xl" style="background: rgba(239,123,77,0.15); border: 1px solid rgba(239,123,77,0.3);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #EF7B4D;" aria-hidden="true"><path d="M6 3v12M18 9a3 3 0 100-6 3 3 0 000 6zM6 21a3 3 0 100-6 3 3 0 000 6zM18 9a9 9 0 01-9 9"/></svg>
          </div>
          <span class="text-sm font-semibold" style="color: rgba(255,255,255,0.75);">GitOps</span>
        </div>
        <div class="flex items-center gap-3 group cursor-default">
          <div class="w-10 h-10 flex items-center justify-center rounded-xl" style="background: rgba(37,99,235,0.15); border: 1px solid rgba(37,99,235,0.3);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #60A5FA;" aria-hidden="true"><path d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
          </div>
          <span class="text-sm font-semibold" style="color: rgba(255,255,255,0.75);">On-Premise</span>
        </div>
      </div>
    </div>
  </section>
</SolutionLayout>
