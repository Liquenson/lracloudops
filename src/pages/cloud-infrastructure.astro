---
import SolutionLayout from '../components/SolutionLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://lracloudops.com/cloud-infrastructure#service',
  name: 'Cloud Infrastructure Engineering',
  serviceType: 'Cloud Infrastructure',
  description:
    'Codified AWS environments with defined networking, security boundaries and access policies. Terraform modules that are auditable, version-controlled and reproducible across accounts.',
  url: 'https://lracloudops.com/cloud-infrastructure',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: ['ES', 'US', 'LATAM'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Cloud Infrastructure Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Terraform Infrastructure as Code',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'AWS VPC & Networking Design',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'IAM & Security Boundaries' },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Multi-Account AWS Architecture',
        },
      },
    ],
  },
}
---

<SolutionLayout
  titulo="Cloud Infrastructure · AWS Platform Engineering"
  descripcion="Codified AWS environments with defined networking, security boundaries and access policies. Terraform modules that are auditable, version-controlled and reproducible across accounts."
  badgeLabel="01 · Cloud Infrastructure"
  h1="Infrastructure that can be reproduced, audited and recovered."
  heroSubtitle="Manual AWS environments produce configuration drift, undocumented state and infrastructure that cannot be reliably reproduced. We replace that with codified, version-controlled environments where every resource has an owner and every change has a commit."
  schema={schema}
  sectionNumber="01"
  challenges={[
    {
      title: 'Configuration drift',
      desc: 'Environments diverge from their intended state over time. Nobody knows what changed, when, or why. Reproducing the environment from scratch is impossible.',
    },
    {
      title: 'Undocumented state',
      desc: 'Resources created from the console have no audit trail. When the engineer who provisioned them leaves, the knowledge goes with them.',
    },
    {
      title: 'Manual dependency on humans',
      desc: 'Every new account, region or environment requires manual work. Scaling the platform requires scaling the headcount.',
    },
    {
      title: 'Security configuration applied after the fact',
      desc: 'Security groups, IAM policies and network boundaries added retroactively are inconsistent and frequently incomplete.',
    },
  ]}
  archTitle="The platform stack we deliver."
  archSubtitle="Every layer is version-controlled, auditable and recoverable. No manual provisioning, no console-only configuration."
  layers={[
    {
      layer: 'Network Foundation',
      tools: 'Terraform · VPC · Subnets · NAT Gateway · IGW',
      desc: 'Multi-AZ VPC with public subnets for load balancers and private subnets for compute and data. No backend component has a public IP address.',
    },
    {
      layer: 'Compute Layer',
      tools: 'EKS 1.31+ · ECS Fargate · EC2 Auto Scaling',
      desc: 'Kubernetes clusters or Fargate tasks depending on workload requirements. Node groups managed as code. HPA configured at provisioning time.',
    },
    {
      layer: 'Data Layer',
      tools: 'RDS PostgreSQL 15 · Multi-AZ · Encrypted · Private subnets',
      desc: 'Managed databases in private subnets with automated failover, 7-day backups and encryption at rest. Security group access restricted to compute tier only.',
    },
    {
      layer: 'Content Delivery',
      tools: 'CloudFront · S3 · Route 53 · ACM',
      desc: 'CDN, static asset hosting and DNS managed as code. TLS certificates provisioned and rotated automatically.',
    },
    {
      layer: 'Identity & Access',
      tools: 'IAM · OIDC · Least-privilege policies · No static credentials',
      desc: 'OIDC-based authentication for CI/CD pipelines — no long-lived access keys. IAM roles and policies defined in Terraform and reviewed before apply.',
    },
    {
      layer: 'State Management',
      tools: 'S3 backend · DynamoDB locking · SSE-S3 · Workspaces',
      desc: 'Remote Terraform state with encryption and distributed locking. Separate workspaces for dev and production — no shared state files.',
    },
  ]}
  steps={[
    {
      step: '01',
      title: 'Current state assessment',
      desc: 'Review existing architecture, document gaps and identify risk areas before writing a line of Terraform.',
    },
    {
      step: '02',
      title: 'Module design',
      desc: 'Design reusable, independently deployable Terraform modules with clear input/output contracts.',
    },
    {
      step: '03',
      title: 'Environment provisioning',
      desc: 'Deploy dev environment first. Validate end-to-end before applying the same configuration to production.',
    },
    {
      step: '04',
      title: 'Observability and handover',
      desc: 'CloudWatch alarms, cost alerts and runbooks delivered alongside the infrastructure — not as an afterthought.',
    },
  ]}
  outcomes={[
    {
      metric: 'Any environment reproducible',
      detail: 'from a single terraform apply',
    },
    {
      metric: 'Zero manual configuration',
      detail: 'every resource defined in code',
    },
    {
      metric: 'Full audit trail',
      detail: 'every change tied to a commit and a reviewer',
    },
    {
      metric: 'Disaster recovery tested',
      detail: 'reproducibility verified before production',
    },
    {
      metric: 'Security applied at provisioning',
      detail: 'not after the first security review',
    },
    {
      metric: 'New environments in minutes',
      detail: 'not days of manual work',
    },
  ]}
  ctaH2="Start with an infrastructure review."
  ctaSubtitle="Bring your current AWS environment. We assess reproducibility, security posture and state management — and outline a concrete path to codified infrastructure."
>
  <!-- Real Implementation -->
  <section class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="section-label">Real Implementation</span>
        <h2 class="text-3xl sm:text-4xl font-bold mt-5 mb-4" style="color: #0F172A; letter-spacing: -0.025em;">aws-terraform-devops</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">Production AWS infrastructure with modular Terraform — deployed and running.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-7" style="border: 1px solid #E5E7EB; border-left: 4px solid #1E6FFF; box-shadow: 0 1px 3px rgba(15,23,42,0.04);">
          <h3 class="text-base font-bold mb-3" style="color: #0A2540;">Infrastructure Stack</h3>
          <ul class="space-y-2 text-sm" style="color: #64748B;">
            <li>• VPC with public + private subnets, IGW, NAT Gateway</li>
            <li>• EKS cluster — managed node groups, IRSA</li>
            <li>• RDS PostgreSQL 15 Multi-AZ — automated failover &lt;60s</li>
            <li>• S3 remote state + DynamoDB locking — no state conflicts</li>
            <li>• IAM OIDC — zero static credentials</li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl p-7" style="border: 1px solid #E5E7EB; border-left: 4px solid #1E6FFF; box-shadow: 0 1px 3px rgba(15,23,42,0.04);">
          <h3 class="text-base font-bold mb-3" style="color: #0A2540;">Terraform Modules</h3>
          <ul class="space-y-2 text-sm" style="color: #64748B;">
            <li>• <code>modules/vpc</code> — networking layer</li>
            <li>• <code>modules/eks</code> — cluster + node groups</li>
            <li>• <code>modules/rds</code> — PostgreSQL 15 Multi-AZ</li>
            <li>• <code>modules/iam</code> — roles, policies, OIDC</li>
            <li>• <code>modules/ecr</code> — container registry</li>
          </ul>
        </div>
      </div>
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        <a href="/projects/aws-terraform-devops" class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all" style="background: #EEF4FF; color: #1E6FFF;">
          Read case study →
        </a>
        <a href="https://github.com/lra-cloud-ops/aws-terraform-devops" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all" style="background: #F1F5F9; color: #0A2540;">
          View on GitHub →
        </a>
      </div>
    </div>
  </section>
</SolutionLayout>
