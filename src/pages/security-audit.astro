---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Security Agent · Cloud Security Audit · AI-Powered · Free"
  descripcion="Detect IAM, networking, secrets and compliance vulnerabilities in your cloud infrastructure without account access. CIS Benchmark, HIPAA, PCI-DSS."
>
  <!-- HERO -->
  <section
    class="relative overflow-hidden"
    style="background: #0A2540;"
    aria-labelledby="sa-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.1) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-7 text-xs font-bold tracking-widest uppercase"
        style="background: rgba(220,38,38,0.2); border: 1px solid rgba(252,165,165,0.35); color: #FCA5A5;"
      >
        <span
          class="w-2 h-2 rounded-full flex-shrink-0"
          style="background: #F87171; animation: pulse 2s infinite;"
          aria-hidden="true"></span>
        AI-Powered · HIPAA · CIS Benchmark
      </div>
      <h1
        id="sa-hero-heading"
        class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight"
        style="letter-spacing: -0.035em;"
      >
        Security Agent
      </h1>
      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto"
        style="color: rgba(147,184,255,0.85);"
      >
        Automated cloud security audit. Detect IAM, networking, secrets and
        compliance vulnerabilities without account access.
      </p>
    </div>
  </section>

  <!-- FORM + RESULTS -->
  <section class="bg-white py-16" aria-label="Security audit form">
    <div class="max-w-3xl mx-auto px-6">
      <form id="sa-form" class="space-y-6" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label
              for="sa-cloud"
              class="block text-sm font-semibold mb-2"
              style="color: #0F172A;">Cloud</label
            >
            <select
              id="sa-cloud"
              class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
              style="border-color: #E2E8F0; color: #0F172A;"
            >
              <option value="AWS" selected>Amazon Web Services (AWS)</option>
              <option value="Azure">Microsoft Azure</option>
              <option value="GCP">Google Cloud Platform</option>
              <option value="Multi-cloud">Multi-cloud</option>
            </select>
          </div>
          <div>
            <label
              for="sa-compliance"
              class="block text-sm font-semibold mb-2"
              style="color: #0F172A;">Compliance framework</label
            >
            <select
              id="sa-compliance"
              class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
              style="border-color: #E2E8F0; color: #0F172A;"
            >
              <option value="General" selected>General / Best Practices</option>
              <option value="CIS Benchmark">CIS Benchmark</option>
              <option value="HIPAA">HIPAA</option>
              <option value="PCI-DSS">PCI-DSS</option>
              <option value="SOC2">SOC2</option>
            </select>
          </div>
        </div>
        <div>
          <label
            for="sa-description"
            class="block text-sm font-semibold mb-2"
            style="color: #0F172A;"
          >
            Describe your infrastructure and security configuration
            <span class="font-normal text-xs ml-1" style="color: #64748B;"
              >(required)</span
            >
          </label>
          <textarea
            id="sa-description"
            rows="8"
            placeholder="Example: We have a VPC with EC2 instances directly exposed to the internet without WAF. Security groups allow traffic from 0.0.0.0/0 on port 22. We use an AWS access key hardcoded in the code. MFA is not enabled for IAM users. CloudTrail is active but without alerts..."
            class="w-full px-4 py-3 rounded-xl text-sm border resize-none focus:outline-none focus:ring-2"
            style="border-color: #E2E8F0; color: #0F172A;"></textarea>
        </div>
        <button
          type="submit"
          id="sa-submit"
          class="w-full inline-flex items-center justify-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.01]"
          style="background: #DC2626; box-shadow: 0 4px 20px rgba(220,38,38,0.4);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path>
          </svg>
          <span id="sa-btn-text">Audit security →</span>
        </button>
        <p id="sa-error" class="hidden text-sm text-red-600 text-center"></p>
      </form>

      <!-- Loading -->
      <div id="sa-loading" class="hidden text-center py-16">
        <div
          class="inline-flex items-center gap-3 px-6 py-4 rounded-2xl"
          style="background: #FFF5F5; border: 1px solid #FCA5A5;"
        >
          <svg
            class="w-5 h-5 animate-spin"
            style="color: #DC2626;"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="text-sm font-medium" style="color: #DC2626;"
            >Analyzing security vulnerabilities...</span
          >
        </div>
      </div>

      <!-- Results -->
      <div id="sa-results" class="hidden mt-10 space-y-6">
        <div class="rounded-2xl p-8" style="background: #0A2540;">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
              <p
                class="text-xs font-bold uppercase tracking-widest mb-2"
                style="color: #93C5FD;"
              >
                Risk level
              </p>
              <div id="sa-risk-badge" class="text-3xl font-extrabold"></div>
            </div>
            <div class="text-right">
              <p
                class="text-xs font-semibold uppercase tracking-widest mb-1"
                style="color: #93C5FD;"
              >
                Overall score
              </p>
              <div
                id="sa-overall"
                class="text-5xl font-extrabold"
                style="color: #60A5FA;"
              >
              </div>
              <p class="text-xs" style="color: rgba(147,184,255,0.6);">/ 10</p>
            </div>
          </div>
          <p
            id="sa-summary"
            class="mt-5 text-sm leading-relaxed"
            style="color: rgba(147,184,255,0.85);"
          >
          </p>
        </div>

        <div class="rounded-2xl p-6" style="border: 1px solid #E5E7EB;">
          <h2 class="text-base font-bold mb-5" style="color: #0F172A;">
            Scores by area
          </h2>
          <div id="sa-scores" class="space-y-4"></div>
        </div>

        <div
          id="sa-findings-section"
          class="hidden rounded-2xl p-6"
          style="border: 1px solid #FCA5A5; background: #FFF5F5;"
        >
          <h2
            class="text-base font-bold mb-4 flex items-center gap-2"
            style="color: #DC2626;"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              ></path>
            </svg>
            Critical findings
          </h2>
          <div id="sa-findings" class="space-y-4"></div>
        </div>

        <div
          class="rounded-2xl p-6"
          style="background: #F0FDF4; border: 1px solid #BBF7D0;"
        >
          <h2 class="text-base font-bold mb-3" style="color: #15803D;">
            Quick fixes
          </h2>
          <ul id="sa-quickfixes" class="space-y-2"></ul>
        </div>

        <div
          id="sa-gaps-section"
          class="hidden rounded-2xl p-6"
          style="background: #FFFBEB; border: 1px solid #FDE68A;"
        >
          <h2 class="text-base font-bold mb-3" style="color: #92400E;">
            Compliance gaps
          </h2>
          <ul id="sa-gaps" class="space-y-2"></ul>
        </div>

        <div class="text-center pt-4 pb-2">
          <p class="text-base font-semibold mb-4" style="color: #0F172A;">
            Want us to implement these fixes?
          </p>
          <a
            href="/en/contact"
            class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02]"
            style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.35);"
          >
            Implement fixes with LRA →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('sa-form') as HTMLFormElement
  const loading = document.getElementById('sa-loading')!
  const results = document.getElementById('sa-results')!
  const errorEl = document.getElementById('sa-error')!
  const btnText = document.getElementById('sa-btn-text')!
  const submitBtn = document.getElementById('sa-submit') as HTMLButtonElement

  const riskColors: Record<string, string> = {
    CRITICAL: '#DC2626',
    HIGH: '#EA580C',
    MEDIUM: '#D97706',
    LOW: '#16A34A',
  }
  const scoreLabels: Record<string, string> = {
    iam: 'IAM',
    networking: 'Networking',
    secrets: 'Secrets',
    compliance: 'Compliance',
    encryption: 'Encryption',
    logging: 'Logging',
  }

  function scoreColor(n: number): string {
    if (n <= 4) return '#DC2626'
    if (n <= 6) return '#D97706'
    if (n <= 8) return '#2563EB'
    return '#16A34A'
  }

  const severityColors: Record<string, string> = {
    CRITICAL: '#DC2626',
    HIGH: '#EA580C',
    MEDIUM: '#D97706',
    LOW: '#16A34A',
  }

  interface Finding {
    severity: string
    title: string
    description: string
    remediation: string
    cis_reference?: string
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    const desc = (
      document.getElementById('sa-description') as HTMLTextAreaElement
    ).value
    const cloud = (document.getElementById('sa-cloud') as HTMLSelectElement)
      .value
    const compliance = (
      document.getElementById('sa-compliance') as HTMLSelectElement
    ).value

    if (desc.trim().length < 20) {
      errorEl.textContent =
        'Please describe your infrastructure in more detail (minimum 20 characters).'
      errorEl.classList.remove('hidden')
      return
    }

    form.classList.add('hidden')
    loading.classList.remove('hidden')
    submitBtn.disabled = true
    btnText.textContent = 'Analyzing...'

    try {
      const res = await fetch('/api/security-agent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          description: desc,
          cloud,
          compliance_framework: compliance,
        }),
      })
      const json = (await res.json()) as {
        audit?: Record<string, unknown>
        error?: string
      }
      if (json.error) throw new Error(json.error)
      const a = json.audit ?? {}

      const risk = typeof a.risk_level === 'string' ? a.risk_level : 'MEDIUM'
      const riskEl = document.getElementById('sa-risk-badge')!
      riskEl.textContent = risk
      riskEl.style.color = riskColors[risk] ?? '#D97706'

      const overall = typeof a.overall_score === 'number' ? a.overall_score : 0
      const overallEl = document.getElementById('sa-overall')!
      overallEl.textContent = String(overall)
      overallEl.style.color = scoreColor(overall)
      document.getElementById('sa-summary')!.textContent =
        typeof a.summary === 'string' ? a.summary : ''

      const scoresEl = document.getElementById('sa-scores')!
      const scores = (
        a.scores && typeof a.scores === 'object' ? a.scores : {}
      ) as Record<string, number>
      scoresEl.innerHTML = Object.entries(scores)
        .map(([key, val]) => {
          const color = scoreColor(val)
          return `<div>
            <div class="flex justify-between text-sm mb-1.5">
              <span style="color:#0F172A; font-weight:600;">${scoreLabels[key] ?? key}</span>
              <span style="color:${color}; font-weight:700;">${val}/10</span>
            </div>
            <div class="h-2.5 rounded-full overflow-hidden" style="background:#F1F5F9;">
              <div class="h-full rounded-full" style="width:${val * 10}%; background:${color};"></div>
            </div>
          </div>`
        })
        .join('')

      const findingsSection = document.getElementById('sa-findings-section')!
      const findings = Array.isArray(a.critical_findings)
        ? (a.critical_findings as Finding[])
        : []
      if (findings.length > 0) {
        findingsSection.classList.remove('hidden')
        document.getElementById('sa-findings')!.innerHTML = findings
          .map(
            (f) =>
              `<div class="rounded-xl p-4" style="background:white; border:1px solid #FCA5A5;">
              <div class="flex items-start gap-3">
                <span class="text-xs font-bold px-2 py-0.5 rounded-full flex-shrink-0 mt-0.5"
                  style="background:${severityColors[f.severity] ?? '#64748B'}20; color:${severityColors[f.severity] ?? '#64748B'}; border:1px solid ${severityColors[f.severity] ?? '#64748B'}40;">
                  ${f.severity}
                </span>
                <div>
                  <div class="text-sm font-bold" style="color:#0F172A;">${f.title}</div>
                  <div class="text-xs mt-1" style="color:#64748B;">${f.description}</div>
                  <div class="text-xs mt-2 font-medium" style="color:#15803D;">✓ ${f.remediation}</div>
                  ${f.cis_reference ? `<div class="text-xs mt-1" style="color:#94A3B8;">CIS: ${f.cis_reference}</div>` : ''}
                </div>
              </div>
            </div>`
          )
          .join('')
      }

      const qf = Array.isArray(a.quick_fixes) ? (a.quick_fixes as string[]) : []
      document.getElementById('sa-quickfixes')!.innerHTML = qf
        .map(
          (f) =>
            `<li class="flex gap-2.5 text-sm" style="color:#15803D;"><span style="flex-shrink:0;">✓</span><span>${f}</span></li>`
        )
        .join('')

      const gapsSection = document.getElementById('sa-gaps-section')!
      const gaps = Array.isArray(a.compliance_gaps)
        ? (a.compliance_gaps as string[])
        : []
      if (gaps.length > 0) {
        gapsSection.classList.remove('hidden')
        document.getElementById('sa-gaps')!.innerHTML = gaps
          .map(
            (g) =>
              `<li class="flex gap-2.5 text-sm" style="color:#92400E;"><span style="flex-shrink:0;">•</span><span>${g}</span></li>`
          )
          .join('')
      }

      loading.classList.add('hidden')
      results.classList.remove('hidden')
    } catch (err) {
      loading.classList.add('hidden')
      form.classList.remove('hidden')
      submitBtn.disabled = false
      btnText.textContent = 'Audit security →'
      errorEl.textContent =
        err instanceof Error
          ? err.message
          : 'Error in the audit. Please try again.'
      errorEl.classList.remove('hidden')
    }
  })
</script>
