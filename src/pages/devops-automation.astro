---
import SolutionLayout from '../components/SolutionLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://lracloudops.com/devops-automation#service',
  name: 'DevOps Automation',
  serviceType: 'CI/CD Pipeline Engineering',
  description: 'CI/CD pipelines that ship code to production reliably. Build, test, scan and deploy pipelines with quality gates, automated rollback and full audit trails.',
  url: 'https://lracloudops.com/devops-automation',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: ['ES', 'US', 'LATAM'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'DevOps Automation Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'CI/CD Pipeline Design' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'GitHub Actions Workflows' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Jenkins Pipeline Engineering' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Quality Gate Implementation' } },
    ],
  },
}
---

<SolutionLayout
  titulo="DevOps Automation · CI/CD Pipeline Engineering"
  descripcion="CI/CD pipelines that ship code to production reliably. Build, test, scan and deploy pipelines with quality gates, automated rollback and full audit trails."
  badgeLabel="03 · DevOps Automation"
  h1="Code merged. Tests passed. Production updated. Automatically."
  heroSubtitle="Manual release processes introduce human error, compress deployment windows and make rollback difficult. We replace that with pipelines that enforce quality gates before any code reaches production — and rollback is a single command."
  schema={schema}
  sectionNumber="03"
  challenges={[
    { title: 'Manual release coordination', desc: 'Releases require coordination between developers, QA and operations. Each release is a risk event, not a routine operation.' },
    { title: 'Inconsistent quality enforcement', desc: 'Code coverage thresholds and security scans are checked manually, or not at all. Standards depend on who reviews the pull request.' },
    { title: 'Static credentials in CI', desc: 'Long-lived access keys stored in CI secrets are a credential exposure waiting to happen. Rotation is manual and infrequent.' },
    { title: 'Rollback is a crisis', desc: 'Without tested rollback procedures, reverting a broken deployment requires manual steps that extend the outage window.' },
  ]}
  archTitle="The pipeline architecture we deliver."
  archSubtitle="Every stage is automated. Every quality gate is enforced before production. Every release is traceable."
  layers={[
    { layer: 'Source Control', tools: 'GitHub · Branch protection · Required reviews · Status checks', desc: 'Protected branches require passing CI before merge. No code reaches production without a reviewer and a green pipeline.' },
    { layer: 'Build Stage', tools: 'Maven · Gradle · pip · npm · Multi-stage Docker', desc: 'Reproducible builds with pinned dependencies. Multi-stage Docker builds that produce minimal production images with no build tooling included.' },
    { layer: 'Quality Gates', tools: 'SonarCloud · JaCoCo · pytest-cov · Coverage thresholds', desc: 'Coverage gate enforced on every pull request. SonarCloud blocks merge on critical security issues. No manual exception process.' },
    { layer: 'Container Registry', tools: 'ECR · Image scanning · Deterministic tags · Immutable images', desc: 'Images tagged with the commit SHA — no latest tag in production. ECR vulnerability scanning runs on every push.' },
    { layer: 'Deployment', tools: 'ArgoCD · Helm · Rolling updates · maxUnavailable=0', desc: 'Zero-downtime rolling deployments via Kubernetes. ArgoCD syncs from Git — no kubectl apply in production.' },
    { layer: 'Authentication', tools: 'OIDC · GitHub Actions · AWS · No static credentials', desc: 'GitHub Actions authenticates to AWS via OIDC. No access keys stored anywhere. Credentials are issued per-run and expire automatically.' },
  ]}
  steps={[
    { step: '01', title: 'Pipeline audit', desc: 'Review the current release process, identify manual steps and measure deployment frequency and lead time.' },
    { step: '02', title: 'Pipeline design', desc: 'Define the stage sequence, quality gates and deployment strategy before writing a single workflow file.' },
    { step: '03', title: 'Incremental rollout', desc: 'Implement and validate one stage at a time. Quality gates are introduced as warnings before being enforced.' },
    { step: '04', title: 'Runbook and handover', desc: 'Document the pipeline, failure modes and rollback procedures. Run a walkthrough with the team before handover.' },
  ]}
  outcomes={[
    { metric: 'Deployments without manual steps', detail: 'commit to production is fully automated' },
    { metric: 'Quality gates enforced on every PR', detail: 'not discovered in production' },
    { metric: 'Zero static credentials in CI', detail: 'OIDC authentication throughout' },
    { metric: 'Rollback in under 5 minutes', detail: 'git revert triggers the same pipeline' },
    { metric: 'Full deployment audit trail', detail: 'every release tied to a commit and a timestamp' },
    { metric: 'Deployment frequency increased', detail: 'releases become routine, not risk events' },
  ]}
  ctaH2="Start with a pipeline review."
  ctaSubtitle="Bring your current release process. We identify manual steps, missing quality gates and credential exposure — and outline a path to automated delivery."
/>
