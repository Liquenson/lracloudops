---
import SolutionLayout from '../components/SolutionLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://lracloudops.com/es/devops-automation#service',
  name: 'DevOps Automation · CI/CD',
  serviceType: 'DevOps Automation',
  description:
    'Pipelines end-to-end que verifican tests, análisis de seguridad y puertas de política antes de llegar al clúster. Cada release es trazable. Cada rollback tarda un comando.',
  url: 'https://lracloudops.com/es/devops-automation',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: 'Worldwide',
  inLanguage: 'es-ES',
}
---

<SolutionLayout
  titulo="DevOps Automation · CI/CD Pipelines"
  descripcion="Pipelines end-to-end que verifican tests, análisis de seguridad y puertas de política antes de llegar al clúster. Cada release es trazable. Cada rollback tarda un comando."
  badgeLabel="03 · DevOps Automation"
  h1="Cada release trazable. Cada rollback en un comando."
  heroSubtitle="Los despliegues manuales producen incidentes de formas predecibles: pasos que divergen entre entornos, flags olvidados bajo presión, análisis de seguridad omitidos. La automatización no es comodidad — es la forma en que se eliminan las causas raíz de estos incidentes."
  schema={schema}
  sectionNumber="03"
  challenges={[
    {
      title: 'Pasos de despliegue que divergen',
      desc: 'El proceso de dev difiere del de staging que difiere del de prod. Los bugs que no aparecen en dev aparecen en prod porque los entornos no son equivalentes.',
    },
    {
      title: 'Análisis de seguridad opcionales',
      desc: 'Las revisiones de seguridad que requieren un paso manual separado se saltan bajo presión de tiempo. Las vulnerabilidades llegan a producción porque el proceso no las requiere explícitamente.',
    },
    {
      title: 'Credenciales estáticas en CI',
      desc: 'Las claves de acceso AWS en secretos de repositorio no expiran, se filtran en logs accidentalmente, y requieren rotación manual que rara vez ocurre.',
    },
    {
      title: 'Rollback no ensayado',
      desc: 'El procedimiento de rollback existe en un documento. No se ha probado. Falla durante el incidente que lo requiere porque tiene dependencias que nadie recordaba.',
    },
  ]}
  archTitle="El pipeline de entrega que construimos."
  archSubtitle="Puertas de calidad enforced. Sin credenciales estáticas. Rollback probado antes de llegar a producción."
  layers={[
    {
      layer: 'Puerta de Calidad de Código',
      tools: 'pytest · JUnit · SonarCloud · Cobertura ≥ 80%',
      desc: 'Tests unitarios e integración ejecutados en cada push. SonarCloud con umbral de cobertura mínima configurado como puerta de bloqueo — no como informe opcional.',
    },
    {
      layer: 'Análisis de Seguridad',
      tools: 'Trivy · OWASP Dependency Check · Hadolint · Semgrep',
      desc: 'Escaneo de vulnerabilidades de imagen Docker, dependencias y código fuente. Los findings de severidad alta bloquean el pipeline — no se envían por email para revisión manual.',
    },
    {
      layer: 'Construcción y Registro',
      tools: 'Docker · ECR · Multi-stage builds · Image signing',
      desc: 'Builds Docker multi-stage que producen imágenes mínimas. Push a ECR con firma de imagen. Las imágenes sin verificar de calidad nunca llegan al registro.',
    },
    {
      layer: 'Autenticación AWS',
      tools:
        'OIDC Federation · Roles IAM temporales · Sin acceso a larga duración',
      desc: 'GitHub Actions asume roles IAM via OIDC. Las credenciales expiran con el job. Sin AWS_ACCESS_KEY_ID en secretos de repositorio.',
    },
    {
      layer: 'Despliegue y Verificación',
      tools: 'Helm · kubectl · ECS update · Health checks post-deploy',
      desc: 'Despliegue via Helm o actualización de servicio ECS. Verificación de health checks post-despliegue. El pipeline no completa hasta confirmar que el servicio responde.',
    },
    {
      layer: 'Gestión de Rollback',
      tools: 'Task definition versionada · Helm history · ArgoCD rollback',
      desc: 'La definición de tarea anterior se guarda antes de cada despliegue. Rollback a cualquier versión anterior en un comando. El procedimiento está documentado y probado en dev antes de necesitarlo en prod.',
    },
  ]}
  steps={[
    {
      step: '01',
      title: 'Auditoría del proceso actual',
      desc: 'Documentamos cada paso del despliegue actual. Identificamos pasos manuales, análisis opcionales y puntos donde el proceso diverge entre entornos.',
    },
    {
      step: '02',
      title: 'Diseño del pipeline',
      desc: 'Diseñamos el pipeline con puertas secuenciales y verificaciones paralelas donde aplica. Cada puerta tiene criterios explícitos de éxito y fallo.',
    },
    {
      step: '03',
      title: 'Implementación e integración',
      desc: 'Pipeline implementado en GitHub Actions o Jenkins. OIDC configurado. Primer despliegue automatizado end-to-end verificado en dev.',
    },
    {
      step: '04',
      title: 'Ensayo de rollback',
      desc: 'El procedimiento de rollback se ensaya en dev antes de activar el pipeline en producción. Si el rollback falla en dev, no llegamos a prod.',
    },
  ]}
  outcomes={[
    {
      metric: 'Proceso idéntico en todos los entornos',
      detail: 'el mismo pipeline de dev a prod',
    },
    {
      metric: 'Análisis de seguridad enforced',
      detail: 'no omitibles, bloqueantes por diseño',
    },
    {
      metric: 'Cero credenciales estáticas',
      detail: 'OIDC en todos los pipelines',
    },
    {
      metric: 'Rollback probado',
      detail: 'verificado antes de necesitarlo en producción',
    },
    {
      metric: 'Cada deploy trazable',
      detail: 'commit → imagen → despliegue → validación',
    },
    {
      metric: 'Tiempo de despliegue reducido',
      detail: 'de horas a minutos con puertas automáticas',
    },
  ]}
  ctaH2="Automatiza tu proceso de entrega."
  ctaSubtitle="Trae tu proceso de despliegue actual y los requisitos de tu equipo. Diseñamos el pipeline que elimina los pasos manuales y garantiza que la calidad y la seguridad son enforced, no opcionales."
  backLabel="Volver a Soluciones"
  relatedSolutions={[
    { href: '/platform-engineering', label: 'Platform Engineering' },
    { href: '/cloud-infrastructure', label: 'Infraestructura Cloud' },
    { href: '/observability', label: 'Observabilidad & SRE' },
  ]}
/>
