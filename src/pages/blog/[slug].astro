---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('esBlog')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const projectLinks: Record<string, { name: string; slug: string }[]> = {
  'kubernetes-bare-metal-kubeadm': [
    { name: 'k8s-on-premise', slug: 'k8s-on-premise' },
    { name: 'k8s-devops-platform', slug: 'k8s-devops-platform' },
  ],
  'gitops-argocd-zero-manual-deploys': [
    { name: 'gitops-stack', slug: 'gitops-stack' },
    { name: 'k8s-devops-platform', slug: 'k8s-devops-platform' },
  ],
  'gitops-argocd-kubernetes': [
    { name: 'k8s-devops-platform', slug: 'k8s-devops-platform' },
    { name: 'gitops-stack', slug: 'gitops-stack' },
  ],
  'terraform-modular-6-projects-one-pattern': [
    { name: 'aws-terraform-devops', slug: 'aws-terraform-devops' },
    { name: 'gitops-stack', slug: 'gitops-stack' },
  ],
  'terraform-aws-produccion': [
    { name: 'aws-terraform-devops', slug: 'aws-terraform-devops' },
  ],
  'terraform-modulos-reutilizables': [
    { name: 'aws-terraform-devops', slug: 'aws-terraform-devops' },
    { name: 'gitops-stack', slug: 'gitops-stack' },
  ],
  'github-actions-pipeline': [
    { name: 'aws-terraform-devops', slug: 'aws-terraform-devops' },
    { name: 'gitops-stack', slug: 'gitops-stack' },
  ],
  'docker-best-practices': [
    { name: 'aws-terraform-devops', slug: 'aws-terraform-devops' },
    { name: 'linux-fleet-manager', slug: 'linux-fleet-manager' },
  ],
  'aws-devops-agent': [
    { name: 'aws-devops-agent', slug: 'aws-devops-agent' },
  ],
}
const relatedProjects = projectLinks[post.id] ?? []

const _bodyText = (post as any).body ?? ''
const _wordCount = _bodyText.trim().split(/\s+/).filter(Boolean).length
const readingTime = Math.max(1, Math.round(_wordCount / 200))
const publishedLabel = post.data.fecha.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
})

const postUrl = `https://lracloudops.com/blog/${post.id}`
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': `${postUrl}#article`,
  headline: post.data.titulo,
  description: post.data.descripcion,
  url: postUrl,
  datePublished: post.data.fecha.toISOString().split('T')[0],
  dateModified: post.data.fecha.toISOString().split('T')[0],
  author: {
    '@type': 'Person',
    name: 'Ruben Liquenson',
    url: 'https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/',
  },
  publisher: { '@id': 'https://lracloudops.com/#organization' },
  isPartOf: { '@id': 'https://lracloudops.com/#website' },
  keywords: post.data.tags.join(', '),
  inLanguage: 'es-ES',
  about: post.data.tags.map((tag: string) => ({ '@type': 'Thing', name: tag })),
}
---

<Layout
  titulo={post.data.titulo}
  descripcion={post.data.descripcion}
  schema={articleSchema}
>
  <!-- HEADER DEL ARTÍCULO -->
  <section style="background-color: #0A2540;" class="relative overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none opacity-40"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div class="relative max-w-4xl mx-auto px-6 py-16 sm:py-20">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-xs font-medium mb-8 transition-colors"
        style="color: rgba(147,184,255,0.7);"
        onmouseover="this.style.color='rgba(147,184,255,1)'"
        onmouseout="this.style.color='rgba(147,184,255,0.7)'"
      >
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Blog Técnico
      </a>
      <div class="flex flex-wrap gap-2 mb-5">
        {
          post.data.tags.map((tag) => (
            <span
              class="text-xs font-medium px-3 py-1.5 rounded-full"
              style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);"
            >
              {tag}
            </span>
          ))
        }
      </div>
      <h1
        class="text-3xl sm:text-4xl font-extrabold text-white mb-5"
        style="letter-spacing: -0.02em;"
      >
        {post.data.titulo}
      </h1>
      <p class="text-base mb-6" style="color: rgba(147,184,255,0.75);">
        {post.data.descripcion}
      </p>
      <p class="text-sm font-semibold" style="color: rgba(147,184,255,0.75);">
        Publicado el {publishedLabel} &middot; {readingTime} min de lectura
      </p>
    </div>
  </section>

  <!-- CONTENIDO -->
  <section class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-6">
      <div
        class="prose prose-gray max-w-none
        prose-headings:font-bold prose-headings:text-gray-900 prose-headings:tracking-tight
        prose-h2:text-2xl prose-h3:text-xl
        prose-p:text-gray-600 prose-p:leading-relaxed prose-p:text-base
        prose-a:text-[#1E6FFF] prose-a:no-underline hover:prose-a:underline
        prose-code:text-[#1E6FFF] prose-code:bg-[#EEF4FF] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:text-sm prose-code:font-medium prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-gray-950 prose-pre:text-gray-100 prose-pre:rounded-xl prose-pre:shadow-lg
        prose-li:text-gray-600
        prose-strong:text-gray-800 prose-strong:font-semibold
        prose-blockquote:border-[#1E6FFF] prose-blockquote:text-gray-600"
      >
        <Content />
      </div>

      <!-- Related projects -->
      {relatedProjects.length > 0 && (
        <div class="mt-12 pt-8 border-t border-gray-100">
          <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">Proyectos relacionados</h3>
          <div class="flex flex-wrap gap-3">
            {relatedProjects.map(({ name, slug }) => (
              <a
                href={`/projects/${slug}`}
                class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-xl transition-all hover:opacity-90"
                style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
              >
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
                {name} →
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Related services -->
      <div class="mt-8 pt-8 border-t border-gray-100">
        <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">
          Servicios relacionados
        </h3>
        <div class="flex flex-wrap gap-3">
          <a
            href="/cloud-infrastructure"
            class="inline-flex items-center text-sm font-medium px-4 py-2 rounded-xl transition-all hover:opacity-90"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
            >Infraestructura Cloud →</a
          >
          <a
            href="/devops-automation"
            class="inline-flex items-center text-sm font-medium px-4 py-2 rounded-xl transition-all hover:opacity-90"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
            >Automatización DevOps →</a
          >
          <a
            href="/platform-engineering"
            class="inline-flex items-center text-sm font-medium px-4 py-2 rounded-xl transition-all hover:opacity-90"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
            >Platform Engineering →</a
          >
        </div>
      </div>

      <!-- Footer del artículo -->
      <div class="mt-8 pt-8 border-t border-gray-100">
        <div
          class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
        >
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
            style="color: #64748b;"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver al Blog
          </a>
          <a
            href="/contacto"
            class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all hover:opacity-90"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
          >
            ¿Tienes preguntas? Contáctame
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
