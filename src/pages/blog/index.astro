---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('esBlog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf()
)
---

<Layout
  titulo="Blog Técnico · Infraestructura Cloud y Platform Engineering"
  descripcion="Artículos técnicos sobre AWS, Kubernetes, Terraform y CI/CD. Decisiones de arquitectura, estrategias de implementación y lecciones de producción."
>
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none opacity-40"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-2xl">
        <span
          class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6"
          style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);"
        >
          Blog · {posts.length} artículo{posts.length !== 1 ? 's' : ''}
        </span>
        <h1
          class="text-4xl sm:text-5xl font-extrabold text-white mb-5"
          style="letter-spacing: -0.02em;"
        >
          Notas de ingeniería.
        </h1>
        <p class="text-lg" style="color: rgba(147,184,255,0.8);">
          Decisiones de arquitectura, estrategias de implementación y lecciones
          aprendidas en producción.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-6">
      {
        posts.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-gray-400">Artículos próximamente.</p>
          </div>
        ) : (
          <div class="space-y-4">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                aria-label={`Leer artículo: ${post.data.titulo}`}
                class="group flex flex-col sm:flex-row sm:items-start justify-between gap-6 p-6 sm:p-7 rounded-2xl transition-all duration-200 block"
                style="background: white; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
                onmouseenter="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 10px 28px rgba(10,37,64,0.09)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.transform=''; this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';"
              >
                <div class="flex-1">
                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.data.tags.map((tag) => (
                      <span
                        class="text-xs font-medium px-2.5 py-1 rounded-full"
                        style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h2
                    class="text-lg font-bold mb-2 group-hover:text-[#1E6FFF] transition-colors"
                    style="color: #0A2540;"
                  >
                    {post.data.titulo}
                  </h2>
                  <p class="text-sm leading-relaxed" style="color: #64748b;">
                    {post.data.descripcion}
                  </p>
                </div>
                <div class="flex sm:flex-col items-center sm:items-end gap-4 flex-shrink-0">
                  <span
                    class="text-xs whitespace-nowrap"
                    style="color: #94a3b8;"
                  >
                    {post.data.fecha.toLocaleDateString('es-ES', {
                      day: 'numeric',
                      month: 'short',
                      year: 'numeric',
                    })}
                  </span>
                  <span
                    class="inline-flex items-center gap-1 text-xs font-semibold group-hover:gap-2 transition-all"
                    style="color: #1E6FFF;"
                  >
                    Leer
                    <svg
                      class="w-3.5 h-3.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- LEAD MAGNET -->
  <section class="bg-white pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <div
        class="rounded-2xl p-8 sm:p-10"
        style="background: linear-gradient(135deg, #0A2540 0%, #0f3460 100%); border: 1px solid rgba(30,111,255,0.3);"
      >
        <div class="flex flex-col sm:flex-row sm:items-center gap-6">
          <div class="flex-1">
            <span
              class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
              style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);"
            >
              Descarga gratuita
            </span>
            <h2 class="text-xl sm:text-2xl font-extrabold text-white mb-2" style="letter-spacing: -0.02em;">
              Checklist de Producción AWS — 47 verificaciones
            </h2>
            <p class="text-sm" style="color: rgba(147,184,255,0.8);">
              El mismo checklist que usamos en cada proyecto antes del go-live
            </p>
          </div>
          <form id="blog-lead-form" class="flex flex-col sm:flex-row gap-3 flex-shrink-0 w-full sm:w-auto">
            <input type="hidden" name="access_key" value="e8aaab4e-270c-4163-bb76-6a8dfc247485" />
            <input type="hidden" name="subject" value="Descarga Checklist AWS — lracloudops.com/blog" />
            <input
              type="email"
              name="email"
              required
              placeholder="tu@empresa.com"
              class="px-4 py-3 text-sm rounded-xl border outline-none transition-all"
              style="background: rgba(255,255,255,0.08); color: white; border-color: rgba(147,184,255,0.3); min-width: 220px;"
              onfocus="this.style.borderColor='#1E6FFF'; this.style.background='rgba(255,255,255,0.12)';"
              onblur="this.style.borderColor='rgba(147,184,255,0.3)'; this.style.background='rgba(255,255,255,0.08)';"
            />
            <button
              type="submit"
              id="blog-lead-btn"
              class="px-6 py-3 text-sm font-semibold text-white rounded-xl transition-all hover:-translate-y-px flex-shrink-0"
              style="background: #1E6FFF; box-shadow: 0 4px 16px rgba(30,111,255,0.4);"
            >
              Descargar gratis
            </button>
          </form>
          <p id="blog-lead-success" class="hidden text-sm font-medium" style="color: #86efac;">
            ✓ ¡Enviado! Revisa tu bandeja de entrada.
          </p>
        </div>
        <p class="text-xs mt-4" style="color: rgba(147,184,255,0.5);">
          Sin spam. Recibirás solo el checklist. Puedes darte de baja cuando quieras.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const blogForm = document.getElementById('blog-lead-form') as HTMLFormElement
  const blogBtn = document.getElementById('blog-lead-btn') as HTMLButtonElement
  const blogSuccess = document.getElementById('blog-lead-success') as HTMLParagraphElement

  blogForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    blogBtn.textContent = 'Enviando...'
    blogBtn.disabled = true
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(blogForm))),
      })
      const data = await res.json()
      if (data.success) {
        blogForm.style.display = 'none'
        blogSuccess.classList.remove('hidden')
      } else {
        blogBtn.textContent = 'Error — intenta de nuevo'
        blogBtn.disabled = false
      }
    } catch {
      blogBtn.textContent = 'Error — intenta de nuevo'
      blogBtn.disabled = false
    }
  })
</script>
