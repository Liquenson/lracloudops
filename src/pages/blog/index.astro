---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())

const categorias = ['Todos', 'AWS', 'Kubernetes', 'Terraform', 'Docker', 'CI/CD', 'AI+DevOps']
---

<Layout
  titulo="Blog Técnico"
  descripcion="Artículos sobre Cloud Operations, DevOps, Terraform, Kubernetes y CI/CD basados en proyectos reales de producción."
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-2xl">
        <span class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6" style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);">
          Blog · {posts.length} artículo{posts.length !== 1 ? 's' : ''}
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-5" style="letter-spacing: -0.02em;">Artículos técnicos</h1>
        <p class="text-lg" style="color: rgba(147,184,255,0.8);">
          Experiencias reales, no tutoriales genéricos. Todo lo que escribo viene de proyectos en producción.
        </p>
      </div>
    </div>
  </section>

  <!-- POSTS -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-6">

      <!-- Filtros por categoría -->
      <div class="flex flex-wrap gap-2 mb-10" id="filtros-blog">
        {categorias.map(cat => (
          <button
            data-categoria={cat}
            class={`filtro-btn text-xs font-semibold px-4 py-2 rounded-full border transition-all duration-150 ${cat === 'Todos' ? 'filtro-activo' : ''}`}
            style={cat === 'Todos'
              ? 'background: #0A2540; color: white; border-color: #0A2540;'
              : 'background: white; color: #64748b; border-color: #e2e8f0;'}
          >
            {cat}
          </button>
        ))}
      </div>

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-400">Próximamente nuevos artículos.</p>
        </div>
      ) : (
        <div class="space-y-4" id="lista-posts">
          {posts.map(post => (
            <a
              href={`/blog/${post.id}`}
              data-tags={post.data.tags.join(',')}
              class="post-card group flex flex-col sm:flex-row sm:items-start justify-between gap-6 p-6 sm:p-7 rounded-2xl border border-gray-100 hover:border-gray-200 hover:-translate-y-0.5 transition-all duration-200 block"
              style="background: #fafafa;"
            >
              <div class="flex-1">
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.map(tag => (
                    <span class="text-xs font-medium px-2.5 py-1 rounded-full" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">{tag}</span>
                  ))}
                </div>
                <h2 class="text-lg font-bold mb-2 group-hover:text-[#1E6FFF] transition-colors" style="color: #0A2540;">{post.data.titulo}</h2>
                <p class="text-sm leading-relaxed" style="color: #64748b;">{post.data.descripcion}</p>
              </div>
              <div class="flex sm:flex-col items-center sm:items-end gap-4 flex-shrink-0">
                <span class="text-xs whitespace-nowrap" style="color: #94a3b8;">
                  {post.data.fecha.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
                </span>
                <span class="inline-flex items-center gap-1 text-xs font-semibold group-hover:gap-2 transition-all" style="color: #1E6FFF;">
                  Leer
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}

      <!-- Mensaje sin resultados -->
      <div id="sin-resultados" class="hidden text-center py-16">
        <p class="text-sm" style="color: #64748b;">No hay artículos en esta categoría aún.</p>
      </div>

      <!-- CTA: Contacto -->
      <div class="mt-16 pt-12 border-t border-gray-100 text-center">
        <p class="text-sm mb-4" style="color: #64748b;">¿Tienes un tema que te gustaría que cubriera?</p>
        <a href="/contacto" class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3 rounded-xl transition-all hover:opacity-90" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
          Sugerir un tema
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  const botones = document.querySelectorAll<HTMLButtonElement>('.filtro-btn')
  const tarjetas = document.querySelectorAll<HTMLElement>('.post-card')
  const sinResultados = document.getElementById('sin-resultados')

  const categoriaATags: Record<string, string[]> = {
    'AWS': ['AWS'],
    'Kubernetes': ['Kubernetes'],
    'Terraform': ['Terraform'],
    'Docker': ['Docker'],
    'CI/CD': ['CI/CD'],
    'AI+DevOps': ['AI', 'Claude', 'Agentes'],
  }

  function filtrar(categoria: string) {
    let visibles = 0

    tarjetas.forEach(card => {
      const tags = (card.dataset.tags || '').split(',')
      let mostrar = false

      if (categoria === 'Todos') {
        mostrar = true
      } else {
        const tagsObjetivo = categoriaATags[categoria] || [categoria]
        mostrar = tagsObjetivo.some(t => tags.includes(t))
      }

      card.style.display = mostrar ? '' : 'none'
      if (mostrar) visibles++
    })

    if (sinResultados) {
      sinResultados.classList.toggle('hidden', visibles > 0)
    }
  }

  botones.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.categoria || 'Todos'

      botones.forEach(b => {
        const esActivo = b.dataset.categoria === cat
        b.style.background = esActivo ? '#0A2540' : 'white'
        b.style.color = esActivo ? 'white' : '#64748b'
        b.style.borderColor = esActivo ? '#0A2540' : '#e2e8f0'
      })

      filtrar(cat)
    })
  })
</script>
