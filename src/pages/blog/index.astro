---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

export const prerender = true
---

<Layout
  title="Engineering Notes — Ruben Liquenson"
  description="Technical articles on AWS, Kubernetes, Terraform, and GitOps by Ruben Liquenson."
  lang="en"
>
  <Header />

  <section class="bg-dark on-dark section-sm">
    <div class="container">
      <div class="eyebrow">Blog</div>
      <h1 style="color: #FFF; margin-bottom: 1rem;">Engineering Notes</h1>
      <p style="color: #94A3B8; max-width: 560px; font-size: 1.125rem;">
        Technical write-ups on AWS, Kubernetes, Terraform, and GitOps — from
        real infrastructure work.
      </p>
    </div>
  </section>

  <section class="bg-light section" style="text-align: center;">
    <div class="container">
      <p style="font-size: 1.125rem; color: var(--text-muted);">
        Coming soon — technical articles.
      </p>
      <div style="margin-top: 2rem;">
        <a href="/projects" class="btn btn-secondary btn-pill"
          >View projects instead →</a
        >
      </div>
    </div>
  </section>

  <Footer />
</Layout>
