---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
---
<Layout
  titulo="Blog"
  descripcion="Artículos técnicos sobre Cloud Operations, DevOps, Terraform, Kubernetes y CI/CD basados en experiencia real."
>
  <section class="max-w-5xl mx-auto px-6 py-24">
    <p class="text-xs font-medium text-teal-600 uppercase tracking-widest mb-3">Blog</p>
    <h1 class="text-4xl font-medium text-gray-900 mb-4">Artículos técnicos</h1>
    <p class="text-gray-400 max-w-xl mb-16">Experiencias reales, no tutoriales genéricos. Todo lo que escribo lo he aplicado en producción.</p>
    <div class="space-y-px">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="flex items-start justify-between py-6 border-b border-gray-100 hover:bg-gray-50 -mx-4 px-4 rounded-lg transition-colors group">
          <div class="flex-1 pr-8">
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.tags.map(tag => (
                <span class="text-xs bg-teal-50 text-teal-600 px-2 py-0.5 rounded">{tag}</span>
              ))}
            </div>
            <h2 class="text-lg font-medium text-gray-900 mb-2 group-hover:text-teal-600 transition-colors">{post.data.titulo}</h2>
            <p class="text-sm text-gray-400 leading-relaxed">{post.data.descripcion}</p>
          </div>
          <div class="text-xs text-gray-300 whitespace-nowrap mt-1">
            {post.data.fecha.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
