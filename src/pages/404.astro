---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Page not found">
  <div
    style="min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem;"
  >
    <div>
      <p
        style="font-family: var(--font-mono); font-size: 0.875rem; color: #0078D4; margin-bottom: 1rem;"
      >
        404
      </p>
      <h1 style="font-size: 2rem; margin-bottom: 1rem;">Page not found</h1>
      <p style="margin-bottom: 2rem;">
        The page you're looking for doesn't exist.
      </p>
      <a href="/" class="btn btn-primary btn-pill">← Back to home</a>
    </div>
  </div>
</Layout>
