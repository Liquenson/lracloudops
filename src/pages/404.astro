<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Page not found | LRA Cloud Ops</title>
    <meta
      name="description"
      content="The page you are looking for does not exist or has been moved."
    />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        height: 100%;
      }
      body {
        min-height: 100vh;
        background-color: #0a2540;
        background-image: radial-gradient(
          circle,
          rgba(96, 165, 250, 0.09) 1px,
          transparent 1px
        );
        background-size: 30px 30px;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 1.5rem;
        text-align: center;
      }
      a {
        text-decoration: none;
      }

      .logo-wrap {
        margin-bottom: 2.75rem;
      }
      .logo-wrap img {
        height: 36px;
        width: auto;
        filter: brightness(0) invert(1) opacity(0.85);
      }

      .error-code {
        font-size: clamp(5rem, 18vw, 8rem);
        font-weight: 800;
        color: #1e6fff;
        letter-spacing: -0.05em;
        line-height: 1;
        margin-bottom: 1.5rem;
        font-variant-numeric: tabular-nums;
      }

      .heading {
        font-size: clamp(1.375rem, 4vw, 1.875rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.025em;
        margin-bottom: 0.875rem;
      }

      .subtext {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8125rem;
        color: rgba(148, 163, 184, 0.65);
        max-width: 420px;
        line-height: 1.7;
        margin-bottom: 2.75rem;
      }

      .btn-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #2563eb;
        color: #ffffff;
        font-size: 0.875rem;
        font-weight: 600;
        padding: 0.875rem 1.75rem;
        border-radius: 0.75rem;
        box-shadow: 0 4px 20px rgba(37, 99, 235, 0.4);
        transition:
          transform 0.15s ease,
          opacity 0.15s ease;
      }
      .btn-primary:hover {
        opacity: 0.9;
        transform: translateY(-1px);
      }
      .btn-primary:active {
        transform: scale(0.98);
      }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        color: rgba(148, 163, 184, 0.85);
        font-size: 0.875rem;
        font-weight: 600;
        padding: 0.875rem 1.75rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(148, 163, 184, 0.2);
        transition:
          background 0.15s ease,
          border-color 0.15s ease,
          color 0.15s ease;
      }
      .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(148, 163, 184, 0.35);
        color: #ffffff;
      }

      .divider {
        width: 48px;
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
        margin: 3rem auto;
      }

      .footer-note {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6875rem;
        color: rgba(148, 163, 184, 0.22);
      }
    </style>
  </head>
  <body>
    <a href="/en/" class="logo-wrap" aria-label="LRA Cloud Ops — Home">
      <img
        src="/logo.svg"
        alt="LRA Cloud Ops"
        width="120"
        height="36"
        loading="eager"
      />
    </a>

    <p class="error-code" aria-label="Error 404">404</p>

    <h1 class="heading">This page does not exist.</h1>

    <p class="subtext">The requested path was not found on the server.</p>

    <div class="btn-group">
      <a href="/en/" class="btn-primary">
        <svg
          width="16"
          height="16"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to home
      </a>
      <a href="/en/services" class="btn-secondary">
        See services
        <svg
          width="16"
          height="16"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <div class="divider" aria-hidden="true"></div>

    <p class="footer-note">lracloudops.com &nbsp;·&nbsp; status 404</p>
  </body>
</html>
