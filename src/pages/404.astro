---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="404 — Page not found · LRA CloudOps"
  description="The page you're looking for doesn't exist or has been moved."
  lang="en"
>
  <section
    style="min-height: 70vh; display: flex; align-items: center; justify-content: center; background: #F8F9FA; padding: 2rem;"
  >
    <div style="text-align: center; max-width: 480px;">
      <p
        style="font-family: 'Red Hat Mono', monospace; font-size: 0.875rem; font-weight: 600; color: #1A73E8; margin-bottom: 1rem; letter-spacing: 0.06em;"
      >
        404
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: #202124; margin-bottom: 0.875rem; line-height: 1.2;"
      >
        Page not found
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 2rem;"
      >
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div
        style="display: flex; gap: 0.875rem; justify-content: center; flex-wrap: wrap;"
      >
        <a
          href="/"
          style="display: inline-flex; align-items: center; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
        >
          ← Back to home
        </a>
        <a
          href="/projects"
          style="display: inline-flex; align-items: center; background: transparent; color: #1A73E8; padding: 0.75rem 1.5rem; border-radius: 4px; border: 1px solid #DADCE0; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
        >
          View projects
        </a>
      </div>
    </div>
  </section>
</Layout>
