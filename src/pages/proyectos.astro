---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Arquitecturas de Referencia e Implementaciones de Plataforma"
  descripcion="Entornos AWS de producción, implementaciones de platform engineering y arquitecturas GitOps. Workloads reales, resultados documentados: pipeline de 45 min, cero deploys manuales, cluster K8s en 20 min."
>
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none opacity-40"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-3xl">
        <span
          class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6"
          style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);"
        >
          Implementaciones documentadas · Workloads de producción
        </span>
        <h1
          class="text-4xl sm:text-5xl font-extrabold text-white mb-5 animate-fade-left"
          style="letter-spacing: -0.02em;"
        >
          Arquitecturas de Referencia
        </h1>
        <p
          class="text-lg max-w-2xl animate-fade-up delay-200"
          style="color: rgba(147,184,255,0.8);"
        >
          Plataformas de producción, implementaciones GitOps y automatización de
          infraestructura. Workloads reales, no demos.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16" style="background: #f8fafc;">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          [
            {
              nombre: 'AWS Terraform DevOps Platform',
              madurez: 'Producción',
              categoria: 'Infraestructura Cloud',
              desc: 'Despliegues manuales de 3 semanas → pipeline automatizado de 45 minutos. Infraestructura AWS con Terraform modular: EKS 1.31 + RDS PostgreSQL 15 Multi-AZ + CI/CD dual (GitHub Actions + Jenkins) + gates SonarCloud. 100% automatizado, cero downtime.',
              impacto: { valor: '45 min', label: 'despliegue (antes: 3 semanas)' },
              slug: 'aws-terraform-devops',
              github: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
            },
            {
              nombre: 'GitOps Stack — CI/CD Platform',
              madurez: 'Producción',
              categoria: 'DevOps & GitOps',
              desc: 'kubectl apply manuales sin trazabilidad → cero deploys manuales en producción, cada cambio en Git. Pipeline GitOps sobre AWS EKS con Terraform + Jenkins + Ansible + CloudWatch. Commit a producción en menos de 8 minutos.',
              impacto: { valor: '0', label: 'deploys manuales en producción' },
              slug: 'gitops-stack',
              github: 'https://github.com/lra-cloud-ops/gitops-stack',
            },
            {
              nombre: 'Linux Fleet Manager',
              madurez: 'Producción',
              categoria: 'SRE & Automatización',
              desc: 'Gestión de flotas a escala sin agentes — solo SSH, cero agentes en hosts objetivo. 100% de scripts validados con ShellCheck en CI (Ubuntu, macOS, Windows). Diseño idempotente: operaciones de flota seguras para re-ejecutar sin efectos secundarios.',
              impacto: { valor: '0', label: 'agentes requeridos en hosts' },
              slug: 'linux-fleet-manager',
              github: 'https://github.com/lra-cloud-ops/linux-fleet-manager',
            },
            {
              nombre: 'Kubernetes GitOps Platform',
              madurez: 'Referencia',
              categoria: 'Kubernetes & GitOps',
              desc: 'Cero kubectl apply manuales en producción. ArgoCD entrega cada despliegue declarativamente desde Git — drifts corregidos automáticamente. KinD refleja producción exactamente, eliminando fallos de paridad local/producción. Prometheus + Grafana desde el día uno.',
              impacto: { valor: '0', label: 'kubectl apply manuales en producción' },
              slug: 'k8s-devops-platform',
              github: 'https://github.com/lra-cloud-ops/k8s-devops-platform',
            },
          ].map((p) => (
            <div
              class="bg-white rounded-2xl flex flex-col group hover:-translate-y-1 transition-all duration-200"
              style="border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.07); transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;"
              onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 10px 28px rgba(10,37,64,0.10)'; this.style.borderColor='rgba(30,111,255,0.2)';"
              onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.07)'; this.style.borderColor='#e8eef4';"
            >
              <div
                class="h-1 rounded-t-2xl"
                style={
                  p.madurez === 'Producción'
                    ? 'background: linear-gradient(90deg, #16a34a, #22c55e);'
                    : p.madurez === 'En desarrollo'
                      ? 'background: linear-gradient(90deg, #d97706, #f59e0b);'
                      : 'background: linear-gradient(90deg, #6b7280, #9ca3af);'
                }
              />
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center justify-between mb-3">
                  <span
                    class="text-xs font-semibold uppercase tracking-wider"
                    style="color: #94a3b8;"
                  >
                    {p.categoria}
                  </span>
                  <span
                    class="text-xs font-semibold px-2.5 py-1 rounded-full"
                    style={
                      p.madurez === 'Producción'
                        ? 'background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;'
                        : p.madurez === 'En desarrollo'
                          ? 'background:#fffbeb; color:#b45309; border:1px solid #fde68a;'
                          : 'background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb;'
                    }
                  >
                    {p.madurez}
                  </span>
                </div>

                <h2 class="text-base font-bold mb-2 group-hover:text-blue-700 transition-colors" style="color: #0A2540;">
                  {p.nombre}
                </h2>
                <p
                  class="text-sm leading-relaxed flex-1 mb-4"
                  style="color: #64748b;"
                >
                  {p.desc}
                </p>

                <!-- Impact metric chip -->
                <div
                  class="flex items-baseline gap-2 mb-4 px-4 py-3 rounded-xl"
                  style="background: #EEF4FF; border: 1px solid #c3d9ff;"
                >
                  <span class="text-2xl font-black" style="color: #1E6FFF; letter-spacing: -0.04em;">{p.impacto.valor}</span>
                  <span class="text-xs font-medium" style="color: #3b5bdb;">{p.impacto.label}</span>
                </div>

                <div class="flex items-center gap-2 pt-4 border-t border-gray-100">
                  <a
                    href={`/projects/${p.slug}`}
                    class="flex-1 inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-3 py-2 rounded-lg transition-all hover:-translate-y-px"
                    style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
                  >
                    Ver detalle →
                  </a>
                  {p.github && (
                    <a
                      href={p.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-8 h-8 flex items-center justify-center rounded-lg border border-gray-200 hover:border-gray-300 transition-colors"
                      style="color: #64748b;"
                      aria-label={`${p.nombre} en GitHub`}
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path
                          fill-rule="evenodd"
                          clip-rule="evenodd"
                          d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
