---
import Layout from '../layouts/Layout.astro'

const proyectos = [
  {
    nombre: "AWS Terraform DevOps",
    descripcion: "Infraestructura AWS production-ready con cluster EKS, autoscaling horizontal y RDS MySQL Multi-AZ gestionados 100% con Terraform modular. Pipeline completo con SonarCloud, cobertura ≥80% y despliegue automático via Helm. Incluye Jenkins + GitHub Actions en paralelo.",
    stack: ["Terraform", "AWS EKS", "RDS MySQL", "Docker", "GitHub Actions", "Jenkins", "Helm"],
    madurez: "Producción",
    cicd: true,
    github: "https://github.com/Liquenson/aws-terraform-devops",
    categoria: "Cloud & IaC",
    iconPath: "M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6",
    slug: "aws-terraform-devops",
  },
  {
    nombre: "TBF Cloud Infrastructure",
    descripcion: "Plataforma SaaS completa con backend Spring Boot 4, frontend React/Vite y toda la infraestructura AWS en Terraform modular. HTTPS con ACM, CloudFront CDN, ECS Fargate, RDS Multi-AZ y secretos gestionados en AWS Secrets Manager.",
    stack: ["Spring Boot 4", "React 18", "Terraform", "AWS ECS Fargate", "CloudFront", "PostgreSQL 15"],
    madurez: "Producción",
    cicd: true,
    github: null,
    categoria: "Full Stack + Cloud",
    iconPath: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    slug: "tbf-cloud-infrastructure",
  },
  {
    nombre: "Linux Fleet Manager",
    descripcion: "Framework de automatización Bash (v2.1.0) para gestionar flotas de servidores Linux a escala, generando inventarios en CSV y JSON. Pipeline CI/CD multi-plataforma con ShellCheck validado en Ubuntu, macOS y Windows.",
    stack: ["Bash 4.0+", "ShellCheck", "SSH", "CSV / JSON", "GitHub Actions"],
    madurez: "Producción",
    cicd: true,
    github: "https://github.com/Liquenson/linux-fleet-manager",
    categoria: "SRE & Automatización",
    iconPath: "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
    slug: "linux-fleet-manager",
  },
  {
    nombre: "Docker DevOps Platform",
    descripcion: "Plataforma backend containerizada con FastAPI y PostgreSQL 15 en Docker Compose multi-servicio con build multi-stage y usuario no-root. Demuestra best practices de containerización: health checks, retry logic y preparación para NGINX reverse proxy.",
    stack: ["Python 3.12", "FastAPI 0.115", "Uvicorn", "PostgreSQL 15", "Docker", "Docker Compose", "GitHub Actions"],
    madurez: "En Desarrollo",
    cicd: true,
    github: "https://github.com/Liquenson/docker-devops-platform",
    categoria: "Containerización",
    iconPath: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10",
    slug: "docker-devops-platform",
  },
  {
    nombre: "Kubernetes DevOps Platform",
    descripcion: "Plataforma GitOps sobre Kubernetes usando ArgoCD como controlador declarativo con GitHub como única fuente de verdad. Cluster local KinD con 3 nodos, sincronización automática, prune y selfHeal habilitados.",
    stack: ["Kubernetes 1.29", "ArgoCD", "KinD", "Docker", "Kustomize", "GitOps", "YAML"],
    madurez: "Demo",
    cicd: true,
    github: "https://github.com/Liquenson/k8s-devops-platform",
    categoria: "Kubernetes & GitOps",
    iconPath: "M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01",
    slug: "k8s-devops-platform",
  },
  {
    nombre: "Medical Appointment System",
    descripcion: "Plataforma web MVC de gestión de citas médicas con autenticación JDBC por roles (Admin, Doctor, Paciente) y verificación de email. Multi-perfil: H2 in-memory en local, PostgreSQL 15 en producción via Docker Compose.",
    stack: ["Java 17", "Spring Boot 3.2", "Spring Security 6", "Thymeleaf", "H2", "PostgreSQL 15", "Docker"],
    madurez: "En Desarrollo",
    cicd: true,
    github: "https://github.com/Liquenson/medical-appointment-system",
    categoria: "Backend & Web",
    iconPath: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
    slug: "medical-appointment-system",
  },
  {
    nombre: "AWS DevOps Agent",
    descripcion: "Agente CLI inteligente impulsado por Claude Sonnet 4.6 que permite monitorear y gestionar más de 25 servicios AWS mediante lenguaje natural. Integra auditoría de seguridad con GuardDuty, análisis de costos y gestión de EC2, S3, RDS, Lambda y EKS.",
    stack: ["Python", "Claude Sonnet 4.6", "boto3", "Anthropic SDK", "AWS"],
    madurez: "Demo",
    cicd: false,
    github: null,
    categoria: "AI + DevOps",
    iconPath: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    slug: "aws-devops-agent",
  },
  {
    nombre: "Python CI/CD Template",
    descripcion: "Template production-ready de API REST con Flask diseñado como punto de partida para microservicios Python con DevOps integrado desde el inicio. Pipeline completo: flake8, pytest con cobertura de código y verificación del contenedor Docker en CI.",
    stack: ["Python 3.11", "Flask 3.0.3", "pytest", "flake8", "Docker", "GitHub Actions"],
    madurez: "Template",
    cicd: true,
    github: "https://github.com/Liquenson/python-cicd-template",
    categoria: "Templates",
    iconPath: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
    slug: "python-cicd-template",
  },
  {
    nombre: "Spring Boot REST Template",
    descripcion: "Template production-ready de API REST con Spring Boot preconfigurado con seguridad, persistencia JPA y documentación Swagger automática. Genera imagen Docker sin Dockerfile mediante el plugin Jib de Maven.",
    stack: ["Java 8", "Spring Boot 2.7", "Spring Security", "Swagger", "MapStruct", "Jib", "JaCoCo"],
    madurez: "Template",
    cicd: false,
    github: "https://github.com/Liquenson/springboot-rest-template",
    categoria: "Templates",
    iconPath: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4",
    slug: "springboot-rest-template",
  },
  {
    nombre: "LRA Cloud Operations",
    descripcion: "Sitio web de portafolio y marketing para la marca LRA Cloud Operations con blog técnico sobre DevOps y cloud. Construido con Astro 6 + Tailwind CSS 4 y desplegado globalmente en Cloudflare Pages con CI/CD automático.",
    stack: ["Astro 6.2", "Tailwind CSS 4", "TypeScript", "Cloudflare Pages", "Content Collections"],
    madurez: "Producción",
    cicd: true,
    github: "https://github.com/Liquenson/lracloudops",
    categoria: "Frontend & Web",
    iconPath: "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9",
    slug: "lracloudops",
  },
]

function badgeStyle(madurez: string) {
  const map: Record<string, string> = {
    "Producción":    "background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;",
    "En Desarrollo": "background:#fffbeb; color:#b45309; border:1px solid #fde68a;",
    "Demo":          "background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb;",
    "Template":      "background:#EEF4FF; color:#1E6FFF; border:1px solid #c3d9ff;",
  }
  return map[madurez] ?? map["Demo"]
}

const produccion = proyectos.filter(p => p.madurez === "Producción")
const enDesarrollo = proyectos.filter(p => p.madurez === "En Desarrollo")
const demo = proyectos.filter(p => p.madurez === "Demo")
const templates = proyectos.filter(p => p.madurez === "Template")
---

<Layout
  titulo="Proyectos"
  descripcion="Portafolio DevOps y cloud: infraestructura AWS con Terraform, Kubernetes, Docker, CI/CD, Spring Boot, FastAPI y más."
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6" style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);">
          {proyectos.length} proyectos · Todos los niveles
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-5" style="letter-spacing: -0.02em;">Proyectos</h1>
        <p class="text-lg max-w-2xl" style="color: rgba(147,184,255,0.8);">
          Infraestructura en producción, automatización CI/CD y plataformas cloud modernas que reflejan prácticas utilizadas en entornos enterprise reales.
        </p>
      </div>
    </div>
  </section>

  <!-- LEYENDA -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-wrap gap-3 items-center">
      <span class="text-xs font-semibold uppercase tracking-widest mr-1" style="color: #94a3b8;">Estado:</span>
      {[
        { label: "Producción",    style: "background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;" },
        { label: "En Desarrollo", style: "background:#fffbeb; color:#b45309; border:1px solid #fde68a;" },
        { label: "Demo",          style: "background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb;" },
        { label: "Template",      style: "background:#EEF4FF; color:#1E6FFF; border:1px solid #c3d9ff;" },
      ].map(b => (
        <span class="text-xs font-medium px-3 py-1 rounded-full" style={b.style}>{b.label}</span>
      ))}
      <span class="hidden sm:block w-px h-4 bg-gray-200 mx-1"></span>
      <span class="inline-flex items-center gap-1.5 text-xs font-medium" style="color: #64748b;">
        <span class="w-2 h-2 rounded-full bg-green-400"></span>CI/CD activo
      </span>
    </div>
  </section>

  <!-- GRID DE PROYECTOS -->
  <section class="py-16" style="background: #f8fafc;">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Stats row -->
      <div class="flex flex-wrap gap-3 mb-10">
        {[
          { count: produccion.length, label: 'Producción' },
          { count: enDesarrollo.length, label: 'En Desarrollo' },
          { count: demo.length, label: 'Demo' },
          { count: templates.length, label: 'Templates' },
        ].map(({ count, label }) => (
          <div class="bg-white px-4 py-2.5 rounded-xl border border-gray-100 flex items-center gap-2">
            <span class="text-lg font-bold" style="color: #0A2540;">{count}</span>
            <span class="text-xs" style="color: #64748b;">{label}</span>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        {proyectos.map(p => (
          <div class="bg-white rounded-2xl flex flex-col group hover:-translate-y-0.5 transition-all duration-200" style="box-shadow: 0 2px 20px rgba(0,0,0,0.07); border: 1px solid #f1f5f9;">

            <!-- Card top bar accent -->
            <div class="h-1 rounded-t-2xl" style={
              p.madurez === 'Producción' ? 'background: linear-gradient(90deg, #16a34a, #22c55e);' :
              p.madurez === 'En Desarrollo' ? 'background: linear-gradient(90deg, #d97706, #f59e0b);' :
              p.madurez === 'Demo' ? 'background: linear-gradient(90deg, #6b7280, #9ca3af);' :
              'background: linear-gradient(90deg, #1E6FFF, #5B9BFF);'
            }></div>

            <div class="p-7 flex flex-col flex-1">
              <!-- Header -->
              <div class="flex items-start justify-between mb-5">
                <div class="w-11 h-11 flex items-center justify-center rounded-xl flex-shrink-0" style="background-color: #EEF4FF;">
                  <svg class="w-5 h-5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={p.iconPath} />
                  </svg>
                </div>
                <div class="flex flex-col items-end gap-1.5">
                  <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style={badgeStyle(p.madurez)}>
                    {p.madurez}
                  </span>
                  {p.cicd && (
                    <span class="inline-flex items-center gap-1 text-xs font-medium" style="color: #64748b;">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>CI/CD
                    </span>
                  )}
                </div>
              </div>

              <!-- Categoría -->
              <p class="text-xs font-semibold uppercase tracking-wider mb-1.5" style="color: #1E6FFF;">{p.categoria}</p>

              <!-- Título -->
              <h3 class="text-base font-bold mb-2.5" style="color: #0A2540;">{p.nombre}</h3>

              <!-- Descripción -->
              <p class="text-sm leading-relaxed mb-5 flex-1" style="color: #64748b;">{p.descripcion}</p>

              <!-- Stack tags -->
              <div class="flex flex-wrap gap-1.5 mb-5">
                {p.stack.map(tag => (
                  <span class="text-xs px-2.5 py-1 rounded-full" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0;">{tag}</span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100 mt-auto">
                {p.github ? (
                  <a
                    href={p.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-semibold transition-opacity hover:opacity-70"
                    style="color: #0A2540;"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                    </svg>
                    GitHub
                  </a>
                ) : (
                  <span class="inline-flex items-center gap-1.5 text-xs" style="color: #cbd5e1;">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    Privado
                  </span>
                )}
                {p.slug && (
                  <a href={`/projects/${p.slug}`} class="inline-flex items-center gap-1 text-xs font-semibold transition-colors" style="color: #1E6FFF;">
                    Case Study
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(30,111,255,0.12) 0%, transparent 70%);"></div>
    <div class="relative max-w-4xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" style="letter-spacing: -0.02em;">¿Tienes un proyecto en mente?</h2>
      <p class="mb-9 max-w-xl mx-auto text-base" style="color: rgba(147,184,255,0.8);">
        Puedo ayudarte a diseñar, implementar y automatizar la infraestructura cloud que tu negocio necesita.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02] hover:shadow-xl"
          style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 20px rgba(30,111,255,0.4);"
        >
          Diseñemos tu infraestructura
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/servicios"
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);"
        >
          Ver servicios
        </a>
      </div>
    </div>
  </section>

</Layout>
