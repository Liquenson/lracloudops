---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="Create your account — Platform"
  description="Sign up for Platform."
>
  <main class="auth-page">
    <a href="/" class="auth-logo">
      <img src="/lracloudops-icon.svg" alt="" width="32" height="32" />
      <span>Platform</span>
    </a>

    <div class="auth-card">
      <h2>Create your account</h2>

      <form class="auth-form">
        <div class="form-group">
          <label class="form-label" for="name">Name</label>
          <input
            class="input"
            type="text"
            id="name"
            name="name"
            placeholder="Jane Doe"
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input
            class="input"
            type="email"
            id="email"
            name="email"
            placeholder="you@company.com"
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input
            class="input"
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
          />
        </div>

        <button type="button" class="btn-primary-block">Create account</button>
      </form>

      <div class="auth-divider"><span>Or continue with</span></div>

      <div class="social-buttons">
        <button type="button" class="btn-social">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
          GitHub
        </button>
        <button type="button" class="btn-social">
          <svg width="18" height="18" viewBox="0 0 24 24">
            <path
              fill="#4285F4"
              d="M23.52 12.27c0-.85-.08-1.67-.22-2.46H12v4.66h6.47c-.28 1.5-1.13 2.78-2.4 3.63v3.02h3.89c2.27-2.09 3.58-5.17 3.58-8.85z"
            ></path>
            <path
              fill="#34A853"
              d="M12 24c3.24 0 5.96-1.07 7.95-2.9l-3.89-3.02c-1.08.72-2.45 1.15-4.06 1.15-3.12 0-5.77-2.11-6.72-4.94H1.27v3.11C3.25 21.3 7.31 24 12 24z"
            ></path>
            <path
              fill="#FBBC05"
              d="M5.28 14.29a7.2 7.2 0 010-4.58V6.6H1.27a12 12 0 000 10.8z"
            ></path>
            <path
              fill="#EA4335"
              d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.45-3.45C17.95 1.19 15.24 0 12 0 7.31 0 3.25 2.7 1.27 6.6l4.01 3.11C6.23 6.86 8.88 4.75 12 4.75z"
            ></path>
          </svg>
          Google
        </button>
      </div>

      <p class="auth-footer-text">
        Already have an account? <a href="/login">Sign in</a>
      </p>
    </div>

    <p class="auth-legal">
      By creating an account, you agree to our placeholder Terms of Service and
      Privacy Policy.
    </p>
  </main>
</Layout>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    background: #faf9f8;
    padding: 2rem 1rem;
  }
  .auth-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Red Hat Display', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #111827;
    text-decoration: none;
  }
  .auth-card {
    width: 100%;
    max-width: 420px;
    background: #ffffff;
    border: 1px solid #edebe9;
    border-radius: 8px;
    padding: 2rem;
  }
  .auth-card h2 {
    text-align: center;
    color: #111827;
    margin-bottom: 1.5rem;
  }
  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }
  .btn-primary-block {
    width: 100%;
    background: #0078d4;
    color: #ffffff;
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.75rem;
    border-radius: 6px;
    margin-top: 0.375rem;
    transition: background 150ms ease;
  }
  .btn-primary-block:hover {
    background: #106ebe;
  }
  .auth-divider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 1.5rem 0;
    color: #a19f9d;
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.8125rem;
  }
  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid #edebe9;
  }
  .auth-divider span {
    padding: 0 0.75rem;
  }
  .social-buttons {
    display: flex;
    gap: 0.75rem;
  }
  .btn-social {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem;
    border: 1px solid #edebe9;
    border-radius: 6px;
    background: #ffffff;
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    transition: background 150ms ease;
  }
  .btn-social:hover {
    background: #faf9f8;
  }
  .auth-footer-text {
    text-align: center;
    margin-top: 1.5rem;
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.875rem;
    color: #6b7280;
  }
  .auth-footer-text a {
    color: #0078d4;
    font-weight: 600;
    text-decoration: none;
  }
  .auth-legal {
    max-width: 420px;
    text-align: center;
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.75rem;
    color: #a19f9d;
    line-height: 1.6;
  }
</style>
