---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { getTranslations } from '../../i18n/index'

const t = await getTranslations('fr')
const allProjects = await getCollection('projects', ({ data }) => !data.draft)
const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3)
---

<Layout
  titulo={t.site?.tagline ?? 'Platform Engineering pour les infrastructures critiques.'}
  descripcion={t.hero?.subtitle ?? 'Nous concevons, automatisons et opérons des plateformes cloud-natives sur AWS.'}
>
  <!-- HERO -->
  <section class="relative overflow-hidden hero-gradient" aria-labelledby="hero-heading">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background-image: radial-gradient(circle, rgba(96,165,250,0.14) 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse 90% 60% at 50% 115%, rgba(37,99,235,0.22) 0%, transparent 65%);"></div>
    <div class="relative max-w-7xl mx-auto px-5 sm:px-6 py-14 sm:py-24 lg:py-32 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center">
      <div class="animate-fade-left">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full mb-8 text-xs font-semibold" style="background: rgba(37,99,235,0.15); border: 1px solid rgba(96,165,250,0.3); color: #93C5FD;">
          <span class="w-2 h-2 rounded-full bg-blue-400 flex-shrink-0 animate-pulse-soft" aria-hidden="true"></span>
          {t.hero?.badge}
        </div>
        <h1 id="hero-heading" class="text-[34px] sm:text-[52px] lg:text-[62px] font-extrabold text-white leading-[1.04] mb-7" style="letter-spacing: -0.035em;">
          {t.hero?.title}<br />{t.hero?.title2}<br />
          <span style="color: #60A5FA;">{t.hero?.title3}</span>
        </h1>
        <p class="text-lg sm:text-xl leading-relaxed mb-8 max-w-[520px]" style="color: rgba(148,163,184,0.85);">{t.hero?.subtitle}</p>
        <div class="flex flex-wrap gap-4 mb-10">
          <a href="/contact" class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02]" style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.45);">
            {t.hero?.cta_primary}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/projects" class="inline-flex items-center gap-2.5 text-sm font-semibold px-7 py-4 rounded-xl border transition-all hover:bg-white/10" style="color: rgba(148,163,184,0.9); border-color: rgba(148,163,184,0.25);">
            {t.hero?.cta_secondary}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <p style="font-size: 0.875rem; color: rgba(255,255,255,0.7); margin-bottom: 0.75rem;">{t.hero?.trust}</p>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
          {[t.hero?.response, t.hero?.no_lock].filter(Boolean).map(item => (
            <span class="flex items-center gap-1.5 text-xs font-medium" style="color: rgba(148,163,184,0.65);">
              <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: #60A5FA;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              {item}
            </span>
          ))}
        </div>
      </div>
      <div class="relative flex justify-center lg:justify-end animate-fade-up delay-200">
        <div class="relative w-full max-w-[510px]">
          <div class="absolute -inset-6 rounded-3xl pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.25) 0%, transparent 70%); filter: blur(24px);"></div>
          <div class="relative rounded-2xl overflow-hidden" style="background: #0d1117; border: 1px solid rgba(255,255,255,0.09); box-shadow: 0 40px 80px rgba(0,0,0,0.55);">
            <div class="flex items-center gap-2 px-4 py-3.5" style="background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.07);">
              <div class="w-3 h-3 rounded-full" style="background: #FF5F57;"></div>
              <div class="w-3 h-3 rounded-full" style="background: #FEBC2E;"></div>
              <div class="w-3 h-3 rounded-full" style="background: #28C840;"></div>
              <div class="flex-1 text-center"><span class="text-xs font-mono" style="color: rgba(255,255,255,0.25);">aws-production · main</span></div>
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              <span class="text-xs font-mono" style="color: rgba(255,255,255,0.25);">live</span>
            </div>
            <div class="p-5 font-mono text-xs sm:text-sm leading-relaxed space-y-1">
              <div class="flex items-center gap-2"><span style="color: #79C0FF;">❯</span><span class="text-white">terraform apply --auto-approve</span></div>
              <div class="mt-2 text-[0.68rem]" style="color: rgba(255,255,255,0.35);">Plan: 14 to add, 0 to change, 0 to destroy.</div>
              <div class="space-y-0.5 mt-2">
                {[['aws_vpc.main', '6s'],['aws_eks_cluster.main', '2m 18s'],['aws_rds_cluster.db', '1m 44s'],['module.alb.aws_lb.main', '52s']].map(([res, time]) => (
                  <div class="text-xs"><span style="color: #3FB950;">✓</span> <span style="color: rgba(255,255,255,0.5);">{res}</span> <span style="color: rgba(255,255,255,0.22);">({time})</span></div>
                ))}
              </div>
              <div class="mt-2.5 text-xs font-semibold" style="color: #3FB950;">Apply complete! Resources: 14 added.</div>
            </div>
            <div class="px-5 pb-4 pt-2.5" style="border-top: 1px solid rgba(255,255,255,0.06);">
              <div class="flex items-center gap-0.5">
                {['Build', 'Test', 'Security', 'Docker', 'Deploy'].map((step, i) => (
                  <div class="flex items-center">
                    <div class="flex items-center gap-1 text-xs font-mono">
                      <span style="color: #3FB950;">✓</span>
                      <span style="color: rgba(255,255,255,0.4); font-size: 0.62rem;">{step}</span>
                    </div>
                    {i < 4 && <div class="w-4 h-px mx-1" style="background: rgba(63,185,80,0.3);"/>}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BADGE STRIP -->
  <section style="background: white; border-bottom: 1px solid #E2E8F0; padding: 12px 0;">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        <span class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full" style="background: #F5F0FF; color: #7B42BC; border: 1px solid #D6B9F5;">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
          {t.trust?.hashicorp}
        </span>
        <span class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full" style="background: #EFF8FF; color: #049FD9; border: 1px solid #BAE6FD;">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          {t.trust?.cisco}
        </span>
        <span class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full" style="background: #FFF5F5; color: #EE3124; border: 1px solid #FCA5A5;">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          {t.trust?.fortinet}
        </span>
        <a href="/certifications" class="text-xs font-semibold transition-colors hover:opacity-80" style="color: #1E6FFF;">{t.trust?.view_credentials}</a>
        <span class="hidden sm:block w-px h-4 bg-gray-200" aria-hidden="true"></span>
        <span class="text-xs font-medium" style="color: #64748b;">{t.trust?.oidc}</span>
        <span class="hidden sm:block w-px h-4 bg-gray-200" aria-hidden="true"></span>
        <span class="text-xs font-medium" style="color: #64748b;">{t.trust?.gdpr}</span>
      </div>
    </div>
  </section>

  <!-- TECH STRIP -->
  <section style="background: #F8FAFC; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB;">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <p class="text-center text-[11px] font-bold uppercase tracking-widest mb-12" style="color: #94A3B8;">{t.tech?.section_label}</p>
      <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-5 gap-5">
        {[
          { name: 'AWS', svgPath: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6' },
          { name: 'Terraform', svgPath: 'M12 2L2 7.5v9L12 21l10-4.5v-9z M2 7.5l10 5m0 0l10-5m-10 5v9' },
          { name: 'Kubernetes', svgPath: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
          { name: 'Docker', svgPath: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10' },
          { name: 'GitHub Actions', svgPath: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
          { name: 'Prometheus', svgPath: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
          { name: 'Grafana', svgPath: 'M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z' },
          { name: 'ArgoCD', svgPath: 'M6 3v12M18 9a3 3 0 100-6 3 3 0 000 6zM6 21a3 3 0 100-6 3 3 0 000 6zM18 9a9 9 0 01-9 9' },
          { name: 'Helm', svgPath: 'M12 3a9 9 0 100 18A9 9 0 0012 3zm0 0v3m0 12v3m9-9h-3M3 12h3m12.364-6.364l-2.121 2.121M8.757 15.243l-2.121 2.121m0-14.728l2.121 2.121M15.243 15.243l2.121 2.121M12 9a3 3 0 100 6 3 3 0 000-6z' },
          { name: 'Ansible', svgPath: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
        ].map(({ name, svgPath }) => (
          <div class="flex flex-col items-center gap-3 group cursor-default" title={name}>
            <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-white transition-all group-hover:shadow-md" style="border: 1px solid #E5E7EB;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7" style="color: rgba(15,23,42,0.45);" aria-hidden="true"><path d={svgPath} /></svg>
            </div>
            <span class="text-[11px] font-semibold text-center leading-tight" style="color: #64748B;">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- METRICS -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="text-center mb-14 animate-fade-up">
        <span class="section-label">{t.metrics?.section_label}</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-5 mb-4" style="color: #0F172A; letter-spacing: -0.025em;">{t.metrics?.title}</h2>
        <p class="text-lg max-w-xl mx-auto" style="color: #64748B;">{t.metrics?.subtitle}</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-px rounded-2xl overflow-hidden animate-fade-up" style="background: #E5E7EB;">
        {[
          { value: t.metrics?.projects_value ?? '4+', label: t.metrics?.projects_label ?? '', sub: t.metrics?.projects_sub ?? '' },
          { value: t.metrics?.engineers_value ?? '4', label: t.metrics?.engineers_label ?? '', sub: t.metrics?.engineers_sub ?? '' },
          { value: t.metrics?.iac_value ?? '100%', label: t.metrics?.iac_label ?? '', sub: t.metrics?.iac_sub ?? '' },
          { value: t.metrics?.years_value ?? '4+', label: t.metrics?.years_label ?? '', sub: t.metrics?.years_sub ?? '' },
          { value: t.metrics?.tech_value ?? '15+', label: t.metrics?.tech_label ?? '', sub: t.metrics?.tech_sub ?? '' },
          { value: t.metrics?.response_value ?? '24h', label: t.metrics?.response_label ?? '', sub: t.metrics?.response_sub ?? '' },
        ].map(({ value, label, sub }) => (
          <div class="flex flex-col items-center justify-center text-center px-6 py-12 bg-white hover:bg-blue-50 transition-colors cursor-default">
            <div class="text-3xl sm:text-4xl font-black mb-2 leading-none" style="color: #1E6FFF; letter-spacing: -0.04em;">{value}</div>
            <div class="text-sm font-bold mb-1" style="color: #0A2540;">{label}</div>
            <div class="text-xs" style="color: #94A3B8;">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section style="background: #F8FAFC; border-top: 1px solid #E5E7EB;">
    <div class="max-w-7xl mx-auto px-6 py-24">
      <div class="text-center mb-16 animate-fade-up">
        <span class="section-label">{t.services?.section_label}</span>
        <h2 class="text-4xl sm:text-5xl font-bold mt-5 mb-5" style="color: #0F172A; letter-spacing: -0.025em;">{t.services?.title}</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">{t.services?.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6', title: t.services?.cloud_infra_title ?? '', desc: t.services?.cloud_infra_desc ?? '', href: '/cloud-infrastructure' },
          { icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2', title: t.services?.kubernetes_title ?? '', desc: t.services?.kubernetes_desc ?? '', href: '/platform-engineering' },
          { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: t.services?.devops_title ?? '', desc: t.services?.devops_desc ?? '', href: '/devops-automation' },
          { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', title: t.services?.platform_title ?? '', desc: t.services?.platform_desc ?? '', href: '/platform-engineering' },
          { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: t.services?.observability_title ?? '', desc: t.services?.observability_desc ?? '', href: '/observability' },
          { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: t.services?.security_title ?? '', desc: t.services?.security_desc ?? '', href: '/services' },
        ].map(({ icon, title, desc, href }, i) => (
          <div class={`bg-white rounded-2xl p-8 flex flex-col card-lift animate-fade-up ${['delay-100','delay-200','delay-300','delay-100','delay-200','delay-300'][i]}`} style="border-left: 4px solid #1E6FFF; border-top: 1px solid #E5E7EB; border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06);">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-6 flex-shrink-0" style="background: #EFF6FF;" aria-hidden="true">
              <svg class="w-5 h-5" style="color: #2563EB;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon}/></svg>
            </div>
            <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed flex-1 mb-6" style="color: #64748B;">{desc}</p>
            <a href={href} class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors mt-auto" style="color: #2563EB;">
              {t.services?.learn_more}
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/services" class="inline-flex items-center gap-2 text-sm font-semibold px-7 py-3.5 rounded-xl border transition-all hover:bg-white" style="color: #0F172A; border-color: #D1D5DB; background: white;">
          {t.services?.view_all}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- PLATFORM ARCHITECTURE -->
  <section class="py-24 relative overflow-hidden" style="background: #0B1220;">
    <div class="absolute inset-0 pointer-events-none opacity-20" aria-hidden="true" style="background-image: radial-gradient(circle, rgba(96,165,250,0.15) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 animate-fade-up">
        <span class="inline-flex items-center text-[10px] font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5" style="background: rgba(37,99,235,0.18); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);">{t.arch?.section_label}</span>
        <h2 class="text-4xl sm:text-5xl font-bold text-white mt-2 mb-5" style="letter-spacing: -0.025em;">{t.arch?.title}<br />{t.arch?.title2}</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: rgba(148,163,184,0.8);">{t.arch?.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-left">
          <div class="space-y-0">
            {[
              { label: 'AWS', sub: 'Cloud Provider · Multi-AZ · 99.99% SLA', color: '#FF9900', icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6' },
              { label: 'Terraform', sub: 'Infrastructure as Code · Modular', color: '#7B42BC', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4' },
