---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Evaluación de Madurez DevOps | LRA Cloud Operations"
  descripcion="10 preguntas para entender el nivel de madurez de tu infraestructura y obtener recomendaciones personalizadas de nuestro equipo."
  keywords="evaluación madurez DevOps, auditoría infraestructura, Kubernetes, cloud readiness"
>
  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <span
        class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        Herramienta Gratuita
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Evaluación de Madurez DevOps
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        10 preguntas para entender la madurez de tu infraestructura y obtener
        recomendaciones personalizadas de nuestro equipo.
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.6);">
        IaC · CI/CD · Seguridad · Observabilidad · Kubernetes · GitOps
      </p>
    </div>
  </section>

  <!-- ─── ASSESSMENT WIDGET ─────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-6">
      <!-- Progress bar -->
      <div class="mb-10">
        <div class="flex items-center justify-between mb-2">
          <span
            class="text-xs font-semibold"
            style="color: #64748b;"
            id="progress-label">Pregunta 1 de 10</span
          >
          <span
            class="text-xs font-semibold"
            style="color: #1E6FFF;"
            id="score-display">Puntuación: 0 / 30</span
          >
        </div>
        <div
          class="h-2 rounded-full overflow-hidden"
          style="background: #e2e8f0;"
        >
          <div
            id="progress-bar"
            class="h-full rounded-full transition-all duration-500"
            style="width: 10%; background: linear-gradient(90deg, #1E6FFF, #60A5FA);"
          >
          </div>
        </div>
      </div>

      <!-- Question container -->
      <div id="question-container">
        <!-- Injected by JS -->
      </div>

      <!-- Result container -->
      <div id="result-container" class="hidden">
        <!-- Injected by JS -->
      </div>
    </div>
  </section>
</Layout>

<script>
  const questions = [
    {
      q: '¿Cómo gestionas la infraestructura?',
      options: [
        { label: 'CLI/Consola manual', pts: 0 },
        { label: 'Algunos scripts/plantillas', pts: 1 },
        { label: 'Terraform/CloudFormation', pts: 2 },
        { label: 'IaC completo con módulos y estado remoto', pts: 3 },
      ],
    },
    {
      q: '¿Con qué frecuencia despliegas a producción?',
      options: [
        { label: 'Mensual o menos', pts: 0 },
        { label: 'Semanal', pts: 1 },
        { label: 'Diario', pts: 2 },
        { label: 'Varias veces al día con rollback automático', pts: 3 },
      ],
    },
    {
      q: '¿Cómo gestionas secretos y credenciales?',
      options: [
        { label: 'Hardcodeados en el código', pts: 0 },
        { label: 'Variables de entorno', pts: 1 },
        { label: 'Secrets Manager / Vault', pts: 2 },
        { label: 'Federación OIDC — sin claves estáticas nunca', pts: 3 },
      ],
    },
    {
      q: '¿Cuál es tu madurez en CI/CD?',
      options: [
        { label: 'Despliegues manuales', pts: 0 },
        { label: 'CI básico con tests', pts: 1 },
        { label: 'CI/CD completo con quality gates', pts: 2 },
        { label: 'GitOps con ArgoCD, rollback automático', pts: 3 },
      ],
    },
    {
      q: '¿Cómo monitorizas tu infraestructura?',
      options: [
        { label: 'Sin monitorización', pts: 0 },
        { label: 'Métricas básicas de cloud', pts: 1 },
        { label: 'Prometheus + Grafana', pts: 2 },
        {
          label: 'Observabilidad completa — métricas, logs, trazas, alertas',
          pts: 3,
        },
      ],
    },
    {
      q: '¿Cómo gestionas Kubernetes?',
      options: [
        { label: 'No usamos Kubernetes', pts: 0 },
        { label: 'Despliegues manuales con kubectl', pts: 1 },
        { label: 'Helm charts con CI/CD', pts: 2 },
        { label: 'GitOps con ArgoCD, auto-sync, prune y selfHeal', pts: 3 },
      ],
    },
    {
      q: '¿Cómo manejas la seguridad en tu pipeline?',
      options: [
        { label: 'Sin escáner de seguridad', pts: 0 },
        { label: 'Escaneo básico de dependencias', pts: 1 },
        { label: 'SAST + escaneo de contenedores', pts: 2 },
        { label: 'DevSecOps completo con policy gates y SonarQube', pts: 3 },
      ],
    },
    {
      q: '¿Cuál es tu estrategia de recuperación ante desastres?',
      options: [
        { label: 'Sin estrategia formal', pts: 0 },
        { label: 'Backups manuales', pts: 1 },
        { label: 'Backups automatizados con RTO/RPO definidos', pts: 2 },
        {
          label: 'Multi-AZ con failover automático y runbooks probados',
          pts: 3,
        },
      ],
    },
    {
      q: '¿Cómo gestionas los costes cloud?',
      options: [
        { label: 'Sin gestión de costes', pts: 0 },
        { label: 'Revisión mensual', pts: 1 },
        { label: 'Estrategia de etiquetas + alertas de presupuesto', pts: 2 },
        { label: 'Práctica FinOps con automatización de optimización', pts: 3 },
      ],
    },
    {
      q: '¿Cómo documentas tu infraestructura?',
      options: [
        { label: 'Sin documentación', pts: 0 },
        { label: 'Archivos README básicos', pts: 1 },
        { label: 'Diagramas de arquitectura + runbooks', pts: 2 },
        { label: 'Documentación viva como código, autogenerada', pts: 3 },
      ],
    },
  ]

  const results = [
    {
      range: [0, 10],
      level: 'Etapa Inicial',
      badge: 'Alto Riesgo',
      badgeColor: '#EF4444',
      bg: '#FEF2F2',
      border: '#FECACA',
      text: 'Tu infraestructura depende en gran medida de procesos manuales. Esto genera riesgo significativo, entregas lentas y altos costes operativos. Recomendamos empezar con fundamentos IaC y automatización CI/CD básica.',
      cta: 'Reservar una evaluación gratuita de infraestructura →',
    },
    {
      range: [11, 18],
      level: 'Etapa en Desarrollo',
      badge: 'En Crecimiento',
      badgeColor: '#D97706',
      bg: '#FFFBEB',
      border: '#FDE68A',
      text: 'Tienes automatización en marcha pero quedan brechas críticas en seguridad, observabilidad y fiabilidad de despliegues. Enfócate en estandarizar tu pipeline e implementar gestión adecuada de secretos.',
      cta: 'Obtener una hoja de ruta de mejora personalizada →',
    },
    {
      range: [19, 25],
      level: 'Etapa Definida',
      badge: 'Base Sólida',
      badgeColor: '#2563EB',
      bg: '#EEF4FF',
      border: '#c3d9ff',
      text: 'Buen nivel de madurez. Tienes prácticas DevOps sólidas. Ahora enfócate en GitOps, observabilidad avanzada y automatización de seguridad para alcanzar la madurez plena de producción.',
      cta: 'Ver cómo podemos acelerar tu camino →',
    },
    {
      range: [26, 30],
      level: 'Etapa Optimizada',
      badge: 'Nivel Enterprise',
      badgeColor: '#15803D',
      bg: '#F0FDF4',
      border: '#BBF7D0',
      text: '¡Excelente! Operas a nivel enterprise con automatización, seguridad y prácticas de fiabilidad sólidas. Hablemos de ingeniería de plataformas avanzada y optimización FinOps.',
      cta: 'Hablar con nuestros ingenieros senior →',
    },
  ]

  let currentQ = 0
  let score = 0
  let answers: number[] = []

  const calUrl = 'https://cal.com/ruben-alexis-h6qkjk/30min'

  function letterOf(i: number) {
    return ['A', 'B', 'C', 'D'][i]
  }

  function renderQuestion() {
    const qc = document.getElementById('question-container')!
    const q = questions[currentQ]
    const pct = Math.round(((currentQ + 1) / questions.length) * 100)

    ;(
      document.getElementById('progress-label') as HTMLSpanElement
    ).textContent = `Pregunta ${currentQ + 1} de ${questions.length}`
    ;(document.getElementById('score-display') as HTMLSpanElement).textContent =
      `Puntuación: ${score} / 30`
    ;(document.getElementById('progress-bar') as HTMLDivElement).style.width =
      `${pct}%`

    qc.innerHTML = `
    <div class="rounded-2xl p-8 sm:p-10 animate-fade" style="border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 8px 32px rgba(10,37,64,0.09);">
      <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #94a3b8;">Pregunta ${currentQ + 1}</p>
      <h2 class="text-xl sm:text-2xl font-bold mb-8" style="color: #0A2540;">${q.q}</h2>
      <div class="space-y-3">
        ${q.options
          .map(
            (opt, i) => `
          <button
            class="option-btn w-full text-left flex items-center gap-4 px-5 py-4 rounded-xl border-2 transition-all hover:border-blue-400 hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-blue-400"
            style="border-color: #e2e8f0; background: white;"
            data-pts="${opt.pts}"
            data-idx="${i}"
          >
            <span class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0" style="background: #EEF4FF; color: #1E6FFF;">${letterOf(i)}</span>
            <span class="text-sm font-medium" style="color: #334155;">${opt.label}</span>
          </button>
        `
          )
          .join('')}
      </div>
    </div>
  `

    qc.querySelectorAll('.option-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const pts = parseInt((btn as HTMLElement).dataset.pts ?? '0')
        answers.push(pts)
        score += pts
        currentQ++
        if (currentQ < questions.length) {
          renderQuestion()
        } else {
          showResult()
        }
      })
    })
  }

  function showResult() {
    const qc = document.getElementById('question-container')!
    const rc = document.getElementById('result-container')!
    const pb = document.getElementById('progress-bar') as HTMLDivElement
    const pl = document.getElementById('progress-label') as HTMLSpanElement
    const sd = document.getElementById('score-display') as HTMLSpanElement

    qc.classList.add('hidden')
    rc.classList.remove('hidden')
    pb.style.width = '100%'
    pl.textContent = 'Evaluación completada'
    sd.textContent = `Puntuación final: ${score} / 30`

    const result = results.find(
      (r) => score >= r.range[0] && score <= r.range[1]
    )!
    const pct = Math.round((score / 30) * 100)

    rc.innerHTML = `
    <div class="rounded-2xl p-8 sm:p-10 text-center" style="background: ${result.bg}; border: 2px solid ${result.border};">
      <div class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-4" style="background: white; color: ${result.badgeColor}; border: 1px solid ${result.border};">
        ${result.badge}
      </div>
      <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style="color: #0A2540;">${result.level}</h2>
      <div class="text-5xl font-black mb-2" style="color: ${result.badgeColor};">${score}<span class="text-2xl font-bold text-gray-400">/30</span></div>
      <div class="text-sm mb-6" style="color: #64748b;">${pct}% puntuación de madurez</div>

      <div class="h-3 rounded-full overflow-hidden mb-8 mx-auto max-w-xs" style="background: rgba(0,0,0,0.08);">
        <div class="h-full rounded-full" style="width: ${pct}%; background: ${result.badgeColor};"></div>
      </div>

      <p class="text-base leading-relaxed mb-8 max-w-md mx-auto" style="color: #334155;">${result.text}</p>

      <div id="email-capture" style="margin: 1.5rem 0; padding: 1.5rem; background: #EEF4FF; border-radius: 12px; border: 1px solid #C7D7FD;">
        <p style="font-weight: 600; color: #0A2540; margin-bottom: 0.5rem;">Recibe tu plan de acción personalizado por email</p>
        <p style="font-size: 0.875rem; color: #64748b; margin-bottom: 1rem;">Te enviaremos una hoja de ruta detallada basada en tu puntuación. Sin spam.</p>
        <form id="assessment-email-form" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <input type="hidden" name="access_key" value="e8aaab4e-270c-4163-bb76-6a8dfc247485">
          <input type="hidden" name="subject" id="assessment-subject">
          <input type="hidden" name="assessment_score" id="assessment-score-field">
          <input type="hidden" name="assessment_level" id="assessment-level-field">
          <input type="email" name="email" placeholder="tu@empresa.com" required
            style="flex: 1; min-width: 200px; padding: 0.75rem 1rem; border: 1px solid #C7D7FD; border-radius: 8px; font-size: 0.875rem;">
          <button type="submit"
            style="padding: 0.75rem 1.5rem; background: #1E6FFF; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">
            Enviarme mi plan →
          </button>
        </form>
        <p id="email-success" style="display:none; color: #16a34a; font-size: 0.875rem; margin-top: 0.75rem;">✓ ¡Revisa tu bandeja de entrada! Te enviaremos tu plan en 24 horas.</p>
      </div>

      <a href="${calUrl}" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-bold text-white px-8 py-4 rounded-xl mb-4 transition-all hover:opacity-90 hover:-translate-y-px"
        style="background: #1E6FFF; box-shadow: 0 4px 16px rgba(30,111,255,0.35);">
        ${result.cta}
      </a>

      <div class="mt-6">
        <button id="retake-btn" class="text-sm font-semibold transition-colors hover:underline" style="color: #64748b;">
          Repetir Evaluación
        </button>
      </div>
    </div>

    <div class="mt-8 rounded-2xl p-6" style="background: #F8FAFC; border: 1px solid #e2e8f0;">
      <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">Tu respuesta por pregunta</h3>
      <div class="space-y-2">
        ${questions
          .map((q, i) => {
            const pts = answers[i] ?? 0
            const opt =
              q.options[q.options.findIndex((o) => o.pts === pts)] ??
              q.options[0]
            const color =
              pts === 3
                ? '#15803d'
                : pts === 2
                  ? '#2563EB'
                  : pts === 1
                    ? '#D97706'
                    : '#EF4444'
            return `
            <div class="flex items-center gap-3 text-xs">
              <span class="w-5 h-5 rounded-full flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0" style="background: ${color};">${pts}</span>
              <span style="color: #64748b;">${q.q}</span>
            </div>
          `
          })
          .join('')}
      </div>
    </div>
  `

    // Email capture setup
    const subjEl = document.getElementById(
      'assessment-subject'
    ) as HTMLInputElement
    const scoreEl2 = document.getElementById(
      'assessment-score-field'
    ) as HTMLInputElement
    const levelEl = document.getElementById(
      'assessment-level-field'
    ) as HTMLInputElement
    if (subjEl)
      subjEl.value = `Evaluación Madurez DevOps — Puntuación ${score}/30 (${result.level})`
    if (scoreEl2) scoreEl2.value = String(score)
    if (levelEl) levelEl.value = result.level
    const emailForm = document.getElementById(
      'assessment-email-form'
    ) as HTMLFormElement
    emailForm?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const fd = new FormData(emailForm)
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: fd,
        })
        if (res.ok) {
          emailForm.style.display = 'none'
          const ok = document.getElementById('email-success')
          if (ok) ok.style.display = 'block'
        }
      } catch {}
    })

    document.getElementById('retake-btn')?.addEventListener('click', () => {
      currentQ = 0
      score = 0
      answers = []
      qc.classList.remove('hidden')
      rc.classList.add('hidden')
      ;(document.getElementById('progress-bar') as HTMLDivElement).style.width =
        '10%'
      renderQuestion()
    })
  }

  renderQuestion()
</script>

<style>
  @keyframes fade {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade {
    animation: fade 0.25s ease forwards;
  }
</style>
