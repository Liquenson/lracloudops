---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---

<Layout
  title="lra-ai-platform — LRA CloudOps"
  description="Multi-agent platform for DevOps automation. 8 specialized agents, 14 live integrations, 9 workflows, Governance Engine with 5 RBAC levels."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <!-- HERO -->
  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <!-- Breadcrumb -->
      <div
        style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem;"
      >
        <a href="/" style="color: #5F6368; text-decoration: none;">Home</a>
        <span style="color: #DADCE0;">/</span>
        <a href="/projects" style="color: #5F6368; text-decoration: none;"
          >Projects</a
        >
        <span style="color: #DADCE0;">/</span>
        <span style="color: #202124; font-weight: 500;">lra-ai-platform</span>
      </div>

      <div
        style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;"
        class="hero-project-grid"
      >
        <div>
          <!-- Badge -->
          <div
            style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E6F4EA; color: #137333; padding: 0.25rem 0.75rem; border-radius: 4px; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;"
          >
            <span
              style="width: 6px; height: 6px; background: #137333; border-radius: 50%;"
            ></span>
            Active Development
          </div>

          <h1
            style="font-family: 'Red Hat Mono', monospace; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem; letter-spacing: -0.02em;"
          >
            lra-ai-platform
          </h1>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; line-height: 1.7; max-width: 620px; margin-bottom: 1.5rem;"
          >
            Multi-agent platform for DevOps and Platform Engineering. 8
            specialized agents execute real infrastructure operations across
            AWS, Kubernetes and Terraform — with a 5-level Governance Engine on
            every action.
          </p>

          <!-- Tags -->
          <div
            style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;"
          >
            {
              [
                'Python 3.11+',
                'FastAPI',
                'boto3',
                'Kubernetes',
                'Terraform',
                'Ansible',
                'Trivy',
                'Checkov',
              ].map((tag) => (
                <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.2rem 0.625rem; border-radius: 4px;">
                  {tag}
                </span>
              ))
            }
          </div>

          <!-- CTAs -->
          <div style="display: flex; gap: 0.875rem; flex-wrap: wrap;">
            <a
              href="https://github.com/lra-cloud-ops/lra-ai-platform"
              target="_blank"
              rel="noopener"
              style="display: inline-flex; align-items: center; gap: 0.5rem; background: #202124; color: #FFFFFF; padding: 0.625rem 1.25rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
              class="btn-premium"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                ></path></svg
              >
              View on GitHub
            </a>
            <a
              href="/contact"
              style="display: inline-flex; align-items: center; background: transparent; color: #1A73E8; padding: 0.625rem 1.25rem; border-radius: 4px; border: 1px solid #DADCE0; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
              class="btn-premium-outline"
            >
              Request demo
            </a>
          </div>
        </div>

        <!-- Stats -->
        <div
          style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; min-width: 240px;"
        >
          {
            [
              { value: '8', label: 'Agents' },
              { value: '14', label: 'Integrations' },
              { value: '9', label: 'Workflows' },
              { value: '33', label: 'Tests · 0.14s' },
            ].map(({ value, label }) => (
              <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1rem; text-align: center;">
                <div style="font-family: 'Red Hat Display', sans-serif; font-size: 2rem; font-weight: 900; color: #1A73E8; line-height: 1;">
                  {value}
                </div>
                <div style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368; margin-top: 0.25rem;">
                  {label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IT DOES -->
  <section
    style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
    data-animate="fade-up"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;"
        class="two-col-grid"
      >
        <div>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;"
          >
            What it does
          </p>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;"
          >
            8 agents. 14 integrations. One governance engine.
          </h2>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;"
          >
            lra-ai-platform routes intents to specialized agents via keyword
            matching. Each agent executes real tasks through live integrations —
            no mocks, no simulations. Every action passes through a 5-level RBAC
            engine before execution.
          </p>
          <div style="display: flex; flex-direction: column; gap: 0.625rem;">
            {
              [
                'lra scan — security audit on any GitHub repository',
                'infrastructure_review — multi-cloud AWS/Azure/GCP analysis',
                'security_review — Trivy + Checkov on every push',
                'pr_review — automated code review on pull requests',
                'documentation_update — README, ADR, Runbooks from code',
                'deploy_eks — full EKS deployment pipeline',
                'REST API at localhost:8000 — 13+ endpoints',
                'CLI: lra init · lra scan · lra review · lra run · lra status',
              ].map((item) => (
                <div style="display: flex; align-items: start; gap: 0.75rem;">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"
                  >
                    <path
                      d="M20 6L9 17l-5-5"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">
                    {item}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Terminal -->
        <div
          style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; line-height: 1.9; color: #5F6368;"
        >
          <div
            style="color: #9AA0A6; font-style: italic; margin-bottom: 0.75rem;"
          >
            # lra-ai-platform CLI
          </div>
          <div style="margin-bottom: 0.5rem;">
            <span style="color: #1A73E8; font-weight: 600;">$</span>
            <span style="color: #202124; font-weight: 500;">
              lra scan --github lra-cloud-ops/aws-terraform-devops</span
            >
          </div>
          <div style="margin-left: 1rem; color: #5F6368;">
            → Scanning repository...
          </div>
          <div
            style="margin-left: 1rem; color: #5F6368; margin-bottom: 0.5rem;"
          >
            → Running Trivy + Checkov...
          </div>
          <div style="margin-left: 1rem; color: #137333;">✓ Critical: 0</div>
          <div style="margin-left: 1rem; color: #137333;">
            ✓ Checkov: 47/50 passed
          </div>
          <div
            style="margin-left: 1rem; color: #F29900; margin-bottom: 0.75rem;"
          >
            ⚠ Medium: 2 → documented
          </div>
          <div style="margin-bottom: 0.5rem;">
            <span style="color: #1A73E8; font-weight: 600;">$</span>
            <span style="color: #202124; font-weight: 500;">
              lra review aws</span
            >
          </div>
          <div style="margin-left: 1rem; color: #137333;">
            ✓ EKS: healthy · 3 nodes
          </div>
          <div style="margin-left: 1rem; color: #137333;">
            ✓ RDS: running · 99.9%
          </div>
          <div
            style="margin-left: 1rem; color: #137333; margin-bottom: 0.75rem;"
          >
            ✓ ArgoCD: synced · 0 drift
          </div>
          <div style="margin-left: 1rem; color: #137333;">
            ✓ Completed in 4.2s
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8 AGENTS GRID -->
  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
    data-animate="fade-up"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Agents
      </p>
      <h2
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 2rem;"
      >
        8 specialized agents
      </h2>

      <div
        style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;"
        class="agents-grid"
        data-animate="stagger"
      >
        {
          [
            {
              name: 'Founder Agent',
              role: 'Creates GitHub repos, generates README, ARCHITECTURE, ROADMAP',
              tools: ['github'],
              color: '#1A73E8',
            },
            {
              name: 'Cloud Architect',
              role: 'Reviews AWS, Azure, GCP infrastructure and Well-Architected compliance',
              tools: ['aws', 'azure', 'gcp', 'github'],
              color: '#137333',
            },
            {
              name: 'DevOps Engineer',
              role: 'Executes Terraform, kubectl, Helm, Ansible operations',
              tools: ['terraform', 'kubernetes', 'ansible'],
              color: '#1A73E8',
            },
            {
              name: 'Security Engineer',
              role: 'Runs Trivy and Checkov scans on images, IaC, K8s, GitHub Actions',
              tools: ['trivy', 'checkov', 'github'],
              color: '#C5221F',
            },
            {
              name: 'SRE Agent',
              role: 'Configures Prometheus alerts, Grafana dashboards, CloudWatch alarms',
              tools: ['prometheus', 'grafana', 'cloudwatch'],
              color: '#137333',
            },
            {
              name: 'OpenShift Agent',
              role: 'Manages OpenShift projects, deployments, operators via oc CLI',
              tools: ['openshift', 'kubernetes'],
              color: '#C5221F',
            },
            {
              name: 'Documentation Agent',
              role: 'Generates README, ADR, Runbooks from code analysis',
              tools: ['github', 'local'],
              color: '#1A73E8',
            },
            {
              name: 'Reviewer Agent',
              role: 'Reviews PRs, analyzes code quality, posts GitHub comments',
              tools: ['github', 'trivy', 'checkov'],
              color: '#137333',
            },
          ].map((agent) => (
            <div
              style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.25rem;"
              class="card-premium"
              data-animate-child
            >
              <div
                style={`width: 8px; height: 8px; border-radius: 50%; background: ${agent.color}; margin-bottom: 0.875rem;`}
              />
              <h3 style="font-family: 'Red Hat Display', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #202124; margin-bottom: 0.5rem;">
                {agent.name}
              </h3>
              <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368; line-height: 1.5; margin-bottom: 0.875rem;">
                {agent.role}
              </p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.25rem;">
                {agent.tools.map((tool) => (
                  <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.6875rem; color: #5F6368; background: #F8F9FA; border: 1px solid #DADCE0; padding: 0.125rem 0.375rem; border-radius: 3px;">
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- GOVERNANCE ENGINE -->
  <section
    style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
    data-animate="fade-up"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Governance
      </p>
      <h2
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 0.5rem;"
      >
        5-level RBAC. Fail-safe by default.
      </h2>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;"
      >
        Every task passes through the Governance Engine before execution. Deny
        by default.
      </p>

      <div
        style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem;"
        class="governance-grid"
      >
        {
          [
            {
              level: '1',
              name: 'READ_ONLY',
              desc: 'List repos, read metrics',
              color: '#137333',
            },
            {
              level: '2',
              name: 'PROPOSE',
              desc: 'Create PRs, generate docs',
              color: '#1A73E8',
            },
            {
              level: '3',
              name: 'DEVELOPMENT',
              desc: 'Commits, deploy to dev',
              color: '#1A73E8',
            },
            {
              level: '4',
              name: 'PRODUCTION',
              desc: 'Deploy to prod',
              color: '#F29900',
            },
            {
              level: '5',
              name: 'ADMIN',
              desc: 'Modify agents and policies',
              color: '#C5221F',
            },
          ].map((level) => (
            <div
              style={`background: #F8F9FA; border: 1px solid #DADCE0; border-top: 3px solid ${level.color}; border-radius: 6px; padding: 1rem;`}
            >
              <div
                style={`font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 700; color: ${level.color}; margin-bottom: 0.375rem;`}
              >
                Level {level.level}
              </div>
              <div style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; font-weight: 700; color: #202124; margin-bottom: 0.25rem;">
                {level.name}
              </div>
              <div style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; color: #5F6368; line-height: 1.4;">
                {level.desc}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; text-align: center;"
    data-animate="fade-up"
  >
    <div style="max-width: 560px; margin: 0 auto;">
      <h2
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #202124; margin-bottom: 1rem;"
      >
        Explore the source code
      </h2>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem; line-height: 1.7;"
      >
        All code is public. Clone it, run it, evaluate it.
      </p>
      <div
        style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;"
      >
        <a
          href="https://github.com/lra-cloud-ops/lra-ai-platform"
          target="_blank"
          rel="noopener"
          style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
          class="btn-premium"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path></svg
          >
          View on GitHub →
        </a>
        <a
          href="/contact"
          style="display: inline-flex; align-items: center; background: transparent; color: #1A73E8; padding: 0.75rem 1.5rem; border-radius: 4px; border: 1px solid #DADCE0; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
          class="btn-premium-outline"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 1024px) {
    .agents-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    .governance-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }
  @media (max-width: 768px) {
    .hero-project-grid {
      grid-template-columns: 1fr !important;
    }
    .two-col-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
    .agents-grid {
      grid-template-columns: 1fr !important;
    }
    .governance-grid {
      grid-template-columns: 1fr 1fr !important;
    }
  }
</style>
