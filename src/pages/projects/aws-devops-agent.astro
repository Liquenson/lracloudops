---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---

<Layout
  title="aws-devops-agent — LRA CloudOps"
  description="CLI agent using an AI model in a real tool-use loop. 31 boto3 functions covering 24 AWS services. Ask in plain language."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <!-- HERO -->
  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem;"
      >
        <a href="/" style="color: #5F6368; text-decoration: none;">Home</a>
        <span style="color: #DADCE0;">/</span>
        <a href="/projects" style="color: #5F6368; text-decoration: none;"
          >Projects</a
        >
        <span style="color: #DADCE0;">/</span>
        <span style="color: #202124; font-weight: 500;">aws-devops-agent</span>
      </div>

      <div
        style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;"
        class="hero-project-grid"
      >
        <div>
          <div
            style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E8F0FE; color: #1A73E8; padding: 0.25rem 0.75rem; border-radius: 4px; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;"
          >
            PoC — Proof of Concept
          </div>

          <h1
            style="font-family: 'Red Hat Mono', monospace; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
          >
            aws-devops-agent
          </h1>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; line-height: 1.7; max-width: 620px; margin-bottom: 1.5rem;"
          >
            CLI agent using an AI model in a real tool-use loop. Ask about
            your AWS infrastructure in plain language. The AI agent selects
            from 31 boto3 functions and executes against your live account.
          </p>

          <div
            style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;"
          >
            {
              [
                'Python 3.11+',
                'AI model',
                'boto3',
                'Anthropic SDK',
                'tool-use',
              ].map((tag) => (
                <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.2rem 0.625rem; border-radius: 4px;">
                  {tag}
                </span>
              ))
            }
          </div>

          <div style="display: flex; gap: 0.875rem; flex-wrap: wrap;">
            <a
              href="https://github.com/lra-cloud-ops/aws-devops-agent"
              target="_blank"
              rel="noopener"
              style="display: inline-flex; align-items: center; gap: 0.5rem; background: #202124; color: #FFFFFF; padding: 0.625rem 1.25rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
              class="btn-premium"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                ></path></svg
              >
              View on GitHub
            </a>
          </div>
        </div>

        <div
          style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; min-width: 240px;"
        >
          {
            [
              { value: '24', label: 'AWS Services' },
              { value: '31', label: 'boto3 Tools' },
              { value: '593', label: 'Lines of code' },
              { value: 'AI', label: 'Model' },
            ].map(({ value, label }) => (
              <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1rem; text-align: center;">
                <div style="font-family: 'Red Hat Display', sans-serif; font-size: 1.75rem; font-weight: 900; color: #1A73E8; line-height: 1;">
                  {value}
                </div>
                <div style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368; margin-top: 0.25rem;">
                  {label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section
    style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
    data-animate="fade-up"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;"
        class="two-col-grid"
      >
        <div>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;"
          >
            How it works
          </p>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;"
          >
            Ask. AI decides. AWS responds.
          </h2>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;"
          >
            You describe what you need in plain language. An AI model
            enters a tool-use loop — selecting the right boto3 function,
            executing it against your AWS account, and returning a structured
            response.
          </p>

          <div style="display: flex; flex-direction: column; gap: 1rem;">
            {
              [
                {
                  step: '01',
                  title: 'You ask',
                  desc: 'Write in plain Spanish or English. No CLI syntax required.',
                },
                {
                  step: '02',
                  title: 'AI selects',
                  desc: 'The model picks from 31 boto3-backed functions based on your intent.',
                },
                {
                  step: '03',
                  title: 'AWS executes',
                  desc: 'The function runs against your live account. Real data, real response.',
                },
              ].map(({ step, title, desc }) => (
                <div style="display: flex; gap: 1rem; align-items: start;">
                  <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 700; color: #1A73E8; background: #E8F0FE; padding: 0.25rem 0.5rem; border-radius: 4px; flex-shrink: 0; margin-top: 2px;">
                    {step}
                  </span>
                  <div>
                    <p style="font-family: 'Red Hat Display', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #202124; margin-bottom: 0.25rem;">
                      {title}
                    </p>
                    <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; line-height: 1.5;">
                      {desc}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Terminal -->
        <div
          style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; line-height: 1.9; color: #5F6368;"
        >
          <div
            style="color: #9AA0A6; font-style: italic; margin-bottom: 0.75rem;"
          >
            # aws-devops-agent · AI tool-use loop
          </div>
          <div style="margin-bottom: 0.75rem;">
            <span style="color: #5F6368;">You:</span>
            <span style="color: #202124; font-weight: 500;">
              What EC2 instances are running?</span
            >
          </div>
          <div style="margin-bottom: 0.25rem;">
            <span style="color: #1A73E8; font-weight: 600;">AI</span>
            <span style="color: #5F6368;"> → calling list_ec2_instances()</span>
          </div>
          <div
            style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; padding: 0.75rem; margin-bottom: 0.75rem;"
          >
            <div style="color: #137333;">
              i-0a1b2c3d · t3.medium · running · prod-api
            </div>
            <div style="color: #137333;">
              i-0e4f5a6b · t3.small · running · staging
            </div>
          </div>
          <div style="margin-bottom: 0.75rem;">
            <span style="color: #5F6368;">You:</span>
            <span style="color: #202124; font-weight: 500;">
              Any dangerous security groups?</span
            >
          </div>
          <div style="margin-bottom: 0.25rem;">
            <span style="color: #1A73E8; font-weight: 600;">AI</span>
            <span style="color: #5F6368;">
              → calling check_security_groups()</span
            >
          </div>
          <div
            style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; padding: 0.75rem;"
          >
            <div style="color: #137333;">✓ No critical 0.0.0.0/0 rules</div>
            <div style="color: #F29900;">⚠ sg-0a1b: port 22 open — review</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AWS SERVICES -->
  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
    data-animate="fade-up"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Coverage
      </p>
      <h2
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 2rem;"
      >
        24 AWS services
      </h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        {
          [
            'EC2',
            'S3',
            'RDS',
            'EKS',
            'ECS',
            'Lambda',
            'IAM',
            'SNS',
            'SQS',
            'CloudFormation',
            'Route53',
            'CloudWatch',
            'ALB/ELB',
            'ECR',
            'DynamoDB',
            'ElastiCache',
            'API Gateway',
            'CodePipeline',
            'CodeBuild',
            'CloudFront',
            'SSM',
            'EventBridge',
            'GuardDuty',
            'Cost Explorer',
          ].map((service) => (
            <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.375rem 0.75rem; border-radius: 4px;">
              {service}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section
    style="background: #FFFFFF; padding: 3rem 1.5rem; text-align: center;"
    data-animate="fade-up"
  >
    <div style="max-width: 560px; margin: 0 auto;">
      <h2
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #202124; margin-bottom: 1rem;"
      >
        Explore the source
      </h2>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;"
      >
        593 lines. One file. Real AI tool-use.
      </p>
      <a
        href="https://github.com/lra-cloud-ops/aws-devops-agent"
        target="_blank"
        rel="noopener"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; text-decoration: none;"
        class="btn-premium"
      >
        View on GitHub →
      </a>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 768px) {
    .hero-project-grid {
      grid-template-columns: 1fr !important;
    }
    .two-col-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
