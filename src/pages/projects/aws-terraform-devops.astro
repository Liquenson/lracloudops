---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import { getTagClass } from '../../lib/tagColors'
---

<Layout
  title="aws-terraform-devops — LRA CloudOps"
  description="Complete AWS infrastructure with 7 Terraform modules. EKS 1.31, RDS PostgreSQL 15, ECR, Flask app deployed via Helm. ArgoCD GitOps. SonarCloud quality gate."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <!-- HERO -->
  <section style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-family: var(--font-body); font-size: 0.875rem;">
        <a href="/" style="color: var(--color-text-secondary); text-decoration: none;">Home</a>
        <span style="color: #DADCE0;">/</span>
        <a href="/projects" style="color: var(--color-text-secondary); text-decoration: none;">Projects</a>
        <span style="color: #DADCE0;">/</span>
        <span style="color: var(--color-text); font-weight: 500;">aws-terraform-devops</span>
      </div>

      <div style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;" class="hero-project-grid">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-success-light); color: var(--color-success); padding: 0.25rem 0.75rem; border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;">
            <span style="width: 6px; height: 6px; background: #137333; border-radius: 50%;"></span>
            Active
          </div>

          <h1 style="font-family: var(--font-mono); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;">aws-terraform-devops<span style="font-family:var(--font-mono);font-size:0.75rem;font-weight:600;color:var(--color-success);background:var(--color-success-light);border:1px solid #137333;padding:0.25rem 0.75rem;border-radius:var(--radius-sm);margin-left:1rem;">Core Platform</span></h1>
          <p style="font-family: var(--font-body); font-size: 1.0625rem; color: var(--color-text-secondary); line-height: 1.7; max-width: 620px; margin-bottom: 1.5rem;">
            Production-ready AWS infrastructure with 7 Terraform modules. Multi-AZ VPC, EKS 1.31, RDS PostgreSQL 15, ECR registry. Flask app deployed via Helm, managed by ArgoCD, quality-gated by SonarCloud.
          </p>

          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;">
            {['Terraform', 'AWS EKS 1.31', 'RDS PostgreSQL 15', 'Helm', 'ArgoCD', 'GitHub Actions', 'Jenkins', 'SonarCloud'].map(tag => (
              <span class={getTagClass(tag)} style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-secondary); background: var(--color-bg); border: 1px solid var(--color-border); padding: 0.2rem 0.625rem; border-radius: var(--radius-sm);">{tag}</span>
            ))}
          </div>

          <div style="display: flex; gap: 0.875rem; flex-wrap: wrap;">
            <a href="https://github.com/lra-cloud-ops/aws-terraform-devops" target="_blank" rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem; background: #202124; color: #FFFFFF; padding: 0.625rem 1.25rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
              class="btn-premium"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              View on GitHub
            </a>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; min-width: 240px;">
          {[
            { value: '7', label: 'TF Modules' },
            { value: '26', label: 'TF Files' },
            { value: '18', label: 'Tests' },
            { value: '71', label: 'Commits' },
          ].map(({ value, label }) => (
            <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1rem; text-align: center;">
              <div style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-primary); line-height: 1;">{value}</div>
              <div style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-text-secondary); margin-top: 0.25rem;">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TERRAFORM MODULES -->
  <section style="background: var(--color-bg); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Infrastructure</p>
      <h2 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 2rem;">7 Terraform modules</h2>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem;" class="modules-grid" data-animate="stagger">
        {[
          { name: 'vpc', desc: 'Multi-AZ VPC, public/private subnets, NAT, IGW', detail: '10.0.0.0/16 · eu-west-1a/b/c' },
          { name: 'eks', desc: 'EKS 1.31 cluster with managed node groups', detail: 'Auto-scaling · t3.medium' },
          { name: 'rds', desc: 'RDS PostgreSQL 15, Multi-AZ, encrypted', detail: 'Automated backups · failover' },
          { name: 'ecr', desc: 'ECR registry with lifecycle policies', detail: 'Image scanning enabled' },
          { name: 'iam', desc: 'Roles and policies with least-privilege', detail: 'OIDC · service accounts' },
          { name: 'cloudwatch', desc: 'Metrics, logs, alarms and dashboards', detail: 'Container Insights enabled' },
          { name: 's3_bucket', desc: 'Terraform state backend, versioning', detail: 'DynamoDB lock table' },
        ].map(mod => (
          <div style="background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem;" class="card-premium" data-animate-child>
            <p style="font-family: var(--font-mono); font-size: 0.9375rem; font-weight: 700; color: var(--color-primary); margin-bottom: 0.5rem;">module.{mod.name}</p>
            <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.5; margin-bottom: 0.5rem;">{mod.desc}</p>
            <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted);">{mod.detail}</p>
          </div>
        ))}
      </div>

      <!-- Architecture flow -->
      <div style="background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-text-secondary); line-height: 2;">
        <div style="color: var(--color-text); font-weight: 600; margin-bottom: 0.5rem;">Deployment pipeline:</div>
        <div>GitHub push → <span style="color: var(--color-primary);">GitHub Actions</span> (lint + validate + plan) → <span style="color: var(--color-success);">SonarCloud</span> (quality gate) → <span style="color: var(--color-primary);">ECR</span> (image push) → <span style="color: var(--color-success);">ArgoCD</span> (sync to EKS)</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--color-bg-soft); padding: 3rem 1.5rem; text-align: center;" data-animate="fade-up">
    <div style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--color-text); margin-bottom: 1rem;">26 Terraform files. All public.</h2>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); margin-bottom: 2rem;">7 modules, 2 environments (dev/prod), full CI/CD.</p>
      <a href="https://github.com/lra-cloud-ops/aws-terraform-devops" target="_blank" rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-weight: 600; text-decoration: none;"
        class="btn-premium"
      >
        View on GitHub →
      </a>
    </div>
  </section>

  <!-- ECOSYSTEM -->
  <section style="background:var(--color-bg-soft);padding:3rem 1.5rem;border-top:1px solid #DADCE0;">
    <div style="max-width:1280px;margin:0 auto;">
      <p style="font-family:var(--font-body);font-size:0.75rem;font-weight:600;color:var(--color-primary);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.5rem;">Ecosystem</p>
      <h2 style="font-family:var(--font-display);font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:700;color:var(--color-text);margin-bottom:0.5rem;">Role in the platform</h2>
      <p style="font-family:var(--font-body);font-size:1rem;color:var(--color-text-secondary);margin-bottom:2rem;max-width:640px;">aws-terraform-devops is the infrastructure layer — it provisions the AWS environment that all other projects run on.</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="grid-2">
        {[
          { action:'Audited by', target:'lra-ai-platform', desc:'SecurityAgent scans this repo on every push via lra scan — Trivy + Checkov.', href:'/projects/lra-ai-platform' },
          { action:'Queried by', target:'aws-devops-agent', desc:'The AI agent reads EC2, EKS and RDS resources provisioned by these Terraform modules.', href:'/projects/aws-devops-agent' },
          { action:'Complements', target:'k8s-on-premise', desc:'Managed EKS vs bare-metal kubeadm — same GitOps patterns at different layers.', href:'/projects/k8s-on-premise' },
          { action:'Documented by', target:'lra-ai-platform', desc:'DocumentationAgent keeps architecture docs in sync with the Terraform codebase.', href:'/projects/lra-ai-platform' },
        ].map(({ action, target, desc, href }) => (
          <div style="background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:1.25rem;">
            <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
              <span style="font-family:var(--font-body);font-size:0.8125rem;color:var(--color-text-muted);">{action}</span>
              <a href={href} style="font-family:var(--font-mono);font-size:0.8125rem;font-weight:600;color:var(--color-primary);text-decoration:none;">{target} →</a>
            </div>
            <p style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);margin:0;line-height:1.6;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
@media (max-width: 1199px) {
  .modules-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
@media (max-width: 767px) {
  .hero-project-grid { grid-template-columns: 1fr !important; }
  .modules-grid { grid-template-columns: 1fr !important; }
}
</style>
