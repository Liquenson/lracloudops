---
import Layout from '../../layouts/Layout.astro'
import ArchitectureDiagram from '../../components/ArchitectureDiagram.astro'
---

<Layout
  titulo="AWS Landing Zone Architecture | LRA Cloud Operations"
  descripcion="Multi-account AWS Landing Zone architecture with Security Account, Shared Services and workload OUs. SCP guardrails, GuardDuty and centralized CloudTrail."
  keywords="AWS Landing Zone architecture, AWS multi-account strategy, AWS Organizations SCPs, AWS Control Tower, Terraform landing zone"
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-6xl mx-auto px-6 py-16 sm:py-20">
      <div class="flex items-center gap-2 text-xs mb-8" style="color: rgba(147,184,255,0.5);">
        <a href="/" class="hover:text-white transition-colors" style="color: rgba(147,184,255,0.5);">Home</a>
        <span>/</span>
        <a href="/architectures" class="hover:text-white transition-colors" style="color: rgba(147,184,255,0.5);">Architectures</a>
        <span>/</span>
        <span style="color: rgba(147,184,255,0.9);">AWS Landing Zone</span>
      </div>
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="text-xs font-semibold px-3 py-1.5 rounded-full" style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;">Production Tested</span>
        <span class="text-xs font-semibold px-3 py-1.5 rounded-full" style="background: rgba(255,153,0,0.15); color: #FF9900; border: 1px solid rgba(255,153,0,0.3);">AWS Organizations</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4" style="letter-spacing: -0.02em;">AWS Landing Zone</h1>
      <p class="text-lg max-w-2xl" style="color: rgba(147,184,255,0.8);">Multi-account AWS strategy for enterprise workloads. Security isolation, centralized logging and guardrails across all accounts.</p>
    </div>
  </section>

  <!-- MAIN -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Content -->
        <div class="lg:col-span-2 space-y-10">

          <!-- Overview -->
          <div>
            <h2 class="text-2xl font-bold mb-4" style="color: #0A2540;">Overview</h2>
            <p class="text-base leading-relaxed mb-4" style="color: #64748b;">A Landing Zone establishes a secure, well-architected multi-account AWS environment based on AWS best practices. This pattern eliminates the single-account anti-pattern that creates security and billing risks as organizations grow.</p>
            <p class="text-base leading-relaxed" style="color: #64748b;">Each workload environment (dev, staging, prod) lives in its own AWS account. Security tooling runs in a dedicated Security account. Shared networking and DNS live in a Shared Services account. AWS Organizations Service Control Policies enforce guardrails across the entire structure.</p>
          </div>

          <!-- Diagram -->
          <div>
            <h2 class="text-2xl font-bold mb-4" style="color: #0A2540;">Architecture Diagram</h2>
            <ArchitectureDiagram title="AWS Landing Zone — Account Structure" description="Multi-account hierarchy with Security, Shared Services and workload accounts managed through AWS Organizations." archId="landing-zone">
              <svg viewBox="0 0 720 420" xmlns="http://www.w3.org/2000/svg" class="w-full" style="min-width: 520px; font-family: Inter, system-ui, sans-serif;">
                <!-- Root Account -->
                <rect x="270" y="10" width="180" height="50" rx="8" fill="#0A2540" stroke="#1E6FFF" stroke-width="1.5"/>
                <text x="360" y="31" text-anchor="middle" fill="white" font-size="11" font-weight="700">Root Account</text>
                <text x="360" y="48" text-anchor="middle" fill="#93C5FD" font-size="9">Billing · Organizations · SCPs</text>

                <!-- Vertical line from Root -->
                <line x1="360" y1="60" x2="360" y2="90" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>

                <!-- Horizontal bar -->
                <line x1="100" y1="90" x2="620" y2="90" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>

                <!-- Security Account -->
                <line x1="100" y1="90" x2="100" y2="115" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>
                <rect x="20" y="115" width="160" height="60" rx="8" fill="#EE3124" fill-opacity="0.12" stroke="#EE3124" stroke-width="1.5"/>
                <text x="100" y="137" text-anchor="middle" fill="#0A2540" font-size="11" font-weight="700">Security Account</text>
                <text x="100" y="152" text-anchor="middle" fill="#64748b" font-size="9">CloudTrail · Config</text>
                <text x="100" y="165" text-anchor="middle" fill="#64748b" font-size="9">GuardDuty · Security Hub</text>

                <!-- Shared Services -->
                <line x1="280" y1="90" x2="280" y2="115" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>
                <rect x="200" y="115" width="160" height="60" rx="8" fill="#7B42BC" fill-opacity="0.1" stroke="#7B42BC" stroke-width="1.5"/>
                <text x="280" y="137" text-anchor="middle" fill="#0A2540" font-size="11" font-weight="700">Shared Services</text>
                <text x="280" y="152" text-anchor="middle" fill="#64748b" font-size="9">Route 53 · ACM</text>
                <text x="280" y="165" text-anchor="middle" fill="#64748b" font-size="9">Transit Gateway · Bastion</text>

                <!-- Dev OU -->
                <line x1="460" y1="90" x2="460" y2="115" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>
                <rect x="390" y="115" width="140" height="40" rx="8" fill="#EEF4FF" stroke="#1E6FFF" stroke-width="1.5"/>
                <text x="460" y="133" text-anchor="middle" fill="#0A2540" font-size="11" font-weight="700">Dev OU</text>
                <text x="460" y="147" text-anchor="middle" fill="#64748b" font-size="9">Development workloads</text>

                <!-- Dev Account -->
                <line x1="460" y1="155" x2="460" y2="175" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>
                <rect x="390" y="175" width="140" height="55" rx="8" fill="#EEF4FF" fill-opacity="0.5" stroke="#1E6FFF" stroke-width="1"/>
                <text x="460" y="195" text-anchor="middle" fill="#0A2540" font-size="10" font-weight="600">Dev Account</text>
                <text x="460" y="210" text-anchor="middle" fill="#64748b" font-size="9">VPC · EKS · RDS</text>
                <text x="460" y="222" text-anchor="middle" fill="#64748b" font-size="9">Single-AZ (cost optimised)</text>

                <!-- Prod OU -->
                <line x1="600" y1="90" x2="600" y2="115" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>
                <rect x="540" y="115" width="155" height="40" rx="8" fill="#EEF4FF" stroke="#1E6FFF" stroke-width="1.5"/>
                <text x="617" y="133" text-anchor="middle" fill="#0A2540" font-size="11" font-weight="700">Prod OU</text>
                <text x="617" y="147" text-anchor="middle" fill="#64748b" font-size="9">Production workloads</text>

                <!-- Prod Account -->
                <line x1="617" y1="155" x2="617" y2="175" stroke="#1E6FFF" stroke-width="1.5" stroke-dasharray="4,3"/>
                <rect x="540" y="175" width="155" height="55" rx="8" fill="#0A2540" fill-opacity="0.06" stroke="#0A2540" stroke-width="1.5"/>
                <text x="617" y="195" text-anchor="middle" fill="#0A2540" font-size="10" font-weight="700">Prod Account</text>
                <text x="617" y="210" text-anchor="middle" fill="#64748b" font-size="9">VPC · EKS · RDS Multi-AZ</text>
                <text x="617" y="222" text-anchor="middle" fill="#64748b" font-size="9">Deletion protection ON</text>

                <!-- SCP arrows -->
                <text x="360" y="290" text-anchor="middle" fill="#64748b" font-size="10">SCPs applied at OU level — inherited by all accounts</text>
                <rect x="140" y="300" width="440" height="28" rx="6" fill="none" stroke="#1E6FFF" stroke-width="1" stroke-dasharray="3,3"/>
                <text x="360" y="318" text-anchor="middle" fill="#1E6FFF" font-size="10" font-weight="600">Service Control Policies — deny root usage, enforce MFA, restrict regions</text>

                <!-- CloudTrail arrow -->
                <path d="M 180 145 Q 220 270 360 300" stroke="#EE3124" stroke-width="1" fill="none" stroke-dasharray="3,3" marker-end="url(#arrowRed)"/>
                <text x="240" y="245" fill="#EE3124" font-size="9">All API calls</text>

                <defs>
                  <marker id="arrowRed" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
                    <path d="M0,0 L0,6 L6,3 z" fill="#EE3124"/>
                  </marker>
                </defs>
              </svg>
            </ArchitectureDiagram>
          </div>

          <!-- Components -->
          <div>
            <h2 class="text-2xl font-bold mb-5" style="color: #0A2540;">Components</h2>
            <div class="space-y-4">
              {[
                { name: 'Root Account', detail: 'Billing consolidation, AWS Organizations management, SCP enforcement. No workloads run here. Root credentials locked away with MFA.', color: '#0A2540' },
                { name: 'Security Account', detail: 'Centralized CloudTrail for all accounts, AWS Config rules, GuardDuty findings aggregation, Security Hub. Read-only access to all other accounts for security auditing.', color: '#EE3124' },
                { name: 'Shared Services Account', detail: 'Route 53 hosted zones, AWS Certificate Manager, Transit Gateway hub. Shared NAT Gateway to reduce per-account NAT costs. Optional bastion host.', color: '#7B42BC' },
                { name: 'Workload Accounts', detail: 'One account per environment (dev, staging, prod). Isolated blast radius. VPC, EKS/ECS, RDS, S3 per account. SCPs restrict dangerous operations.', color: '#1E6FFF' },
              ].map(({ name, detail, color }) => (
                <div class="flex gap-4 p-5 rounded-xl" style="background: #F8FAFC; border: 1px solid #e2e8f0;">
                  <div class="w-2 rounded-full flex-shrink-0 mt-1" style={`background: ${color};`}></div>
                  <div>
                    <h3 class="text-sm font-bold mb-1" style="color: #0A2540;">{name}</h3>
                    <p class="text-sm leading-relaxed" style="color: #64748b;">{detail}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Trade-offs -->
          <div>
            <h2 class="text-2xl font-bold mb-5" style="color: #0A2540;">Trade-offs</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {[
                { label: 'Complexity', pro: 'Better security isolation and blast radius reduction', con: 'Higher operational overhead, more IAM to manage' },
                { label: 'Cost', pro: 'Free Tier applies per account, consolidated billing visibility', con: 'Transit Gateway data transfer charges, multiple NAT costs' },
                { label: 'Management', pro: 'SCPs centrally enforced, audit trail in one place', con: 'Requires AWS Organizations, Control Tower recommended' },
              ].map(({ label, pro, con }) => (
                <div class="p-5 rounded-xl" style="background: white; border: 1px solid #e2e8f0;">
                  <h4 class="text-sm font-bold mb-3" style="color: #0A2540;">{label}</h4>
                  <p class="text-xs leading-relaxed mb-2" style="color: #059669;">✅ {pro}</p>
                  <p class="text-xs leading-relaxed" style="color: #DC2626;">⚠️ {con}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Best Practices -->
          <div>
            <h2 class="text-2xl font-bold mb-5" style="color: #0A2540;">Best Practices</h2>
            <div class="space-y-3">
              {[
                'Never use root account for daily operations — lock the credentials and forget them',
                'Enable MFA on all IAM users, enforce via SCP',
                'Use AWS IAM Identity Center (SSO) for human access — no IAM users in workload accounts',
                'Automate account vending with AWS Control Tower Account Factory',
                'GuardDuty must be enabled in every account and every region you use',
                'Log everything to the Security account — S3 bucket with object lock for immutability',
              ].map(item => (
                <div class="flex items-start gap-3 p-4 rounded-xl" style="background: #F0FDF4; border: 1px solid #BBF7D0;">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #059669;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  <p class="text-sm leading-relaxed" style="color: #166534;">{item}</p>
                </div>
              ))}
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-5">
            <div class="rounded-2xl p-6" style="background: #F8FAFC; border: 1px solid #e2e8f0;">
              <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">Stack</h3>
              <div class="flex flex-wrap gap-1.5">
                {['AWS Organizations', 'SCPs', 'CloudTrail', 'Config', 'GuardDuty', 'Security Hub', 'Transit Gateway', 'Route 53', 'Terraform', 'Control Tower'].map(tag => (
                  <span class="text-xs px-2.5 py-1 rounded-full" style="background: white; color: #64748b; border: 1px solid #e2e8f0;">{tag}</span>
                ))}
              </div>
            </div>
            <div class="rounded-2xl p-6" style="background: #EEF4FF; border: 1px solid #c3d9ff;">
              <h3 class="text-sm font-bold mb-2" style="color: #0A2540;">Need this implemented?</h3>
              <p class="text-xs leading-relaxed mb-4" style="color: #64748b;">We implement Landing Zones with Terraform from scratch. Includes SCP design, Control Tower setup and account vending automation.</p>
              <a href="/contact" class="flex items-center justify-center gap-2 text-sm font-bold text-white py-3 rounded-xl hover:opacity-90 transition-opacity" style="background: #1E6FFF;">
                Start a conversation →
              </a>
            </div>
            <div class="rounded-2xl p-5" style="background: white; border: 1px solid #e2e8f0;">
              <h3 class="text-xs font-bold mb-3 uppercase tracking-wider" style="color: #94A3B8;">Related</h3>
              <div class="space-y-2">
                <a href="/architectures/eks-production-platform" class="block text-sm font-medium hover:opacity-70 transition-opacity" style="color: #1E6FFF;">EKS Production Platform →</a>
                <a href="/docs/terraform-standards" class="block text-sm font-medium hover:opacity-70 transition-opacity" style="color: #1E6FFF;">Terraform Standards →</a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  if (typeof window !== 'undefined' && (window as any).cf) {
    (window as any).cf.track('architecture_viewed', { architecture: 'aws-landing-zone' })
  }
</script>
