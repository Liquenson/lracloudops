---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Evaluación de Preparación Kubernetes | LRA Cloud Operations"
  descripcion="8 preguntas para evaluar si tu equipo y aplicación están listos para ejecutar Kubernetes en producción."
  keywords="evaluación preparación Kubernetes, K8s producción, adopción EKS, madurez Kubernetes, orquestación de contenedores"
>
  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <span
        class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        Herramienta Gratuita
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Evaluación de Preparación Kubernetes
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        ¿Está tu equipo listo para ejecutar Kubernetes en producción?
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.6);">
        8 preguntas &middot; 5 minutos &middot; Informe personalizado gratuito
      </p>
    </div>
  </section>

  <!-- ASSESSMENT -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-6">
      <div class="mb-10">
        <div class="flex items-center justify-between mb-2">
          <span
            class="text-xs font-semibold"
            style="color: #64748b;"
            id="progress-label">Pregunta 1 de 8</span
          >
          <span
            class="text-xs font-semibold"
            style="color: #326CE5;"
            id="score-display">Puntuación: 0 / 24</span
          >
        </div>
        <div
          class="h-2 rounded-full overflow-hidden"
          style="background: #e2e8f0;"
        >
          <div
            id="progress-bar"
            class="h-full rounded-full transition-all duration-500"
            style="width: 12.5%; background: linear-gradient(90deg, #326CE5, #60A5FA);"
          >
          </div>
        </div>
      </div>

      <div id="question-container"></div>
      <div id="result-container" class="hidden"></div>
    </div>
  </section>
</Layout>

<script>
  const CAL = 'https://cal.com/ruben-alexis-h6qkjk/30min'
  const questions = [
    {
      q: '¿Cuál es tu experiencia actual con contenedores?',
      options: [
        { label: 'Sin contenedores', pts: 0 },
        { label: 'Docker solo para desarrollo local', pts: 1 },
        { label: 'Docker en producción', pts: 2 },
        { label: 'Docker Compose o Swarm en producción', pts: 3 },
      ],
    },
    {
      q: '¿Cómo gestionas actualmente los despliegues?',
      options: [
        { label: 'Despliegues SSH manuales', pts: 0 },
        { label: 'Scripts o Ansible', pts: 1 },
        { label: 'CI/CD básico con Docker', pts: 2 },
        { label: 'GitOps o despliegues basados en Helm', pts: 3 },
      ],
    },
    {
      q: '¿Entiende tu equipo los conceptos de Kubernetes?',
      options: [
        { label: 'Sin conocimiento de Kubernetes', pts: 0 },
        { label: 'Familiarizado con conceptos básicos', pts: 1 },
        { label: 'Experiencia práctica con kubectl y manifests', pts: 2 },
        { label: 'Experiencia con Helm, RBAC y networking', pts: 3 },
      ],
    },
    {
      q: '¿Cómo gestionas la configuración de la aplicación?',
      options: [
        { label: 'Valores hardcodeados', pts: 0 },
        { label: 'Archivos de entorno', pts: 1 },
        { label: 'ConfigMaps y Secrets básicos', pts: 2 },
        { label: 'External Secrets Operator o integración con Vault', pts: 3 },
      ],
    },
    {
      q: '¿Cuál es tu complejidad de red?',
      options: [
        { label: 'Servicio único, sin routing necesario', pts: 0 },
        { label: 'Routing HTTP básico', pts: 1 },
        { label: 'Múltiples servicios con balanceo de carga', pts: 2 },
        { label: 'Multi-cluster, requisitos de service mesh', pts: 3 },
      ],
    },
    {
      q: '¿Cómo gestionas los requisitos de recursos?',
      options: [
        { label: 'Sin gestión de recursos', pts: 0 },
        { label: 'Solo estimaciones aproximadas', pts: 1 },
        { label: 'Límites básicos de CPU y memoria definidos', pts: 2 },
        { label: 'Requests/limits adecuados, VPA o KEDA configurado', pts: 3 },
      ],
    },
    {
      q: '¿Cuáles son tus requisitos de disponibilidad?',
      options: [
        { label: 'Downtime aceptable', pts: 0 },
        { label: 'Disponibilidad best effort', pts: 1 },
        { label: 'Objetivo SLA 99,9%', pts: 2 },
        { label: '99,95%+ con Multi-AZ y failover automático', pts: 3 },
      ],
    },
    {
      q: '¿Cómo planeas gestionar la seguridad?',
      options: [
        { label: 'Aún no considerado', pts: 0 },
        { label: 'RBAC básico', pts: 1 },
        { label: 'NetworkPolicies y SecurityContexts', pts: 2 },
        { label: 'Políticas OPA/Kyverno, pod security standards', pts: 3 },
      ],
    },
  ]

  const results = [
    {
      range: [0, 8],
      title: 'No preparado — Empezar con Docker',
      desc: 'Enfócate primero en contenedorizar tu aplicación. Kubernetes añade complejidad operativa — domina Docker antes de pasar a orquestación.',
      cta: 'Empezar con nuestra implementación Docker + CI/CD',
      color: '#DC2626',
      bg: '#FEF2F2',
      border: '#FECACA',
    },
    {
      range: [9, 16],
      title: 'Fase de aprendizaje — Buen progreso',
      desc: 'Tienes la base. Empieza con un servicio Kubernetes gestionado como EKS y workloads simples antes de añadir complejidad.',
      cta: 'Obtener una hoja de ruta de adopción Kubernetes',
      color: '#D97706',
      bg: '#FFFBEB',
      border: '#FDE68A',
    },
    {
      range: [17, 22],
      title: 'Casi preparado — Refina tu enfoque',
      desc: 'Base sólida. Aborda seguridad y gestión de recursos antes de producción. Considera GitOps para automatización de despliegues.',
      cta: 'Programar una revisión de arquitectura Kubernetes',
      color: '#326CE5',
      bg: '#EEF4FF',
      border: '#C7D7FD',
    },
    {
      range: [23, 24],
      title: 'Listo para Kubernetes — Nivel producción',
      desc: 'Tu equipo y aplicación están listos para Kubernetes en producción. Hablemos de GitOps avanzado, service mesh y multi-cluster.',
      cta: 'Hablar con nuestros especialistas en Kubernetes',
      color: '#059669',
      bg: '#F0FDF4',
      border: '#BBF7D0',
    },
  ]

  let current = 0,
    score = 0
  const total = questions.length,
    maxScore = total * 3

  function render() {
    const el = (id: string) => document.getElementById(id)!
    el('progress-label').textContent = `Pregunta ${current + 1} de ${total}`
    el('score-display').textContent = `Puntuación: ${score} / ${maxScore}`
    ;(el('progress-bar') as HTMLElement).style.width =
      `${(current / total) * 100}%`
    const q = questions[current]
    el('question-container').innerHTML = `
    <div class="bg-white rounded-2xl p-8" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(10,37,64,0.04),0 4px 16px rgba(10,37,64,0.06);">
      <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color:#326CE5;">Pregunta ${current + 1} de ${total}</p>
      <h2 class="text-xl font-bold mb-7" style="color:#0A2540;letter-spacing:-0.01em;">${q.q}</h2>
      <div class="space-y-3">${q.options
        .map(
          (opt, i) => `
        <button onclick="selectAnswer(${opt.pts})" class="w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all hover:-translate-y-0.5"
          style="background:#F8FAFC;border:1.5px solid #e2e8f0;color:#0A2540;"
          onmouseover="this.style.borderColor='#326CE5';this.style.background='#EEF4FF';"
          onmouseout="this.style.borderColor='#e2e8f0';this.style.background='#F8FAFC';">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold mr-3" style="background:#EEF4FF;color:#326CE5;">${'ABCD'[i]}</span>${opt.label}
        </button>`
        )
        .join('')}
      </div>
    </div>`
  }

  function selectAnswer(pts: number) {
    score += pts
    current++
    if (current < total) {
      render()
    } else {
      showResult()
    }
  }

  function showResult() {
    const el = (id: string) => document.getElementById(id)!
    ;(el('progress-bar') as HTMLElement).style.width = '100%'
    el('progress-label').textContent = 'Evaluación completada'
    el('score-display').textContent = `Puntuación final: ${score} / ${maxScore}`
    const r =
      results.find((x) => score >= x.range[0] && score <= x.range[1]) ??
      results[0]
    const pct = Math.round((score / maxScore) * 100)
    el('question-container').classList.add('hidden')
    el('result-container').classList.remove('hidden')
    if (typeof window !== 'undefined' && (window as any).cf) {
      ;(window as any).cf.track('assessment_completed', {
        type: 'kubernetes-readiness-es',
        score,
      })
    }
    el('result-container').innerHTML = `
    <div class="rounded-2xl p-8 mb-6" style="background:${r.bg};border:1px solid ${r.border};">
      <div class="flex items-start gap-5 mb-6">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0 text-white font-black text-lg" style="background:${r.color};">${pct}%</div>
        <div>
          <h2 class="text-xl font-bold mb-2" style="color:#0A2540;">${r.title}</h2>
          <p class="text-sm leading-relaxed" style="color:#64748b;">${r.desc}</p>
        </div>
      </div>

      <div id="email-capture" style="margin: 1.5rem 0; padding: 1.5rem; background: #EEF4FF; border-radius: 12px; border: 1px solid #C7D7FD;">
        <p style="font-weight: 600; color: #0A2540; margin-bottom: 0.5rem;">Recibe tu plan de acción personalizado por email</p>
        <p style="font-size: 0.875rem; color: #64748b; margin-bottom: 1rem;">Te enviaremos una hoja de ruta detallada basada en tu puntuación. Sin spam.</p>
        <form id="assessment-email-form" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <input type="hidden" name="access_key" value="e8aaab4e-270c-4163-bb76-6a8dfc247485">
          <input type="hidden" name="subject" id="assessment-subject">
          <input type="hidden" name="assessment_score" id="assessment-score-field">
          <input type="hidden" name="assessment_level" id="assessment-level-field">
          <input type="email" name="email" placeholder="tu@empresa.com" required
            style="flex: 1; min-width: 200px; padding: 0.75rem 1rem; border: 1px solid #C7D7FD; border-radius: 8px; font-size: 0.875rem;">
          <button type="submit"
            style="padding: 0.75rem 1.5rem; background: #1E6FFF; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">
            Enviarme mi plan →
          </button>
        </form>
        <p id="email-success" style="display:none; color: #16a34a; font-size: 0.875rem; margin-top: 0.75rem;">✓ ¡Revisa tu bandeja de entrada! Te enviaremos tu plan en 24 horas.</p>
      </div>

      <a href="${CAL}" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-bold px-6 py-3.5 rounded-xl transition-all hover:opacity-90 hover:-translate-y-px"
        style="background:${r.color};color:white;box-shadow:0 4px 16px rgba(0,0,0,0.15);">
        ${r.cta} →
      </a>
    </div>
    <button onclick="location.reload()" class="text-sm font-medium hover:opacity-70 transition-opacity" style="color:#64748b;">← Repetir evaluación</button>`

    // Email capture setup
    const subjEl = document.getElementById(
      'assessment-subject'
    ) as HTMLInputElement
    const scoreEl2 = document.getElementById(
      'assessment-score-field'
    ) as HTMLInputElement
    const levelEl = document.getElementById(
      'assessment-level-field'
    ) as HTMLInputElement
    if (subjEl)
      subjEl.value = `Evaluación Preparación Kubernetes — Puntuación ${score}/${maxScore} (${r.title})`
    if (scoreEl2) scoreEl2.value = String(score)
    if (levelEl) levelEl.value = r.title
    const emailForm = document.getElementById(
      'assessment-email-form'
    ) as HTMLFormElement
    emailForm?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const fd = new FormData(emailForm)
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: fd,
        })
        if (res.ok) {
          emailForm.style.display = 'none'
          const ok = document.getElementById('email-success')
          if (ok) ok.style.display = 'block'
        }
      } catch {}
    })
  }

  ;(window as any).selectAnswer = selectAnswer
  render()
</script>
