---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="DevOps Interview Agent · Práctica de Entrevistas Técnicas · AI-Powered · Gratis"
  descripcion="Practica entrevistas técnicas de DevOps con IA. Preguntas reales sobre Linux, Docker, Kubernetes, AWS, Terraform y CI/CD con feedback inmediato."
>
  <!-- HERO -->
  <section
    class="relative overflow-hidden"
    style="background: #0A2540;"
    aria-labelledby="iv-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.1) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-7 text-xs font-bold tracking-widest uppercase"
        style="background: rgba(37,99,235,0.25); border: 1px solid rgba(96,165,250,0.35); color: #93C5FD;"
      >
        <span
          class="w-2 h-2 rounded-full flex-shrink-0"
          style="background: #60A5FA; animation: pulse 2s infinite;"
          aria-hidden="true"></span>
        AI-Powered · Gratis · Linux · K8s · AWS
      </div>
      <h1
        id="iv-hero-heading"
        class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight"
        style="letter-spacing: -0.035em;"
      >
        DevOps Interview Agent
      </h1>
      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto"
        style="color: rgba(147,184,255,0.85);"
      >
        Practica entrevistas técnicas de DevOps con IA. Preguntas reales,
        feedback inmediato y evaluación por tema.
      </p>
    </div>
  </section>

  <!-- INTERVIEW INTERFACE -->
  <section class="bg-white py-16" aria-label="Interfaz de entrevista DevOps">
    <div class="max-w-3xl mx-auto px-6">
      <!-- Config (shown before start) -->
      <div id="iv-config" class="space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label
              for="iv-level"
              class="block text-sm font-semibold mb-2"
              style="color: #0F172A;">Nivel</label
            >
            <select
              id="iv-level"
              class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
              style="border-color: #E2E8F0; color: #0F172A;"
            >
              <option value="Junior">Junior (0-2 años)</option>
              <option value="Mid" selected>Mid-level (2-5 años)</option>
              <option value="Senior">Senior (5+ años)</option>
            </select>
          </div>
          <div>
            <label
              for="iv-topic"
              class="block text-sm font-semibold mb-2"
              style="color: #0F172A;">Tema</label
            >
            <select
              id="iv-topic"
              class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
              style="border-color: #E2E8F0; color: #0F172A;"
            >
              <option value="General DevOps" selected>General DevOps</option>
              <option value="Linux">Linux</option>
              <option value="Docker">Docker</option>
              <option value="Kubernetes">Kubernetes</option>
              <option value="AWS">AWS</option>
              <option value="Terraform">Terraform</option>
              <option value="CI/CD">CI/CD</option>
            </select>
          </div>
        </div>
        <button
          id="iv-start"
          class="w-full text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.01]"
          style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.4);"
        >
          Empezar entrevista →
        </button>
      </div>

      <!-- Interview area (shown during interview) -->
      <div id="iv-interview" class="hidden space-y-5">
        <!-- Score bar -->
        <div
          class="flex items-center justify-between py-3 px-4 rounded-xl"
          style="background: #F8FAFF; border: 1px solid #DBEAFE;"
        >
          <div class="text-sm font-semibold" style="color: #0F172A;">
            Pregunta <span id="iv-q-num">1</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs" style="color: #64748B;">Score acumulado:</span
            >
            <span
              id="iv-score"
              class="text-sm font-bold"
              style="color: #2563EB;">—</span
            >
          </div>
        </div>

        <!-- Question display -->
        <div
          id="iv-question-box"
          class="rounded-2xl p-6"
          style="background: #0A2540; display: none;"
        >
          <div class="flex items-center gap-2 mb-3">
            <span
              id="iv-topic-badge"
              class="text-xs font-bold px-2 py-0.5 rounded-full"
              style="background: rgba(37,99,235,0.3); color: #93C5FD; border: 1px solid rgba(96,165,250,0.3);"
            ></span>
            <span
              id="iv-level-badge"
              class="text-xs font-semibold"
              style="color: rgba(147,184,255,0.6);"></span>
          </div>
          <p
            id="iv-question-text"
            class="text-base font-semibold text-white leading-relaxed"
          >
          </p>
        </div>

        <!-- Answer area -->
        <div id="iv-answer-area" class="hidden space-y-3">
          <label
            for="iv-answer"
            class="block text-sm font-semibold"
            style="color: #0F172A;">Tu respuesta</label
          >
          <textarea
            id="iv-answer"
            rows="5"
            placeholder="Escribe tu respuesta aquí..."
            class="w-full px-4 py-3 rounded-xl text-sm border resize-none focus:outline-none focus:ring-2"
            style="border-color: #E2E8F0; color: #0F172A;"></textarea>
          <button
            id="iv-submit-answer"
            class="w-full text-sm font-semibold text-white px-7 py-3.5 rounded-xl transition-all hover:scale-[1.01]"
            style="background: #2563EB;"
          >
            Enviar respuesta →
          </button>
        </div>

        <!-- Evaluation panel -->
        <div
          id="iv-eval"
          class="hidden rounded-2xl p-6 space-y-4"
          style="background: #F8FAFF; border: 1px solid #DBEAFE;"
        >
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-bold" style="color: #0F172A;">
              Evaluación
            </h3>
            <div class="flex items-center gap-2">
              <span class="text-xs" style="color: #64748B;">Puntuación:</span>
              <span
                id="iv-eval-score"
                class="text-xl font-extrabold"
                style="color: #2563EB;"></span>
              <span class="text-xs" style="color: #64748B;">/10</span>
            </div>
          </div>
          <p
            id="iv-feedback"
            class="text-sm leading-relaxed"
            style="color: #475569;"
          >
          </p>
          <div class="rounded-xl p-4" style="background: #0F172A;">
            <p class="text-xs font-bold mb-2" style="color: #60A5FA;">
              Respuesta correcta:
            </p>
            <p
              id="iv-correct"
              class="text-xs leading-relaxed"
              style="color: #CBD5E1;"
            >
            </p>
          </div>
          <button
            id="iv-next"
            class="w-full text-sm font-semibold text-white px-7 py-3.5 rounded-xl transition-all hover:scale-[1.01]"
            style="background: #2563EB;"
          >
            Siguiente pregunta →
          </button>
        </div>

        <!-- Loading -->
        <div id="iv-loading" class="hidden text-center py-8">
          <div
            class="inline-flex items-center gap-3 px-5 py-3 rounded-2xl"
            style="background: #EEF4FF; border: 1px solid #93C5FD;"
          >
            <svg
              class="w-4 h-4 animate-spin"
              style="color: #2563EB;"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span class="text-sm" style="color: #2563EB;" id="iv-loading-text"
              >Generando pregunta...</span
            >
          </div>
        </div>

        <p id="iv-error" class="hidden text-sm text-red-600 text-center"></p>

        <!-- CTA at bottom -->
        <div class="text-center pt-4">
          <p class="text-sm" style="color: #64748B;">
            ¿Preparándote para entrevistas? —
            <a
              href="/contacto"
              class="font-semibold underline"
              style="color: #2563EB;">Habla con LRA sobre oportunidades</a
            >
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  interface Message {
    role: string
    content: string
  }
  interface InterviewResult {
    type: string
    topic?: string
    level?: string
    question?: string
    score?: number
    feedback?: string
    correct_answer?: string
    content?: string
  }

  const configEl = document.getElementById('iv-config')!
  const interviewEl = document.getElementById('iv-interview')!
  const questionBox = document.getElementById('iv-question-box')!
  const answerArea = document.getElementById('iv-answer-area')!
  const evalEl = document.getElementById('iv-eval')!
  const loadingEl = document.getElementById('iv-loading')!
  const loadingText = document.getElementById('iv-loading-text')!
  const errorEl = document.getElementById('iv-error')!

  let messages: Message[] = []
  let questionCount = 0
  let totalScore = 0
  let answeredCount = 0

  async function callAgent(userMsg: string): Promise<InterviewResult> {
    const level = (document.getElementById('iv-level') as HTMLSelectElement)
      .value
    const topic = (document.getElementById('iv-topic') as HTMLSelectElement)
      .value
    messages.push({ role: 'user', content: userMsg })

    const res = await fetch('/api/interview-agent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages, level, topic }),
    })
    const json = (await res.json()) as {
      result?: InterviewResult
      error?: string
    }
    if (json.error) throw new Error(json.error)

    const result =
      json.result ?? ({ type: 'message', content: '...' } as InterviewResult)
    messages.push({ role: 'assistant', content: JSON.stringify(result) })
    return result
  }

  document.getElementById('iv-start')!.addEventListener('click', async () => {
    configEl.classList.add('hidden')
    interviewEl.classList.remove('hidden')
    await askQuestion()
  })

  async function askQuestion(): Promise<void> {
    questionCount++
    document.getElementById('iv-q-num')!.textContent = String(questionCount)
    questionBox.style.display = 'none'
    answerArea.classList.add('hidden')
    evalEl.classList.add('hidden')
    errorEl.classList.add('hidden')
    loadingText.textContent = 'Generando pregunta...'
    loadingEl.classList.remove('hidden')

    try {
      const result = await callAgent('siguiente')
      loadingEl.classList.add('hidden')

      if (result.type === 'question') {
        document.getElementById('iv-topic-badge')!.textContent =
          result.topic ?? ''
        document.getElementById('iv-level-badge')!.textContent =
          result.level ?? ''
        document.getElementById('iv-question-text')!.textContent =
          result.question ?? ''
        questionBox.style.display = 'block'
        ;(document.getElementById('iv-answer') as HTMLTextAreaElement).value =
          ''
        answerArea.classList.remove('hidden')
      }
    } catch (err) {
      loadingEl.classList.add('hidden')
      errorEl.textContent =
        err instanceof Error ? err.message : 'Error. Intenta de nuevo.'
      errorEl.classList.remove('hidden')
    }
  }

  document
    .getElementById('iv-submit-answer')!
    .addEventListener('click', async () => {
      const answer = (
        document.getElementById('iv-answer') as HTMLTextAreaElement
      ).value.trim()
      if (!answer) return

      answerArea.classList.add('hidden')
      loadingText.textContent = 'Evaluando respuesta...'
      loadingEl.classList.remove('hidden')

      try {
        const result = await callAgent(answer)
        loadingEl.classList.add('hidden')

        if (result.type === 'evaluation') {
          const score = typeof result.score === 'number' ? result.score : 0
          answeredCount++
          totalScore += score
          const avg = Math.round((totalScore / answeredCount) * 10) / 10

          document.getElementById('iv-eval-score')!.textContent = String(score)
          const scoreEl = document.getElementById('iv-eval-score')!
          scoreEl.style.color =
            score >= 8
              ? '#16A34A'
              : score >= 6
                ? '#2563EB'
                : score >= 4
                  ? '#D97706'
                  : '#DC2626'

          document.getElementById('iv-feedback')!.textContent =
            result.feedback ?? ''
          document.getElementById('iv-correct')!.textContent =
            result.correct_answer ?? ''
          document.getElementById('iv-score')!.textContent =
            `${avg}/10 (${answeredCount} preguntas)`
          evalEl.classList.remove('hidden')
        }
      } catch (err) {
        loadingEl.classList.add('hidden')
        answerArea.classList.remove('hidden')
        errorEl.textContent =
          err instanceof Error
            ? err.message
            : 'Error evaluando. Intenta de nuevo.'
        errorEl.classList.remove('hidden')
      }
    })

  document.getElementById('iv-next')!.addEventListener('click', async () => {
    await askQuestion()
  })
</script>
