---
import Layout from '../layouts/Layout.astro'
import SaasHeader from '../components/layout/SaasHeader.astro'
import SaasFooter from '../components/layout/SaasFooter.astro'

const plans = [
  {
    name: 'Free',
    price: '€0',
    period: '/mo',
    features: [
      'Placeholder feature one',
      'Placeholder feature two',
      'Placeholder feature three',
      'Placeholder feature four',
      'Placeholder feature five',
    ],
    cta: 'Start for free',
    featured: false,
  },
  {
    name: 'Starter',
    price: '€49',
    period: '/mo',
    features: [
      'Placeholder feature one',
      'Placeholder feature two',
      'Placeholder feature three',
      'Placeholder feature four',
      'Placeholder feature five',
    ],
    cta: 'Start free trial',
    featured: false,
  },
  {
    name: 'Professional',
    price: '€199',
    period: '/mo',
    features: [
      'Placeholder feature one',
      'Placeholder feature two',
      'Placeholder feature three',
      'Placeholder feature four',
      'Placeholder feature five',
    ],
    cta: 'Start free trial',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    features: [
      'Placeholder feature one',
      'Placeholder feature two',
      'Placeholder feature three',
      'Placeholder feature four',
      'Placeholder feature five',
    ],
    cta: 'Talk to sales',
    featured: false,
  },
]

const faqs = [
  {
    q: 'Placeholder question one?',
    a: 'Placeholder answer copy explaining the topic in one or two sentences.',
  },
  {
    q: 'Placeholder question two?',
    a: 'Placeholder answer copy explaining the topic in one or two sentences.',
  },
  {
    q: 'Placeholder question three?',
    a: 'Placeholder answer copy explaining the topic in one or two sentences.',
  },
  {
    q: 'Placeholder question four?',
    a: 'Placeholder answer copy explaining the topic in one or two sentences.',
  },
  {
    q: 'Placeholder question five?',
    a: 'Placeholder answer copy explaining the topic in one or two sentences.',
  },
  {
    q: 'Placeholder question six?',
    a: 'Placeholder answer copy explaining the topic in one or two sentences.',
  },
]
---

<Layout title="Pricing — Platform" description="Simple, transparent pricing.">
  <SaasHeader />

  <main>
    <!-- HERO PRICING -->
    <section class="pricing-hero">
      <div class="container">
        <h1>Simple, transparent pricing</h1>
        <p>
          Placeholder subtitle describing the pricing philosophy in one line.
        </p>
        <div
          class="toggle"
          style="margin-top: 2rem;"
          role="tablist"
          aria-label="Billing period"
        >
          <button
            class="toggle-option active"
            type="button"
            role="tab"
            aria-selected="true">Monthly</button
          >
          <button
            class="toggle-option"
            type="button"
            role="tab"
            aria-selected="false">Annual</button
          >
        </div>
      </div>
    </section>

    <!-- PRICING CARDS -->
    <section class="section">
      <div class="container">
        <div class="pricing-grid">
          {
            plans.map((plan) => (
              <div class={`pricing-card ${plan.featured ? 'featured' : ''}`}>
                {plan.featured && (
                  <span class="pricing-badge">Most popular</span>
                )}
                <div>
                  <h3>{plan.name}</h3>
                  <p class="pricing-price">
                    {plan.price}
                    {plan.period && <span>{plan.period}</span>}
                  </p>
                </div>
                <ul class="feature-list">
                  {plan.features.map((f) => (
                    <li>{f}</li>
                  ))}
                </ul>
                <a
                  href="/signup"
                  class={plan.featured ? 'btn-primary' : 'btn-outline'}
                  style="justify-content: center;"
                >
                  {plan.cta}
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section faq-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">FAQ</span>
          <h2>Frequently asked questions</h2>
        </div>
        <div class="faq-list">
          {
            faqs.map((item) => (
              <details class="faq-item">
                <summary>
                  {item.q}
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </summary>
                <p>{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="container final-cta-inner">
        <h2>Ready to get started?</h2>
        <p>
          Placeholder subtitle inviting the visitor to take the next step with
          the platform.
        </p>
        <div class="cta-buttons">
          <a href="/signup" class="btn-primary btn-lg">Start for free →</a>
          <a href="#" class="btn-outline-white">Talk to sales</a>
        </div>
      </div>
    </section>
  </main>

  <SaasFooter />
</Layout>

<style>
  .pricing-hero {
    background: #0d1b2e;
    padding-block: clamp(4rem, 8vw, 5.5rem) clamp(3rem, 6vw, 4rem);
    text-align: center;
  }
  .pricing-hero h1 {
    color: #ffffff;
    margin-bottom: 0.75rem;
  }
  .pricing-hero p {
    color: #a19f9d;
    font-size: 1.0625rem;
    max-width: 480px;
    margin-inline: auto;
  }

  .section-heading {
    text-align: center;
    max-width: 640px;
    margin: 0 auto clamp(2rem, 4vw, 3rem);
  }
  .eyebrow {
    display: inline-block;
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0078d4;
    margin-bottom: 0.75rem;
  }
  .section-heading h2 {
    color: #111827;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    align-items: start;
  }
  .pricing-card {
    position: relative;
  }
  .pricing-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: #0078d4;
    color: #ffffff;
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }
  .pricing-card h3 {
    color: #111827;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }
  .btn-primary {
    font-family: 'Red Hat Text', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #ffffff;
    background: #0078d4;
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    transition: background 150ms ease;
  }
  .btn-primary:hover {
    background: #106ebe;
  }
  .btn-outline {
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    color: #0078d4;
    border: 1px solid #0078d4;
    padding: 0.5625rem 1.25rem;
    border-radius: 9999px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: background 150ms ease;
  }
  .btn-outline:hover {
    background: #eff6fc;
  }
  .btn-lg {
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
  }
  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: border-color 150ms ease;
  }
  .btn-outline-white:hover {
    border-color: #ffffff;
  }

  /* FAQ */
  .faq-section {
    background: #faf9f8;
  }
  .faq-list {
    max-width: 760px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    background: #ffffff;
    border: 1px solid #edebe9;
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    color: #111827;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary svg {
    flex-shrink: 0;
    color: #6b7280;
    transition: transform 150ms ease;
  }
  .faq-item[open] summary svg {
    transform: rotate(180deg);
  }
  .faq-item p {
    margin-top: 0.75rem;
    color: #6b7280;
    font-size: 0.9375rem;
  }

  /* FINAL CTA */
  .final-cta {
    background: #0d1b2e;
    padding-block: clamp(4rem, 8vw, 6rem);
  }
  .final-cta-inner {
    text-align: center;
  }
  .final-cta-inner h2 {
    color: #ffffff;
    margin-bottom: 1rem;
  }
  .final-cta-inner p {
    color: #a19f9d;
    font-size: 1.0625rem;
    max-width: 480px;
    margin: 0 auto 2rem;
  }
  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 960px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
