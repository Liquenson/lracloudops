---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
---

<Layout
  title="Transparent Pricing — LRA CloudOps"
  description="Transparent pricing for Platform Engineering services — free infrastructure audit, fixed-scope engineering projects from €400, platform retainer at €499/month."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <!-- Hero -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0; text-align: center;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Transparent Pricing</p>
      <h1 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;">Fixed scope. Fixed price.</h1>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368;">No hourly billing. No scope creep. Defined deliverables on every engagement.</p>
    </div>
  </section>

  <!-- 3 plans -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem;">
    <div style="max-width: 1100px; margin: 0 auto;">

      <!-- Engagement calculator -->
      <div style="background:#F8F9FA;border:1px solid #DADCE0;border-radius:12px;padding:2rem;margin-bottom:3rem;" data-animate="fade-up">
        <h3 style="font-family:'Red Hat Display',sans-serif;font-size:1.125rem;font-weight:700;color:#202124;margin-bottom:1.5rem;">Find the right engagement</h3>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;" class="grid-2">
          <div>
            <label style="font-family:'Red Hat Text',sans-serif;font-size:0.875rem;font-weight:600;color:#202124;display:block;margin-bottom:0.5rem;">Primary need</label>
            <select id="calc-need" style="width:100%;padding:0.625rem 0.875rem;font-family:'Red Hat Text',sans-serif;font-size:0.9375rem;color:#202124;background:#FFFFFF;border:1px solid #DADCE0;border-radius:6px;outline:none;">
              <option value="audit">Security audit</option>
              <option value="cicd">CI/CD pipeline</option>
              <option value="aws">AWS infrastructure</option>
              <option value="k8s">Kubernetes platform</option>
              <option value="ongoing">Ongoing platform ops</option>
            </select>
          </div>
          <div>
            <label style="font-family:'Red Hat Text',sans-serif;font-size:0.875rem;font-weight:600;color:#202124;display:block;margin-bottom:0.5rem;">Number of repositories</label>
            <select id="calc-repos" style="width:100%;padding:0.625rem 0.875rem;font-family:'Red Hat Text',sans-serif;font-size:0.9375rem;color:#202124;background:#FFFFFF;border:1px solid #DADCE0;border-radius:6px;outline:none;">
              <option value="1">1 repository</option>
              <option value="2-5">2-5 repositories</option>
              <option value="6+">6+ repositories</option>
            </select>
          </div>
        </div>

        <div id="calc-result" style="background:#FFFFFF;border:1px solid #1A73E8;border-radius:8px;padding:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <div>
            <p style="font-family:'Red Hat Text',sans-serif;font-size:0.875rem;color:#5F6368;margin:0 0 0.25rem;">Recommended engagement</p>
            <p id="calc-plan" style="font-family:'Red Hat Display',sans-serif;font-size:1.125rem;font-weight:700;color:#202124;margin:0;">Infrastructure Audit — Free</p>
          </div>
          <a href="/audit" id="calc-cta" style="display:inline-flex;align-items:center;gap:0.375rem;background:#1A73E8;color:#FFFFFF;padding:0.625rem 1.25rem;border-radius:4px;font-family:'Red Hat Text',sans-serif;font-size:0.875rem;font-weight:600;text-decoration:none;white-space:nowrap;">
            Get started →
          </a>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="pricing-grid">

        <!-- Free Audit -->
        <div style="border: 1px solid #DADCE0; border-radius: 8px; padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
          <div>
            <p style="font-family: 'Red Hat Display', sans-serif; font-size: 1.0625rem; font-weight: 700; color: #202124; margin-bottom: 0.25rem;">Infrastructure Audit</p>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">Automated security and IaC analysis of any GitHub repository. Delivered within 24 hours.</p>
          </div>
          <div style="display: flex; align-items: baseline; gap: 0.25rem;">
            <span style="font-family: 'Red Hat Display', sans-serif; font-size: 3rem; font-weight: 900; color: #202124; line-height: 1; letter-spacing: -0.04em;">Free</span>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; flex: 1;">
            {[
              'lra scan on 1 GitHub repository',
              'Trivy — security vulnerabilities',
              'Checkov — IaC misconfigurations',
              'PASS/FAIL report by email',
              'Concrete fix recommendations',
              'Delivered within 24 hours',
            ].map(f => (
              <li style="display: flex; align-items: start; gap: 0.625rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">{f}</span>
              </li>
            ))}
          </ul>
          <a href="/contact" style="display: block; text-align: center; padding: 0.75rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none; background: transparent; color: #1A73E8; border: 1px solid #DADCE0;" class="btn-premium-outline">
            Request free audit
          </a>
        </div>

        <!-- DevOps Project -->
        <div style="border: 2px solid #1A73E8; border-radius: 8px; padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; position: relative; box-shadow: 0 4px 20px rgba(26,115,232,0.12);">
          <div style="position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: #1A73E8; color: #FFFFFF; font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; padding: 0.25rem 1rem; border-radius: 9999px; white-space: nowrap;">
            Most popular
          </div>
          <div>
            <p style="font-family: 'Red Hat Display', sans-serif; font-size: 1.0625rem; font-weight: 700; color: #202124; margin-bottom: 0.25rem;">Engineering Project</p>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">Fixed-scope delivery — CI/CD pipeline, AWS infrastructure, Kubernetes platform or security remediation. Timeline and deliverables defined upfront.</p>
          </div>
          <div style="display: flex; align-items: baseline; gap: 0.25rem;">
            <span style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; font-weight: 500;">From</span>
            <span style="font-family: 'Red Hat Text', sans-serif; font-size: 1.25rem; color: #5F6368; font-weight: 500;">€</span>
            <span style="font-family: 'Red Hat Display', sans-serif; font-size: 3rem; font-weight: 900; color: #202124; line-height: 1; letter-spacing: -0.04em;">400</span>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; flex: 1;">
            {[
              'CI/CD pipeline setup (GitHub Actions + ArgoCD)',
              'AWS infrastructure with Terraform',
              'Kubernetes cluster setup',
              'Security scan included (Trivy + Checkov)',
              'Complete documentation',
              'Delivery: 1-2 weeks',
              'Fixed price per project',
            ].map(f => (
              <li style="display: flex; align-items: start; gap: 0.625rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">{f}</span>
              </li>
            ))}
          </ul>
          <a href="/contact" style="display: block; text-align: center; padding: 0.75rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none; background: #1A73E8; color: #FFFFFF;" class="btn-premium">
            Request quote
          </a>
        </div>

        <!-- Monthly Consulting -->
        <div id="retainer" style="border: 1px solid #DADCE0; border-radius: 8px; padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; scroll-margin-top: 88px;">
          <div>
            <p style="font-family: 'Red Hat Display', sans-serif; font-size: 1.0625rem; font-weight: 700; color: #202124; margin-bottom: 0.25rem;">Platform Retainer</p>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">Ongoing platform operations — monthly security scans, infrastructure reviews, CI/CD audits and direct engineering access. Month-to-month, no lock-in.</p>
          </div>
          <div style="display: flex; align-items: baseline; gap: 0.25rem;">
            <span style="font-family: 'Red Hat Text', sans-serif; font-size: 1.25rem; color: #5F6368; font-weight: 500;">€</span>
            <span style="font-family: 'Red Hat Display', sans-serif; font-size: 3rem; font-weight: 900; color: #202124; line-height: 1; letter-spacing: -0.04em;">499</span>
            <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">/month</span>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; flex: 1;">
            {[
              'Everything in Project',
              'Monthly lra scan on all repos',
              'infrastructure_review — AWS/K8s analysis',
              'CI/CD pipeline audit',
              'Direct email + LinkedIn access',
              'Implementation support',
              'No long-term contract',
            ].map(f => (
              <li style="display: flex; align-items: start; gap: 0.625rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">{f}</span>
              </li>
            ))}
          </ul>
          <a href="/contact" style="display: block; text-align: center; padding: 0.75rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none; background: transparent; color: #1A73E8; border: 1px solid #DADCE0;" class="btn-premium-outline">
            Get started
          </a>
        </div>
      </div>

      <!-- Note -->
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #9AA0A6; text-align: center; margin-top: 2rem;">
        Project pricing varies by scope. AWS Infrastructure: €800-2.000. Kubernetes setup: €1.000-2.500. CI/CD only: €400-800. Contact us for a custom quote.
      </p>
    </div>
  </section>

  <!-- What's included -->
  <section style="background:var(--color-bg-soft);padding:var(--section-py) var(--container-px);border-top:1px solid var(--color-border);" data-animate="fade-up">
    <div style="max-width:860px;margin-inline:auto;">
      <h2 style="font-family:var(--font-display);font-size:clamp(var(--text-2xl),2.5vw,var(--text-4xl));font-weight:700;color:var(--color-text);margin-bottom:var(--space-8);text-align:center;">What's included</h2>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-family:var(--font-body);font-size:var(--text-md);">
          <thead>
            <tr style="border-bottom:2px solid var(--color-border);">
              <th style="text-align:left;padding:var(--space-4);color:var(--color-text-secondary);font-weight:600;"></th>
              <th style="text-align:center;padding:var(--space-4);color:var(--color-text);font-weight:700;">Free Audit</th>
              <th style="text-align:center;padding:var(--space-4);color:var(--color-primary);font-weight:700;background:var(--color-primary-light);border-radius:var(--radius-md) var(--radius-md) 0 0;">Engineering Project</th>
              <th style="text-align:center;padding:var(--space-4);color:var(--color-text);font-weight:700;">Platform Retainer</th>
            </tr>
          </thead>
          <tbody>
            {[
              { feature: 'lra scan security audit', free: true, project: true, retainer: true },
              { feature: 'AI-generated remediation report', free: true, project: true, retainer: true },
              { feature: 'Trivy + Checkov analysis', free: true, project: true, retainer: true },
              { feature: 'Implementation support', free: false, project: true, retainer: true },
              { feature: 'Infrastructure as Code (Terraform)', free: false, project: true, retainer: true },
              { feature: 'Kubernetes platform setup', free: false, project: true, retainer: true },
              { feature: 'GitOps pipeline (ArgoCD)', free: false, project: true, retainer: true },
              { feature: 'Monthly security scans', free: false, project: false, retainer: true },
              { feature: 'Infrastructure drift detection', free: false, project: false, retainer: true },
              { feature: 'Direct engineering access', free: false, project: false, retainer: true },
              { feature: 'Monthly platform review', free: false, project: false, retainer: true },
            ].map(({ feature, free, project, retainer }, i) => (
              <tr style={`border-bottom:1px solid var(--color-border);${i % 2 === 0 ? '' : 'background:var(--color-bg-soft);'}`}>
                <td style="padding:var(--space-3) var(--space-4);color:var(--color-text);">{feature}</td>
                <td style="text-align:center;padding:var(--space-3);">{free ? '✓' : '—'}</td>
                <td style="text-align:center;padding:var(--space-3);background:rgba(26,115,232,0.04);">{project ? '✓' : '—'}</td>
                <td style="text-align:center;padding:var(--space-3);">{retainer ? '✓' : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-top: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 860px; margin: 0 auto;">
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 2rem; text-align: center;">Frequently asked questions</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {[
          {
            q: 'Do you support private repositories?',
            a: 'Yes. Both public and private GitHub repositories are supported. For private repos, temporary read access is granted via a revocable GitHub token.'
          },
          {
            q: 'What is required to get started?',
            a: 'A GitHub repository URL and an email address. No installation, no setup, no credit card.'
          },
          {
            q: 'What is the audit turnaround time?',
            a: 'Reports are delivered within 24-48 hours of the request. Larger repositories may take up to 72 hours.'
          },
          {
            q: 'Which technologies does lra scan support?',
            a: 'Terraform, Kubernetes manifests, Dockerfiles, GitHub Actions workflows, AWS CloudFormation and Ansible. Trivy also scans container images when present in the repository.'
          },
          {
            q: 'Is the Platform Retainer contract-based?',
            a: 'No long-term contract. Billing is month-to-month, cancellable with 7 days notice.'
          },
          {
            q: 'What happens after the free audit?',
            a: 'The report is delivered by email. If ongoing support is needed, a Platform Retainer engagement can be discussed — no pressure.'
          },
        ].map(({ q, a }) => (
          <details style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; overflow: hidden;">
            <summary style="padding: 1.125rem 1.5rem; font-family: 'Red Hat Display', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #202124; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between;">
              {q}
              <span style="font-size: 1.25rem; color: #1A73E8; flex-shrink: 0; margin-left: 1rem;">+</span>
            </summary>
            <div style="padding: 0 1.5rem 1.125rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; line-height: 1.7; border-top: 1px solid #DADCE0; padding-top: 1rem;">
              {a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 1199px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 767px) {
    .pricing-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  const needEl = document.getElementById('calc-need') as HTMLSelectElement
  const reposEl = document.getElementById('calc-repos') as HTMLSelectElement
  const planEl = document.getElementById('calc-plan')
  const ctaEl = document.getElementById('calc-cta') as HTMLAnchorElement

  const recommendations: Record<string, { plan: string; cta: string; href: string }> = {
    'audit-1': { plan: 'Infrastructure Audit — Free', cta: 'Start free audit →', href: '/audit' },
    'audit-2-5': { plan: 'Infrastructure Audit — Free (all repos)', cta: 'Start free audit →', href: '/audit' },
    'audit-6+': { plan: 'Platform Retainer — €499/month (unlimited scans)', cta: 'View retainer →', href: '/pricing#retainer' },
    'cicd-1': { plan: 'Engineering Project — from €400', cta: 'View project pricing →', href: '/pricing' },
    'cicd-2-5': { plan: 'Engineering Project — from €600', cta: 'View project pricing →', href: '/pricing' },
    'cicd-6+': { plan: 'Platform Retainer — €499/month', cta: 'View retainer →', href: '/pricing#retainer' },
    'aws-1': { plan: 'Engineering Project — €800-2.000', cta: 'View project pricing →', href: '/pricing' },
    'aws-2-5': { plan: 'Engineering Project — €800-2.000', cta: 'View project pricing →', href: '/pricing' },
    'aws-6+': { plan: 'Platform Retainer — €499/month', cta: 'View retainer →', href: '/pricing#retainer' },
    'k8s-1': { plan: 'Engineering Project — €1.000-2.500', cta: 'View project pricing →', href: '/pricing' },
    'k8s-2-5': { plan: 'Engineering Project — €1.000-2.500', cta: 'View project pricing →', href: '/pricing' },
    'k8s-6+': { plan: 'Platform Retainer — €499/month', cta: 'View retainer →', href: '/pricing#retainer' },
    'ongoing-1': { plan: 'Platform Retainer — €499/month', cta: 'View retainer →', href: '/pricing#retainer' },
    'ongoing-2-5': { plan: 'Platform Retainer — €499/month', cta: 'View retainer →', href: '/pricing#retainer' },
    'ongoing-6+': { plan: 'Platform Retainer — €499/month', cta: 'View retainer →', href: '/pricing#retainer' },
  }

  function update() {
    const key = `${needEl.value}-${reposEl.value}`
    const rec = recommendations[key] || recommendations['audit-1']
    if (planEl) planEl.textContent = rec.plan
    if (ctaEl) { ctaEl.textContent = rec.cta; ctaEl.href = rec.href }
  }

  needEl?.addEventListener('change', update)
  reposEl?.addEventListener('change', update)
  update()
</script>
