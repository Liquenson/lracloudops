---
import Layout from '../layouts/Layout.astro'

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is included in the initial assessment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A review of your current architecture, infrastructure, delivery processes and observability setup. We identify gaps and outline a concrete approach — at no charge and before any commitment.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can scopes be adjusted after the engagement starts?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. We define the initial scope clearly, but if requirements change during the engagement we discuss adjustments transparently. No surprise invoices.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you work with teams that have no existing cloud infrastructure?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Greenfield is our preferred starting point. We provision everything as code from day one — no legacy constraints, no manual configurations to unwind.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the typical delivery timeline for an implementation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most implementation engagements deliver a production-ready environment in 4–8 weeks depending on scope. Complex multi-account or regulated environments take longer.',
      },
    },
  ],
}
---

<Layout
  titulo="Pricing | DevOps Consulting & Platform Engineering | LRA Cloud Operations"
  descripcion="Fixed-scope DevOps and cloud infrastructure engagements with clear deliverables. Advisory from €400, full implementation from €3,000, ongoing retainer from €800/mo."
  keywords="DevOps consulting pricing Spain, Kubernetes implementation cost, AWS infrastructure pricing Europe, platform engineering rates, Terraform implementation price, cloud consulting fees"
  schema={faqSchema}
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"></div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6" style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);">
        Engagement Models
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6" style="letter-spacing: -0.02em;">
        Engagement Models.<br />Real Value.
      </h1>
      <p class="text-lg leading-relaxed max-w-2xl mx-auto" style="color: rgba(147,184,255,0.8);">
        Fixed-scope engagements with clear deliverables from day one. No hidden fees, no ambiguous statements of work.
      </p>
    </div>
  </section>

  <!-- PRICING TIERS -->
  <section class="py-20 bg-white" aria-labelledby="pricing-heading">
    <div class="max-w-6xl mx-auto px-6">

      <div class="text-center mb-12">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
          Engagement models
        </span>
        <h2 id="pricing-heading" class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">Choose your engagement</h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          Every engagement includes an initial technical assessment. We define scope before any commitment.
        </p>
      </div>

      <!-- Why engagement vs. hiring -->
      <div class="mb-16 rounded-2xl overflow-hidden" style="border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.06);">
        <div class="px-7 py-5" style="background: #0A2540;">
          <h3 class="text-base font-bold text-white">Why engagement vs. hiring full-time?</h3>
          <p class="text-sm mt-1" style="color: rgba(147,184,255,0.7);">A direct comparison across cost, time-to-start and accountability.</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr style="border-bottom: 1px solid #e2e8f0;">
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider" style="color: #94a3b8; background: #f8fafc;"></th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider" style="color: #1E6FFF; background: #EEF4FF;">LRA Cloud Ops</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider" style="color: #64748b; background: #f8fafc;">DevOps FTE (Spain)</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider" style="color: #64748b; background: #f8fafc;">Big Consultancy</th>
              </tr>
            </thead>
            <tbody>
              {[
                { label: 'Cost', lra: '€8K–25K/project', fte: '€45K–70K/year + benefits', big: '€150K–400K/project' },
                { label: 'Start time', lra: '1–2 weeks', fte: '2–4 months hiring', big: '3–6 months' },
                { label: 'Senior access', lra: 'Direct', fte: 'Depends on hire', big: 'Via account manager' },
                { label: 'Accountability', lra: 'Full ownership', fte: 'Internal politics', big: 'Diluted' },
                { label: 'Flexibility', lra: 'Scope-based', fte: 'Fixed headcount', big: 'Contract lock-in' },
              ].map(({ label, lra, fte, big }, i) => (
                <tr style={i % 2 === 0 ? 'background: white;' : 'background: #fafbfc;'}>
                  <td class="px-6 py-3.5 text-xs font-bold" style="color: #0A2540;">{label}</td>
                  <td class="px-6 py-3.5 text-xs font-semibold" style="color: #1E6FFF; background: rgba(238,244,255,0.5);">{lra}</td>
                  <td class="px-6 py-3.5 text-xs" style="color: #64748b;">{fte}</td>
                  <td class="px-6 py-3.5 text-xs" style="color: #64748b;">{big}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">

        <!-- Tier 1: Advisory -->
        <div class="rounded-2xl p-8 flex flex-col" style="border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.06);">
          <div class="mb-6">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-5" style="background: #EEF4FF;">
              <svg class="w-5 h-5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2" style="color: #0A2540;">Advisory</h3>
            <div class="text-3xl font-extrabold mb-1" style="color: #0A2540; letter-spacing: -0.03em;">
              from <span style="color: #1E6FFF;">€400</span>
            </div>
            <p class="text-sm" style="color: #64748b;">Per engagement</p>
          </div>

          <p class="text-sm leading-relaxed mb-6" style="color: #64748b;">
            Ideal for teams evaluating their cloud strategy or needing expert guidance before committing to implementation.
          </p>

          <ul class="space-y-3 mb-8 flex-1">
            {[
              'Infrastructure audit',
              'Architecture recommendations',
              '1–2 working sessions',
              'Technical report',
              'Gap analysis & roadmap',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm" style="color: #334155;">
                <svg class="w-4 h-4 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a href="/contact"
            class="w-full text-center text-sm font-semibold px-6 py-3.5 rounded-xl transition-all hover:opacity-90 block"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
            Get started
          </a>
        </div>

        <!-- Tier 2: Implementation (MOST POPULAR) -->
        <div class="rounded-2xl p-8 flex flex-col relative" style="background: #0A2540; border: 2px solid #1E6FFF; box-shadow: 0 8px 40px rgba(30,111,255,0.25);">
          <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
            <span class="text-xs font-bold px-4 py-1.5 rounded-full whitespace-nowrap" style="background: #1E6FFF; color: white; box-shadow: 0 2px 8px rgba(30,111,255,0.4);">
              MOST POPULAR
            </span>
          </div>

          <div class="mb-6">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-5" style="background: rgba(30,111,255,0.2);">
              <svg class="w-5 h-5" style="color: #93b8ff;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2 text-white">Implementation</h3>
            <div class="text-3xl font-extrabold mb-1 text-white" style="letter-spacing: -0.03em;">
              from <span style="color: #93b8ff;">€8,000</span>
            </div>
            <p class="text-sm" style="color: rgba(147,184,255,0.6);">Typical: €8,000–25,000 depending on scope</p>
          </div>

          <p class="text-sm leading-relaxed mb-6" style="color: rgba(147,184,255,0.8);">
            Ideal for companies building their cloud platform from scratch or modernizing legacy infrastructure.
          </p>

          <ul class="space-y-3 mb-8 flex-1">
            {[
              'End-to-end AWS infrastructure with Terraform',
              'Full CI/CD pipeline automation',
              'Kubernetes or ECS Fargate deployment',
              'Prometheus + Grafana observability',
              'Complete technical documentation',
              '30-day post-delivery support',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm" style="color: rgba(147,184,255,0.9);">
                <svg class="w-4 h-4 flex-shrink-0" style="color: #93b8ff;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a href="/contact"
            class="w-full text-center text-sm font-semibold px-6 py-3.5 rounded-xl transition-all hover:-translate-y-px block text-white"
            style="background: #1E6FFF; box-shadow: 0 4px 16px rgba(30,111,255,0.4);">
            Start implementation
          </a>
        </div>

        <!-- Tier 3: Retainer -->
        <div class="rounded-2xl p-8 flex flex-col" style="border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.06);">
          <div class="mb-6">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-5" style="background: #EEF4FF;">
              <svg class="w-5 h-5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2" style="color: #0A2540;">Retainer</h3>
            <div class="text-3xl font-extrabold mb-1" style="color: #0A2540; letter-spacing: -0.03em;">
              from <span style="color: #1E6FFF;">€800</span>
            </div>
            <p class="text-sm" style="color: #64748b;">Per month</p>
          </div>

          <p class="text-sm leading-relaxed mb-6" style="color: #64748b;">
            Ideal for teams needing ongoing DevOps expertise without hiring a full-time engineer.
          </p>

          <ul class="space-y-3 mb-8 flex-1">
            {[
              '24/7 monitoring with proactive alerts',
              'Security patches and updates',
              'Priority technical support',
              'Monthly infrastructure report',
              'Cost optimization reviews',
              'On-demand engineering hours',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm" style="color: #334155;">
                <svg class="w-4 h-4 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a href="/contact"
            class="w-full text-center text-sm font-semibold px-6 py-3.5 rounded-xl transition-all hover:opacity-90 block"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
            Start retainer
          </a>
        </div>

      </div>

      <!-- Hourly banner -->
      <div class="mt-10 rounded-2xl px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-4" style="background: #F8FAFC; border: 1px solid #e2e8f0;">
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm" style="color: #64748b;">
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background: #1E6FFF;" aria-hidden="true"></span>
            <strong style="color: #0A2540;">Hourly rate:</strong> €50–70/h
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background: #1E6FFF;" aria-hidden="true"></span>
            Custom scopes available
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background: #10B981;" aria-hidden="true"></span>
            Response within 24 hours
          </span>
        </div>
        <a href="/contact" class="text-sm font-semibold px-5 py-2.5 rounded-xl flex-shrink-0 transition-all hover:opacity-90" style="background: #0A2540; color: white;">
          Discuss your scope →
        </a>
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 border-t border-gray-100" style="background: #F8FAFC;" aria-labelledby="faq-heading">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 id="faq-heading" class="text-3xl font-bold mb-4" style="color: #0A2540;">Common questions</h2>
      </div>
      <div class="space-y-4">
        {[
          {
            q: 'What is included in the initial assessment?',
            a: 'A review of your current architecture, infrastructure, delivery processes and observability setup. We identify gaps and outline a concrete approach — at no charge and before any commitment.',
          },
          {
            q: 'Can scopes be adjusted after the engagement starts?',
            a: 'Yes. We define the initial scope clearly, but if requirements change during the engagement we discuss adjustments transparently. No surprise invoices.',
          },
          {
            q: 'Do you work with teams that have no existing cloud infrastructure?',
            a: 'Yes. Greenfield is our preferred starting point. We provision everything as code from day one — no legacy constraints, no manual configurations to unwind.',
          },
          {
            q: 'What is the typical delivery timeline for an implementation?',
            a: 'Most implementation engagements deliver a production-ready environment in 4–8 weeks depending on scope. Complex multi-account or regulated environments take longer.',
          },
          {
            q: 'How do you handle our AWS credentials?',
            a: 'We never use static access keys. All automation uses OIDC federation — temporary tokens scoped to the minimum required permissions. Your credentials never leave your account.',
          },
          {
            q: 'Can you sign an NDA before the initial call?',
            a: 'Yes. We routinely sign NDAs before any technical discussion. Contact us and we\'ll send our standard NDA within 24 hours.',
          },
          {
            q: 'What happens after the 30-day support period?',
            a: 'You own everything — code, infrastructure, documentation. We offer optional retainer contracts for ongoing support, but there\'s no lock-in.',
          },
          {
            q: 'Can we speak with previous clients?',
            a: 'We can provide references upon request after an initial call. Client confidentiality prevents us from publishing names publicly.',
          },
        ].map(({ q, a }) => (
          <div class="bg-white rounded-2xl p-6" style="border: 1px solid #e2e8f0;">
            <h3 class="text-sm font-bold mb-2" style="color: #0A2540;">{q}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748b;">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden" style="background: linear-gradient(90deg, #1D4ED8 0%, #2563EB 55%, #60A5FA 100%);" aria-labelledby="pricing-cta-heading">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-4xl mx-auto px-6 py-20 text-center">
      <h2 id="pricing-cta-heading" class="text-4xl font-extrabold text-white mb-5" style="letter-spacing: -0.025em;">
        Ready to start?
      </h2>
      <p class="text-lg mb-8 max-w-xl mx-auto" style="color: rgba(255,255,255,0.8);">
        Describe your project and we will outline the right engagement model. No sales process, no deck — just a technical conversation.
      </p>
      <a href="/contact"
        class="inline-flex items-center gap-2 text-base font-bold px-8 py-4 rounded-xl transition-all hover:bg-blue-50 hover:-translate-y-px shadow-xl"
        style="background: white; color: #1D4ED8;">
        Start a conversation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
