---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="LRA AI · IA Aplicada a DevOps e Infraestructura Cloud"
  descripcion="Amplía tus capacidades DevOps con inteligencia artificial aplicada. DevOps Advisor disponible 24/7, gestión de AWS en lenguaje natural y diagnóstico automatizado de infraestructura."
  keywords="LRA AI, IA DevOps, inteligencia artificial infraestructura, DevOps Advisor, AWS agente IA, Claude Sonnet DevOps, automatización IA cloud, diagnóstico infraestructura IA"
>
  <!-- ── HERO ── -->
  <section
    class="relative overflow-hidden"
    style="background: #0a0a0a;"
    aria-labelledby="lra-ai-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.08) 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 90% 70% at 50% 115%, rgba(30,111,255,0.18) 0%, transparent 60%);"
    >
    </div>

    <div
      class="relative max-w-5xl mx-auto px-5 sm:px-6 py-24 sm:py-32 text-center"
    >
      <!-- LRA Logo mark -->
      <div class="flex justify-center mb-8" aria-hidden="true">
        <div
          class="w-20 h-20 flex items-center justify-center rounded-2xl"
          style="background: rgba(30,111,255,0.15); border: 1px solid rgba(96,165,250,0.3);"
        >
          <img
            src="/lracloudops-icon.svg"
            alt="LRA Cloud Ops"
            width="44"
            height="44"
            style="opacity:0.9;"
          />
        </div>
      </div>

      <h1
        id="lra-ai-hero-heading"
        class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.04em; line-height: 1.05;"
      >
        LRA AI
      </h1>

      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-8"
        style="color: rgba(147,184,255,0.85);"
      >
        Amplía tus capacidades DevOps con inteligencia artificial aplicada.
        DevOps Advisor disponible 24/7, gestión de AWS en lenguaje natural y
        diagnóstico automatizado de infraestructura.
      </p>

      <!-- Cloud badge -->
      <div class="flex justify-center mb-10">
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold"
          style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); color: rgba(147,184,255,0.8);"
        >
          <span
            class="w-1.5 h-1.5 rounded-full flex-shrink-0"
            style="background:#60A5FA;"
            aria-hidden="true"></span>
          Disponible en AWS · Azure · Google Cloud
        </div>
      </div>

      <div class="flex flex-wrap gap-4 justify-center">
        <button
          onclick="document.getElementById('lra-chat-toggle')?.click()"
          class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
          style="background: #2563EB; box-shadow: 0 4px 24px rgba(37,99,235,0.5);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
            ></path>
          </svg>
          Hablar con el Advisor
        </button>
        <a
          href="#casos-de-uso"
          class="inline-flex items-center gap-2.5 text-sm font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.2);"
        >
          Ver casos de uso
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── MÉTRICAS ── -->
  <section
    style="background: #0f0f0f; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06);"
    aria-label="Métricas de impacto"
  >
    <div class="max-w-5xl mx-auto px-6 py-14">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {
          [
            {
              value: '45 min',
              label: 'despliegue automatizado',
              sub: 'antes: 3 semanas',
            },
            {
              value: '0',
              label: 'deploys manuales en producción',
              sub: 'todo desde Git',
            },
            {
              value: '24/7',
              label: 'DevOps Advisor disponible',
              sub: 'sin interrupción',
            },
            {
              value: '25+',
              label: 'servicios AWS gestionados por IA',
              sub: 'con boto3 + Claude',
            },
          ].map(({ value, label, sub }) => (
            <div class="text-center">
              <div
                class="text-4xl sm:text-5xl font-extrabold mb-2"
                style="color: #1E6FFF; letter-spacing: -0.04em;"
              >
                {value}
              </div>
              <div class="text-sm font-medium text-white mb-1">{label}</div>
              <div class="text-xs" style="color: rgba(147,184,255,0.5);">
                {sub}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── 4 PILARES ── -->
  <section style="background: #0a0a0a;" aria-labelledby="pilares-heading">
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-24">
      <div class="text-center mb-16">
        <span
          class="inline-flex items-center text-xs font-bold px-3 py-1.5 rounded-full mb-4 uppercase tracking-widest"
          style="background: rgba(30,111,255,0.15); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
          >Capacidades</span
        >
        <h2
          id="pilares-heading"
          class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
          style="letter-spacing: -0.03em;"
        >
          IA en cada capa de la plataforma
        </h2>
        <p
          class="text-lg max-w-xl mx-auto"
          style="color: rgba(147,184,255,0.7);"
        >
          Cuatro formas concretas en que la IA acelera la ingeniería.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          [
            {
              badge: 'Disponible 24/7',
              icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z',
              title: 'DevOps Advisor',
              desc: 'Consultoría técnica 24/7 con Claude Sonnet. Preguntas sobre AWS, Kubernetes, Terraform y GitOps respondidas en segundos con contexto real de producción.',
              cta: 'Probar el Advisor',
              ctaAction: 'chat',
              accent: '#2563EB',
            },
            {
              badge: 'Open Source',
              icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
              title: 'AWS Agent',
              desc: 'Gestiona más de 25 servicios AWS en lenguaje natural. Describe lo que necesitas, el agente lo ejecuta con boto3 y Claude Sonnet como capa de razonamiento.',
              cta: 'Ver en GitHub',
              ctaHref: 'https://github.com/lra-cloud-ops',
              accent: '#2563EB',
            },
            {
              badge: 'Servicio Premium',
              icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
              title: 'AI-Assisted Review',
              desc: 'Revisión de arquitectura asistida por IA. La IA detecta patrones en segundos, el ingeniero valida y recomienda. Diagnóstico más rápido y preciso.',
              cta: 'Ver planes',
              ctaHref: '/pricing',
              accent: '#2563EB',
            },
            {
              badge: 'GitHub Actions',
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Daily Agent',
              desc: 'Agente de mantenimiento que audita el proyecto diariamente, genera contenido técnico y abre PRs automáticamente. Infraestructura que se mantiene sola.',
              cta: 'Ver GitHub Actions',
              ctaHref: 'https://github.com/lra-cloud-ops',
              accent: '#2563EB',
            },
          ].map(
            ({ badge, icon, title, desc, cta, ctaAction, ctaHref, accent }) => (
              <div
                class="rounded-2xl p-8 flex flex-col"
                style="background: #141414; border: 1px solid rgba(255,255,255,0.08); transition: border-color 0.2s;"
              >
                <div
                  class="text-xs font-bold uppercase tracking-widest mb-5"
                  style="color: #60A5FA;"
                >
                  {badge}
                </div>
                <div
                  class="w-12 h-12 flex items-center justify-center rounded-xl mb-5 flex-shrink-0"
                  style="background: rgba(37,99,235,0.15);"
                  aria-hidden="true"
                >
                  <svg
                    class="w-6 h-6"
                    style="color: #60A5FA;"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d={icon}
                    />
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">{title}</h3>
                <p
                  class="text-sm leading-relaxed flex-1 mb-6"
                  style="color: rgba(147,184,255,0.7);"
                >
                  {desc}
                </p>
                {ctaAction === 'chat' ? (
                  <button
                    onclick="document.getElementById('lra-chat-toggle')?.click()"
                    class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
                    style="color: #60A5FA; background: none; border: none; cursor: pointer; padding: 0;"
                  >
                    {cta}
                    <svg
                      class="w-3.5 h-3.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </button>
                ) : (
                  <a
                    href={ctaHref}
                    target={ctaHref?.startsWith('http') ? '_blank' : undefined}
                    rel={
                      ctaHref?.startsWith('http')
                        ? 'noopener noreferrer'
                        : undefined
                    }
                    class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
                    style="color: #60A5FA;"
                  >
                    {cta}
                    <svg
                      class="w-3.5 h-3.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </a>
                )}
              </div>
            )
          )
        }
      </div>
    </div>
  </section>

  <!-- ── CASOS DE USO ── -->
  <section
    id="casos-de-uso"
    style="background: #0f0f0f; border-top: 1px solid rgba(255,255,255,0.06);"
    aria-labelledby="casos-heading"
  >
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-24">
      <div class="text-center mb-16">
        <span
          class="inline-flex items-center text-xs font-bold px-3 py-1.5 rounded-full mb-4 uppercase tracking-widest"
          style="background: rgba(30,111,255,0.15); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
          >Proyectos reales</span
        >
        <h2
          id="casos-heading"
          class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
          style="letter-spacing: -0.03em;"
        >
          Casos de uso en producción
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          [
            {
              project: 'aws-terraform-devops',
              outcome:
                'Despliegues de 3 semanas → 45 minutos con pipeline automatizado',
              stack: ['Terraform', 'EKS', 'GitHub Actions', 'Jenkins'],
              icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
            },
            {
              project: 'gitops-stack',
              outcome: '0 deploys manuales en producción. Cada cambio en Git.',
              stack: ['ArgoCD', 'Kubernetes', 'CloudWatch'],
              icon: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5',
            },
            {
              project: 'linux-fleet-manager',
              outcome: 'Gestión de flota sin agentes. Solo SSH.',
              stack: ['Bash', 'ShellCheck', 'CI/CD'],
              icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            },
          ].map(({ project, outcome, stack, icon }) => (
            <div
              class="rounded-2xl p-7 flex flex-col"
              style="background: #141414; border: 1px solid rgba(255,255,255,0.08);"
            >
              <div
                class="w-10 h-10 flex items-center justify-center rounded-xl mb-5"
                style="background: rgba(37,99,235,0.15);"
                aria-hidden="true"
              >
                <svg
                  class="w-5 h-5"
                  style="color: #60A5FA;"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={icon}
                  />
                </svg>
              </div>
              <div
                class="text-xs font-mono mb-3"
                style="color: rgba(96,165,250,0.7);"
              >
                {project}
              </div>
              <p class="text-base font-semibold text-white leading-snug mb-5 flex-1">
                {outcome}
              </p>
              <div class="flex flex-wrap gap-2">
                {stack.map((tag) => (
                  <span
                    class="text-xs px-2.5 py-1 rounded-lg font-medium"
                    style="background: rgba(37,99,235,0.12); color: rgba(147,184,255,0.8); border: 1px solid rgba(96,165,250,0.2);"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── DISPONIBLE EN ── -->
  <section
    style="background: #0a0a0a; border-top: 1px solid rgba(255,255,255,0.06);"
    aria-label="Plataformas cloud compatibles"
  >
    <div class="max-w-4xl mx-auto px-6 py-14 text-center">
      <p
        class="text-sm font-semibold uppercase tracking-widest mb-8"
        style="color: rgba(147,184,255,0.5);"
      >
        Disponible en
      </p>
      <div class="flex flex-wrap items-center justify-center gap-10 sm:gap-16">
        {
          [
            {
              name: 'Amazon Web Services',
              svgPath:
                'M18.75 10.5h.75m-18 0h.75M12 3.75a8.25 8.25 0 100 16.5 8.25 8.25 0 000-16.5zM12 9v3l2.25 2.25',
              label: 'AWS',
            },
            {
              name: 'Microsoft Azure',
              svgPath:
                'M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z',
              label: 'Azure',
            },
            {
              name: 'Google Cloud',
              svgPath:
                'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
              label: 'Google Cloud',
            },
          ].map(({ name, svgPath, label }) => (
            <div class="flex flex-col items-center gap-3 opacity-60 hover:opacity-100 transition-opacity">
              <div
                class="w-12 h-12 flex items-center justify-center rounded-xl"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
              >
                <svg
                  class="w-6 h-6 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={svgPath}
                  />
                </svg>
              </div>
              <span class="text-xs font-semibold text-white">{label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── FILOSOFÍA ── -->
  <section
    style="background: #0f0f0f; border-top: 1px solid rgba(255,255,255,0.06);"
    aria-labelledby="filosofia-heading"
  >
    <div class="max-w-3xl mx-auto px-6 py-20 sm:py-24 text-center">
      <span
        class="inline-flex items-center text-xs font-bold px-3 py-1.5 rounded-full mb-6 uppercase tracking-widest"
        style="background: rgba(30,111,255,0.15); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
        >Filosofía</span
      >
      <h2
        id="filosofia-heading"
        class="text-3xl sm:text-4xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.03em;"
      >
        IA como herramienta, no como sustituto
      </h2>
      <p
        class="text-lg leading-relaxed mb-8"
        style="color: rgba(147,184,255,0.75);"
      >
        Usamos IA para acelerar el diagnóstico, generar runbooks y automatizar
        tareas repetitivas. El ingeniero toma las decisiones críticas de
        arquitectura. Ningún cambio de infraestructura se ejecuta basado
        únicamente en salida de modelo — siempre hay validación humana antes de
        producción.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left mt-10">
        {
          [
            {
              icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Transparencia total',
              desc: 'Cada recomendación de IA se documenta con su razonamiento. El cliente sabe qué decidió el modelo y qué validó el ingeniero.',
            },
            {
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title: 'Validación humana obligatoria',
              desc: 'Ningún cambio en producción sin revisión del ingeniero. La IA propone, el ingeniero valida.',
            },
            {
              icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
              title: 'Sin vendor lock-in',
              desc: 'Construimos sobre APIs estándar. Si Claude deja de ser la mejor opción, migramos sin rediseñar.',
            },
            {
              icon: 'M13 10V3L4 14h7v7l9-11h-7z',
              title: 'IA donde añade valor real',
              desc: 'Análisis de logs, runbooks, diagnóstico inicial. No para reemplazar el criterio técnico en arquitectura.',
            },
          ].map(({ icon, title, desc }) => (
            <div
              class="flex gap-4 p-5 rounded-2xl"
              style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);"
            >
              <div
                class="w-9 h-9 flex items-center justify-center rounded-xl flex-shrink-0"
                style="background: rgba(37,99,235,0.15);"
                aria-hidden="true"
              >
                <svg
                  class="w-4.5 h-4.5"
                  style="color: #60A5FA; width:18px; height:18px;"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={icon}
                  />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-bold text-white mb-1">{title}</h3>
                <p
                  class="text-sm leading-relaxed"
                  style="color: rgba(147,184,255,0.65);"
                >
                  {desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── CTA FINAL ── -->
  <section
    class="relative overflow-hidden"
    style="background: #0a0a0a; border-top: 1px solid rgba(255,255,255,0.06);"
    aria-labelledby="lra-ai-cta-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(30,111,255,0.2) 0%, transparent 65%);"
    >
    </div>
    <div class="relative max-w-3xl mx-auto px-6 py-24 text-center">
      <h2
        id="lra-ai-cta-heading"
        class="text-3xl sm:text-4xl font-extrabold text-white mb-5"
        style="letter-spacing: -0.03em;"
      >
        Habla con nuestro DevOps Advisor ahora
      </h2>
      <p
        class="text-lg mb-8 max-w-xl mx-auto"
        style="color: rgba(147,184,255,0.75);"
      >
