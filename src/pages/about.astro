---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Our Team | DevOps Engineers & Cloud Architects | LRA Cloud Operations"
  descripcion="The LRA Cloud Operations team — platform engineers specializing in AWS, Azure, Kubernetes, Terraform and GitOps with 10+ years of combined production experience."
>
  <!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0D1B2E;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.15) 0%, transparent 65%);"
    ></div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <span
        class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        Our Team
      </span>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-5 leading-tight">
        The engineers behind<br />LRA Cloud Operations
      </h1>
      <p class="text-lg text-[#94a3b8] max-w-2xl mx-auto leading-relaxed">
        A specialized team with 10+ years of combined experience in production cloud infrastructure.
      </p>
    </div>
  </section>

  <!-- ─── TEAM PROFILES ────────────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-5 sm:px-6 space-y-20">

      <!-- ── RUBEN LIQUENSON ─────────────────────────────────────────────── -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-14 items-start">
        <!-- Left: photo + identity -->
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
          <img
            src="/team/ruben-liquenson.png"
            alt="Ruben Liquenson"
            width="180"
            height="180"
            class="rounded-full object-cover mb-5 shadow-lg"
            style="width:180px;height:180px;object-fit:cover;border-radius:50%;"
          />
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Ruben Liquenson</h2>
          <span
            class="inline-block text-sm font-semibold px-3 py-1 rounded-full mb-4"
            style="background:#EEF4FF;color:#1E6FFF;"
          >DevOps Engineer &amp; AWS Specialist</span>
          <p class="text-sm text-gray-500 flex items-center gap-1 mb-1">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z"/></svg>
            Nibble Tech LLC
          </p>
          <p class="text-sm text-gray-500 flex items-center gap-1 mb-5">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            Las Palmas de Gran Canaria, España
          </p>
          <a
            href="https://www.linkedin.com/in/rubenliquenson-490961269"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-lg border transition-colors"
            style="border-color:#1E6FFF;color:#1E6FFF;"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            LinkedIn
          </a>
        </div>

        <!-- Right: detail -->
        <div class="lg:col-span-2 space-y-7">
          <p class="text-gray-600 leading-relaxed">
            DevOps Engineer with over 4 years of experience designing and operating production-grade cloud infrastructures on AWS. Specialized in Kubernetes (EKS), Terraform, CI/CD with Jenkins, and configuration automation with Ansible via AWS SSM. Builds complete platforms following the GitOps pattern, with integrated observability and security applied from design.
          </p>

          <!-- Stack -->
          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Stack</h3>
            <div class="flex flex-wrap gap-2">
              {['AWS', 'Kubernetes', 'Terraform', 'Ansible', 'Jenkins', 'Docker', 'ArgoCD', 'Helm', 'Prometheus', 'Grafana', 'Python', 'Bash'].map(t => (
                <span class="text-xs font-medium px-3 py-1 rounded-full" style="background:#EEF4FF;color:#1E6FFF;">{t}</span>
              ))}
            </div>
          </div>

          <!-- Certifications -->
          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Certifications</h3>
            <ul class="space-y-1.5">
              {[
                'ITLA — IT Essentials (2018–2019)',
                'INFOTEP — HP Information Technology Essential 1 (2018)',
                'AWS Solutions Architect (in progress)',
                'CKA Certified Kubernetes Administrator (in progress)',
              ].map(c => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="#22c55e" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  {c}
                </li>
              ))}
            </ul>
          </div>

          <!-- Experience -->
          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Experience</h3>
            <div class="space-y-4">
              {[
                { role: 'DevOps Engineer', company: 'Nibble Tech LLC', period: 'May 2026 – Present' },
                { role: 'DevOps Engineer', company: 'iCareMedical', period: 'May 2022 – May 2026 · 4 years' },
                { role: 'Linux System Administrator', company: 'DR Financial Services', period: 'Feb 2021 – Apr 2022' },
              ].map(e => (
                <div class="flex gap-4">
                  <div class="flex flex-col items-center">
                    <div class="w-3 h-3 rounded-full flex-shrink-0 mt-1" style="background:#1E6FFF;"></div>
                    <div class="w-px flex-1 mt-1" style="background:#e2e8f0;"></div>
                  </div>
                  <div class="pb-4">
                    <p class="font-semibold text-gray-900 text-sm">{e.role}</p>
                    <p class="text-gray-500 text-sm">{e.company}</p>
                    <p class="text-gray-400 text-xs mt-0.5">{e.period}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <hr class="border-gray-100" />

      <!-- ── KELVIN OSAIGBOVO ─────────────────────────────────────────────── -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-14 items-start">
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
          <img
            src="/team/kelvin-osaigbovo.png"
            alt="Kelvin Osaigbovo"
            width="180"
            height="180"
            class="rounded-full object-cover mb-5 shadow-lg"
            style="width:180px;height:180px;object-fit:cover;border-radius:50%;"
          />
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Kelvin Osaigbovo</h2>
          <span
            class="inline-block text-sm font-semibold px-3 py-1 rounded-full mb-4"
            style="background:#EEF4FF;color:#1E6FFF;"
          >DevOps Engineer &amp; Azure Specialist</span>
          <p class="text-sm text-gray-500 flex items-center gap-1 mb-1">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z"/></svg>
            UST España
          </p>
          <p class="text-sm text-gray-500 flex items-center gap-1 mb-5">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            Las Palmas de Gran Canaria, España
          </p>
          <a
            href="https://www.linkedin.com/in/kelvinosaigbovo"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-lg border transition-colors"
            style="border-color:#1E6FFF;color:#1E6FFF;"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            LinkedIn
          </a>
        </div>

        <div class="lg:col-span-2 space-y-7">
          <p class="text-gray-600 leading-relaxed">
            DevOps Engineer with over 4 years of experience building, deploying, and maintaining cloud environments. Strong focus on CI/CD pipelines, AWS and Azure architecture, and container technologies. Expert in Terraform, Ansible, Docker, Kubernetes, and core AWS services.
          </p>

          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Stack</h3>
            <div class="flex flex-wrap gap-2">
              {['AWS', 'Azure', 'Kubernetes', 'Docker', 'Terraform', 'Ansible', 'Jenkins', 'CI/CD', 'Python', 'Bash', 'Shell'].map(t => (
                <span class="text-xs font-medium px-3 py-1 rounded-full" style="background:#EEF4FF;color:#1E6FFF;">{t}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Certifications</h3>
            <ul class="space-y-1.5">
              {[
                'Microsoft Certified: Azure Fundamentals',
                'Introduction to Cybersecurity (Cisco)',
                'Helm Course',
                'Certificado de Español B1',
              ].map(c => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="#22c55e" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  {c}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Experience</h3>
            <div class="space-y-4">
              {[
                { role: 'Developer II DevOps Engineering', company: 'UST España', period: 'Jun 2025 – Present' },
                { role: 'DevOps Engineer', company: 'UST España', period: 'Jun 2024 – Jun 2025' },
                { role: 'DevOps Engineer', company: 'Intrum', period: 'Feb 2023 – Jun 2024' },
                { role: 'DevOps Engineer', company: 'Data Service Group', period: 'May 2019 – Feb 2023' },
                { role: 'Linux System Administrator', company: 'Data Service Group', period: 'Feb 2018 – Apr 2019' },
              ].map(e => (
                <div class="flex gap-4">
                  <div class="flex flex-col items-center">
                    <div class="w-3 h-3 rounded-full flex-shrink-0 mt-1" style="background:#1E6FFF;"></div>
                    <div class="w-px flex-1 mt-1" style="background:#e2e8f0;"></div>
                  </div>
                  <div class="pb-4">
                    <p class="font-semibold text-gray-900 text-sm">{e.role}</p>
                    <p class="text-gray-500 text-sm">{e.company}</p>
                    <p class="text-gray-400 text-xs mt-0.5">{e.period}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Education</h3>
            <ul class="space-y-1.5">
              {[
                "UNED — Bachelor's degree, Computer Engineering",
                "Yaba College of Technology — National Diploma, Science Lab Technology",
              ].map(e => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="#22c55e" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  {e}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <hr class="border-gray-100" />

      <!-- ── DARWIN POCHET ────────────────────────────────────────────────── -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-14 items-start">
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
          <img
            src="/team/darwin-pochet.png"
            alt="Darwin Pochet"
            width="180"
            height="180"
            class="rounded-full object-cover mb-5 shadow-lg"
            style="width:180px;height:180px;object-fit:cover;border-radius:50%;"
          />
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Darwin Pochet</h2>
          <span
            class="inline-block text-sm font-semibold px-3 py-1 rounded-full mb-4"
            style="background:#EEF4FF;color:#1E6FFF;"
          >CEO &amp; Founder — Network Infrastructure</span>
          <p class="text-sm text-gray-500 flex items-center gap-1 mb-1">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z"/></svg>
            Nibble Tech LLC
          </p>
          <p class="text-sm text-gray-500 flex items-center gap-1 mb-5">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            Raleigh, North Carolina, USA
          </p>
          <a
            href="https://www.linkedin.com/in/darwinpochet-156aa295"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-lg border transition-colors"
            style="border-color:#1E6FFF;color:#1E6FFF;"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            LinkedIn
          </a>
        </div>

        <div class="lg:col-span-2 space-y-7">
          <p class="text-gray-600 leading-relaxed">
            Experienced Network Administrator and CEO with strong background in IT services. Skilled in server management, Windows Server, Cisco Systems, and Active Directory. AI enthusiast and founder of Nibble Tech LLC, providing IT consulting to SMBs for over 8 years.
          </p>

          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Stack</h3>
            <div class="flex flex-wrap gap-2">
              {['Network Infrastructure', 'Windows Server', 'Cisco', 'Active Directory', 'Python', 'JavaScript', 'Node.js', 'AI/ML', 'VoIP', 'VPN', 'Firewall', 'VMware'].map(t => (
                <span class="text-xs font-medium px-3 py-1 rounded-full" style="background:#EEF4FF;color:#1E6FFF;">{t}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Certifications</h3>
            <ul class="space-y-1.5">
              {[
                'ITIL® 4 Foundation',
                'ICND2 3.0: Configuring Multiarea OSPFv2',
                'Cisco CCNA Networking',
                'The Guiding Principles of the Service Value System',
              ].map(c => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="#22c55e" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  {c}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Experience</h3>
            <div class="space-y-4">
              {[
                { role: 'Founder & CEO', company: 'Nibble Tech LLC', period: 'Mar 2018 – Present · 8 years' },
                { role: 'IT Specialist', company: 'HCLTech', period: 'May 2022 – Jan 2024' },
                { role: 'Chief Information Officer', company: 'Help On The Way Inc', period: 'Sep 2018 – Dec 2020' },
                { role: 'Network Administrator', company: 'ISAMANET Call Center', period: 'Oct 2010 – May 2015' },
              ].map(e => (
                <div class="flex gap-4">
                  <div class="flex flex-col items-center">
                    <div class="w-3 h-3 rounded-full flex-shrink-0 mt-1" style="background:#1E6FFF;"></div>
                    <div class="w-px flex-1 mt-1" style="background:#e2e8f0;"></div>
                  </div>
                  <div class="pb-4">
                    <p class="font-semibold text-gray-900 text-sm">{e.role}</p>
                    <p class="text-gray-500 text-sm">{e.company}</p>
                    <p class="text-gray-400 text-xs mt-0.5">{e.period}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── STATS ─────────────────────────────────────────────────────────────── -->
  <section class="py-16" style="background:#F8FAFC;">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: '10+', label: 'Years Combined Experience' },
          { value: '3', label: 'Cloud Providers\nAWS · Azure · GCP' },
          { value: '15+', label: 'Production Projects' },
          { value: '4+', label: 'Years Average Experience' },
        ].map(s => (
          <div>
            <p class="text-4xl font-bold mb-2" style="color:#1E6FFF;">{s.value}</p>
            <p class="text-sm text-gray-500 whitespace-pre-line leading-snug">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────────────────────── -->
  <section class="py-20" style="background:#0D1B2E;">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Work with our team</h2>
      <p class="text-[#94a3b8] text-lg mb-8 leading-relaxed">
        Ready to build production-grade infrastructure? Let's talk about your project.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 font-semibold px-8 py-4 rounded-xl transition-all text-white"
        style="background:#1E6FFF;"
      >
        Schedule a consultation
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>
</Layout>
