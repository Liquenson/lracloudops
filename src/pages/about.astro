                width={400}
                height={400}
                format="webp"
                quality={85}
                loading="lazy"
                decoding="async"
                class="w-32 h-32 rounded-full object-cover"
                style="border: 3px solid #c3d9ff;"
              />
            </div>
            <div class="flex-1 min-w-0">
              <div
