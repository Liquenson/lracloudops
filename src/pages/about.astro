---
import Layout from '../layouts/Layout.astro'
import { Image } from 'astro:assets'
---

<Layout
  titulo="Our Team | DevOps Engineers & Cloud Architects | LRA Cloud Operations"
  descripcion="The LRA Cloud Operations team. Platform engineers specializing in AWS, Kubernetes, Terraform and GitOps. Production workloads delivered as code."
  keywords="DevOps engineers Spain, AWS certified team Las Palmas, Kubernetes specialists Canary Islands, cloud infrastructure consultants Spain, HashiCorp certified Terraform, DevOps team hire Spain"
>
  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>

    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <span
        class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        About
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Infrastructure built for production.
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        Platform engineers focused on cloud infrastructure, automation and
        operational reliability. We design and operate AWS environments,
        Kubernetes platforms and delivery pipelines — as code, from day one.
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.6);">
        AWS · Kubernetes · Terraform · GitOps · Platform Engineering ·
        Observability
      </p>
    </div>
  </section>

  <!-- ─── NUESTRO EQUIPO ───────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span
          class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
          style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
        >
          Team
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">
          The team
        </h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          Platform engineers with production experience in AWS, Kubernetes,
          Terraform and GitOps.
        </p>
      </div>

      <div class="space-y-10">
        <!-- ── LIQUENSON RUBEN ── -->
        <div
          class="bg-white rounded-2xl p-8 sm:p-10 transition-all duration-200 hover:-translate-y-1"
          style="border: 1px solid #e2e8f0; border-left: 3px solid #1E6FFF; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 8px 32px rgba(10,37,64,0.09); border-radius: 16px;"
        >
          <div class="flex justify-center sm:justify-start mb-6">
            <span
              class="inline-flex items-center gap-2 text-xs font-semibold px-4 py-2 rounded-full"
              style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;"
