---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Servicios"
  descripcion="Servicios profesionales de Cloud Operations, DevOps, Kubernetes, Terraform y CI/CD con más de 4 años de experiencia real en producción."
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6" style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);">
          Servicios Cloud & DevOps
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-5" style="letter-spacing: -0.02em;">
          Soluciones cloud con<br />experiencia real en producción
        </h1>
        <p class="text-lg" style="color: rgba(147,184,255,0.8);">
          Cada servicio está respaldado por proyectos reales — no demos, no tutoriales.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  {[
    {
      icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
      titulo: 'AWS Cloud Infrastructure',
      desc: 'Diseño y gestión de infraestructuras multi-AZ altamente disponibles y tolerantes a fallos en AWS. Desde arquitecturas simples hasta entornos complejos con múltiples cuentas y zonas de disponibilidad.',
      items: [
        'VPC, subnets públicas y privadas, NAT Gateways',
        'EC2, ECS, EKS — según el caso de uso',
        'RDS, S3, CloudFront, Route 53, ACM',
        'IAM, Security Groups, políticas de acceso mínimo',
        'CloudWatch, alertas y dashboards de monitoreo',
      ],
      tags: ['EC2','ECS','EKS','ECR','RDS','S3','CloudFront','Route53','CloudWatch','VPC','IAM'],
    },
    {
      icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
      titulo: 'Infrastructure as Code',
      desc: 'Infraestructura reproducible, versionada y auditada. Entornos DEV, TEST y PROD consistentes desde el primer día, sin configuración manual y sin sorpresas.',
      items: [
        'Módulos Terraform reutilizables y versionados',
        'Gestión de estado remoto con S3 + DynamoDB',
        'Ansible para gestión de configuración y parches',
        'Entornos DEV/TEST/PROD desde variables',
        'Revisión de cambios antes de aplicar (plan)',
      ],
      tags: ['Terraform','Ansible','Git','S3 Backend','DynamoDB Lock','tfvars','Workspaces'],
    },
    {
      icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
      titulo: 'CI/CD Pipelines',
      desc: 'Pipelines completamente automatizados con calidad de código integrada en cada despliegue. Desde el commit hasta producción sin intervención manual.',
      items: [
        'Integración con GitHub Actions y Jenkins',
        'Build, test, análisis de calidad y deploy automático',
        'SonarCloud para análisis estático de código',
        'ArgoCD para GitOps en Kubernetes',
        'OIDC para autenticación AWS sin credenciales estáticas',
      ],
      tags: ['Jenkins','GitHub Actions','ArgoCD','SonarCloud','Docker','ECR','OIDC'],
    },
    {
      icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
      titulo: 'Kubernetes & Contenedores',
      desc: 'Orquestación de contenedores en producción con despliegues GitOps, gestión con Helm y escalado automático. Kubernetes sin fricción.',
      items: [
        'Clusters EKS en AWS con nodos administrados',
        'Helm Charts para despliegues reproducibles',
        'GitOps con ArgoCD — código como fuente de verdad',
        'Docker multi-stage para imágenes optimizadas',
        'Autoscaling horizontal y vertical (HPA/VPA)',
      ],
      tags: ['Kubernetes','Docker','Helm','EKS','ArgoCD','Docker Compose','KinD'],
    },
    {
      icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
      titulo: 'Observabilidad & SRE',
      desc: 'Visibilidad total de la infraestructura con alertas proactivas y dashboards en tiempo real. Detecta problemas antes de que afecten a los usuarios.',
      items: [
        'Prometheus para recolección de métricas',
        'Grafana para dashboards personalizados',
        'CloudWatch para logs y alertas en AWS',
        'Alertas proactivas por email y canales',
        'SLIs, SLOs y error budgets para SRE',
      ],
      tags: ['Prometheus','Grafana','CloudWatch','Alertmanager','HAProxy'],
    },
    {
      icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
      titulo: 'Linux & Automatización',
      desc: 'Administración de servidores Linux y automatización de tareas repetitivas. Menos trabajo manual, más tiempo para lo que importa.',
      items: [
        'Administración de CentOS, Ubuntu, RHEL y Debian',
        'Scripts Bash para automatización de flotas',
        'Gestión de volúmenes con LVM',
        'Python para automatizaciones avanzadas con boto3',
        'Fleet management: inventario, parches, compliance',
      ],
      tags: ['Ubuntu','CentOS','Red Hat','Debian','Bash','Python','LVM','VMware'],
    },
  ].map((s, i) => (
    <section class={`border-t border-gray-100 ${i % 2 === 1 ? 'bg-gray-50/50' : 'bg-white'}`}>
      <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid lg:grid-cols-2 gap-12 items-start">

          <!-- Left: Info -->
          <div>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: #EEF4FF;">
              <svg class="w-6 h-6" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={s.icon} />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-4" style="color: #0A2540;">{s.titulo}</h2>
            <p class="leading-relaxed mb-7" style="color: #64748b;">{s.desc}</p>
            <ul class="space-y-2.5">
              {s.items.map(item => (
                <li class="flex items-start gap-2.5 text-sm" style="color: #64748b;">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-2" style="background: #1E6FFF;"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: Tags -->
          <div class="rounded-2xl p-7" style="background: #f8fafc; border: 1px solid #e2e8f0;">
            <p class="text-xs font-semibold uppercase tracking-widest mb-5" style="color: #94a3b8;">Stack tecnológico</p>
            <div class="flex flex-wrap gap-2">
              {s.tags.map(t => (
                <span class="text-xs font-medium px-3 py-1.5 rounded-full bg-white border border-gray-200" style="color: #374151;">{t}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(30,111,255,0.12) 0%, transparent 70%);"></div>
    <div class="relative max-w-4xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" style="letter-spacing: -0.02em;">¿Tienes un proyecto en mente?</h2>
      <p class="mb-9 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        Cuéntame qué estás construyendo y diseñamos la arquitectura cloud que necesitas.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02] hover:shadow-xl"
          style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 20px rgba(30,111,255,0.4);"
        >
          Agenda una consulta
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/proyectos"
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);"
        >
          Ver proyectos
        </a>
      </div>
    </div>
  </section>

</Layout>
