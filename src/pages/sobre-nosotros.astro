---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Sobre Nosotros · Ingeniería orientada a producción"
  descripcion="Conoce al equipo de LRA Cloud Operations. Ingenieros DevOps especializados en AWS, Kubernetes, Terraform y Platform Engineering con más de 4 años de experiencia en producción."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"></div>

    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6" style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);">
        Sobre nosotros
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6" style="letter-spacing: -0.02em;">
        Ingeniería orientada a producción
      </h1>
      <p class="text-lg leading-relaxed max-w-2xl mx-auto" style="color: rgba(147,184,255,0.8);">
        Desarrollamos plataformas cloud-native aplicando prácticas modernas de Platform Engineering, automatización de infraestructura, Kubernetes, observabilidad y despliegues continuos sobre AWS.
      </p>
    </div>
  </section>

  <!-- ─── CARD DEL LÍDER ───────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-6">

      <div class="bg-white rounded-2xl p-8 sm:p-10" style="border: 1px solid #e2e8f0; box-shadow: 0 8px 40px rgba(10,37,64,0.10); border-radius: 16px;">
        <div class="flex flex-col sm:flex-row gap-8 items-start">

          <!-- Avatar -->
          <div class="flex-shrink-0">
            <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-2xl font-bold text-white select-none" style="background: linear-gradient(135deg, #1E6FFF 0%, #0A2540 100%); letter-spacing: -0.01em;">
              LR
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
              <div>
                <h2 class="text-2xl font-bold mb-1" style="color: #0A2540;">Liquenson Ruben</h2>
                <div class="flex items-center gap-1.5 text-sm" style="color: #64748b;">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Las Palmas de Gran Canaria, España
                </div>
              </div>
              <a
                href="https://www.linkedin.com/in/liquenson-ruben-490961269/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-semibold text-white px-4 py-2.5 rounded-xl flex-shrink-0 transition-all hover:opacity-90 hover:scale-[1.02]"
                style="background: linear-gradient(135deg, #0A66C2 0%, #004182 100%); box-shadow: 0 2px 10px rgba(10,102,194,0.3);"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
                <svg class="w-3.5 h-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>

            <!-- Role pills -->
            <div class="flex flex-wrap gap-2 mb-5">
              {['DevOps Engineer', 'Platform Engineer', 'Cloud Engineer', 'Linux SysAdmin'].map(role => (
                <span class="text-xs font-semibold px-3 py-1.5 rounded-full" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
                  {role}
                </span>
              ))}
            </div>

            <p class="text-sm leading-relaxed mb-6" style="color: #64748b;">
              Ingeniero DevOps con más de 4 años diseñando, desplegando y manteniendo infraestructuras cloud escalables y altamente disponibles en AWS. Especializado en IaC con Terraform, orquestación con Kubernetes, Platform Engineering y automatización de pipelines CI/CD.
            </p>

            <!-- Stack tags -->
            <div class="flex flex-wrap gap-1.5">
              {['AWS', 'Terraform', 'Kubernetes', 'Docker', 'Jenkins', 'GitHub Actions', 'Prometheus', 'Grafana', 'Ansible', 'Bash', 'Python'].map(tag => (
                <span class="text-xs px-2.5 py-1 rounded-full" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0;">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── EXPERIENCIA ───────────────────────────────────────────────────── -->
  <section style="background-color: #EEF4FF;" class="py-20">
    <div class="max-w-4xl mx-auto px-6">

      <div class="text-center mb-14">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4" style="background: white; color: #1E6FFF; border: 1px solid #c3d9ff;">
          Trayectoria profesional
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">Experiencia</h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          Entornos reales de producción. Infraestructura que funciona bajo presión.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 sm:left-8 top-0 bottom-0 w-px" style="background: linear-gradient(180deg, #1E6FFF 0%, #c3d9ff 100%);"></div>

        <div class="space-y-10">

          <!-- iCareMedical -->
          <div class="relative flex gap-6 sm:gap-10">
            <!-- Dot -->
            <div class="flex-shrink-0 w-12 sm:w-16 flex justify-center">
              <div class="relative mt-1">
                <div class="w-4 h-4 rounded-full border-2 border-white z-10 relative" style="background: #1E6FFF; box-shadow: 0 0 0 3px rgba(30,111,255,0.2);"></div>
              </div>
            </div>

            <!-- Content -->
            <div class="flex-1 pb-2">
              <div class="bg-white rounded-2xl p-6 sm:p-8" style="border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(10,37,64,0.07); border-radius: 16px;">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
                  <div>
                    <h3 class="text-lg font-bold" style="color: #0A2540;">iCareMedical</h3>
                    <p class="text-sm font-semibold mt-0.5" style="color: #1E6FFF;">Ingeniero DevOps</p>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0"></span>
                    <span class="text-xs font-medium px-3 py-1.5 rounded-full whitespace-nowrap" style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;">mayo 2022 – presente</span>
                  </div>
                </div>
                <ul class="space-y-2.5">
                  {[
                    'Diseñé e implementé pipelines CI/CD completos en AWS con Jenkins, Maven y SonarQube.',
                    'Infraestructura multi-AZ con Terraform cubriendo VPC, EC2, S3, CloudFront, RDS, Route 53 y CloudWatch.',
                    'Orquestación de contenedores con Kubernetes y Helm en producción.',
                    'Automatización con Ansible para gestión de configuración y aprovisionamiento de servidores.',
                    'Monitoreo y observabilidad con Prometheus y Grafana.',
                  ].map(bullet => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748b;">
                      <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-2" style="background: #1E6FFF;"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-5 pt-5 border-t border-gray-100">
                  {['AWS', 'Terraform', 'Kubernetes', 'Helm', 'Jenkins', 'Ansible', 'Prometheus', 'Grafana'].map(tag => (
                    <span class="text-xs px-2.5 py-1 rounded-full" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0;">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- DR Financial Services -->
          <div class="relative flex gap-6 sm:gap-10">
            <!-- Dot -->
            <div class="flex-shrink-0 w-12 sm:w-16 flex justify-center">
              <div class="relative mt-1">
                <div class="w-4 h-4 rounded-full border-2 border-white z-10 relative" style="background: #64748b; box-shadow: 0 0 0 3px rgba(100,116,139,0.2);"></div>
              </div>
            </div>

            <!-- Content -->
            <div class="flex-1 pb-2">
              <div class="bg-white rounded-2xl p-6 sm:p-8" style="border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(10,37,64,0.07); border-radius: 16px;">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
                  <div>
                    <h3 class="text-lg font-bold" style="color: #0A2540;">DR Financial Services</h3>
                    <p class="text-sm font-semibold mt-0.5" style="color: #1E6FFF;">Administrador de Sistemas Linux</p>
                  </div>
                  <span class="text-xs font-medium px-3 py-1.5 rounded-full whitespace-nowrap self-start sm:self-auto" style="background: #f3f4f6; color: #4b5563; border: 1px solid #e5e7eb;">feb 2021 – abr 2022</span>
                </div>
                <ul class="space-y-2.5">
                  {[
                    'Administración de servidores RHEL, CentOS, Ubuntu y Debian en entornos VMware.',
                    'Automatización de tareas operativas con scripts Bash.',
                    'Gestión de LVM, usuarios, permisos y almacenamiento en producción.',
                  ].map(bullet => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748b;">
                      <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-2" style="background: #64748b;"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-5 pt-5 border-t border-gray-100">
                  {['RHEL', 'CentOS', 'Ubuntu', 'Debian', 'VMware', 'Bash', 'LVM'].map(tag => (
                    <span class="text-xs px-2.5 py-1 rounded-full" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0;">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── STACK TÉCNICO ─────────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-6">

      <div class="text-center mb-14">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
          Especialización técnica
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">Stack tecnológico</h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          Dominio completo del ciclo de vida de infraestructura cloud, desde la provisión hasta la observabilidad.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        {[
          {
            icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
            title: 'Cloud & AWS',
            items: ['EC2 · EBS · EKS · ECS · ECR', 'RDS · S3 · CloudFront', 'Route 53 · CloudWatch', 'VPC · NAT Gateways · IAM'],
          },
          {
            icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
            title: 'IaC & Automatización',
            items: ['Terraform modular multi-entorno', 'Ansible (playbooks & roles)', 'State remoto en S3', 'Bash · Python scripting'],
          },
          {
            icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
            title: 'Contenedores & Orquestación',
            items: ['Docker (multi-stage builds)', 'Kubernetes · Helm Charts', 'ArgoCD (GitOps)', 'Autoscaling HPA'],
          },
          {
            icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
            title: 'CI/CD & DevOps',
            items: ['Jenkins · GitHub Actions', 'Maven · SonarQube · Nexus', 'ArgoCD · Docker pipelines', 'OIDC auth para AWS'],
          },
          {
            icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            title: 'Monitoreo & Observabilidad',
            items: ['Prometheus · Grafana', 'Alertmanager', 'CloudWatch dashboards', 'Métricas · Logs · Alertas'],
          },
          {
            icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            title: 'Sistemas & Scripting',
            items: ['CentOS · Ubuntu · Red Hat', 'Gestión LVM · usuarios · permisos', 'Entornos VMware', 'TCP/IP · DNS · Redes'],
          },
        ].map(({ icon, title, items }) => (
          <div class="bg-white rounded-2xl p-6 group hover:-translate-y-1 transition-all duration-200" style="border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(10,37,64,0.07);">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 flex items-center justify-center rounded-xl flex-shrink-0" style="background: #EEF4FF;">
                <svg class="w-5 h-5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                </svg>
              </div>
              <h3 class="text-sm font-bold" style="color: #0A2540;">{title}</h3>
            </div>
            <ul class="space-y-2">
              {items.map(item => (
                <li class="flex items-start gap-2.5 text-sm" style="color: #64748b;">
                  <span class="w-1 h-1 rounded-full flex-shrink-0 mt-2" style="background: #1E6FFF;"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(30,111,255,0.15) 0%, transparent 65%);"></div>

    <div class="relative max-w-3xl mx-auto px-6 py-24 text-center">
      <span class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-8" style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 mr-2 flex-shrink-0"></span>
        Disponibles · Respondemos en menos de 24 horas
      </span>

      <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-5" style="letter-spacing: -0.02em;">
        ¿Quieres trabajar<br />con nosotros?
      </h2>

      <p class="text-lg mb-10 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        Cuéntanos tu proyecto. Evaluamos tu infraestructura actual y diseñamos el camino hacia una plataforma cloud escalable, segura y automatizada.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02] hover:shadow-xl active:scale-[0.98]"
          style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 24px rgba(30,111,255,0.4);"
        >
          Cuéntanos tu proyecto
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/proyectos"
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);"
        >
          Ver nuestros proyectos
        </a>
      </div>
    </div>
  </section>

</Layout>
