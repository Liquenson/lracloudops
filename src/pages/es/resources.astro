              style="background: linear-gradient(135deg, #FF9900 0%, #E07B00 100%); box-shadow: 0 4px 12px rgba(255,153,0,0.3);"
            >
              <svg
                class="w-7 h-7 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
