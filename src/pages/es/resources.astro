                  d="M9 5l7 7-7 7"></path></svg
              >
              Ver Arquitectura
            </a>
          </div>
        </div>
      </div>

      <!-- ─── FORMULARIO DE DESCARGA ──────────────────────────────────────── -->
      <div
        id="download-form-section"
        class="max-w-xl mx-auto rounded-2xl p-10 text-center"
        style="background: white; border: 1px solid #e2e8f0; box-shadow: 0 4px 24px rgba(10,37,64,0.10);"
      >
        <div
          class="w-14 h-14 flex items-center justify-center rounded-2xl mx-auto mb-5"
          style="background: #EEF4FF;"
        >
          <svg
            class="w-6 h-6"
            style="color: #1E6FFF;"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </div>
        <h3
          class="text-xl font-bold mb-2"
          style="color: #0A2540;"
          id="form-resource-title"
        >
          Selecciona un recurso arriba para descargar
        </h3>
        <p class="text-sm mb-7" style="color: #64748b;">
          Introduce tu email de trabajo y te lo enviaremos a tu bandeja de
          entrada. Sin spam, sin campañas de email.
        </p>

        <form id="resource-form" class="space-y-3">
          <input
            type="hidden"
            name="access_key"
            value="e8aaab4e-270c-4163-bb76-6a8dfc247485"
          />
          <input
            type="hidden"
            name="subject"
            id="form-subject"
            value="Descarga de Recurso - LRA Cloud Ops"
          />
          <input type="hidden" name="from_name" value="LRA Cloud Operations" />
          <input
            type="hidden"
            name="resource_requested"
            id="form-resource-hidden"
            value=""
          />
          <input
            type="email"
            name="email"
            required
            placeholder="tu@empresa.com"
            class="w-full px-4 py-3.5 text-sm rounded-xl outline-none transition-all"
            style="background: #F8FAFC; color: #111827; border: 1px solid #e2e8f0;"
            onfocus="this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.2)'; this.style.borderColor='#93b8ff';"
            onblur="this.style.boxShadow='none'; this.style.borderColor='#e2e8f0';"
          />
          <button
            type="submit"
            id="resource-submit-btn"
            class="w-full text-sm font-bold px-6 py-3.5 rounded-xl transition-all hover:-translate-y-px active:scale-[0.98]"
            style="background: #1E6FFF; color: white; box-shadow: 0 4px 16px rgba(30,111,255,0.4); opacity: 0.5; cursor: not-allowed;"
          >
            Enviarme el recurso &rarr;
          </button>
        </form>

        <div
          id="resource-status"
          class="hidden text-sm mt-4 px-4 py-2.5 rounded-lg"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2
        class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
        style="letter-spacing: -0.02em;"
      >
        ¿Necesitas una revisión de arquitectura de producción?
      </h2>
      <p
        class="text-base mb-8 max-w-xl mx-auto"
        style="color: rgba(147,184,255,0.8);"
      >
        Agenda una llamada gratuita de 30 minutos. Revisaremos tu setup actual y
        definiremos una hoja de ruta concreta.
      </p>
      <a
        href="/contacto"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02]"
        style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 24px rgba(30,111,255,0.4);"
      >
        Agendar consulta gratuita
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll(
    '.resource-download-btn'
  ) as NodeListOf<HTMLButtonElement>
  const formSection = document.getElementById('download-form-section')
  const formTitle = document.getElementById('form-resource-title')
  const formSubject = document.getElementById(
    'form-subject'
  ) as HTMLInputElement | null
  const formHidden = document.getElementById(
    'form-resource-hidden'
  ) as HTMLInputElement | null
  const submitBtn = document.getElementById(
    'resource-submit-btn'
  ) as HTMLButtonElement | null
  const form = document.getElementById(
    'resource-form'
  ) as HTMLFormElement | null
  const statusEl = document.getElementById(
    'resource-status'
  ) as HTMLDivElement | null

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const resource = btn.dataset.resource ?? ''
      if (formTitle) formTitle.textContent = resource
      if (formSubject)
        formSubject.value = `Descarga de Recurso: ${resource} - LRA Cloud Ops`
      if (formHidden) formHidden.value = resource
      if (submitBtn) {
        submitBtn.disabled = false
        submitBtn.style.opacity = '1'
        submitBtn.style.cursor = 'pointer'
      }
      formSection?.scrollIntoView({ behavior: 'smooth', block: 'start' })
    })
  })

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!submitBtn || !statusEl) return
    const original = submitBtn.textContent
    submitBtn.textContent = 'Enviando...'
    submitBtn.disabled = true

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      })
      const data = await res.json()
      if (data.success) {
        statusEl.textContent =
          '¡Revisa tu bandeja de entrada! Te enviaremos el recurso en breve.'
        statusEl.style.cssText =
          'display:block; background: rgba(16,185,129,0.1); color: #059669; border: 1px solid rgba(16,185,129,0.3); border-radius: 10px; padding: 12px 16px;'
        form.reset()
        submitBtn.textContent = 'Enviado ✓'
      } else {
        statusEl.textContent = 'Algo salió mal. Por favor, inténtalo de nuevo.'
        statusEl.style.cssText =
          'display:block; background: rgba(239,68,68,0.1); color: #DC2626; border: 1px solid rgba(239,68,68,0.3); border-radius: 10px; padding: 12px 16px;'
        submitBtn.textContent = original
        submitBtn.disabled = false
      }
    } catch {
      statusEl.textContent = 'Error de conexión. Por favor, inténtalo de nuevo.'
      statusEl.style.cssText =
        'display:block; background: rgba(239,68,68,0.1); color: #DC2626; border: 1px solid rgba(239,68,68,0.3); border-radius: 10px; padding: 12px 16px;'
      submitBtn.textContent = original
      submitBtn.disabled = false
    }
    statusEl.classList.remove('hidden')
  })
</script>
