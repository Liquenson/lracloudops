---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Recursos de Ingeniería · LRA Cloud Operations"
  descripcion="Recursos de ingeniería de nivel producción: checklists AWS, guías de seguridad Kubernetes, playbooks GitOps y mejores prácticas Terraform. Descarga gratuita."
  keywords="recursos DevOps, checklist AWS producción, guía seguridad Kubernetes, playbook GitOps, mejores prácticas Terraform, PDF ingeniería cloud"
>
  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.2) 0%, transparent 65%);"
    >
    </div>

    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <span
        class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        Recursos Gratuitos
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Recursos Técnicos
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        Guías y recursos basados en despliegues reales en AWS, Kubernetes y
        GitOps. Usados por nuestro equipo en cada proyecto. Descarga gratuita.
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.5);">
        Guías PDF &middot; Sin spam &middot; Enviadas a tu bandeja de entrada
      </p>
    </div>
  </section>

