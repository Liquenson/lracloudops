---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---
<Layout
  title="Pago confirmado — LRA CloudOps"
  description="Tu pago ha sido confirmado. Nos pondremos en contacto en menos de 24 horas."
  lang="es"
>
  <Header lang="es" />

  <section style="background:linear-gradient(135deg,#FFFFFF 0%,#F0F4FF 50%,#FFFFFF 100%);padding:6rem var(--container-px);min-height:60vh;display:flex;align-items:center;">
    <div style="max-width:640px;margin-inline:auto;text-align:center;">

      <div style="width:80px;height:80px;background:var(--color-success-light);border-radius:var(--radius-full);display:flex;align-items:center;justify-content:center;margin:0 auto var(--space-6);">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <h1 style="font-family:var(--font-display);font-size:clamp(var(--text-3xl),4vw,var(--text-5xl));font-weight:700;color:var(--color-text);margin-bottom:var(--space-4);">
        Pago confirmado.
      </h1>

      <p style="font-family:var(--font-body);font-size:var(--text-xl);color:var(--color-text-secondary);line-height:1.7;margin-bottom:var(--space-8);">
        Gracias. Recibirás un email de confirmación en breve.
        Para solicitudes de auditoría, lra scan comenzará automáticamente —
        espera tu informe en menos de 24 horas.
      </p>

      <div style="background:#FFFFFF;border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-6);margin-bottom:var(--space-8);text-align:left;">
        <h2 style="font-family:var(--font-display);font-size:var(--text-xl);font-weight:700;color:var(--color-text);margin-bottom:var(--space-4);">Qué ocurre a continuación</h2>
        <div style="display:flex;flex-direction:column;gap:var(--space-4);">
          {[
            { step: '01', text: 'Recibes una confirmación de pago de Stripe.' },
            { step: '02', text: 'Ruben revisa tu solicitud y confirma el alcance en menos de 24 horas.' },
            { step: '03', text: 'Para auditorías, lra scan corre automáticamente y entrega tu informe por email.' },
            { step: '04', text: 'Para proyectos, recibes un mensaje de inicio con el calendario y los entregables.' },
          ].map(({ step, text }) => (
            <div style="display:flex;align-items:start;gap:var(--space-4);">
              <span style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:700;color:var(--color-primary);background:var(--color-primary-light);padding:0.25rem var(--space-3);border-radius:var(--radius-sm);flex-shrink:0;">{step}</span>
              <p style="font-family:var(--font-body);font-size:var(--text-md);color:var(--color-text-secondary);margin:0;line-height:1.6;">{text}</p>
            </div>
          ))}
        </div>
      </div>

      <div style="display:flex;gap:var(--space-4);justify-content:center;flex-wrap:wrap;">
        <a href="/es/"
          style="display:inline-flex;align-items:center;gap:var(--space-2);background:var(--color-primary);color:#FFFFFF;padding:0.75rem var(--space-6);border-radius:var(--radius-md);font-family:var(--font-body);font-size:var(--text-md);font-weight:600;text-decoration:none;"
        >Volver al inicio</a>
        <a href="mailto:info@lracloudops.com"
          style="display:inline-flex;align-items:center;gap:var(--space-2);background:transparent;color:var(--color-primary);padding:0.75rem var(--space-6);border-radius:var(--radius-md);border:1px solid var(--color-primary-border);font-family:var(--font-body);font-size:var(--text-md);font-weight:600;text-decoration:none;"
        >Contactar</a>
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>
