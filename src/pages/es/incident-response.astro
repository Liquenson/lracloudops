---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Incident Response Agent · Diagnóstico de Incidencias Cloud · AI-Powered · Gratis"
  descripcion="Diagnostica incidencias en producción en segundos. Causa probable, pasos de investigación y plan de remediación para Kubernetes, AWS, RDS y más."
>
  <!-- HERO -->
  <section
    class="relative overflow-hidden"
    style="background: #0A2540;"
    aria-labelledby="ir-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.1) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-7 text-xs font-bold tracking-widest uppercase"
        style="background: rgba(220,38,38,0.2); border: 1px solid rgba(252,165,165,0.35); color: #FCA5A5;"
      >
        <span
          class="w-2 h-2 rounded-full flex-shrink-0"
          style="background: #F87171; animation: pulse 1s infinite;"
          aria-hidden="true"></span>
        AI-Powered · Respuesta inmediata
      </div>
      <h1
        id="ir-hero-heading"
        class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight"
        style="letter-spacing: -0.035em;"
      >
        Incident Response Agent
      </h1>
      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto"
        style="color: rgba(147,184,255,0.85);"
      >
        Diagnostica incidencias en producción en segundos. Causa probable, pasos
        de investigación y plan de remediación paso a paso.
      </p>
    </div>
  </section>

  <!-- FORM + RESULTS -->
  <section
    class="bg-white py-16"
    aria-label="Formulario de diagnóstico de incidencia"
  >
    <div class="max-w-3xl mx-auto px-6">
      <form id="ir-form" class="space-y-5" novalidate>
        <div>
          <label
            for="ir-symptoms"
            class="block text-sm font-semibold mb-2"
            style="color: #0F172A;"
          >
            ¿Qué síntomas estás viendo?
            <span class="font-normal text-xs ml-1" style="color: #64748B;"
              >(requerido)</span
            >
          </label>
          <textarea
            id="ir-symptoms"
            rows="4"
            placeholder="Ejemplo: Los pods del servicio de pagos están en CrashLoopBackOff desde hace 15 minutos. Los clientes no pueden completar compras. El error en los logs es 'OOMKilled'. El deployment tiene 3 réplicas y todas fallan..."
            class="w-full px-4 py-3 rounded-xl text-sm border resize-none focus:outline-none focus:ring-2"
            style="border-color: #E2E8F0; color: #0F172A;"></textarea>
        </div>
        <div>
          <label
            for="ir-infra"
            class="block text-sm font-semibold mb-2"
            style="color: #0F172A;"
          >
            Infraestructura afectada
            <span class="font-normal text-xs ml-1" style="color: #64748B;"
              >(opcional)</span
            >
          </label>
          <input
            id="ir-infra"
            type="text"
            placeholder="Ej: EKS 1.28, RDS PostgreSQL 15, Node t3.xlarge, región us-east-1"
            class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none focus:ring-2"
            style="border-color: #E2E8F0; color: #0F172A;"
          />
        </div>
        <div>
          <label
            for="ir-logs"
            class="block text-sm font-semibold mb-2"
            style="color: #0F172A;"
          >
            Logs o mensajes de error
            <span class="font-normal text-xs ml-1" style="color: #64748B;"
              >(opcional pero muy útil)</span
            >
          </label>
          <textarea
            id="ir-logs"
            rows="5"
            placeholder="Pega aquí tus logs, stack traces, mensajes de error de CloudWatch, kubectl describe pod, etc."
            class="w-full px-4 py-3 rounded-xl text-sm border resize-none focus:outline-none focus:ring-2 font-mono"
            style="border-color: #E2E8F0; color: #0F172A; font-size: 12px;"
          ></textarea>
        </div>
        <button
          type="submit"
          id="ir-submit"
          class="w-full inline-flex items-center justify-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.01]"
          style="background: #DC2626; box-shadow: 0 4px 20px rgba(220,38,38,0.4);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            ></path>
          </svg>
          <span id="ir-btn-text">Diagnosticar incidencia →</span>
        </button>
        <p id="ir-error" class="hidden text-sm text-red-600 text-center"></p>
      </form>

      <!-- Loading -->
      <div id="ir-loading" class="hidden text-center py-16">
        <div
          class="inline-flex items-center gap-3 px-6 py-4 rounded-2xl"
          style="background: #FFF5F5; border: 1px solid #FCA5A5;"
        >
          <svg
            class="w-5 h-5 animate-spin"
            style="color: #DC2626;"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="text-sm font-medium" style="color: #DC2626;"
            >Analizando la incidencia...</span
          >
        </div>
      </div>

      <!-- Results -->
      <div id="ir-results" class="hidden mt-10 space-y-6">
        <!-- Severity + cause -->
        <div class="rounded-2xl p-8" style="background: #0A2540;">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
            <div>
              <p
                class="text-xs font-bold uppercase tracking-widest mb-2"
                style="color: #93C5FD;"
              >
                Severidad
              </p>
              <div id="ir-severity" class="text-4xl font-extrabold"></div>
            </div>
            <div class="text-right">
              <p
                class="text-xs font-semibold uppercase tracking-widest mb-1"
                style="color: #93C5FD;"
              >
                Confianza
              </p>
              <div
                id="ir-confidence"
                class="text-3xl font-extrabold"
                style="color: #60A5FA;"
              >
              </div>
              <p class="text-xs" style="color: rgba(147,184,255,0.6);">%</p>
            </div>
          </div>
          <p
            class="text-xs font-bold uppercase tracking-widest mb-1"
            style="color: #93C5FD;"
          >
            Causa probable
          </p>
          <p id="ir-cause" class="text-base font-semibold text-white mb-3"></p>
          <p
            id="ir-summary"
            class="text-sm leading-relaxed"
            style="color: rgba(147,184,255,0.8);"
          >
          </p>
        </div>

        <!-- Timeline -->
        <div
          id="ir-timeline-section"
          class="hidden rounded-2xl p-6"
          style="border: 1px solid #E5E7EB;"
        >
          <h2 class="text-base font-bold mb-4" style="color: #0F172A;">
            Timeline de la incidencia
          </h2>
          <div id="ir-timeline" class="space-y-3"></div>
        </div>

        <!-- Investigation steps -->
        <div
          class="rounded-2xl p-6"
          style="background: #F8FAFF; border: 1px solid #BFDBFE;"
        >
          <h2 class="text-base font-bold mb-4" style="color: #1E40AF;">
            Pasos de investigación
          </h2>
          <div id="ir-steps" class="space-y-4"></div>
        </div>

        <!-- Immediate remediation -->
        <div
          class="rounded-2xl p-6"
          style="background: #FFF5F5; border: 1px solid #FCA5A5;"
        >
          <h2 class="text-base font-bold mb-3" style="color: #DC2626;">
            Remediación inmediata
          </h2>
          <ul id="ir-remediation" class="space-y-2"></ul>
        </div>

        <!-- Root cause -->
        <div
          class="rounded-2xl p-6"
          style="background: #F1F5F9; border: 1px solid #CBD5E1;"
        >
          <h2 class="text-base font-bold mb-2" style="color: #0F172A;">
            Análisis causa raíz
          </h2>
          <p
            id="ir-rca"
            class="text-sm leading-relaxed"
            style="color: #475569;"
          >
          </p>
        </div>

        <!-- Prevention -->
        <div
          class="rounded-2xl p-6"
          style="background: #F0FDF4; border: 1px solid #BBF7D0;"
        >
          <h2 class="text-base font-bold mb-3" style="color: #15803D;">
            Medidas preventivas
          </h2>
          <ul id="ir-prevention" class="space-y-2"></ul>
        </div>

        <!-- CTA -->
        <div class="text-center pt-4 pb-2">
          <p class="text-base font-semibold mb-4" style="color: #0F172A;">
            ¿Necesitas ayuda en vivo?
          </p>
          <a
            href="/contacto"
            class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02]"
            style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.35);"
          >
            Contactar con LRA →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('ir-form') as HTMLFormElement
  const loading = document.getElementById('ir-loading')!
  const results = document.getElementById('ir-results')!
  const errorEl = document.getElementById('ir-error')!
  const btnText = document.getElementById('ir-btn-text')!
  const submitBtn = document.getElementById('ir-submit') as HTMLButtonElement

  const severityColors: Record<string, string> = {
    P1: '#DC2626',
    P2: '#EA580C',
    P3: '#D97706',
    P4: '#16A34A',
  }

  interface Step {
    step: number
    action: string
    command?: string
    expected?: string
  }

  interface TimelineEvent {
    time: string
    event: string
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    const symptoms = (
      document.getElementById('ir-symptoms') as HTMLTextAreaElement
    ).value
    const infra = (document.getElementById('ir-infra') as HTMLInputElement)
      .value
    const logs = (document.getElementById('ir-logs') as HTMLTextAreaElement)
      .value

    if (symptoms.trim().length < 10) {
      errorEl.textContent =
        'Describe los síntomas con más detalle (mínimo 10 caracteres).'
      errorEl.classList.remove('hidden')
      return
    }

    form.classList.add('hidden')
    loading.classList.remove('hidden')
    submitBtn.disabled = true
    btnText.textContent = 'Analizando...'

    try {
      const res = await fetch('/api/incident-response', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ symptoms, infrastructure: infra, logs }),
      })
      const json = (await res.json()) as {
        incident?: Record<string, unknown>
        error?: string
      }
      if (json.error) throw new Error(json.error)
      const inc = json.incident ?? {}

      const sev = typeof inc.severity === 'string' ? inc.severity : 'P2'
      const sevEl = document.getElementById('ir-severity')!
      sevEl.textContent = sev
      sevEl.style.color = severityColors[sev] ?? '#D97706'

      document.getElementById('ir-confidence')!.textContent = String(
        typeof inc.confidence === 'number' ? inc.confidence : 0
      )
      document.getElementById('ir-cause')!.textContent =
        typeof inc.probable_cause === 'string' ? inc.probable_cause : ''
      document.getElementById('ir-summary')!.textContent =
        typeof inc.summary === 'string' ? inc.summary : ''
      document.getElementById('ir-rca')!.textContent =
        typeof inc.root_cause_analysis === 'string'
          ? inc.root_cause_analysis
          : ''

      const timelineSection = document.getElementById('ir-timeline-section')!
      const timeline = Array.isArray(inc.timeline)
        ? (inc.timeline as TimelineEvent[])
        : []
      if (timeline.length > 0) {
        timelineSection.classList.remove('hidden')
        document.getElementById('ir-timeline')!.innerHTML = timeline
          .map(
            (t) =>
              `<div class="flex gap-4 items-start">
              <div class="flex-shrink-0 text-xs font-mono font-bold px-2 py-1 rounded" style="background:#EEF4FF; color:#2563EB; min-width:48px; text-align:center;">${t.time}</div>
              <div class="text-sm" style="color:#475569;">${t.event}</div>
            </div>`
          )
          .join('')
      }

      const steps = Array.isArray(inc.investigation_steps)
        ? (inc.investigation_steps as Step[])
        : []
      document.getElementById('ir-steps')!.innerHTML = steps
        .map(
          (s) =>
            `<div class="rounded-xl p-4" style="background:white; border:1px solid #DBEAFE;">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0" style="background:#2563EB; color:white;">${s.step}</span>
              <span class="text-sm font-semibold" style="color:#1E40AF;">${s.action}</span>
            </div>
            ${
              s.command
                ? `<div class="mt-2 rounded-lg px-3 py-2 font-mono text-xs" style="background:#0F172A; color:#60A5FA;">${s.command}</div>`
                : ''
            }
            ${s.expected ? `<div class="mt-2 text-xs" style="color:#64748B;">Espera: ${s.expected}</div>` : ''}
          </div>`
        )
        .join('')

      const remediation = Array.isArray(inc.immediate_remediation)
        ? (inc.immediate_remediation as string[])
        : []
      document.getElementById('ir-remediation')!.innerHTML = remediation
        .map(
          (r) =>
            `<li class="flex gap-2.5 text-sm font-medium" style="color:#DC2626;"><span style="flex-shrink:0;">→</span><span>${r}</span></li>`
        )
        .join('')

      const prevention = Array.isArray(inc.prevention)
        ? (inc.prevention as string[])
        : []
      document.getElementById('ir-prevention')!.innerHTML = prevention
        .map(
          (p) =>
            `<li class="flex gap-2.5 text-sm" style="color:#15803D;"><span style="flex-shrink:0;">✓</span><span>${p}</span></li>`
        )
        .join('')

      loading.classList.add('hidden')
      results.classList.remove('hidden')
    } catch (err) {
      loading.classList.add('hidden')
      form.classList.remove('hidden')
      submitBtn.disabled = false
      btnText.textContent = 'Diagnosticar incidencia →'
      errorEl.textContent =
        err instanceof Error
          ? err.message
          : 'Error en el diagnóstico. Intenta de nuevo.'
      errorEl.classList.remove('hidden')
    }
  })
</script>
