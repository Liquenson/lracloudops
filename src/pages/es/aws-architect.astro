---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="AWS Architect Agent · Diseño de Arquitectura AWS · Well-Architected · Gratis"
  descripcion="Genera arquitecturas AWS de nivel enterprise con los 5 pilares del Well-Architected Framework. Serverless, ECS, EKS, RDS, CloudFront y más."
>
  <!-- HERO -->
  <section
    class="relative overflow-hidden"
    style="background: #0A2540;"
    aria-labelledby="aa-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.1) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-7 text-xs font-bold tracking-widest uppercase"
        style="background: rgba(37,99,235,0.25); border: 1px solid rgba(96,165,250,0.35); color: #93C5FD;"
      >
        <span
          class="w-2 h-2 rounded-full flex-shrink-0"
          style="background: #60A5FA; animation: pulse 2s infinite;"
          aria-hidden="true"></span>
        AWS Well-Architected · 5 Pilares · Enterprise
      </div>
      <h1
        id="aa-hero-heading"
        class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight"
        style="letter-spacing: -0.035em;"
      >
        AWS Architect Agent
      </h1>
      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto"
        style="color: rgba(147,184,255,0.85);"
      >
        Describe tu sistema y obtén una arquitectura AWS completa alineada con
        el Well-Architected Framework: componentes, costes estimados y plan de
        migración.
      </p>
    </div>
  </section>

  <!-- FORM + RESULTS -->
  <section
    class="bg-white py-16"
    aria-label="Formulario de diseño de arquitectura AWS"
  >
    <div class="max-w-3xl mx-auto px-6">
      <form id="aa-form" class="space-y-6" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label
              for="aa-workload"
              class="block text-sm font-semibold mb-2"
              style="color: #0F172A;">Tipo de workload</label
            >
            <select
              id="aa-workload"
              class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
              style="border-color: #E2E8F0; color: #0F172A;"
            >
              <option value="Web App" selected>Web App</option>
              <option value="API Backend">API Backend</option>
              <option value="Data Platform">Data Platform</option>
              <option value="ML/AI">ML/AI</option>
              <option value="Event-Driven">Event-Driven</option>
              <option value="Batch Processing">Batch Processing</option>
            </select>
          </div>
          <div>
            <label
              for="aa-scale"
              class="block text-sm font-semibold mb-2"
              style="color: #0F172A;">Escala</label
            >
            <select
              id="aa-scale"
              class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
              style="border-color: #E2E8F0; color: #0F172A;"
            >
              <option value="Startup" selected
                >Startup (&lt;10K usuarios)</option
              >
              <option value="Scale-up">Scale-up (10K-1M)</option>
              <option value="Enterprise">Enterprise (&gt;1M)</option>
            </select>
          </div>
          <div>
            <label
              for="aa-budget"
              class="block text-sm font-semibold mb-2"
              style="color: #0F172A;">Prioridad de coste</label
            >
            <select
              id="aa-budget"
              class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
              style="border-color: #E2E8F0; color: #0F172A;"
            >
              <option value="Cost-optimized" selected>Optimizar coste</option>
              <option value="Balanced">Equilibrado</option>
              <option value="Performance-first">Máximo rendimiento</option>
            </select>
          </div>
        </div>
        <div>
          <label
            for="aa-description"
            class="block text-sm font-semibold mb-2"
            style="color: #0F172A;"
          >
            Describe tu sistema actual o el que quieres construir
            <span class="font-normal text-xs ml-1" style="color: #64748B;"
              >(requerido)</span
            >
          </label>
          <textarea
            id="aa-description"
            rows="7"
            placeholder="Ejemplo: Necesitamos migrar una aplicación monolítica Java a AWS. Tiene ~50K usuarios activos, maneja pagos con Stripe, tiene una base de datos PostgreSQL de 200GB y picos de tráfico en Black Friday de 10x. El equipo tiene 3 desarrolladores y queremos reducir el tiempo de deployment de 2 horas a menos de 10 minutos..."
            class="w-full px-4 py-3 rounded-xl text-sm border resize-none focus:outline-none focus:ring-2"
            style="border-color: #E2E8F0; color: #0F172A;"></textarea>
        </div>
        <button
          type="submit"
          id="aa-submit"
          class="w-full inline-flex items-center justify-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.01]"
          style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.4);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
            ></path>
          </svg>
          <span id="aa-btn-text">Diseñar arquitectura →</span>
        </button>
        <p id="aa-error" class="hidden text-sm text-red-600 text-center"></p>
      </form>

      <!-- Loading -->
      <div id="aa-loading" class="hidden text-center py-16">
        <div
          class="inline-flex items-center gap-3 px-6 py-4 rounded-2xl"
          style="background: #EEF4FF; border: 1px solid #93C5FD;"
        >
          <svg
            class="w-5 h-5 animate-spin"
            style="color: #2563EB;"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="text-sm font-medium" style="color: #2563EB;"
            >Diseñando arquitectura AWS...</span
          >
        </div>
      </div>

      <!-- Results -->
      <div id="aa-results" class="hidden mt-10 space-y-6">
        <!-- Header -->
        <div class="rounded-2xl p-8" style="background: #0A2540;">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
            <div>
              <p
                class="text-xs font-bold uppercase tracking-widest mb-1"
                style="color: #93C5FD;"
              >
                Arquitectura
              </p>
              <h2 id="aa-name" class="text-2xl font-extrabold text-white"></h2>
              <span
                id="aa-pattern"
                class="inline-block mt-2 text-xs font-bold px-3 py-1 rounded-full"
                style="background: rgba(37,99,235,0.3); color: #93C5FD; border: 1px solid rgba(96,165,250,0.3);"
              ></span>
            </div>
            <div class="text-right">
              <p
                class="text-xs font-semibold uppercase tracking-widest mb-1"
                style="color: #93C5FD;"
              >
                Coste estimado
              </p>
              <div
                id="aa-cost"
                class="text-2xl font-extrabold"
                style="color: #60A5FA;"
              >
              </div>
              <p class="text-xs mt-0.5" style="color: rgba(147,184,255,0.6);">
                por mes
              </p>
            </div>
          </div>
          <p
            id="aa-summary"
            class="text-sm leading-relaxed"
            style="color: rgba(147,184,255,0.85);"
          >
          </p>
        </div>

        <!-- Well-Architected pillars -->
        <div class="rounded-2xl p-6" style="border: 1px solid #E5E7EB;">
          <h2 class="text-base font-bold mb-4" style="color: #0F172A;">
            Well-Architected Framework
          </h2>
          <div id="aa-pillars" class="space-y-3"></div>
        </div>

        <!-- Components -->
        <div
          class="rounded-2xl p-6"
          style="background: #F8FAFF; border: 1px solid #E5E7EB;"
        >
          <h2 class="text-base font-bold mb-4" style="color: #0F172A;">
            Componentes AWS
          </h2>
          <div id="aa-components" class="space-y-3"></div>
        </div>

        <!-- Diagram description -->
        <div
          class="rounded-2xl p-6"
          style="background: #F1F5F9; border: 1px solid #CBD5E1;"
        >
          <h2 class="text-base font-bold mb-2" style="color: #0F172A;">
            Flujo de arquitectura
          </h2>
          <p
            id="aa-diagram"
            class="text-sm leading-relaxed"
            style="color: #475569;"
          >
          </p>
        </div>

        <!-- Trade-offs -->
        <div
          class="rounded-2xl p-6"
          style="background: #FFFBEB; border: 1px solid #FDE68A;"
        >
          <h2 class="text-base font-bold mb-3" style="color: #92400E;">
            Trade-offs a considerar
          </h2>
          <ul id="aa-tradeoffs" class="space-y-2"></ul>
        </div>

        <!-- Migration path -->
        <div
          class="rounded-2xl p-6"
          style="background: #F0FDF4; border: 1px solid #BBF7D0;"
        >
          <h2 class="text-base font-bold mb-3" style="color: #15803D;">
            Plan de migración
          </h2>
          <ol id="aa-migration" class="space-y-2"></ol>
        </div>

        <!-- CTA -->
        <div class="text-center pt-4 pb-2">
          <p class="text-base font-semibold mb-4" style="color: #0F172A;">
            ¿Quieres que implementemos esta arquitectura?
          </p>
          <a
            href="/contacto"
            class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02]"
            style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.35);"
          >
            Implementar con LRA →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('aa-form') as HTMLFormElement
  const loading = document.getElementById('aa-loading')!
  const results = document.getElementById('aa-results')!
  const errorEl = document.getElementById('aa-error')!
  const btnText = document.getElementById('aa-btn-text')!
  const submitBtn = document.getElementById('aa-submit') as HTMLButtonElement

  const pillarLabels: Record<string, string> = {
    operational_excellence: 'Excelencia Operacional',
    security: 'Seguridad',
    reliability: 'Fiabilidad',
    performance: 'Eficiencia de Rendimiento',
    cost_optimization: 'Optimización de Costes',
  }

  interface Component {
    service: string
    purpose: string
    sizing: string
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    const desc = (
      document.getElementById('aa-description') as HTMLTextAreaElement
    ).value
    const workload = (
      document.getElementById('aa-workload') as HTMLSelectElement
    ).value
    const scale = (document.getElementById('aa-scale') as HTMLSelectElement)
      .value
    const budget = (document.getElementById('aa-budget') as HTMLSelectElement)
      .value

    if (desc.trim().length < 20) {
      errorEl.textContent =
        'Describe tu sistema con más detalle (mínimo 20 caracteres).'
      errorEl.classList.remove('hidden')
      return
    }

    form.classList.add('hidden')
    loading.classList.remove('hidden')
    submitBtn.disabled = true
    btnText.textContent = 'Diseñando...'

    try {
      const res = await fetch('/api/aws-architect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          description: desc,
          workload_type: workload,
          scale,
          budget_priority: budget,
        }),
      })
      const json = (await res.json()) as {
        architecture?: Record<string, unknown>
        error?: string
      }
      if (json.error) throw new Error(json.error)
      const a = json.architecture ?? {}

      document.getElementById('aa-name')!.textContent =
        typeof a.architecture_name === 'string'
          ? a.architecture_name
          : 'Arquitectura AWS'
      document.getElementById('aa-pattern')!.textContent =
        typeof a.pattern === 'string' ? a.pattern : ''
      document.getElementById('aa-cost')!.textContent =
        typeof a.estimated_monthly_cost === 'string'
          ? a.estimated_monthly_cost
          : '—'
      document.getElementById('aa-summary')!.textContent =
        typeof a.summary === 'string' ? a.summary : ''
      document.getElementById('aa-diagram')!.textContent =
        typeof a.diagram_description === 'string' ? a.diagram_description : ''

      const wa = (
        a.well_architected && typeof a.well_architected === 'object'
          ? a.well_architected
          : {}
      ) as Record<string, string>
      document.getElementById('aa-pillars')!.innerHTML = Object.entries(wa)
        .map(
          ([key, val]) =>
            `<div class="flex gap-3 items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center mt-0.5" style="background:#EEF4FF;">
                <svg class="w-3.5 h-3.5" style="color:#2563EB;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div>
                <span class="text-sm font-semibold" style="color:#0F172A;">${pillarLabels[key] ?? key}:</span>
                <span class="text-sm ml-1" style="color:#475569;">${val}</span>
              </div>
            </div>`
        )
        .join('')

      const components = Array.isArray(a.components)
        ? (a.components as Component[])
        : []
      document.getElementById('aa-components')!.innerHTML = components
        .map(
          (c) =>
            `<div class="flex items-start gap-4 p-4 rounded-xl" style="background:white; border:1px solid #E5E7EB;">
              <div class="flex-shrink-0 px-3 py-1 rounded-lg text-xs font-bold" style="background:#EEF4FF; color:#2563EB;">${c.service}</div>
              <div>
                <div class="text-sm font-semibold" style="color:#0F172A;">${c.purpose}</div>
                <div class="text-xs mt-0.5" style="color:#64748B;">${c.sizing}</div>
              </div>
            </div>`
        )
        .join('')

      const tradeoffs = Array.isArray(a.trade_offs)
        ? (a.trade_offs as string[])
        : []
      document.getElementById('aa-tradeoffs')!.innerHTML = tradeoffs
        .map(
          (t) =>
            `<li class="flex gap-2.5 text-sm" style="color:#92400E;"><span style="flex-shrink:0;">⚠</span><span>${t}</span></li>`
        )
        .join('')

      const migration = Array.isArray(a.migration_path)
        ? (a.migration_path as string[])
        : []
      document.getElementById('aa-migration')!.innerHTML = migration
        .map(
          (m, i) =>
            `<li class="flex gap-3 text-sm" style="color:#15803D;">
              <span class="flex-shrink-0 font-bold w-5">${i + 1}.</span>
              <span>${m}</span>
            </li>`
        )
        .join('')

      loading.classList.add('hidden')
      results.classList.remove('hidden')
    } catch (err) {
      loading.classList.add('hidden')
      form.classList.remove('hidden')
      submitBtn.disabled = false
      btnText.textContent = 'Diseñar arquitectura →'
      errorEl.textContent =
        err instanceof Error
          ? err.message
          : 'Error generando la arquitectura. Intenta de nuevo.'
      errorEl.classList.remove('hidden')
    }
  })
</script>
