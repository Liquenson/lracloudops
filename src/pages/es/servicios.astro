---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

const platformFeatures = [
  'lra scan — auditoría de seguridad en cualquier repo de GitHub',
  'infrastructure_review — análisis multi-cloud',
  'security_review — Trivy + Checkov en cada escaneo',
  'documentation_update — README, ADR, Runbooks',
  'pr_review — revisión de código automatizada',
]

const consultingItems = [
  {
    title: 'Configuración de infraestructura',
    desc: 'EKS, VPC, RDS en AWS desde cero',
  },
  { title: 'Pipelines CI/CD', desc: 'GitHub Actions, ArgoCD, Helm' },
  { title: 'Auditoría de seguridad', desc: 'Trivy, Checkov, revisión IAM' },
  { title: 'Observabilidad', desc: 'Prometheus, Grafana, CloudWatch' },
]
---

<Layout
  title="Servicios — LRA CloudOps"
  description="Acceso a la plataforma y consultoría DevOps. lra-ai-platform como servicio — 8 agentes, 14 integraciones, 9 workflows."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- Page hero -->
  <section
    data-animate="fade-up"
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Servicios
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        Qué ofrecemos
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; max-width: 560px;"
      >
        Acceso a la plataforma y consultoría DevOps. Elige lo que se ajuste a tu
        equipo.
      </p>
    </div>
  </section>

  <!-- SaaS Service -->
  <section
    data-animate="fade-up"
    style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;"
        class="service-grid"
      >
        <div>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;"
          >
            Plataforma
          </p>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;"
          >
            lra-ai-platform como servicio
          </h2>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;"
          >
            Accede a la plataforma completa sin instalar nada. 8 agentes
            especializados ejecutan operaciones de infraestructura en tu nombre
            — escaneando, revisando, desplegando y documentando.
          </p>
          <div
            style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem;"
          >
            {
              platformFeatures.map((item) => (
                <div style="display: flex; align-items: start; gap: 0.75rem;">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"
                  >
                    <path
                      d="M20 6L9 17l-5-5"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">
                    {item}
                  </span>
                </div>
              ))
            }
          </div>
          <a
            href="/es/precios"
            class="btn-premium"
            style="display: inline-flex; align-items: center; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 500; font-size: 0.9375rem; text-decoration: none;"
          >
            Ver precios →
          </a>
        </div>
        <!-- Visual placeholder -->
        <div
          style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 2rem; font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; color: #5F6368; line-height: 1.8;"
        >
          <div style="color: #5F6368; margin-bottom: 0.5rem;">
            # Capacidades de la plataforma
          </div>
          <div>
            <span style="color: #1A73E8;">$</span> lra scan --github org/repo
          </div>
          <div style="color: #137333; margin-left: 1rem;">
            ✓ Trivy: 0 críticos
          </div>
          <div style="color: #137333; margin-left: 1rem;">
            ✓ Checkov: 47 superados
          </div>
          <div style="margin-top: 0.75rem;">
            <span style="color: #1A73E8;">$</span> lra review aws
          </div>
          <div style="color: #137333; margin-left: 1rem;">✓ EKS: saludable</div>
          <div style="color: #137333; margin-left: 1rem;">
            ✓ RDS: en ejecución
          </div>
          <div style="margin-top: 0.75rem;">
            <span style="color: #1A73E8;">$</span> lra run security_review
          </div>
          <div style="color: #137333; margin-left: 1rem;">
            ✓ Informe generado
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consulting Service -->
  <section data-animate="fade-up" style="background: #F8F9FA; padding: 3rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;"
        class="service-grid"
      >
        <!-- Visual -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          {
            consultingItems.map((item) => (
              <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; padding: 1rem;">
                <p style="font-family: 'Red Hat Display', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;">
                  {item.title}
                </p>
                <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368;">
                  {item.desc}
                </p>
              </div>
            ))
          }
        </div>
        <div>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;"
          >
            Consultoría
          </p>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;"
          >
            Ingeniería DevOps bajo demanda
          </h2>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;"
          >
            ¿Necesitas a alguien que diseñe, construya o revise tu
            infraestructura? Trabajamos directamente con tu equipo —
            arquitectura cloud, configuración Kubernetes, pipelines CI/CD,
            hardening de seguridad.
          </p>
          <a
            href="/es/contacto"
            class="btn-premium-outline"
            style="display: inline-flex; align-items: center; background: transparent; color: #1A73E8; padding: 0.75rem 1.5rem; border-radius: 4px; border: 1px solid #DADCE0; font-family: 'Red Hat Text', sans-serif; font-weight: 500; font-size: 0.9375rem; text-decoration: none;"
          >
            Contactar →
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 768px) {
    .service-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
