---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

const auditChecklist = [
  'Trivy — escaneo de vulnerabilidades en contenedores e IaC',
  'Checkov — análisis de Terraform, Kubernetes, Dockerfile',
  'Veredicto PASS/FAIL con hallazgos detallados',
  'Recomendaciones concretas para resolver cada problema',
  'Entregado por email en 24 horas',
]

const consultingItems = [
  { title: 'Escaneo mensual de seguridad', desc: 'lra scan en todos tus repos cada mes' },
  { title: 'Revisión de infraestructura', desc: 'Análisis y recomendaciones de arquitectura AWS/K8s' },
  { title: 'Auditoría de pipelines CI/CD', desc: 'Revisión de GitHub Actions, Jenkins, ArgoCD' },
  { title: 'Acceso directo', desc: 'Email y LinkedIn para preguntas y soporte' },
]

const techs = [
  'AWS', 'Kubernetes', 'Terraform', 'ArgoCD', 'GitHub Actions', 'Docker',
  'Helm', 'Prometheus', 'Grafana', 'Trivy', 'Checkov', 'Ansible', 'Jenkins',
  'SonarCloud', 'Python', 'Bash',
]
---

<Layout
  title="Servicios — LRA CloudOps"
  description="Servicios de Platform Engineering respaldados por proyectos open source que puedes inspeccionar — Infraestructura, Kubernetes, GitOps y automatización con agentes IA."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- Page hero -->
  <section
    data-animate="fade-up"
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Servicios de Platform Engineering
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        No vendemos horas. Entregamos plataformas.
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; max-width: 560px; margin-bottom: 1.5rem;"
      >
        Nuestros servicios son la extensión natural de lo que ya hemos
        construido — patrones probados en producción desde proyectos open
        source reales, aplicados a tu infraestructura.
      </p>

      <div style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 6px; padding: 1rem 1.5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;">
        <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">
          Cada servicio está respaldado por código open source que puedes inspeccionar:
        </span>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          {['aws-terraform-devops', 'lra-ai-platform', 'k8s-on-premise', 'aws-devops-agent'].map(repo => (
            <a href={`https://github.com/lra-cloud-ops/${repo}`} target="_blank" rel="noopener noreferrer"
              style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #1A73E8; text-decoration: none; background: #E8F0FE; border: 1px solid #C5D8F8; padding: 0.125rem 0.5rem; border-radius: 3px;"
              onmouseover="this.style.background='#C5D8F8'"
              onmouseout="this.style.background='#E8F0FE'"
            >{repo} ↗</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Auditoría gratuita -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="service-grid">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E6F4EA; color: #137333; padding: 0.25rem 0.875rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; font-weight: 600; margin-bottom: 1rem;">
            Gratis · Sin compromiso
          </div>
          <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;">Auditoría de infraestructura con lra scan</h2>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;">
            Envíanos la URL de tu repositorio GitHub. Ejecutamos lra scan — Trivy para vulnerabilidades de seguridad, Checkov para misconfiguraciones de IaC — y te enviamos un informe completo en 24 horas.
          </p>
          <div style="display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 2rem;">
            {auditChecklist.map(item => (
              <div style="display: flex; align-items: start; gap: 0.75rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">{item}</span>
              </div>
            ))}
          </div>
          <a href="/es/contacto" style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;" class="btn-premium">
            Solicitar auditoría gratuita →
          </a>
        </div>

        <!-- Terminal claro -->
        <div style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; line-height: 1.9; color: #5F6368;">
          <div style="color: #9AA0A6; font-style: italic; margin-bottom: 0.75rem;"># Auditoría de tu repositorio</div>
          <div style="margin-bottom: 0.5rem;">
            <span style="color: #1A73E8; font-weight: 600;">$</span>
            <span style="color: #202124; font-weight: 500;"> lra scan --github tu-org/tu-repo</span>
          </div>
          <div style="margin-left: 1rem; color: #5F6368;">→ Escaneando repositorio...</div>
          <div style="margin-left: 1rem; color: #5F6368; margin-bottom: 0.5rem;">→ Ejecutando Trivy + Checkov...</div>
          <div style="margin-left: 1rem; color: #137333;">✓ Críticos: 0</div>
          <div style="margin-left: 1rem; color: #137333;">✓ Altos: 0</div>
          <div style="margin-left: 1rem; color: #F29900; margin-bottom: 0.75rem;">⚠ Medios: 2 → recomendaciones incluidas</div>
          <div style="margin-left: 1rem; color: #137333; font-weight: 600;">✓ Informe entregado a tu email</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consultoría mensual -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="service-grid">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;" class="consulting-cards">
          {consultingItems.map(item => (
            <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; padding: 1rem;" class="card-premium">
              <p style="font-family: 'Red Hat Display', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;">{item.title}</p>
              <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368;">{item.desc}</p>
            </div>
          ))}
        </div>
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E8F0FE; color: #1A73E8; padding: 0.25rem 0.875rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; font-weight: 600; margin-bottom: 1rem;">
            €499/mes
          </div>
          <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 1rem; line-height: 1.2;">Consultoría DevOps continua</h2>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;">
            Soporte mensual para equipos sin ingeniero DevOps dedicado. Escaneos de seguridad, revisiones de infraestructura, auditorías de pipelines y acceso directo para preguntas.
          </p>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; line-height: 1.7; margin-bottom: 2rem;">
            Empieza con la auditoría gratuita. Si te resulta valiosa, montamos un acuerdo mensual. Sin contratos a largo plazo.
          </p>
          <a href="/es/contacto" style="display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: #1A73E8; padding: 0.75rem 1.5rem; border-radius: 4px; border: 1px solid #DADCE0; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;" class="btn-premium-outline">
            Contactar →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios de proyecto -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Servicios</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 0.5rem;">Qué construimos para ti</h2>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;">Proyectos a precio fijo. Sin sorpresas por horas.</p>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;" class="services-list-grid" data-animate="stagger">
        {[
          {
            title: 'Infraestructura AWS con Terraform',
            price: '€800 – €2.000',
            time: '1-2 semanas',
            color: '#1A73E8',
            features: [
              'VPC multi-AZ con subredes públicas/privadas',
              'Clúster EKS con node groups auto-escalables',
              'RDS PostgreSQL con backups y failover',
              'ECR, S3, IAM con políticas de mínimo privilegio',
              'Monitorización y alertas con CloudWatch',
              'Módulos Terraform completos — reproducibles',
            ]
          },
          {
            title: 'Setup de Kubernetes',
            price: '€1.000 – €2.500',
            time: '2-3 semanas',
            color: '#137333',
            features: [
              'EKS en AWS o on-premise con kubeadm',
              'Calico CNI con políticas de red',
              'NGINX Ingress con terminación TLS',
              'ArgoCD GitOps — despliegues declarativos',
              'Stack de observabilidad Prometheus + Grafana',
              'Helm charts para tus aplicaciones',
            ]
          },
          {
            title: 'Pipeline CI/CD',
            price: '€400 – €800',
            time: '3-5 días',
            color: '#F29900',
            features: [
              'GitHub Actions — lint, test, build, deploy',
              'Build multi-stage con Docker + push a ECR',
              'Deploy automatizado a EKS vía Helm/ArgoCD',
              'Integración de quality gate con SonarCloud',
              'Escaneo de seguridad (Trivy + Checkov) en cada PR',
              'Separación de entornos (dev/staging/prod)',
            ]
          },
          {
            title: 'Auditoría de Seguridad',
            price: '€199 – €299',
            time: '2-3 días',
            color: '#C5221F',
            features: [
              'lra scan en todos tus repositorios de GitHub',
              'Trivy — vulnerabilidades de contenedores e IaC',
              'Checkov — Terraform, K8s, Dockerfile, Actions',
              'Informe PASS/FAIL con clasificación de severidad',
              'Recomendaciones concretas de solución por hallazgo',
              'Opcional: soporte en la implementación incluido',
            ]
          },
        ].map(service => (
          <div style={`background: #F8F9FA; border: 1px solid #DADCE0; border-top: 3px solid ${service.color}; border-radius: 8px; padding: 1.5rem;`} class="card-premium" data-animate-child>
            <div style="display: flex; align-items: start; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
              <h3 style="font-family: 'Red Hat Display', sans-serif; font-size: 1rem; font-weight: 700; color: #202124;">{service.title}</h3>
              <div style="text-align: right;">
                <div style={`font-family: 'Red Hat Display', sans-serif; font-size: 1.0625rem; font-weight: 700; color: ${service.color};`}>{service.price}</div>
                <div style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6;">{service.time}</div>
              </div>
            </div>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              {service.features.map(f => (
                <li style="display: flex; align-items: start; gap: 0.625rem;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style={`color: ${service.color}; flex-shrink: 0; margin-top: 2px;`}><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; line-height: 1.5;">{f}</span>
                </li>
              ))}
            </ul>
            <a href="/es/contacto" style="display: inline-flex; align-items: center; gap: 0.375rem; margin-top: 1.25rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #1A73E8; text-decoration: none;"
              onmouseover="this.style.textDecoration='underline'"
              onmouseout="this.style.textDecoration='none'"
            >
              Solicitar presupuesto →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cómo trabajamos -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-top: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Proceso</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 0.5rem;">Cómo trabajamos</h2>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;">Desde tu primer mensaje hasta el informe entregado — sin sorpresas.</p>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="process-grid">
        {[
          { step: '01', title: 'Nos contactas', desc: 'Envía la URL de tu repo GitHub por el formulario. Respondemos en menos de 24 horas para confirmar.', time: 'Día 1' },
          { step: '02', title: 'Ejecutamos la auditoría', desc: 'Ejecutamos lra scan — Trivy para vulnerabilidades, Checkov para misconfiguraciones IaC. Análisis completo de tu código.', time: 'Día 2' },
          { step: '03', title: 'Recibes el informe', desc: 'Informe PASS/FAIL completo por email. Incluye todos los hallazgos, niveles de severidad y recomendaciones concretas.', time: 'Día 3' },
        ].map(({ step, title, desc, time }) => (
          <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; position: relative;" class="card-premium">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 700; color: #1A73E8; background: #E8F0FE; padding: 0.25rem 0.625rem; border-radius: 4px;">{step}</span>
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6;">{time}</span>
            </div>
            <h3 style="font-family: 'Red Hat Display', sans-serif; font-size: 1rem; font-weight: 700; color: #202124; margin-bottom: 0.5rem;">{title}</h3>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; line-height: 1.6;">{desc}</p>
          </div>
        ))}
      </div>
      <div style="margin-top: 1.5rem; padding: 1rem 1.5rem; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: #137333; flex-shrink: 0;"></span>
        <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; font-weight: 500;">Respondemos a cada solicitud en menos de 24 horas.</span>
        <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">Repos privados aceptados. Sin compromiso a largo plazo.</span>
      </div>
    </div>
  </section>

  <!-- Tecnologías -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Stack</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 2rem;">Tecnologías con las que trabajamos</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
        {techs.map(tech => (
          <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.875rem; color: #202124; background: #F8F9FA; border: 1px solid #DADCE0; padding: 0.375rem 0.875rem; border-radius: 4px;">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 767px) {
    .service-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
    .consulting-cards {
      grid-template-columns: 1fr !important;
    }
    .process-grid {
      grid-template-columns: 1fr !important;
    }
    .services-list-grid {
      grid-template-columns: 1fr !important;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .service-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    .services-list-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .consulting-cards { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>
