---
import Layout from '../../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft)
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }))
}

const { project } = Astro.props
const { Content } = await render(project)
const { titulo, descripcion, fecha, categoria, madurez, stack, cicd, github, metricas, highlights, outcomes, arquitectura } = project.data

const titulo_es = (project.data as any).titulo_es
const descripcion_es = (project.data as any).descripcion_es
const highlights_es = (project.data as any).highlights_es

const displayTitle = titulo_es ?? titulo
const displayDescription = descripcion_es ?? descripcion
const displayHighlights = highlights_es ?? highlights

function badgeStyle(m: string) {
  const map: Record<string, string> = {
    'Production':    'background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;',
    'In Development':'background:#fffbeb; color:#b45309; border:1px solid #fde68a;',
    'Reference':     'background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb;',
    'Starter':       'background:#EEF4FF; color:#1E6FFF; border:1px solid #c3d9ff;',
  }
  return map[m] ?? map['Reference']
}

const projectUrl = `https://lracloudops.com/es/projects/${project.id}`

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': github ? 'SoftwareSourceCode' : 'CreativeWork',
  '@id': `${projectUrl}#project`,
  name: displayTitle,
  description: displayDescription,
  url: projectUrl,
  datePublished: fecha.toISOString().split('T')[0],
  author: {
    '@type': 'Person',
    name: 'Liquenson Rubén',
    url: 'https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/',
  },
  creator: { '@id': 'https://lracloudops.com/#organization' },
  keywords: stack.join(', '),
  programmingLanguage: stack.filter((s: string) =>
    ['Java', 'Python', 'Bash', 'TypeScript', 'Go', 'Rust'].some(l => s.startsWith(l))
  ),
  runtimePlatform: stack.filter((s: string) =>
    ['Docker', 'Kubernetes', 'AWS', 'Cloudflare', 'ECS', 'EKS'].some(l => s.includes(l))
  ),
  ...(github ? { codeRepository: github } : {}),
  ...(github ? { license: 'https://opensource.org/licenses/MIT' } : {}),
  isPartOf: { '@id': 'https://lracloudops.com/#organization' },
  inLanguage: 'es-ES',
}
---

<Layout titulo={displayTitle} descripcion={displayDescription} schema={projectSchema}>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.15) 0%, transparent 65%);"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-16 sm:py-20">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-xs mb-8" style="color: rgba(147,184,255,0.5);">
        <a href="/es" onmouseover="this.style.color='rgba(147,184,255,0.9)'" onmouseout="this.style.color='rgba(147,184,255,0.5)'" class="transition-colors">Inicio</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <a href="/es/proyectos" onmouseover="this.style.color='rgba(147,184,255,0.9)'" onmouseout="this.style.color='rgba(147,184,255,0.5)'" class="transition-colors">Proyectos</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <span style="color: rgba(147,184,255,0.8);">{displayTitle}</span>
      </div>

      <div class="max-w-4xl">
        <!-- Badges row -->
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span class="text-xs font-semibold px-3 py-1.5 rounded-full" style={badgeStyle(madurez)}>{madurez}</span>
          <span class="text-xs font-semibold px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.08); color: rgba(147,184,255,0.8); border: 1px solid rgba(255,255,255,0.1);">{categoria}</span>
          {cicd && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium" style="color: #3fb950;">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>CI/CD Active
            </span>
          )}
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-5" style="letter-spacing: -0.02em;">{displayTitle}</h1>
        <p class="text-lg mb-6 max-w-2xl" style="color: rgba(147,184,255,0.8);">{displayDescription}</p>
        <p class="text-xs" style="color: rgba(147,184,255,0.4);">
          {fecha.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}
        </p>
      </div>
    </div>
  </section>

  <!-- METRICS -->
  {metricas && metricas.length > 0 && (
    <section class="bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {metricas.map(({ value, label }) => (
            <div class="text-center">
              <div class="text-3xl font-extrabold mb-1" style="color: #0A2540; letter-spacing: -0.02em;">{value}</div>
              <div class="text-xs font-medium" style="color: #64748b;">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- MAIN CONTENT -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Markdown content (2/3) -->
        <div class="lg:col-span-2">
          <div class="prose prose-gray max-w-none
            prose-headings:font-bold prose-headings:text-gray-900 prose-headings:tracking-tight
            prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-5
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4
            prose-p:text-gray-600 prose-p:leading-relaxed prose-p:text-base prose-p:mb-4
            prose-a:text-[#1E6FFF] prose-a:no-underline hover:prose-a:underline
            prose-code:text-[#1E6FFF] prose-code:bg-[#EEF4FF] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:text-sm prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
            prose-pre:bg-gray-950 prose-pre:text-gray-100 prose-pre:rounded-xl prose-pre:shadow-lg prose-pre:font-mono
            prose-li:text-gray-600 prose-li:mb-1
            prose-strong:text-gray-800 prose-strong:font-semibold
            prose-blockquote:border-l-4 prose-blockquote:border-[#1E6FFF] prose-blockquote:bg-[#EEF4FF] prose-blockquote:px-5 prose-blockquote:py-3 prose-blockquote:rounded-r-xl prose-blockquote:text-gray-700 prose-blockquote:not-italic
          ">
            <Content />
          </div>
        </div>

        <!-- Sidebar (1/3) -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">

            <!-- Technology stack -->
            <div class="bg-white rounded-2xl p-6" style="border: 1px solid #e2e8f0; box-shadow: 0 2px 12px rgba(0,0,0,0.05);">
              <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">Stack tecnológico</h3>
              <div class="flex flex-wrap gap-1.5">
                {stack.map(tag => (
                  <span class="text-xs px-2.5 py-1 rounded-full" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0;">{tag}</span>
                ))}
              </div>
            </div>

            <!-- Key highlights -->
            {displayHighlights && displayHighlights.length > 0 && (
              <div class="bg-white rounded-2xl p-6" style="border: 1px solid #e2e8f0; box-shadow: 0 2px 12px rgba(0,0,0,0.05);">
                <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">Puntos clave</h3>
                <ul class="space-y-3">
                  {displayHighlights.map(h => (
                    <li class="flex gap-2.5">
                      <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-xs leading-relaxed" style="color: #64748b;">{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Repository -->
            <div class="bg-white rounded-2xl p-6" style="border: 1px solid #e2e8f0; box-shadow: 0 2px 12px rgba(0,0,0,0.05);">
              <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">Repositorio</h3>
              {github ? (
                <a
                  href={github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 p-3 rounded-xl border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-all group"
                >
                  <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" style="color: #0A2540;">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                  </svg>
                  <div>
                    <div class="text-sm font-semibold" style="color: #0A2540;">Ver en GitHub</div>
                    <div class="text-xs" style="color: #64748b;">Código fuente público</div>
                  </div>
                  <svg class="w-4 h-4 ml-auto" style="color: #94a3b8;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              ) : (
                <div class="flex items-center gap-3 p-3 rounded-xl" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                  <svg class="w-5 h-5 flex-shrink-0" style="color: #94a3b8;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  <div>
                    <div class="text-sm font-medium" style="color: #64748b;">Repositorio privado</div>
                    <div class="text-xs" style="color: #94a3b8;">Contactar para acceso</div>
                  </div>
                </div>
              )}
            </div>

            <!-- CTA -->
            <div class="rounded-2xl p-6" style="background: linear-gradient(135deg, #0A2540, #1a3d6e);">
              <h3 class="text-sm font-bold text-white mb-2">¿Necesitas algo similar?</h3>
              <p class="text-xs mb-4" style="color: rgba(147,184,255,0.8);">Podemos diseñar e implementar una arquitectura adaptada a tus requisitos.</p>
              <a
                href="/es/contacto"
                class="flex items-center justify-center gap-2 w-full text-sm font-semibold text-white py-3 rounded-xl transition-all hover:opacity-90"
                style="background: rgba(30,111,255,0.6); border: 1px solid rgba(30,111,255,0.5);"
              >
                Contáctanos
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MEASURED OUTCOMES -->
  {outcomes && outcomes.length > 0 && (
    <section style="background: #F0FDF4;" class="py-14 border-t border-green-100">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-10">
          <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-3" style="background: white; color: #15803d; border: 1px solid #BBF7D0;">Resultados</span>
          <h2 class="text-2xl font-bold" style="color: #0A2540;">Resultados medidos</h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 max-w-4xl mx-auto">
          {outcomes.map((outcome: string) => {
            const colonIdx = outcome.indexOf(': ')
            const label = colonIdx > -1 ? outcome.slice(0, colonIdx) : outcome
            const detail = colonIdx > -1 ? outcome.slice(colonIdx + 2) : ''
            return (
              <div class="bg-white rounded-2xl p-6 flex items-start gap-4" style="border: 1px solid #BBF7D0; box-shadow: 0 1px 4px rgba(34,197,94,0.08);">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: #DCFCE7;">
                  <svg class="w-5 h-5" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-bold mb-1" style="color: #0A2540;">{label}</div>
                  {detail && <div class="text-sm leading-relaxed" style="color: #166534;">{detail}</div>}
                </div>
              </div>
            )
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ARCHITECTURE COMPONENTS -->
  {arquitectura && arquitectura.length > 0 && (
    <section style="background: #f8fafc;" class="py-16">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-10">
          <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-3" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">Arquitectura</span>
          <h2 class="text-2xl font-bold" style="color: #0A2540;">Componentes del sistema</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {arquitectura.map(({ nombre, descripcion: desc }) => (
            <div class="bg-white rounded-xl p-5" style="border: 1px solid #e2e8f0; box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background: #EEF4FF;">
                  <div class="w-2 h-2 rounded-sm" style="background: #1E6FFF;"></div>
                </div>
                <div>
                  <h3 class="text-sm font-bold mb-1" style="color: #0A2540;">{nombre}</h3>
                  <p class="text-xs leading-relaxed" style="color: #64748b;">{desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- PROJECT NAVIGATION -->
  <section class="bg-white py-12 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
      <a href="/es/proyectos" class="inline-flex items-center gap-2 text-sm font-medium transition-colors" style="color: #64748b;">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Todos los proyectos
      </a>
      <a href="/es/contacto" class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3 rounded-xl transition-all hover:opacity-90" style="background: #0A2540; color: white;">
        Hablar de tu proyecto
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
