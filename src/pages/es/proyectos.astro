---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import { getAllRepos, getAllProjectConfigs, formatDateES, type RepoData, type ProjectConfig } from '../../lib/github'
import { getTagClass } from '../../lib/tagColors'

let githubData: Record<string, RepoData> = {}
let projectConfigs: Record<string, ProjectConfig | null> = {}
try {
  ;[githubData, projectConfigs] = await Promise.all([getAllRepos(), getAllProjectConfigs()])
} catch {
  // El build nunca debe fallar por un problema de la API de GitHub — las tarjetas usan datos estáticos como fallback
}

const MATURITY_BADGES: Record<string, { label: string; color: string; bg: string }> = {
  'lra-ai-platform': { label: 'Plataforma Core', color: '#137333', bg: '#E6F4EA' },
  'aws-terraform-devops': { label: 'Plataforma Core', color: '#137333', bg: '#E6F4EA' },
  'k8s-on-premise': { label: 'Soporte', color: '#1A73E8', bg: '#E8F0FE' },
  'aws-devops-agent': { label: 'Lab', color: '#F29900', bg: '#FFF8E1' },
}

const PROJECT_CONNECTIONS = [
  { from: 'lra-ai-platform', arrow: 'ejecuta auditorías de seguridad sobre', to: 'aws-terraform-devops', desc: 'El SecurityAgent escanea los módulos Terraform en busca de misconfiguraciones vía Checkov.' },
  { from: 'aws-terraform-devops', arrow: 'aprovisiona el clúster para', to: 'k8s-on-premise', desc: 'El módulo EKS crea la capa de Kubernetes gestionado que complementa el bare-metal.' },
  { from: 'aws-devops-agent', arrow: 'consulta la infraestructura de', to: 'aws-terraform-devops', desc: 'El agente IA lee recursos EC2, RDS y EKS aprovisionados por Terraform.' },
  { from: 'lra-ai-platform', arrow: 'documenta y revisa', to: 'todos los proyectos', desc: 'DocumentationAgent y ReviewerAgent se ejecutan en todos los repositorios del ecosistema.' },
]

const PROJECT_DEFAULTS = [
  {
    name: 'lra-ai-platform',
    slug: 'lra-ai-platform',
    category: 'AI Agents',
    color: '#1A73E8',
    desc: '8 agentes especializados orquestan operaciones DevOps en AWS, Kubernetes y Terraform con un Governance Engine de 5 niveles.',
    tags: ['Python', 'FastAPI', 'boto3', 'Kubernetes', 'Terraform'],
    status: 'Activo',
    statusColor: '#137333',
    githubHref: 'https://github.com/lra-cloud-ops/lra-ai-platform',
    stats: [
      { label: 'Agentes', value: '8' },
      { label: 'Integraciones', value: '14' },
      { label: 'Workflows', value: '9' },
      { label: 'Tests', value: '33' },
    ],
  },
  {
    name: 'aws-devops-agent',
    slug: 'aws-devops-agent',
    category: 'Cloud AI',
    color: '#137333',
    desc: 'Agente CLI que usa un modelo de IA en un bucle de tool-use. 31 funciones boto3 cubriendo 24 servicios AWS. Pregunta en lenguaje natural.',
    tags: ['Python', 'Anthropic', 'Modelo IA', 'boto3', 'AWS'],
    status: 'PoC',
    statusColor: '#F29900',
    githubHref: 'https://github.com/lra-cloud-ops/aws-devops-agent',
    stats: [
      { label: 'Servicios AWS', value: '24' },
      { label: 'Tools', value: '31' },
      { label: 'Líneas', value: '593' },
      { label: 'Modelo', value: 'IA' },
    ],
  },
  {
    name: 'aws-terraform-devops',
    slug: 'aws-terraform-devops',
    category: 'Infrastructure',
    color: '#F29900',
    desc: 'Entorno AWS completo: VPC multi-AZ, EKS 1.31, RDS PostgreSQL 15, ECR. App Flask desplegada vía Helm. Sync ArgoCD. Gate SonarCloud.',
    tags: ['Terraform', 'AWS', 'EKS', 'Helm', 'ArgoCD', 'SonarCloud'],
    status: 'Activo',
    statusColor: '#137333',
    githubHref: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
    stats: [
      { label: 'Módulos TF', value: '7' },
      { label: 'Archivos TF', value: '26' },
      { label: 'Tests', value: '18' },
      { label: 'Commits', value: '71' },
    ],
  },
  {
    name: 'k8s-on-premise',
    slug: 'k8s-on-premise',
    category: 'Kubernetes',
    color: '#C5221F',
    desc: 'Clúster Kubernetes multi-nodo desde cero: bootstrap kubeadm, Calico CNI, NGINX Ingress, add-ons Helm y sync GitOps con ArgoCD.',
    tags: ['Kubernetes', 'kubeadm', 'Calico', 'Vagrant', 'Helm', 'ArgoCD'],
    status: 'Activo',
    statusColor: '#137333',
    githubHref: 'https://github.com/lra-cloud-ops/k8s-on-premise',
    stats: [
      { label: 'Nodos', value: '3' },
      { label: 'Scripts', value: '6' },
      { label: 'Commits', value: '25' },
      { label: 'CNI', value: 'Calico' },
    ],
  },
] as const

const STATUS_LABELS_ES: Record<string, string> = {
  Active: 'Activo',
  PoC: 'PoC',
  Lab: 'Lab',
  Archive: 'Archivado',
}

const STATUS_COLORS: Record<string, string> = {
  Active: '#137333',
  PoC: '#F29900',
  Lab: '#1A73E8',
  Archive: '#5F6368',
}

function mergeConfigStats(
  defaultStats: readonly { label: string; value: string }[],
  config: ProjectConfig | null | undefined
) {
  if (!config?.stats) return defaultStats
  return defaultStats.map((stat) => {
    const key = Object.keys(config.stats).find((k) => k.toLowerCase() === stat.label.toLowerCase().replace(/\s+/g, ''))
    return key ? { ...stat, value: String(config.stats[key]) } : stat
  })
}

const projects = PROJECT_DEFAULTS.map((project) => {
  const config = projectConfigs[project.slug]
  const github = githubData[project.slug]

  let stats = mergeConfigStats(project.stats, config)
  stats = stats.map((stat) =>
    stat.label === 'Commits' && github?.commits ? { ...stat, value: String(github.commits) } : stat
  )

  return {
    ...project,
    desc: config?.descriptionES || project.desc,
    status: (config?.status && STATUS_LABELS_ES[config.status]) || project.status,
    statusColor: (config?.status && STATUS_COLORS[config.status]) || project.statusColor,
    tags: config?.tags?.length ? config.tags : project.tags,
    stats,
    github,
  }
})

const liveCommitTotal = Object.values(githubData).reduce((sum, repo) => sum + (repo?.commits || 0), 0)
const totalCommitsDisplay = liveCommitTotal > 0 ? `${liveCommitTotal}+` : '121+'
---

<Layout
  title="Plataforma Open Source — LRA CloudOps"
  description="Cuatro proyectos open source. Cuatro capacidades de Platform Engineering — Infrastructure as Code, Kubernetes, GitOps y orquestación IA."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- Page hero -->
  <section
    data-animate="fade-up"
    style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Plataforma Open Source
      </p>
      <h1
        style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;"
      >
        Cuatro capacidades. Una plataforma.
      </h1>
      <p
        style="font-family: var(--font-body); font-size: 1.0625rem; color: var(--color-text-secondary); max-width: 560px;"
      >
        Implementaciones de grado producción del stack de Platform Engineering —
        inspecciona el código, ejecuta las herramientas, construye sobre la base.
      </p>
    </div>
  </section>

  <!-- Barra de stats globales -->
  <section style="background: var(--color-bg-soft); border-bottom: 1px solid #DADCE0; padding: 1.25rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
          {[
            { value: '4', label: 'proyectos open source' },
            { value: totalCommitsDisplay, label: 'commits' },
            { value: '51', label: 'tests' },
          ].map(({ value, label }) => (
            <div style="display: flex; align-items: baseline; gap: 0.375rem;">
              <span style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 900; color: var(--color-primary); letter-spacing: -0.03em;">{value}</span>
              <span style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary);">{label}</span>
            </div>
          ))}
        </div>
        <div style="height: 20px; width: 1px; background: #DADCE0; flex-shrink: 0;"></div>
        <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
          {['Python', 'Terraform', 'Bash', 'HCL', 'YAML'].map(lang => (
            <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-secondary); background: var(--color-bg); border: 1px solid var(--color-border); padding: 0.125rem 0.5rem; border-radius: 3px;">{lang}</span>
          ))}
        </div>
        <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener noreferrer"
          style="margin-left: auto; display: inline-flex; align-items: center; gap: 0.375rem; font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-primary); text-decoration: none;"
          class="link-hover-underline"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          github.com/lra-cloud-ops →
        </a>
      </div>
    </div>
  </section>

  <!-- Projects grid -->
  <section style="background: var(--color-bg); padding: 3rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        data-animate="stagger"
        style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;"
        class="projects-grid"
      >
        {
          projects.map((project) => (
            <div
              data-animate-child
              class="card-premium"
              style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: box-shadow 200ms ease;"
            >
              <div
                style={`background: ${project.color}08; border-bottom: 1px solid #DADCE0; padding: 1.25rem 1.5rem; display: flex; align-items: start; justify-content: space-between;`}
              >
                <div>
                  <p
                    style={`font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: ${project.color}; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.375rem;`}
                  >
                    {project.category}
                  </p>
                  <h2 style="font-family: var(--font-mono); font-size: 1.0625rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.375rem;">
                    {project.name}
                  </h2>
                  <span
                    style={`font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 600; color: ${MATURITY_BADGES[project.slug].color}; background: ${MATURITY_BADGES[project.slug].bg}; border: 1px solid ${MATURITY_BADGES[project.slug].color}; padding: 0.125rem 0.5rem; border-radius: 3px;`}
                  >
                    {MATURITY_BADGES[project.slug].label}
                  </span>
                </div>
                <span
                  class={project.status === 'Activo' ? 'status-active' : undefined}
                  style={`font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: ${project.statusColor}; background: ${project.statusColor}12; padding: 0.25rem 0.625rem; border-radius: var(--radius-sm); border: 1px solid ${project.statusColor}30; white-space: nowrap;`}
                >
                  {project.status}
                </span>
              </div>

              <div style="display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid #DADCE0;" class="project-stats-grid">
                {project.stats.map(({ label, value }, i) => (
                  <div
                    style={`padding: 0.875rem 1rem; text-align: center; ${i < 3 ? 'border-right: 1px solid #DADCE0;' : ''}`}
                  >
                    <div
                      style={`font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: ${project.color}; line-height: 1;`}
                      data-count={/^\d+$/.test(value) ? value : undefined}
                    >
                      {value}
                    </div>
                    <div style="font-family: var(--font-body); font-size: 0.6875rem; color: var(--color-text-secondary); margin-top: 0.25rem;">
                      {label}
                    </div>
                  </div>
                ))}
              </div>

              <div style="padding: 1.25rem 1.5rem;">
                <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 1.25rem;">
                  {project.desc}
                </p>

                <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1.25rem;">
                  {project.tags.map((tag) => (
                    <span class={getTagClass(tag)} style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-secondary); background: var(--color-bg-soft); border: 1px solid var(--color-border); padding: 0.2rem 0.5rem; border-radius: 3px;">
                      {tag}
                    </span>
                  ))}
                </div>

                {project.github?.pushedAt && (
                  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem; padding-top: 0.875rem; border-top: 1px solid #DADCE0; flex-wrap: wrap;">
                    <span style="display: inline-flex; align-items: center; gap: 0.25rem; font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-secondary);">
                      ★ {project.github.stars}
                    </span>
                    <span style="display: inline-flex; align-items: center; gap: 0.25rem; font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-secondary);">
                      ⑂ {project.github.forks}
                    </span>
                    <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-secondary);">
                      Actualizado {formatDateES(project.github.pushedAt)}
                    </span>
                  </div>
                )}

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
                  <a
                    href={`/es/proyectos/${project.slug}`}
                    style="display: inline-flex; align-items: center; gap: 0.375rem; font-family: var(--font-body); font-size: 0.875rem; font-weight: 600; color: var(--color-primary); text-decoration: none;"
                    class="link-hover-underline"
                  >
                    Ver detalles →
                  </a>
                  <a
                    href={project.githubHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${project.name} en GitHub`}
                    style="display: inline-flex; align-items: center; color: var(--color-text-secondary); text-decoration: none;"
                    class="icon-hover-dark"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Cómo se conectan estos proyectos -->
  <section style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-top: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Ecosistema</p>
      <h2 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">Dependencias de ingeniería</h2>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); margin-bottom: 2rem;">Cómo interactúan los cuatro repositorios en producción.</p>

      <div style="display: flex; flex-direction: column; gap: 0.75rem; max-width: 720px;">
        {PROJECT_CONNECTIONS.map(({ from, arrow, to, desc }) => (
          <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
              <span style="font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 600; color: var(--color-primary);">{from}</span>
              <span style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-text-muted);">→ {arrow} →</span>
              <span style="font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 600; color: var(--color-text);">{to}</span>
            </div>
            <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary); margin: 0; line-height: 1.6;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 767px) {
    .projects-grid {
      grid-template-columns: 1fr !important;
    }
  }

  @media (max-width: 480px) {
    .project-stats-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  .link-hover-underline:hover {
    text-decoration: underline !important;
  }

  .icon-hover-dark:hover {
    color: #202124 !important;
  }
</style>

<script is:inline src="/js/stat-counter.js"></script>
