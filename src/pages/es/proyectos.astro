---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

export const prerender = true

const projects = [
  {
    name: 'aws-terraform-devops',
    longDesc:
      'Plataforma AWS de nivel producción construida con módulos Terraform. Incluye VPC con subredes Multi-AZ, cluster EKS con node groups gestionados, RDS PostgreSQL con backups automáticos, Application Load Balancer, CDN CloudFront y stack de observabilidad completo.',
    tags: [
      'AWS',
      'EKS 1.31',
      'Terraform',
      'RDS PostgreSQL 15',
      'ArgoCD',
      'Jenkins',
      'Prometheus',
      'Grafana',
    ],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
    metrics: [
      { label: 'Tiempo de deploy', value: '45min' },
      { label: 'Deploys manuales', value: '0' },
      { label: 'Disponibilidad', value: '99.9%' },
      { label: 'Cobertura IaC', value: '100%' },
    ],
  },
  {
    name: 'gitops-stack',
    longDesc:
      'Implementación GitOps completa siguiendo el modelo declarativo. ArgoCD vigila los repositorios Git y sincroniza automáticamente el estado del cluster. El drift se detecta y reconcilia automáticamente.',
    tags: [
      'ArgoCD',
      'GitOps',
      'Kubernetes',
      'Helm',
      'AWS EKS',
      'Ansible',
      'CloudWatch',
    ],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/gitops-stack',
    metrics: [
      { label: 'kubectl manual', value: '0' },
      { label: 'Tiempo de deploy', value: '<8min' },
      { label: 'Cobertura IaC', value: '100%' },
      { label: 'Credenciales AWS', value: '0 estáticas' },
    ],
  },
  {
    name: 'k8s-devops-platform',
    longDesc:
      'Plataforma DevOps local completa para desarrollo. Usa KinD (Kubernetes in Docker) para replicar el entorno de producción. Incluye stack GitOps completo, observabilidad y pipelines CI/CD.',
    tags: [
      'Kubernetes',
      'KinD',
      'ArgoCD',
      'Helm',
      'Prometheus',
      'Grafana',
      'Alertmanager',
    ],
    status: 'Reference',
    href: 'https://github.com/lra-cloud-ops/k8s-devops-platform',
    metrics: [
      { label: 'kubectl manual', value: '0' },
      { label: 'Deploys GitOps', value: '100%' },
      { label: 'Paridad con prod', value: 'Exacta' },
      { label: 'Auto-heal', value: 'Activo' },
    ],
  },
  {
    name: 'linux-fleet-manager',
    longDesc:
      'Herramienta de gestión de flota de nivel producción que opera vía agentes SSH sin requerir agentes en los hosts destino. Todos los scripts están validados con ShellCheck y probados en CI en múltiples plataformas.',
    tags: ['Bash', 'SSH', 'Linux', 'ShellCheck', 'CI/CD', 'Ansible'],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/linux-fleet-manager',
    metrics: [
      { label: 'Agentes en hosts', value: '0' },
      { label: 'Score ShellCheck', value: '100%' },
      { label: 'Plataformas', value: '3 SO' },
      { label: 'Idempotente', value: 'Sí' },
    ],
  },
]
---

<Layout
  title="Proyectos — Ruben Liquenson"
  description="Proyectos DevOps open source de Ruben Liquenson. AWS EKS, Terraform, GitOps, Kubernetes — infraestructura de nivel producción."
  lang="es"
>
  <Header />

  <section class="bg-dark on-dark section-sm">
    <div class="container">
      <div class="eyebrow">Open Source</div>
      <h1 style="color: #FFF; margin-bottom: 1rem;">Proyectos</h1>
      <p style="color: #94A3B8; max-width: 560px; font-size: 1.125rem;">
        Proyectos de infraestructura de nivel producción. Código real, métricas
        reales, entornos reales. No demos de sandbox.
      </p>
    </div>
  </section>

  <section class="bg-light section">
    <div class="container">
      <div style="display: flex; flex-direction: column; gap: 3rem;">
        {
          projects.map((project, i) => (
            <article
              class={`project-article ${i === 0 ? 'project-article-featured' : ''}`}
            >
              <div style="display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: start; margin-bottom: 1.5rem;">
                <div>
                  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
                    <a
                      href={project.href}
                      target="_blank"
                      rel="noopener"
                      style="font-family: var(--font-mono); font-size: 1.25rem; font-weight: 700; color: var(--color-primary); text-decoration: none;"
                    >
                      {project.name} ↗
                    </a>
                    <span
                      class={`badge ${project.status === 'Production' ? 'badge-green' : 'badge-blue'}`}
                    >
                      {project.status}
                    </span>
                  </div>
                  <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">
                    {project.longDesc}
                  </p>
                </div>
              </div>

              <div class="metrics-grid">
                {project.metrics.map((m, mi) => (
                  <div
                    class={`metric-item ${mi < project.metrics.length - 1 ? 'metric-border' : ''}`}
                  >
                    <div class="metric-value">{m.value}</div>
                    <div class="metric-label">{m.label}</div>
                  </div>
                ))}
              </div>

              <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
                {project.tags.map((tag) => (
                  <span class="tech-pill" style="font-size: 0.75rem;">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .project-article {
    padding: 2.5rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    background: #fff;
  }
  .project-article-featured {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: var(--surface-subtle);
    border-radius: var(--radius-sm);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .metric-item {
    padding: 1rem;
    text-align: center;
  }
  .metric-border {
    border-right: 1px solid var(--border-light);
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-primary);
  }
  .metric-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
