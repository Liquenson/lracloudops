---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

const plans = [
  {
    name: 'Starter',
    price: '49',
    period: '/mes',
    desc: 'Para equipos pequeños que empiezan con automatización DevOps.',
    features: [
      'lra scan — escaneos ilimitados en GitHub',
      'infrastructure_review — mensual',
      'security_review — bajo demanda',
      '1 cuenta cloud (AWS)',
      'Soporte por email',
      'Acceso al dashboard',
    ],
    cta: 'Empezar',
    featured: false,
  },
  {
    name: 'Professional',
    price: '199',
    period: '/mes',
    desc: 'Acceso completo a la plataforma. Los 8 agentes. Los 9 workflows.',
    features: [
      'Todo lo de Starter',
      'Los 8 agentes — acceso completo',
      'Los 9 workflows automatizados',
      'pr_review en cada PR',
      'documentation_update semanal',
      '3 cuentas cloud',
      'Soporte prioritario',
      'Acceso API',
    ],
    cta: 'Empezar',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    desc: 'Infraestructura dedicada. SLA. Arquitecto DevOps asignado.',
    features: [
      'Todo lo de Professional',
      'deploy_eks gestionado',
      'Arquitecto DevOps dedicado',
      'Desarrollo de agentes a medida',
      'SLA 99.9%',
      'Cuentas cloud ilimitadas',
      'Soporte on-call',
    ],
    cta: 'Contactar',
    featured: false,
  },
]
---

<Layout
  title="Precios — LRA CloudOps"
  description="Precios simples y transparentes. Empieza con lo que necesitas. Escala cuando crezcas."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0; text-align: center;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Precios
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        Precios simples y transparentes
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368;"
      >
        Empieza con lo que necesitas. Escala cuando crezcas.
      </p>
    </div>
  </section>

  <section style="background: #FFFFFF; padding: 3rem 1.5rem;">
    <div style="max-width: 960px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;"
        class="pricing-grid"
      >
        {
          plans.map((plan) => (
            <div
              style={`border-radius: 8px; padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; position: relative; ${plan.featured ? 'border: 2px solid #1A73E8; box-shadow: 0 4px 20px rgba(26,115,232,0.12);' : 'border: 1px solid #DADCE0;'}`}
            >
              {plan.featured && (
                <div style="position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: #1A73E8; color: #FFFFFF; font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; padding: 0.25rem 1rem; border-radius: 9999px; white-space: nowrap;">
                  Más popular
                </div>
              )}
              <div>
                <p style="font-family: 'Red Hat Display', sans-serif; font-size: 1.0625rem; font-weight: 700; color: #202124; margin-bottom: 0.25rem;">
                  {plan.name}
                </p>
                <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">
                  {plan.desc}
                </p>
              </div>
              <div style="display: flex; align-items: baseline; gap: 0.25rem;">
                {plan.price !== 'Custom' && (
                  <span style="font-family: 'Red Hat Text', sans-serif; font-size: 1.25rem; color: #5F6368;">
                    €
                  </span>
                )}
                <span style="font-family: 'Red Hat Display', sans-serif; font-size: 2.5rem; font-weight: 900; color: #202124; line-height: 1; letter-spacing: -0.04em;">
                  {plan.price}
                </span>
                <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">
                  {plan.period}
                </span>
              </div>
              <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; flex: 1;">
                {plan.features.map((f) => (
                  <li style="display: flex; align-items: start; gap: 0.625rem;">
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      style="color: #1A73E8; flex-shrink: 0; margin-top: 2px;"
                    >
                      <path
                        d="M20 6L9 17l-5-5"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;">
                      {f}
                    </span>
                  </li>
                ))}
              </ul>
              <a
                href={plan.name === 'Enterprise' ? '/es/contacto' : '/es/login'}
                style={`display: block; text-align: center; padding: 0.75rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none; ${plan.featured ? 'background: #1A73E8; color: #FFFFFF;' : 'background: transparent; color: #1A73E8; border: 1px solid #DADCE0;'}`}
              >
                {plan.cta}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
