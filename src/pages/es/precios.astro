---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---

<Layout
  title="Precios Transparentes — LRA CloudOps"
  description="Precios transparentes para servicios de Platform Engineering — auditoría de infraestructura gratuita, proyectos de ingeniería de alcance fijo desde €800, retención de plataforma a €699/mes."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- Hero -->
  <section style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0; text-align: center;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Precios Transparentes</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;">Alcance fijo. Precio fijo.</h1>
      <p style="font-family: var(--font-body); font-size: 1.0625rem; color: var(--color-text-secondary);">Sin facturación por horas. Sin scope creep. Entregables definidos en cada proyecto.</p>
    </div>
  </section>

  <!-- 3 planes -->
  <section style="background: var(--color-bg); padding: 3rem 1.5rem;">
    <div style="max-width: 1100px; margin: 0 auto;">

      <!-- Calculadora de colaboración -->
      <div style="background:var(--color-bg-soft);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:2rem;margin-bottom:3rem;" data-animate="fade-up">
        <h3 style="font-family:var(--font-display);font-size:1.125rem;font-weight:700;color:var(--color-text);margin-bottom:1.5rem;">Encuentra el tipo de colaboración adecuado</h3>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;" class="grid-2">
          <div>
            <label style="font-family:var(--font-body);font-size:0.875rem;font-weight:600;color:var(--color-text);display:block;margin-bottom:0.5rem;">Necesidad principal</label>
            <select id="calc-need" style="width:100%;padding:0.625rem 0.875rem;font-family:var(--font-body);font-size:0.9375rem;color:var(--color-text);background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-md);outline:none;">
              <option value="audit">Auditoría de seguridad</option>
              <option value="cicd">Pipeline CI/CD</option>
              <option value="aws">Infraestructura AWS</option>
              <option value="k8s">Plataforma Kubernetes</option>
              <option value="ongoing">Operaciones continuas</option>
            </select>
          </div>
          <div>
            <label style="font-family:var(--font-body);font-size:0.875rem;font-weight:600;color:var(--color-text);display:block;margin-bottom:0.5rem;">Número de repositorios</label>
            <select id="calc-repos" style="width:100%;padding:0.625rem 0.875rem;font-family:var(--font-body);font-size:0.9375rem;color:var(--color-text);background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-md);outline:none;">
              <option value="1">1 repositorio</option>
              <option value="2-5">2-5 repositorios</option>
              <option value="6+">6+ repositorios</option>
            </select>
          </div>
        </div>

        <div id="calc-result" style="background:var(--color-bg);border:1px solid #1A73E8;border-radius:var(--radius-lg);padding:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <div>
            <p style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);margin:0 0 0.25rem;">Colaboración recomendada</p>
            <p id="calc-plan" style="font-family:var(--font-display);font-size:1.125rem;font-weight:700;color:var(--color-text);margin:0;">Auditoría de Infraestructura — Gratis</p>
          </div>
          <a href="/es/auditoria" id="calc-cta" style="display:inline-flex;align-items:center;gap:0.375rem;background:#1A73E8;color:#FFFFFF;padding:0.625rem 1.25rem;border-radius:var(--radius-sm);font-family:var(--font-body);font-size:0.875rem;font-weight:600;text-decoration:none;white-space:nowrap;">
            Empezar →
          </a>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="pricing-grid">

        <!-- Auditoría gratuita -->
        <div style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
          <div>
            <p style="font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.25rem;">Auditoría de Infraestructura</p>
            <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary);">Análisis automatizado de seguridad e IaC de cualquier repositorio de GitHub. Entregado en 24 horas.</p>
          </div>
          <div style="display: flex; align-items: baseline; gap: 0.25rem;">
            <span style="font-family: var(--font-display); font-size: 3rem; font-weight: 900; color: var(--color-text); line-height: 1; letter-spacing: -0.04em;">Gratis</span>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; flex: 1;">
            {[
              'lra scan en 1 repositorio de GitHub',
              'Trivy — vulnerabilidades de seguridad',
              'Checkov — misconfiguraciones de IaC',
              'Informe PASS/FAIL por email',
              'Recomendaciones concretas de solución',
              'Entregado en 24 horas',
            ].map(f => (
              <li style="display: flex; align-items: start; gap: 0.625rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: var(--color-primary); flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text-secondary);">{f}</span>
              </li>
            ))}
          </ul>
          <a href="/es/auditoria" style="display: block; text-align: center; padding: 0.75rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-weight: 600; font-size: 0.9375rem; text-decoration: none; background: transparent; color: var(--color-primary); border: 1px solid var(--color-border);" class="btn-premium-outline">
            Solicitar auditoría gratuita
          </a>
          <p style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-muted); text-align: center; margin: 0;">
            Soporte de remediación de pago desde €249
          </p>
        </div>

        <!-- Proyecto DevOps -->
        <div style="border: 2px solid #1A73E8; border-radius: var(--radius-lg); padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; position: relative; box-shadow: 0 4px 20px rgba(26,115,232,0.12);">
          <div style="position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: #1A73E8; color: #FFFFFF; font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; padding: 0.25rem 1rem; border-radius: var(--radius-full); white-space: nowrap;">
            Más popular
          </div>
          <div>
            <p style="font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.25rem;">Proyecto de Ingeniería</p>
            <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary);">Entrega de alcance fijo — pipeline CI/CD, infraestructura AWS, plataforma Kubernetes o remediación de seguridad. Timeline y entregables definidos por adelantado.</p>
          </div>
          <div style="display: flex; align-items: baseline; gap: 0.25rem;">
            <span style="font-family: var(--font-body); font-size: 1.0625rem; color: var(--color-text-secondary); font-weight: 500;">Desde</span>
            <span style="font-family: var(--font-body); font-size: 1.25rem; color: var(--color-text-secondary); font-weight: 500;">€</span>
            <span style="font-family: var(--font-display); font-size: 3rem; font-weight: 900; color: var(--color-text); line-height: 1; letter-spacing: -0.04em;">800</span>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; flex: 1;">
            {[
              'Pipeline CI/CD (GitHub Actions + ArgoCD)',
              'Infraestructura AWS con Terraform',
              'Setup de clúster Kubernetes',
              'Escaneo de seguridad incluido (Trivy + Checkov)',
              'Documentación completa',
              'Entrega: 1-2 semanas',
              'Precio fijo por proyecto',
            ].map(f => (
              <li style="display: flex; align-items: start; gap: 0.625rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: var(--color-primary); flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text-secondary);">{f}</span>
              </li>
            ))}
          </ul>
          <div style="display:flex;flex-direction:column;gap:var(--space-3);margin-top:auto;">
            <a href="/es/contacto?service=project"
              style="display:inline-flex;align-items:center;justify-content:center;gap:var(--space-2);background:var(--color-primary);color:#FFFFFF;padding:0.75rem var(--space-6);border-radius:var(--radius-md);font-family:var(--font-body);font-size:var(--text-md);font-weight:600;text-decoration:none;transition:background var(--transition-fast);"
              class="btn-hover-primary"
            >
              Solicitar presupuesto →
            </a>
            <p style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text-muted);text-align:center;margin:0;">
              Alcance y precio definidos por adelantado
            </p>
          </div>
        </div>

        <!-- Consultoría mensual -->
        <div id="retainer" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; scroll-margin-top: 88px;">
          <div>
            <p style="font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.25rem;">Retención de Plataforma</p>
            <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary);">Operaciones de plataforma continuas — escaneos de seguridad mensuales, revisiones de infraestructura, auditorías CI/CD y acceso directo de ingeniería. Mes a mes, sin permanencia.</p>
          </div>
          <div style="display: flex; align-items: baseline; gap: 0.25rem;">
            <span style="font-family: var(--font-body); font-size: 1.25rem; color: var(--color-text-secondary); font-weight: 500;">€</span>
            <span style="font-family: var(--font-display); font-size: 3rem; font-weight: 900; color: var(--color-text); line-height: 1; letter-spacing: -0.04em;">699</span>
            <span style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary);">/mes</span>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; flex: 1;">
            {[
              'Todo lo incluido en Proyecto de Ingeniería',
              'lra scan mensual en todos los repositorios',
              'Revisión mensual de infraestructura',
              'Auditoría de pipeline CI/CD',
              'Acceso directo por email y LinkedIn',
              'Soporte de implementación',
              'Sin contrato a largo plazo',
            ].map(f => (
              <li style="display: flex; align-items: start; gap: 0.625rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: var(--color-primary); flex-shrink: 0; margin-top: 2px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text-secondary);">{f}</span>
              </li>
            ))}
          </ul>
          <div style="display:flex;flex-direction:column;gap:var(--space-3);margin-top:auto;">
            <a href="https://buy.stripe.com/TU_LINK_REAL_RETAINER"
              target="_blank"
              rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;justify-content:center;gap:var(--space-2);background:var(--color-primary);color:#FFFFFF;padding:0.75rem var(--space-6);border-radius:var(--radius-md);font-family:var(--font-body);font-size:var(--text-md);font-weight:600;text-decoration:none;transition:background var(--transition-fast);"
              class="btn-hover-primary"
            >
              Suscribirse ahora →
            </a>
            <p style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text-muted);text-align:center;margin:0;">
              Pago seguro con Stripe · Cancela cuando quieras
            </p>
          </div>
        </div>
      </div>

      <!-- Nota -->
      <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-muted); text-align: center; margin-top: 2rem;">
        Pipeline CI/CD: €800-1.200 · Infraestructura AWS: €1.500-3.000 · Plataforma Kubernetes: €2.000-4.000 · Remediación de seguridad: €249-499
      </p>

      <!-- Badge de seguridad de pago -->
      <div style="display:flex;align-items:center;justify-content:center;gap:var(--space-3);margin:var(--space-8) 0;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:var(--space-2);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text-secondary);">Pago seguro con Stripe</span>
        </div>
        <span style="color:var(--color-border);">·</span>
        <span style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text-secondary);">SEPA · Visa · Mastercard · PayPal</span>
        <span style="color:var(--color-border);">·</span>
        <span style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text-secondary);">Cumplimiento PSD2/SCA</span>
      </div>
    </div>
  </section>

  <!-- Qué incluye cada plan -->
  <section style="background:var(--color-bg-soft);padding:var(--section-py) var(--container-px);border-top:1px solid var(--color-border);" data-animate="fade-up">
    <div style="max-width:860px;margin-inline:auto;">
      <h2 style="font-family:var(--font-display);font-size:clamp(var(--text-2xl),2.5vw,var(--text-4xl));font-weight:700;color:var(--color-text);margin-bottom:var(--space-8);text-align:center;">Qué incluye cada plan</h2>
      <div class="pricing-comparison-table">
        <table style="width:100%;border-collapse:collapse;font-family:var(--font-body);font-size:var(--text-md);">
          <thead>
            <tr style="border-bottom:2px solid var(--color-border);">
              <th style="text-align:left;padding:var(--space-4);color:var(--color-text-secondary);font-weight:600;"></th>
              <th style="text-align:center;padding:var(--space-4);color:var(--color-text);font-weight:700;">Auditoría Gratuita</th>
              <th style="text-align:center;padding:var(--space-4);color:var(--color-primary);font-weight:700;background:var(--color-primary-light);border-radius:var(--radius-md) var(--radius-md) 0 0;">Proyecto de Ingeniería</th>
              <th style="text-align:center;padding:var(--space-4);color:var(--color-text);font-weight:700;">Platform Retainer</th>
            </tr>
          </thead>
          <tbody>
            {[
              { feature: 'Auditoría de seguridad lra scan', free: true, project: true, retainer: true },
              { feature: 'Informe de remediación con IA', free: true, project: true, retainer: true },
              { feature: 'Análisis Trivy + Checkov', free: true, project: true, retainer: true },
              { feature: 'Soporte de implementación', free: false, project: true, retainer: true },
              { feature: 'Infrastructure as Code (Terraform)', free: false, project: true, retainer: true },
              { feature: 'Setup de plataforma Kubernetes', free: false, project: true, retainer: true },
              { feature: 'Pipeline GitOps (ArgoCD)', free: false, project: true, retainer: true },
              { feature: 'Scans de seguridad mensuales', free: false, project: false, retainer: true },
              { feature: 'Detección de deriva de infraestructura', free: false, project: false, retainer: true },
              { feature: 'Acceso directo a ingeniería', free: false, project: false, retainer: true },
              { feature: 'Revisión mensual de plataforma', free: false, project: false, retainer: true },
            ].map(({ feature, free, project, retainer }, i) => (
              <tr style={`border-bottom:1px solid var(--color-border);${i % 2 === 0 ? '' : 'background:var(--color-bg-soft);'}`}>
                <td style="padding:var(--space-3) var(--space-4);color:var(--color-text);">{feature}</td>
                <td style="text-align:center;padding:var(--space-3);">{free ? '✓' : '—'}</td>
                <td style="text-align:center;padding:var(--space-3);background:rgba(26,115,232,0.04);">{project ? '✓' : '—'}</td>
                <td style="text-align:center;padding:var(--space-3);">{retainer ? '✓' : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-top: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 860px; margin: 0 auto;">
      <h2 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 2rem; text-align: center;">Preguntas frecuentes</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {[
          {
            q: '¿Admitís repositorios privados?',
            a: 'Sí. Se admiten repositorios de GitHub públicos y privados. Para repos privados, se otorga acceso de lectura temporal mediante un token de GitHub revocable.'
          },
          {
            q: '¿Qué se necesita para empezar?',
            a: 'Una URL de repositorio de GitHub y una dirección de email. Sin instalación, sin configuración, sin tarjeta de crédito.'
          },
          {
            q: '¿Cuál es el plazo de entrega de la auditoría?',
            a: 'Los informes se entregan en 24-48 horas desde la solicitud. Repositorios de mayor tamaño pueden tardar hasta 72 horas.'
          },
          {
            q: '¿Qué tecnologías soporta lra scan?',
            a: 'Terraform, manifiestos Kubernetes, Dockerfiles, GitHub Actions, AWS CloudFormation y Ansible. Trivy también escanea imágenes de contenedor cuando están presentes en el repositorio.'
          },
          {
            q: '¿Hay permanencia en la retención de plataforma?',
            a: 'Sin permanencia. La retención de plataforma se factura mes a mes y puede cancelarse con 7 días de preaviso.'
          },
          {
            q: '¿Qué ocurre tras la auditoría gratuita?',
            a: 'Recibes el informe por email. Si el análisis resulta útil y necesitas soporte continuo, podemos hablar de una retención de plataforma. Sin presión.'
          },
        ].map(({ q, a }) => (
          <details style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden;">
            <summary style="padding: 1.125rem 1.5rem; font-family: var(--font-display); font-size: 0.9375rem; font-weight: 600; color: var(--color-text); cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between;">
              {q}
              <span style="font-size: 1.25rem; color: var(--color-primary); flex-shrink: 0; margin-left: 1rem;">+</span>
            </summary>
            <div style="padding: 0 1.5rem 1.125rem; font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.7; border-top: 1px solid #DADCE0; padding-top: 1rem;">
              {a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 1199px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 767px) {
    .pricing-grid {
      grid-template-columns: 1fr !important;
    }
  }

  .btn-hover-primary:hover {
    background: var(--color-primary-hover) !important;
  }
</style>

<script is:inline src="/js/pricing-calc-es.js"></script>
