---
import SolutionLayout from '../../components/SolutionLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://lracloudops.com/es/observability#service',
  name: 'Observabilidad · Prometheus · Grafana',
  serviceType: 'Observability',
  description: 'Instrumentación desde el día uno, no tras el primer incidente. Métricas Prometheus, logs estructurados y umbrales de alerta configurados antes de que el primer usuario llegue a producción.',
  url: 'https://lracloudops.com/es/observability',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: 'Worldwide',
  inLanguage: 'es-ES',
}
---

<SolutionLayout
  titulo="Observabilidad · Prometheus, Grafana y SRE"
  descripcion="Instrumentación desde el día uno, no tras el primer incidente. Métricas Prometheus, logs estructurados y umbrales de alerta configurados antes de que el primer usuario llegue a producción."
  badgeLabel="04 · Observability"
  h1="Sabes qué está fallando antes de que abran un ticket."
  heroSubtitle="La observabilidad añadida después del primer incidente está diseñada para el incidente que ya ocurrió. La observabilidad diseñada desde el inicio cubre los incidentes que aún no han ocurrido. La diferencia es cuándo se definen los SLIs — antes de la primera carga de usuario, no después."
  schema={schema}
  sectionNumber="04"
  challenges={[
    { title: 'Observabilidad añadida retroactivamente', desc: 'El stack de monitorización se añade tras el primer incidente de producción. Las alertas se configuran para los síntomas del incidente pasado, no para los futuros.' },
    { title: 'Métricas sin contexto de negocio', desc: 'CPU y memoria son necesarias pero no suficientes. Sin métricas de latencia, tasa de errores y saturación específicas de cada servicio, es imposible correlacionar el estado del sistema con el impacto en usuarios.' },
    { title: 'Logs sin estructura', desc: 'Los logs en texto libre requieren búsqueda de texto completo para extraer información. Durante un incidente, buscar en logs no estructurados consume tiempo que debería destinarse a la remediación.' },
    { title: 'Alertas que no apuntan a una acción', desc: 'Una alerta que dice "CPU al 80%" no indica qué hacer. Una alerta que dice "Latencia p99 del servicio de pagos > 2s durante 5 minutos" apunta directamente a una acción.' },
  ]}
  archTitle="El stack de observabilidad que desplegamos."
  archSubtitle="Métricas, logs y alertas configurados como código. Dashboards listos el día del primer despliegue."
  layers={[
    { layer: 'Recolección de Métricas', tools: 'Prometheus · kube-state-metrics · node-exporter · custom metrics', desc: 'Prometheus scrapeando métricas de todos los componentes del clúster, los nodos y los servicios de aplicación. Métricas personalizadas de la aplicación expuestas en el endpoint /metrics.' },
    { layer: 'Visualización', tools: 'Grafana · Dashboards como código · Annotations', desc: 'Dashboards Grafana definidos como JSON y gestionados en Git. Dashboards para infraestructura (nodos, pods, red) y servicios de aplicación (latencia, tasa de errores, throughput) listos en el día uno.' },
    { layer: 'Alerting', tools: 'Alertmanager · PagerDuty · Slack · Escalation policies', desc: 'Alertas definidas en Prometheus alerting rules con umbrales basados en SLIs del servicio. Alertmanager enruta por severidad — crítico a PagerDuty, warning a Slack.' },
    { layer: 'Logs Estructurados', tools: 'JSON logging · Fluent Bit · CloudWatch Logs Insights', desc: 'Aplicaciones configuradas para logs JSON estructurados. Fluent Bit para recolección y envío a CloudWatch Logs. Queries de CloudWatch Logs Insights predefinidas para patrones de error comunes.' },
    { layer: 'Métricas AWS Nativas', tools: 'CloudWatch · Container Insights · RDS Enhanced Monitoring', desc: 'CloudWatch Container Insights para métricas de EKS y ECS. RDS Enhanced Monitoring para métricas de base de datos. Alertas de coste para detectar derivas de gasto antes de que impacten en el presupuesto.' },
    { layer: 'SLIs y SLOs', tools: 'Error budget · Availability targets · Latency budgets', desc: 'SLIs definidos antes del primer despliegue: disponibilidad del servicio, latencia p50/p95/p99, tasa de errores. SLO calculado como disponibilidad objetivo mensual con alerta cuando el error budget se agota.' },
  ]}
  steps={[
    { step: '01', title: 'Definición de SLIs', desc: 'Identificamos las métricas que miden directamente la experiencia del usuario: disponibilidad, latencia, tasa de errores. Los SLIs se definen antes de la instrumentación.' },
    { step: '02', title: 'Instrumentación de aplicaciones', desc: 'Añadimos endpoints /metrics a los servicios. Configuramos logs estructurados en JSON. Verificamos que las métricas críticas están expuestas correctamente.' },
    { step: '03', title: 'Deploy del stack de observabilidad', desc: 'Prometheus, Grafana y Alertmanager desplegados via Helm. Dashboards y reglas de alerta aplicados como código.' },
    { step: '04', title: 'Configuración de alertas y runbooks', desc: 'Alertas configuradas para los SLIs definidos. Cada alerta tiene un runbook que describe el diagnóstico y la remediación — antes de que ocurra el primer incidente.' },
  ]}
  outcomes={[
    { metric: 'Dashboards listos en día 1', detail: 'antes de la primera carga de usuario' },
    { metric: 'Alertas accionables', detail: 'no solo "CPU alta" — qué servicio, qué impacto' },
    { metric: 'MTTD reducido', detail: 'tiempo de detección de incidentes en minutos, no horas' },
    { metric: 'Logs estructurados', detail: 'queries predefinidas para patrones de error comunes' },
    { metric: 'SLOs definidos', detail: 'disponibilidad y latencia medidos continuamente' },
    { metric: 'Observabilidad como código', detail: 'dashboards y alertas en Git, no en la UI de Grafana' },
  ]}
  ctaH2="Instrumenta tu plataforma desde el inicio."
  ctaSubtitle="Trae tus servicios actuales y los requisitos de observabilidad de tu equipo. Diseñamos el stack que permite detectar incidentes antes de que los usuarios los reporten."
  backLabel="Volver a Soluciones"
/>
