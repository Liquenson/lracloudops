---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

const successRedirectUrl = new URL('/es/contacto?success=true', Astro.site).toString()
---

<Layout
  title="Auditoría de Infraestructura Gratuita — LRA CloudOps"
  description="Contacta con LRA CloudOps. Preguntas sobre la plataforma, precios o consultoría DevOps."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Auditoría de Infraestructura Gratuita
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        Comienza con una auditoría de infraestructura gratuita.
      </h1>
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E6F4EA; color: #137333; padding: 0.375rem 0.875rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 500; margin-top: 1rem;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: #137333;"></span>
        Análisis automatizado entregado en menos de 24 horas
      </div>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; max-width: 480px;"
      >
        Envía un repositorio de GitHub. Recibe un análisis completo de
        seguridad e IaC — Trivy, Checkov, remediación generada con IA — en
        menos de 24 horas. Sin compromiso.
      </p>
    </div>
  </section>

  <section style="background: #FFFFFF; padding: 3rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        data-animate="fade-up"
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;"
        class="contact-grid"
      >
        <!-- Contact form -->
        <div>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 700; color: #202124; margin-bottom: 1.5rem;"
          >
            Envía un mensaje
          </h2>
          <form
            style="display: flex; flex-direction: column; gap: 1.25rem;"
            action="https://api.web3forms.com/submit"
            method="POST"
          >
            <input
              type="hidden"
              name="access_key"
              value="e8aaab4e-270c-4163-bb76-6a8dfc247485"
            />
            <input
              type="hidden"
              name="subject"
              value="LRA CloudOps — Formulario de contacto"
            />
            <input type="hidden" name="redirect" value={successRedirectUrl} />

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Nombre
              </label>
              <input
                type="text"
                name="name"
                required
                placeholder="Tu nombre"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              />
            </div>

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Email
              </label>
              <input
                type="email"
                name="email"
                required
                placeholder="tu@empresa.com"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              />
            </div>

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Tema
              </label>
              <select
                name="topic"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
              >
                <option value="">Selecciona un tema</option>
                <option value="audit">Auditoría de infraestructura gratuita</option>
                <option value="platform">Acceso a la plataforma</option>
                <option value="consulting">Consultoría DevOps</option>
                <option value="pricing">Pregunta sobre precios</option>
                <option value="other">Otro</option>
              </select>
            </div>

            <div>
              <label style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;">
                Repositorio de GitHub <span style="color: #9AA0A6; font-weight: 400;">(opcional)</span>
              </label>
              <input type="text" name="github_repo"
                placeholder="org/repo (ej. lra-cloud-ops/aws-terraform-devops)"
                pattern="[\\w.\\-]+/[\\w.\\-]+"
                title="Formato: org/repo"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              />
              <p style="font-family:'Red Hat Text',sans-serif;font-size:0.8125rem;color:#5F6368;margin-top:0.375rem;line-height:1.5;">
                Formato: <code style="font-family:'Red Hat Mono',monospace;background:#F8F9FA;padding:0.125rem 0.375rem;border-radius:3px;font-size:0.75rem;">org/repositorio</code> — admite repositorios públicos y privados. Los repos privados requieren acceso de lectura temporal mediante un token de GitHub que tú controlas.
              </p>
              <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #137333; margin-top: 0.375rem;">
                ✓ Si incluyes un repo de GitHub, recibirás automáticamente una auditoría de seguridad gratuita en minutos.
              </p>
            </div>

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Mensaje
              </label>
              <textarea
                name="message"
                required
                rows="5"
                placeholder="Describe lo que necesitas..."
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; resize: vertical; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-premium"
              style="display: inline-flex; align-items: center; justify-content: center; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; border: none; cursor: pointer;"
            >
              Enviar mensaje →
            </button>
          </form>

          <div
            id="success-message"
            style="display: none; background: #E6F4EA; border: 1px solid #137333; border-radius: 8px; padding: 1.5rem; text-align: center; margin-top: 1rem;"
          >
            <div style="font-size: 2rem; margin-bottom: 0.5rem;">✅</div>
            <h3 style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #137333; margin-bottom: 0.5rem;">
              Solicitud de auditoría recibida.
            </h3>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; line-height: 1.6;">
              Si incluiste un repositorio de GitHub, lra scan ya está en
              marcha — análisis Trivy y Checkov sobre todo tu código.
              Recibirás el informe en menos de 24 horas.
            </p>
          </div>
        </div>

        <!-- Contact info -->
        <div>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 700; color: #202124; margin-bottom: 1.5rem;"
          >
            Contacto directo
          </h2>
          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div
              style="display: flex; align-items: start; gap: 1rem; padding: 1.25rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px;"
            >
              <div
                style="width: 40px; height: 40px; background: #E8F0FE; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#1A73E8"
                  stroke-width="2"
                >
                  <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </div>
              <div>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;"
                >
                  Email
                </p>
                <a
                  href="mailto:info@lracloudops.com"
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #1A73E8; text-decoration: none;"
                >
                  info@lracloudops.com
                </a>
              </div>
            </div>
            <div
              style="display: flex; align-items: start; gap: 1rem; padding: 1.25rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px;"
            >
              <div
                style="width: 40px; height: 40px; background: #E8F0FE; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1A73E8">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </div>
              <div>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;"
                >
                  LinkedIn
                </p>
                <a
                  href="https://www.linkedin.com/in/ruben-liquenson-490961269/"
                  target="_blank"
                  rel="noopener noreferrer"
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #1A73E8; text-decoration: none;"
                >
                  Ruben Liquenson →
                </a>
              </div>
            </div>
            <div
              style="display: flex; align-items: start; gap: 1rem; padding: 1.25rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px;"
            >
              <div
                style="width: 40px; height: 40px; background: #E8F0FE; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#1A73E8"
                  stroke-width="2"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;"
                >
                  Ubicación
                </p>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;"
                >
                  Las Palmas de Gran Canaria<br />Canarias, España · Remoto
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 767px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>

<script>
  const WEBHOOK_URL = 'https://lracloudops-webhook.liquenson-cloud.workers.dev'

  const form = document.querySelector('form[action*="web3forms"]') as HTMLFormElement | null
  const successMessage = document.getElementById('success-message')

  // Show success message after Web3Forms redirects back with ?success=true
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    successMessage?.style.setProperty('display', 'block')
    form?.style.setProperty('display', 'none')
  }

  // Fire the smart-scan webhook alongside the normal Web3Forms submission.
  // Does NOT preventDefault — the browser still navigates to Web3Forms as usual.
  // keepalive lets the request survive that navigation.
  form?.addEventListener('submit', () => {
    const formData = new FormData(form)
    const githubRepo = (formData.get('github_repo') as string || '').trim()

    if (!githubRepo.includes('/')) return

    const payload = {
      name: (formData.get('name') as string) || '',
      email: (formData.get('email') as string) || '',
      github_repo: githubRepo,
      topic: (formData.get('topic') as string) || '',
    }

    try {
      fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        keepalive: true,
      })
    } catch {
      // Fail silently — Web3Forms already handles the actual message
    }
  })
</script>
