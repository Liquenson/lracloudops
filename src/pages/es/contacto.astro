---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Contacto"
  descripcion="Contacta con LRA Cloud Operations para hablar sobre tu proyecto cloud, platform engineering o infraestructura AWS. Evaluación inicial incluida."
>

  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-2xl">
        <span class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6" style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);">
          Contacto
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-5" style="letter-spacing: -0.02em;">Hablemos.</h1>
        <p class="text-lg" style="color: rgba(147,184,255,0.8);">
          Describe lo que estás construyendo y diseñamos juntos la infraestructura que necesitas.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">

        <div>
          <h2 class="text-2xl font-bold mb-2" style="color: #0A2540;">Envíanos un mensaje</h2>
          <p class="text-sm mb-8" style="color: #64748b;">Respondemos en menos de 24 horas · Evaluación inicial sin cargo.</p>

          <form id="es-contact-form" class="space-y-5">
            <input type="hidden" name="access_key" value="e8aaab4e-270c-4163-bb76-6a8dfc247485" />
            <input type="hidden" name="subject" value="Nueva consulta desde lracloudops.com/es" />
            <input type="hidden" name="from_name" value="LRA Cloud Operations" />

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color: #94a3b8;">Nombre completo</label>
              <input type="text" name="name" required placeholder="Tu nombre completo"
                class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200"
                style="color: #111827; border-color: #e2e8f0; background: #fafbfc;"
                onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';" />
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color: #94a3b8;">Email corporativo</label>
              <input type="email" name="email" required placeholder="tu@empresa.com"
                class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200"
                style="color: #111827; border-color: #e2e8f0; background: #fafbfc;"
                onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';" />
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color: #94a3b8;">Alcance estimado</label>
              <div class="relative">
                <select name="budget"
                  class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 appearance-none"
                  style="color: #111827; background-color: #fafbfc; cursor: pointer; border-color: #e2e8f0;"
                  onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                  onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';">
                  <option value="">Selecciona un rango</option>
                  <option value="Menos de 5.000 €">Menos de 5.000 €</option>
                  <option value="5.000 € – 15.000 €">5.000 € – 15.000 €</option>
                  <option value="15.000 € – 50.000 €">15.000 € – 50.000 €</option>
                  <option value="Más de 50.000 €">Más de 50.000 €</option>
                  <option value="Por definir">Por definir</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                  <svg class="w-4 h-4" style="color: #64748b;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color: #94a3b8;">Plazo estimado</label>
              <div class="relative">
                <select name="timeline"
                  class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 appearance-none"
                  style="color: #111827; background-color: #fafbfc; cursor: pointer; border-color: #e2e8f0;"
                  onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                  onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';">
                  <option value="">Selecciona un plazo</option>
                  <option value="Esta semana">Esta semana</option>
                  <option value="Este mes">Este mes</option>
                  <option value="Próximo trimestre">Próximo trimestre</option>
                  <option value="Sin fecha definida">Sin fecha definida</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                  <svg class="w-4 h-4" style="color: #64748b;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color: #94a3b8;">Tipo de engagement</label>
              <div class="relative">
                <select name="engagement_type"
                  class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none appearance-none"
                  style="color: #111827; background-color: #fafbfc; cursor: pointer; border-color: #e2e8f0;"
                  onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)';"
                  onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none';">
                  <option value="">Selecciona una opción</option>
                  <option value="Infraestructura Cloud">Infraestructura Cloud</option>
                  <option value="Platform Engineering">Platform Engineering</option>
                  <option value="Automatización DevOps">Automatización DevOps</option>
                  <option value="Pipeline CI/CD">Pipeline CI/CD</option>
                  <option value="Kubernetes / EKS">Kubernetes / EKS</option>
                  <option value="Terraform IaC">Terraform IaC</option>
                  <option value="Observabilidad">Observabilidad</option>
                  <option value="Revisión de infraestructura">Revisión de infraestructura</option>
                  <option value="Otro">Otro</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                  <svg class="w-4 h-4" style="color: #64748b;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider mb-2" style="color: #94a3b8;">Mensaje</label>
              <textarea name="message" required rows="5"
                placeholder="Describe tu proyecto, infraestructura actual o qué necesitas automatizar..."
                class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 resize-none"
                style="color: #111827; border-color: #e2e8f0; background: #fafbfc;"
                onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"></textarea>
            </div>

            <button type="submit" id="es-btn-submit"
              class="w-full text-sm font-semibold text-white py-4 rounded-xl transition-all duration-200 hover:-translate-y-px"
              style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 16px rgba(30,111,255,0.35);">
              Enviar mensaje
            </button>

            <div id="es-form-status" class="hidden text-sm text-center py-3 rounded-xl"></div>
          </form>
        </div>

        <div class="flex flex-col gap-8">
          <div>
            <h2 class="text-2xl font-bold mb-6" style="color: #0A2540;">Otras formas de contactar</h2>
            <div class="space-y-4">
              <a href="mailto:info@lracloudops.com"
                class="flex items-center gap-4 p-5 rounded-2xl transition-all duration-200 group hover:-translate-y-1"
                style="background: #fafbfc; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
                onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 8px 24px rgba(10,37,64,0.08)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background: #EEF4FF;">
                  <svg class="w-5 h-5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: #94a3b8;">Email</div>
                  <div class="text-sm font-medium group-hover:text-[#1E6FFF] transition-colors" style="color: #0A2540;">info@lracloudops.com</div>
                </div>
              </a>

              <a href="https://www.linkedin.com/in/liquenson-ruben-490961269/" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-4 p-5 rounded-2xl transition-all duration-200 group hover:-translate-y-1"
                style="background: #fafbfc; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
                onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 8px 24px rgba(10,37,64,0.08)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background: #EEF4FF;">
                  <svg class="w-5 h-5" style="color: #1E6FFF;" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: #94a3b8;">LinkedIn</div>
                  <div class="text-sm font-medium group-hover:text-[#1E6FFF] transition-colors" style="color: #0A2540;">LRA Cloud Operations</div>
                </div>
              </a>

              <a href="https://github.com/Liquenson" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-4 p-5 rounded-2xl transition-all duration-200 group hover:-translate-y-1"
                style="background: #fafbfc; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
                onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 8px 24px rgba(10,37,64,0.08)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background: #EEF4FF;">
                  <svg class="w-5 h-5" style="color: #1E6FFF;" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: #94a3b8;">GitHub</div>
                  <div class="text-sm font-medium group-hover:text-[#1E6FFF] transition-colors" style="color: #0A2540;">github.com/Liquenson</div>
                </div>
              </a>
            </div>
          </div>

          <div class="rounded-2xl p-6" style="background: #EEF4FF; border: 1px solid #c3d9ff;">
            <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">Qué podemos hacer por ti</h3>
            <ul class="space-y-2.5">
              {[
                'Diseñar tu arquitectura cloud en AWS',
                'Implementar infraestructura con Terraform',
                'Configurar CI/CD end-to-end',
                'Migrar a Kubernetes / ECS Fargate',
                'Optimizar costos AWS',
                'Configurar observabilidad con Prometheus + Grafana',
              ].map(item => (
                <li class="flex items-center gap-2.5 text-sm" style="color: #334155;">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-2xl p-5 flex items-start gap-4" style="background: white; border: 1px solid #e2e8f0;">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: #f0fdf4;">
              <svg class="w-5 h-5" style="color: #15803d;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: #0A2540;">Respuesta en menos de 24 horas</p>
              <p class="text-xs" style="color: #64748b;">Toda consulta recibe una evaluación inicial sin cargo. Definiremos un enfoque concreto antes de ningún compromiso.</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('es-contact-form') as HTMLFormElement
  const btn = document.getElementById('es-btn-submit') as HTMLButtonElement
  const status = document.getElementById('es-form-status') as HTMLDivElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.textContent = 'Enviando...'
    btn.disabled = true
    btn.style.opacity = '0.8'

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form)))
      })
      const data = await res.json()
      if (data.success) {
        status.textContent = 'Mensaje enviado. Te respondemos en menos de 24 horas.'
        status.style.cssText = 'display:block; background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;'
        form.reset()
      } else {
        status.textContent = 'Error al enviar. Por favor intenta de nuevo.'
        status.style.cssText = 'display:block; background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;'
      }
    } catch {
      status.textContent = 'Error de conexión. Por favor intenta de nuevo.'
      status.style.cssText = 'display:block; background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;'
    }

    btn.textContent = 'Enviar mensaje'
    btn.disabled = false
    btn.style.opacity = '1'
    status.classList.remove('hidden')
  })
</script>
