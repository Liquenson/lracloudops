---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

export const prerender = true
---

<Layout
  title="Contacto — Ruben Liquenson"
  description="Contacta con Ruben Liquenson, Ingeniero DevOps & Especialista AWS. Disponible para puestos de tiempo completo, contratos y freelance."
  lang="es"
>
  <Header />

  <section class="bg-dark on-dark section-sm">
    <div class="container">
      <div class="eyebrow">Contacto</div>
      <h1 style="color: #FFF; margin-bottom: 1rem;">Hablemos</h1>
      <p style="color: #94A3B8; max-width: 560px; font-size: 1.125rem;">
        Abierto a puestos de tiempo completo, contratos y trabajo freelance en
        infraestructura. Cuéntame sobre tu proyecto.
      </p>
    </div>
  </section>

  <section class="bg-light section">
    <div class="container contact-grid">
      <div>
        <h2 style="margin-bottom: 1.5rem; font-size: 1.5rem;">
          Enviar un mensaje
        </h2>
        <form id="contactForm" class="contact-form">
          <input
            type="hidden"
            name="access_key"
            value="e8aaab4e-270c-4163-bb76-6a8dfc247485"
          />
          <input
            type="hidden"
            name="subject"
            value="Nuevo mensaje desde lracloudops.com"
          />
          <input
            type="checkbox"
            name="botcheck"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />

          <label class="form-label" for="name">Nombre</label>
          <input
            class="form-input"
            type="text"
            id="name"
            name="name"
            required
          />

          <label class="form-label" for="email">Email</label>
          <input
            class="form-input"
            type="email"
            id="email"
            name="email"
            required
          />

          <label class="form-label" for="message">Mensaje</label>
          <textarea
            class="form-input"
            id="message"
            name="message"
            rows="6"
            required></textarea>

          <button
            type="submit"
            class="btn btn-primary btn-lg"
            style="margin-top: 1.5rem;">Enviar mensaje</button
          >
          <p id="formStatus" class="form-status"></p>
        </form>
      </div>

      <div>
        <h2 style="margin-bottom: 1.5rem; font-size: 1.5rem;">Detalles</h2>
        <div class="detail-list">
          <div class="detail-item">
            <p class="detail-label">Ubicación</p>
            <p class="detail-value">📍 Las Palmas de Gran Canaria, España</p>
          </div>
          <div class="detail-item">
            <p class="detail-label">Disponibilidad</p>
            <p class="detail-value">
              <span class="status-dot"></span>
              Disponible para trabajo remoto
            </p>
          </div>
          <div class="detail-item">
            <p class="detail-label">Email</p>
            <p class="detail-value">
              <a
                href="mailto:liquenson.cloud@gmail.com"
                style="color: var(--color-primary); font-weight: 600;"
                >liquenson.cloud@gmail.com</a
              >
            </p>
          </div>
          <div class="detail-item">
            <p class="detail-label">Conectar</p>
            <div style="display: flex; gap: 0.75rem;">
              <a
                href="https://www.linkedin.com/in/rubenliquenson-490961269"
                target="_blank"
                rel="noopener"
                class="btn btn-secondary btn-sm">LinkedIn</a
              >
              <a
                href="https://github.com/Liquenson"
                target="_blank"
                rel="noopener"
                class="btn btn-secondary btn-sm">GitHub</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
  }
  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 1rem;
    margin-bottom: 0.375rem;
  }
  .form-input {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    resize: vertical;
  }
  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  .form-status {
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .detail-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .detail-item {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-light);
  }
  .detail-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.375rem;
  }
  .detail-value {
    font-size: 1rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    background: #16a34a;
    border-radius: 50%;
    display: inline-block;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null
  const status = document.getElementById('formStatus')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!status) return
    status.textContent = 'Enviando…'
    status.style.color = 'var(--text-muted)'

    const formData = new FormData(form)
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: formData,
      })
      const data = await res.json()
      if (data.success) {
        status.textContent = 'Mensaje enviado — te responderé pronto.'
        status.style.color = '#16A34A'
        form.reset()
      } else {
        status.textContent =
          'Algo salió mal. Inténtalo de nuevo o escríbeme directamente.'
        status.style.color = '#DC2626'
      }
    } catch {
      status.textContent =
        'Algo salió mal. Inténtalo de nuevo o escríbeme directamente.'
      status.style.color = '#DC2626'
    }
  })
</script>
