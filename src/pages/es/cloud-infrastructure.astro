---
import SolutionLayout from '../../components/SolutionLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://lracloudops.com/cloud-infrastructure#service',
  name: 'Infraestructura Cloud AWS',
  serviceType: 'Cloud Infrastructure',
  description:
    'Entornos AWS codificados con networking definido, límites de seguridad y políticas de acceso. Módulos Terraform auditables, versionados y reproducibles entre cuentas.',
  url: 'https://lracloudops.com/cloud-infrastructure',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: 'Worldwide',
  inLanguage: 'es-ES',
}
---

<SolutionLayout
  titulo="Infraestructura Cloud · Platform Engineering AWS"
  descripcion="Entornos AWS codificados con networking definido, límites de seguridad y políticas de acceso. Módulos Terraform auditables, versionados y reproducibles entre cuentas."
  badgeLabel="01 · Cloud Infrastructure"
  h1="Infraestructura que puede reproducirse, auditarse y recuperarse."
  heroSubtitle="Los entornos AWS creados manualmente producen deriva de configuración, estado no documentado e infraestructura que no puede reproducirse de forma fiable. La reemplazamos con entornos codificados y versionados donde cada recurso tiene un propietario y cada cambio tiene un commit."
  schema={schema}
  sectionNumber="01"
  challenges={[
    {
      title: 'Deriva de configuración',
      desc: 'Los entornos divergen de su estado previsto con el tiempo. Nadie sabe qué cambió, cuándo ni por qué. Reproducir el entorno desde cero es imposible.',
    },
    {
      title: 'Estado no documentado',
      desc: 'Los recursos creados desde la consola no tienen registro de auditoría. Cuando el ingeniero que los aprovisionó se va, el conocimiento se va con él.',
    },
    {
      title: 'Dependencia manual de personas',
      desc: 'Cada nueva cuenta, región o entorno requiere trabajo manual. Escalar la plataforma requiere escalar el personal.',
    },
    {
      title: 'Seguridad aplicada a posteriori',
      desc: 'Los grupos de seguridad, políticas IAM y límites de red añadidos retroactivamente son inconsistentes y con frecuencia incompletos.',
    },
  ]}
  archTitle="El stack de plataforma que entregamos."
  archSubtitle="Cada capa está versionada, es auditable y recuperable. Sin aprovisionamiento manual, sin configuración solo por consola."
  layers={[
    {
      layer: 'Fundación de Red',
      tools: 'Terraform · VPC · Subnets · NAT Gateway · IGW',
      desc: 'VPC Multi-AZ con subnets públicas para balanceadores y privadas para cómputo y datos. Ningún componente de backend tiene IP pública.',
    },
    {
      layer: 'Capa de Cómputo',
      tools: 'EKS 1.31+ · ECS Fargate · EC2 Auto Scaling',
      desc: 'Clústeres Kubernetes o tareas Fargate según los requisitos de la carga de trabajo. Node groups gestionados como código. HPA configurado en el momento del aprovisionamiento.',
    },
    {
      layer: 'Capa de Datos',
      tools: 'RDS PostgreSQL 15 · Multi-AZ · Cifrado · Subnets privadas',
      desc: 'Bases de datos gestionadas en subnets privadas con failover automático, backups de 7 días y cifrado en reposo. Acceso por grupo de seguridad restringido solo a la capa de cómputo.',
    },
    {
      layer: 'Distribución de Contenido',
      tools: 'CloudFront · S3 · Route 53 · ACM',
      desc: 'CDN, hosting de assets estáticos y DNS gestionados como código. Certificados TLS aprovisionados y rotados automáticamente.',
    },
    {
      layer: 'Identidad y Acceso',
      tools:
        'IAM · OIDC · Políticas de mínimo privilegio · Sin credenciales estáticas',
      desc: 'Autenticación basada en OIDC para pipelines CI/CD — sin claves de acceso de larga duración. Roles y políticas IAM definidos en Terraform y revisados antes de aplicar.',
    },
    {
      layer: 'Gestión de Estado',
      tools: 'S3 backend · Bloqueo DynamoDB · SSE-S3 · Workspaces',
      desc: 'Estado Terraform remoto con cifrado y bloqueo distribuido. Workspaces separados para dev y producción — sin archivos de estado compartidos.',
    },
  ]}
  steps={[
    {
      step: '01',
      title: 'Evaluación del estado actual',
      desc: 'Revisamos la arquitectura existente, documentamos brechas e identificamos áreas de riesgo antes de escribir una línea de Terraform.',
    },
    {
      step: '02',
      title: 'Diseño de módulos',
      desc: 'Diseñamos módulos Terraform reutilizables e independientemente desplegables con contratos claros de entrada/salida.',
    },
    {
      step: '03',
      title: 'Aprovisionamiento del entorno',
      desc: 'Desplegamos primero el entorno de desarrollo. Validamos end-to-end antes de aplicar la misma configuración a producción.',
    },
    {
      step: '04',
      title: 'Observabilidad y entrega',
      desc: 'Alarmas CloudWatch, alertas de coste y runbooks entregados junto con la infraestructura — no como una tarea adicional.',
    },
  ]}
  outcomes={[
    {
      metric: 'Cualquier entorno reproducible',
      detail: 'desde un único terraform apply',
    },
    {
      metric: 'Cero configuración manual',
      detail: 'cada recurso definido como código',
    },
    {
      metric: 'Registro de auditoría completo',
      detail: 'cada cambio ligado a un commit y un revisor',
    },
    {
      metric: 'Recuperación ante desastres probada',
      detail: 'reproducibilidad verificada antes de producción',
    },
    {
      metric: 'Seguridad aplicada en aprovisionamiento',
      detail: 'no tras la primera revisión de seguridad',
    },
    {
      metric: 'Nuevos entornos en minutos',
      detail: 'no días de trabajo manual',
    },
  ]}
  ctaH2="Empieza con una revisión de infraestructura."
  ctaSubtitle="Trae tu entorno AWS actual. Evaluamos reproducibilidad, postura de seguridad y gestión de estado — y trazamos un camino concreto hacia infraestructura codificada."
  backLabel="Volver a Soluciones"
  relatedSolutions={[
    { href: '/kubernetes-platforms', label: 'Plataformas Kubernetes' },
    { href: '/platform-engineering', label: 'Platform Engineering' },
    { href: '/observability', label: 'Observabilidad & SRE' },
  ]}
>
  <!-- Flujo de aprovisionamiento IaC -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-10">
        <span class="section-label">Flujo de aprovisionamiento</span>
        <h2 class="text-2xl font-bold mt-4" style="color: #0A2540;">Del código al entorno AWS.</h2>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-0" role="img" aria-label="Flujo IaC: Terraform → AWS → Observabilidad">
        {[
          { label: 'Terraform', sub: 'Módulos auditables', color: '#7B42BC', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4' },
          { label: 'AWS', sub: 'VPC · EKS · RDS · CDN', color: '#FF9900', icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6' },
          { label: 'Observabilidad', sub: 'CloudWatch · Prometheus', color: '#E5421E', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
          { label: 'Estado remoto', sub: 'S3 · DynamoDB lock', color: '#1E6FFF', icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4' },
        ].map(({ label, sub, color, icon }, i, arr) => (
          <div class="flex items-center">
            <div class="flex flex-col items-center text-center px-6 py-5 rounded-2xl min-w-[130px]" style={`background: ${color}12; border: 1.5px solid ${color}30;`}>
              <div class="w-10 h-10 flex items-center justify-center rounded-xl mb-3" style={`background: ${color}20;`} aria-hidden="true">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style={`color: ${color};`}>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                </svg>
              </div>
              <div class="text-sm font-bold mb-0.5" style={`color: ${color};`}>{label}</div>
              <div class="text-xs" style="color: #64748B;">{sub}</div>
            </div>
            {i < arr.length - 1 && (
              <div class="flex items-center px-2" aria-hidden="true">
                <div class="h-px w-8 sm:w-12" style="background: #CBD5E1;"></div>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #CBD5E1;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</SolutionLayout>
