---
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/layout/Header.astro'
import Footer from '../../../components/layout/Footer.astro'

export const prerender = true
---

<Layout
  title="Notas Técnicas — Ruben Liquenson"
  description="Artículos técnicos sobre AWS, Kubernetes, Terraform y GitOps por Ruben Liquenson."
  lang="es"
>
  <Header />

  <section class="bg-dark on-dark section-sm">
    <div class="container">
      <div class="eyebrow">Blog</div>
      <h1 style="color: #FFF; margin-bottom: 1rem;">Notas Técnicas</h1>
      <p style="color: #94A3B8; max-width: 560px; font-size: 1.125rem;">
        Artículos técnicos sobre AWS, Kubernetes, Terraform y GitOps — de
        trabajo real en infraestructura.
      </p>
    </div>
  </section>

  <section class="bg-light section" style="text-align: center;">
    <div class="container">
      <p style="font-size: 1.125rem; color: var(--text-muted);">
        Próximamente — artículos técnicos.
      </p>
      <div style="margin-top: 2rem;">
        <a href="/es/proyectos" class="btn btn-secondary btn-pill"
          >Ver proyectos →</a
        >
      </div>
    </div>
  </section>

  <Footer />
</Layout>
