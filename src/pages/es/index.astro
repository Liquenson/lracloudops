---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3)

const allProjects = await getCollection('projects', ({ data }) => !data.draft)
const displayProjects = allProjects
---

<Layout
  titulo="Infraestructura Cloud y Platform Engineering"
  descripcion="Infraestructura cloud y platform engineering. Kubernetes, Terraform y AWS — diseñados para fiabilidad operacional y entrega automatizada."
>
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 1. HERO ENTERPRISE                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden hero-gradient"
    aria-labelledby="hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.14) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 90% 60% at 50% 115%, rgba(37,99,235,0.22) 0%, transparent 65%);"
    >
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-px pointer-events-none"
      aria-hidden="true"
      style="background: linear-gradient(90deg, transparent, rgba(96,165,250,0.4), transparent);"
    >
    </div>

    <div
      class="relative max-w-7xl mx-auto px-5 sm:px-6 py-14 sm:py-24 lg:py-32 grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-14 lg:gap-20 items-center"
    >
      <!-- Izquierda: Copy -->
      <div class="animate-fade-left">
        <div
          class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full mb-8 text-xs font-semibold"
          style="background: rgba(37,99,235,0.15); border: 1px solid rgba(96,165,250,0.3); color: #93C5FD;"
        >
          <span
            class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0 animate-pulse-soft"
            aria-hidden="true"></span>
          Infraestructura Cloud &middot; Platform Engineering
        </div>

        <h1
          id="hero-heading"
          class="text-[34px] sm:text-[52px] lg:text-[68px] font-extrabold text-white leading-[1.04] mb-7"
          style="letter-spacing: -0.035em;"
        >
          Ingeniería de plataformas<br />para infraestructuras<br />
          <span style="color: #60A5FA;">que deben funcionar.</span>
        </h1>

        <p
          class="text-lg sm:text-xl leading-relaxed mb-10 max-w-[520px]"
          style="color: rgba(148,163,184,0.85);"
        >
          Infraestructura reproducible. Entrega automatizada. Resiliencia
          operacional desde el primer día. Sin aprovisionamiento manual, sin
          arquitectura improvisada, sin cambios sin trazabilidad.
        </p>

        <div class="flex flex-wrap gap-4 mb-12">
          <a
            href="/es/contacto"
            class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
            style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.45);"
          >
            Solicitar revisión de infraestructura
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/es/servicios"
            class="inline-flex items-center gap-2.5 text-sm font-semibold px-7 py-4 rounded-xl border transition-all hover:bg-white/10"
            style="color: rgba(148,163,184,0.9); border-color: rgba(148,163,184,0.25);"
          >
            Ver cómo trabajamos
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Métricas hero -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {
            [
              { value: '4+', label: 'Proyectos open source' },
              { value: '73+', label: 'Commits en producción' },
              { value: '100%', label: 'Infraestructura como código' },
              { value: '25+', label: 'Servicios AWS' },
            ].map(({ value, label }) => (
              <div
                class="text-center px-3 py-4 rounded-xl"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);"
              >
                <div
                  class="text-xl sm:text-2xl font-extrabold text-white mb-1"
                  style="letter-spacing: -0.03em;"
                >
                  {value}
                </div>
                <div
                  class="text-[10px] font-semibold uppercase tracking-wider"
                  style="color: rgba(148,163,184,0.55);"
                >
                  {label}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Derecha: Terminal mockup -->
      <div
        class="relative flex justify-center lg:justify-end animate-fade-up delay-200"
      >
        <div class="relative w-full max-w-[510px]">
          <div
            class="absolute -inset-6 rounded-3xl pointer-events-none"
            aria-hidden="true"
            style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.25) 0%, transparent 70%); filter: blur(24px);"
          >
          </div>

          <div
            class="relative rounded-2xl overflow-hidden"
            style="background: #0d1117; border: 1px solid rgba(255,255,255,0.09); box-shadow: 0 40px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.04);"
          >
            <!-- Chrome bar -->
            <div
              class="flex items-center gap-2 px-4 py-3.5"
              style="background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.07);"
            >
              <div
                class="w-3 h-3 rounded-full"
                style="background: #FF5F57;"
                aria-hidden="true"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full"
                style="background: #FEBC2E;"
                aria-hidden="true"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full"
                style="background: #28C840;"
                aria-hidden="true"
              >
              </div>
              <div class="flex-1 text-center">
                <span
                  class="text-xs font-mono"
                  style="color: rgba(255,255,255,0.25);"
                  >aws-production &middot; main</span
                >
              </div>
              <span
                class="w-1.5 h-1.5 rounded-full bg-emerald-400"
                aria-hidden="true"></span>
              <span
                class="text-xs font-mono"
                style="color: rgba(255,255,255,0.25);">live</span
              >
            </div>

            <!-- Terminal body -->
            <div
              class="p-5 font-mono text-xs sm:text-sm leading-relaxed space-y-1"
              aria-label="Terminal mostrando comandos de Terraform y Kubernetes"
            >
              <div class="flex items-center gap-2">
                <span style="color: #79C0FF;">❯</span>
                <span class="text-white">terraform apply --auto-approve</span>
              </div>
              <div
                class="mt-2 text-[0.68rem]"
                style="color: rgba(255,255,255,0.35);"
              >
                Plan: 14 to add, 0 to change, 0 to destroy.
              </div>
              <div class="space-y-0.5 mt-2">
                {
                  [
                    ['aws_vpc.main', '6s'],
                    ['aws_eks_cluster.main', '2m 18s'],
                    ['aws_rds_cluster.db', '1m 44s'],
                    ['aws_cloudfront_distribution.cdn', '47s'],
                    ['module.alb.aws_lb.main', '52s'],
                  ].map(([res, time]) => (
                    <div class="text-xs">
                      <span style="color: #3FB950;">✓</span>{' '}
                      <span style="color: rgba(255,255,255,0.5);">{res}</span>{' '}
                      <span style="color: rgba(255,255,255,0.22); font-size: 0.65rem;">
                        ({time})
                      </span>
                    </div>
                  ))
                }
              </div>
              <div class="mt-2.5 text-xs font-semibold" style="color: #3FB950;">
                Apply complete! Resources: 14 added.
              </div>

              <div class="mt-5 flex items-center gap-2">
                <span style="color: #79C0FF;">❯</span>
                <span class="text-white">kubectl get pods -n production</span>
              </div>
              <div class="space-y-0.5 mt-1">
                {
                  [
                    'webapp-7d4b9f-x2k9p',
                    'webapp-7d4b9f-m8n3q',
                    'webapp-7d4b9f-p9l1w',
                  ].map((pod) => (
                    <div style="font-size: 0.68rem;">
                      <span style="color: rgba(255,255,255,0.5);">
                        {pod}&nbsp;&nbsp;
                      </span>
                      <span style="color: rgba(255,255,255,0.4);">
                        2/2&nbsp;&nbsp;
                      </span>
                      <span style="color: #3FB950;">Running</span>
                    </div>
                  ))
                }
              </div>
              <div class="mt-4 flex items-center gap-1.5">
                <span style="color: #79C0FF;">❯</span>
                <span
                  class="terminal-cursor w-1.5 h-4 inline-block rounded-sm"
                  style="background: rgba(255,255,255,0.6);"
                  aria-hidden="true"></span>
              </div>
            </div>

            <!-- CI/CD strip -->
            <div
              class="px-5 pb-4 pt-2.5"
              style="border-top: 1px solid rgba(255,255,255,0.06);"
            >
              <div
                class="flex items-center gap-0.5"
                aria-label="Todas las etapas CI/CD completadas"
              >
                {
                  ['Build', 'Test', 'Security', 'Docker', 'Deploy'].map(
                    (step, i) => (
                      <div class="flex items-center">
                        <div class="flex items-center gap-1 text-xs font-mono">
                          <span style="color: #3FB950;" aria-hidden="true">
                            ✓
                          </span>
                          <span style="color: rgba(255,255,255,0.4); font-size: 0.62rem;">
                            {step}
                          </span>
                        </div>
                        {i < 4 && (
                          <div
                            class="w-4 h-px mx-1"
                            style="background: rgba(63,185,80,0.3);"
                            aria-hidden="true"
                          />
                        )}
                      </div>
                    )
                  )
                }
              </div>
            </div>
          </div>

          <!-- Badge: Deploy -->
          <div
            class="absolute -top-5 -right-2 sm:-right-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-400"
            style="border: 1px solid rgba(15,23,42,0.07);"
          >
            <div class="flex items-center gap-2 mb-0.5">
              <span
                class="w-2 h-2 rounded-full bg-emerald-400"
                aria-hidden="true"></span>
              <span class="text-xs font-bold text-gray-800"
                >Deploy successful</span
              >
            </div>
            <p class="text-[10px]" style="color: #64748B;">
              aws-production &middot; 2m ago
            </p>
          </div>

          <!-- Badge: K8s -->
          <div
            class="absolute -bottom-5 -left-2 sm:-left-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-500"
            style="border: 1px solid rgba(15,23,42,0.07);"
          >
            <div class="flex items-center gap-2 mb-1">
              <svg
                class="w-3.5 h-3.5"
                style="color: #2563EB;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"
                ></path>
              </svg>
              <span class="text-xs font-bold text-gray-800">EKS Cluster</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span
                class="w-1.5 h-1.5 rounded-full bg-emerald-400"
                aria-hidden="true"></span>
              <span class="text-[10px]" style="color: #64748B;"
                >3/3 nodes healthy</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 2. TECNOLOGÍAS                                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    class="bg-white"
    style="border-bottom: 1px solid #E5E7EB;"
    aria-label="Tecnologías con las que trabajamos"
  >
    <div class="max-w-7xl mx-auto px-6 py-14">
      <p
        class="text-center text-[10px] font-bold uppercase tracking-widest mb-10"
        style="color: #94A3B8;"
      >
        Tecnologías de plataforma principales
      </p>
      <div
        class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 gap-4 items-center"
      >
        {
          [
            {
              name: 'AWS',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/amazonaws.svg',
            },
            {
              name: 'Kubernetes',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/kubernetes.svg',
            },
            {
              name: 'Docker',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/docker.svg',
            },
            {
              name: 'Terraform',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/terraform.svg',
            },
            {
              name: 'GitHub',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/github.svg',
            },
            {
              name: 'Jenkins',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/jenkins.svg',
            },
            {
              name: 'ArgoCD',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/argo.svg',
            },
            {
              name: 'Prometheus',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/prometheus.svg',
            },
            {
              name: 'Grafana',
              icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/grafana.svg',
            },
          ].map(({ name, icon }) => (
            <div class="tech-logo-item group" title={name}>
              <div
                class="w-10 h-10 flex items-center justify-center rounded-xl transition-colors group-hover:bg-blue-50"
                style="background: white; border: 1px solid #E5E7EB;"
              >
                <img
                  src={icon}
                  alt={name}
                  class="w-6 h-6"
                  style="filter: brightness(0) opacity(0.5);"
                  loading="lazy"
                />
              </div>
              <span class="text-[10px] font-semibold text-gray-600">
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 3. SOLUCIONES                                                        -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-white" aria-labelledby="solutions-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 animate-fade-up">
        <span class="section-label">Soluciones</span>
        <h2
          id="solutions-heading"
          class="text-4xl sm:text-5xl font-bold mt-5 mb-5"
          style="color: #0F172A; letter-spacing: -0.025em;"
        >
          Cuatro disciplinas de plataforma.<br />Un modelo operativo.
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          Cada capa reduce la superficie operativa que gestionan tus equipos.
          Juntas forman una plataforma de entrega repetible.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          [
            {
              icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
              title: 'Infraestructura Cloud',
              desc: 'Entornos AWS codificados con networking definido, límites de seguridad y políticas de acceso. Módulos Terraform auditables, versionados y reproducibles en múltiples cuentas.',
              tags: ['AWS', 'VPC', 'EKS', 'RDS'],
            },
            {
              icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
              title: 'Platform Engineering',
              desc: 'Clusters Kubernetes operados como plataformas internas. Entrega GitOps a través de ArgoCD. Los equipos despliegan sin abrir tickets de infraestructura.',
              tags: ['Kubernetes', 'ArgoCD', 'Helm'],
            },
            {
              icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
              title: 'DevOps Automation',
              desc: 'Pipelines end-to-end que aplican tests, escaneos de seguridad y quality gates antes de llegar al cluster. Cada release es trazable. Cada rollback requiere un solo comando.',
              tags: ['GitHub Actions', 'Jenkins', 'OIDC'],
            },
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'Observability',
              desc: 'Instrumentado desde el primer día, no después del primer incidente. Métricas Prometheus, logs estructurados y umbrales de alerta configurados antes de que el primer usuario llegue a producción.',
              tags: ['Prometheus', 'Grafana', 'SRE'],
            },
          ].map(({ icon, title, desc, tags }, i) => (
            <div
              class={`card card-accent flex flex-col p-7 animate-fade-up ${['delay-100', 'delay-200', 'delay-300', 'delay-400'][i]}`}
            >
              <div
                class="w-12 h-12 flex items-center justify-center rounded-xl mb-6 flex-shrink-0"
                style="background: #EFF6FF;"
                aria-hidden="true"
              >
                <svg
                  class="w-5 h-5"
                  style="color: #2563EB;"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={icon}
                  />
                </svg>
              </div>
              <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">
                {title}
              </h3>
              <p
                class="text-sm leading-relaxed flex-1 mb-5"
                style="color: #64748B;"
              >
                {desc}
              </p>
              <div class="flex flex-wrap gap-1.5 mb-5">
                {tags.map((tag) => (
                  <span class="stack-tag">{tag}</span>
                ))}
              </div>
              <a
                href="/es/servicios"
                class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors mt-auto"
                style="color: #2563EB;"
              >
                Saber más
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </a>
            </div>
          ))
        }
      </div>

      <div class="text-center mt-12 animate-fade-up">
        <a
          href="/es/servicios"
          class="inline-flex items-center gap-2 text-sm font-semibold px-7 py-3.5 rounded-xl border transition-all hover:bg-gray-50"
          style="color: #0F172A; border-color: #E5E7EB;"
        >
          Ver todas las soluciones
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 4. ARQUITECTURA DE PLATAFORMA                                        -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    class="py-24 relative overflow-hidden"
    style="background: #0B1220;"
    aria-labelledby="architecture-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none opacity-20"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.15) 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.18) 0%, transparent 70%);"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 animate-fade-up">
        <span
          class="inline-flex items-center text-[10px] font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5"
          style="background: rgba(37,99,235,0.18); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
        >
          Platform Architecture
        </span>
        <h2
          id="architecture-heading"
          class="text-4xl sm:text-5xl font-bold text-white mt-2 mb-5"
          style="letter-spacing: -0.025em;"
        >
          La plataforma, capa por capa.
        </h2>
        <p
          class="text-lg max-w-2xl mx-auto"
          style="color: rgba(148,163,184,0.8);"
        >
          Seis capas que forman un modelo operativo de infraestructura auditable
          y reproducible. Cada una está versionada y es recuperable.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Diagrama de capas -->
        <div
          class="animate-fade-left"
          role="img"
