---
import Layout from '../../layouts/Layout.astro'
import { industrySvgs } from '../../data/industry-diagrams'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

const newsCards = [
  {
    color: '#1A73E8',
    category: 'AI Agents',
    title: 'lra-ai-platform — 8 agentes, 14 integraciones, 9 workflows',
    desc: 'Plataforma multi-agente para automatización DevOps con Governance Engine.',
    href: 'https://github.com/lra-cloud-ops/lra-ai-platform',
  },
  {
    color: '#137333',
    category: 'Cloud AI',
    title: 'aws-devops-agent — modelo de IA + 24 servicios AWS',
    desc: 'Agente IA que usa un bucle de tool-use para gestionar AWS en lenguaje natural.',
    href: 'https://github.com/lra-cloud-ops/aws-devops-agent',
  },
  {
    color: '#F29900',
    category: 'Infrastructure',
    title: 'aws-terraform-devops — VPC, EKS, RDS, ECR con Terraform',
    desc: 'Infraestructura AWS lista para producción con 7 módulos Terraform y CI/CD.',
    href: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
  },
  {
    color: '#C5221F',
    category: 'Kubernetes',
    title: 'k8s-on-premise — K8s bare metal con kubeadm + ArgoCD',
    desc: 'Clúster Kubernetes multi-nodo desde cero con sync GitOps vía ArgoCD.',
    href: 'https://github.com/lra-cloud-ops/k8s-on-premise',
  },
]

const productCols = [
  {
    cat: 'AI & Automation',
    color: '#1A73E8',
    href: 'https://github.com/lra-cloud-ops/lra-ai-platform',
    items: [
      {
        name: 'lra-ai-platform',
        desc: 'Orquestación multi-agente con Governance Engine',
      },
      {
        name: 'aws-devops-agent',
        desc: 'Bucle de tool-use IA para gestión de AWS',
      },
      { name: 'lra scan', desc: 'Auditoría de seguridad vía Trivy + Checkov' },
      { name: '9 workflows', desc: 'Desde create_project hasta deploy_eks' },
    ],
  },
  {
    cat: 'Cloud Infrastructure',
    color: '#137333',
    href: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
    items: [
      { name: 'AWS VPC', desc: 'Redes multi-AZ con subnets públicas/privadas' },
      { name: 'EKS 1.31', desc: 'Kubernetes gestionado en AWS' },
      {
        name: 'RDS PostgreSQL 15',
        desc: 'Base de datos gestionada con backups',
      },
      {
        name: 'Módulos Terraform',
        desc: 'vpc, eks, rds, ecr, iam, cloudwatch, s3',
      },
    ],
  },
  {
    cat: 'Kubernetes',
    color: '#F29900',
    href: 'https://github.com/lra-cloud-ops/k8s-on-premise',
    items: [
      {
        name: 'Clúster kubeadm',
        desc: '1 master + 2 workers sobre Vagrant/VirtualBox',
      },
      { name: 'Calico networking', desc: 'CNI con políticas de red' },
      { name: 'NGINX Ingress', desc: 'Enrutamiento HTTP/HTTPS' },
      { name: 'ArgoCD GitOps', desc: 'Sincronización declarativa desde Git' },
    ],
  },
  {
    cat: 'DevOps Tools',
    color: '#C5221F',
    href: 'https://github.com/lra-cloud-ops',
    items: [
      { name: 'GitHub Actions', desc: 'CI/CD en cada push' },
      { name: 'SonarCloud', desc: 'Calidad de código y cobertura' },
      { name: 'Helm', desc: 'Gestión de paquetes Kubernetes' },
      { name: 'Prometheus + Grafana', desc: 'Stack de observabilidad' },
    ],
  },
]

const tabs = [
  {
    label: 'AI Agents',
    color: '#1A73E8',
    h3: 'Automatiza DevOps con agentes IA especializados',
    desc: 'lra-ai-platform proporciona 8 agentes especializados — Cloud Architect, Security Engineer, SRE y más — cada uno ejecutando operaciones via 14 integraciones con AWS, Kubernetes, Terraform y Ansible.',
    linkText: 'Explorar lra-ai-platform →',
    href: 'https://github.com/lra-cloud-ops/lra-ai-platform',
  },
  {
    label: 'AWS Infrastructure',
    color: '#F29900',
    h3: 'Infraestructura AWS lista para producción con Terraform',
    desc: 'aws-terraform-devops entrega un entorno AWS completo: VPC multi-AZ, cluster EKS 1.31, RDS PostgreSQL 15, registro ECR y una app Flask desplegada via Helm y gestionada por ArgoCD.',
    linkText: 'Explorar aws-terraform-devops →',
    href: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
  },
  {
    label: 'Kubernetes',
    color: '#C5221F',
    h3: 'Clúster Kubernetes on-premise desde cero',
    desc: 'k8s-on-premise construye un clúster Kubernetes multi-nodo usando kubeadm sobre Vagrant/VirtualBox. Calico CNI, NGINX Ingress, Helm y sync GitOps con ArgoCD incluidos.',
    linkText: 'Explorar k8s-on-premise →',
    href: 'https://github.com/lra-cloud-ops/k8s-on-premise',
  },
  {
    label: 'Security',
    color: '#1A73E8',
    h3: 'Escaneo de seguridad automatizado con Trivy y Checkov',
    desc: 'El agente Security Engineer en lra-ai-platform ejecuta Trivy para vulnerabilidades en contenedores e IaC, y Checkov para misconfiguraciones en Terraform, Kubernetes y Dockerfile — generando un informe PASS/FAIL automáticamente.',
    linkText: null,
    href: null,
  },
  {
    label: 'Natural Language AWS',
    color: '#137333',
    h3: 'Gestiona AWS en lenguaje natural con un agente IA',
    desc: 'aws-devops-agent usa un modelo de IA en un bucle de tool-use para consultar y gestionar 24 servicios AWS. Haz preguntas en español o inglés y obtén datos directamente de tu cuenta AWS.',
    linkText: null,
    href: null,
  },
]

const techs = [
  'AWS',
  'Terraform',
  'Kubernetes',
  'ArgoCD',
  'Ansible',
  'Trivy',
  'Checkov',
  'Agente IA',
  'Prometheus',
  'Grafana',
  'GitHub Actions',
  'SonarCloud',
  'Helm',
  'Vagrant',
]
---

<Layout
  title="LRA CloudOps — Plataforma de Ingeniería DevOps"
  description="Automatización DevOps con agentes especializados. 4 proyectos open source que cubren agentes IA, infraestructura AWS, Kubernetes y automatización cloud."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- ============================================================
     HERO
     ============================================================ -->
  <section
    data-hero
    style="background: linear-gradient(135deg, #FFFFFF 0%, #F0F4FF 50%, #FFFFFF 100%); padding: 5rem 1.5rem 4rem; text-align: center; position: relative; overflow: hidden;"
  >
    <div
      style="position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(26,115,232,0.06) 0%, transparent 70%); pointer-events: none;"
    >
    </div>

    <div
      data-hero-content
      style="max-width: 860px; margin: 0 auto; position: relative; z-index: 1;"
    >
      <div
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E8F0FE; color: #1A73E8; padding: 0.375rem 1rem; border-radius: 9999px; font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; font-weight: 500; margin-bottom: 2rem;"
      >
        <span
          style="width: 6px; height: 6px; background: #1A73E8; border-radius: 50%;"
        ></span>
        Open Source · lra-cloud-ops
      </div>

      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.875rem, 5vw, 3.5rem); font-weight: 900; color: #202124; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1rem;"
      >
        Automatización DevOps.<br />
        Agentes especializados.<br />
        <span style="color: #1A73E8;">Integraciones en vivo.</span>
      </h1>

      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.125rem; color: #5F6368; line-height: 1.7; max-width: 620px; margin-inline: auto; margin-bottom: 2.5rem;"
      >
        4 proyectos open source que cubren agentes IA, infraestructura AWS,
        Kubernetes y automatización cloud. Todas las métricas extraídas
        directamente del código.
      </p>

      <div
        class="cta-group"
        style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem;"
      >
        <a
          href="/es/contacto"
          class="btn-premium"
          style="display: inline-flex; align-items: center; background: #1A73E8; color: #FFFFFF; padding: 0.875rem 2rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 500; font-size: 1rem; text-decoration: none;"
        >
          Solicitar auditoría gratuita →
        </a>
        <a
          href="/es/proyectos"
          class="btn-premium-outline"
          style="display: inline-flex; align-items: center; background: transparent; color: #1A73E8; padding: 0.875rem 2rem; border-radius: 4px; border: 1px solid #DADCE0; font-family: 'Red Hat Text', sans-serif; font-weight: 500; font-size: 1rem; text-decoration: none;"
        >
          ▷ Ver proyectos
        </a>
      </div>

      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; margin-bottom: 3rem;"
      >
        ✓ 4+ años en producción &nbsp;·&nbsp; ✓ AWS · Azure · GCP &nbsp;·&nbsp;
        ✓ Open Source &nbsp;·&nbsp; ✓ Infraestructura healthcare
      </p>

      <!-- Hero visual — animated network diagram -->
      <div class="hero-visual" style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 12px; height: 370px; position: relative; overflow: hidden;" data-hero-visual>

        <!-- Grid pattern background -->
        <div data-hero-bg style="position: absolute; inset: 0; background-image: linear-gradient(#DADCE0 1px, transparent 1px), linear-gradient(90deg, #DADCE0 1px, transparent 1px); background-size: 40px 40px; opacity: 0.4;"></div>

        <!-- SVG network connections -->
        <svg class="hero-network-svg" style="position: absolute; inset: 0; width: 100%; height: 100%;" viewBox="0 0 580 320" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" data-network-svg>

          <!-- Connection lines (drawn between pill centers) -->
          <!-- Center(290,160) to AI Agents(100,160) -->
          <line x1="290" y1="160" x2="140" y2="160" stroke="#1A73E8" stroke-width="1" opacity="0" class="net-line">
            <animate attributeName="opacity" values="0;0.3;0.3" dur="0.4s" begin="0.3s" fill="freeze"/>
          </line>
          <!-- Center to AWS(210,100) -->
          <line x1="290" y1="160" x2="220" y2="100" stroke="#137333" stroke-width="1" opacity="0" class="net-line">
            <animate attributeName="opacity" values="0;0.3;0.3" dur="0.4s" begin="0.5s" fill="freeze"/>
          </line>
          <!-- Center to Kubernetes(290,160) — pulse ring -->
          <circle cx="290" cy="160" r="36" fill="none" stroke="#1A73E8" stroke-width="1.5" opacity="0">
            <animate attributeName="opacity" values="0;0.6;0" dur="2s" begin="0.8s" repeatCount="indefinite"/>
            <animate attributeName="r" values="36;52;36" dur="2s" begin="0.8s" repeatCount="indefinite"/>
          </circle>
          <!-- Center to Terraform(370,100) -->
          <line x1="290" y1="160" x2="360" y2="100" stroke="#F29900" stroke-width="1" opacity="0" class="net-line">
            <animate attributeName="opacity" values="0;0.3;0.3" dur="0.4s" begin="0.7s" fill="freeze"/>
          </line>
          <!-- Center to GitOps(440,160) -->
          <line x1="290" y1="160" x2="440" y2="160" stroke="#C5221F" stroke-width="1" opacity="0" class="net-line">
            <animate attributeName="opacity" values="0;0.3;0.3" dur="0.4s" begin="0.9s" fill="freeze"/>
          </line>

          <!-- Secondary connections between pills -->
          <line x1="140" y1="160" x2="220" y2="100" stroke="#DADCE0" stroke-width="1" opacity="0">
            <animate attributeName="opacity" values="0;0.2;0.2" dur="0.3s" begin="1.1s" fill="freeze"/>
          </line>
          <line x1="220" y1="100" x2="360" y2="100" stroke="#DADCE0" stroke-width="1" opacity="0">
            <animate attributeName="opacity" values="0;0.2;0.2" dur="0.3s" begin="1.2s" fill="freeze"/>
          </line>
          <line x1="360" y1="100" x2="440" y2="160" stroke="#DADCE0" stroke-width="1" opacity="0">
            <animate attributeName="opacity" values="0;0.2;0.2" dur="0.3s" begin="1.3s" fill="freeze"/>
          </line>

          <!-- Data flow dots moving along lines -->
          <circle r="3" fill="#1A73E8" opacity="0">
            <animate attributeName="opacity" values="0;1;0" dur="1.5s" begin="1.5s" repeatCount="indefinite"/>
            <animateMotion dur="1.5s" begin="1.5s" repeatCount="indefinite" path="M290,160 L140,160"/>
          </circle>
          <circle r="3" fill="#137333" opacity="0">
            <animate attributeName="opacity" values="0;1;0" dur="1.8s" begin="2s" repeatCount="indefinite"/>
            <animateMotion dur="1.8s" begin="2s" repeatCount="indefinite" path="M290,160 L220,100"/>
          </circle>
          <circle r="3" fill="#F29900" opacity="0">
            <animate attributeName="opacity" values="0;1;0" dur="2s" begin="2.5s" repeatCount="indefinite"/>
            <animateMotion dur="2s" begin="2.5s" repeatCount="indefinite" path="M290,160 L360,100"/>
          </circle>
          <circle r="3" fill="#C5221F" opacity="0">
            <animate attributeName="opacity" values="0;1;0" dur="1.6s" begin="1.8s" repeatCount="indefinite"/>
            <animateMotion dur="1.6s" begin="1.8s" repeatCount="indefinite" path="M290,160 L440,160"/>
          </circle>

          <!-- Node dots at connection points -->
          <circle cx="140" cy="160" r="3" fill="#1A73E8" opacity="0">
            <animate attributeName="opacity" values="0;1;1" dur="0.3s" begin="0.4s" fill="freeze"/>
          </circle>
          <circle cx="220" cy="100" r="3" fill="#137333" opacity="0">
            <animate attributeName="opacity" values="0;1;1" dur="0.3s" begin="0.6s" fill="freeze"/>
          </circle>
          <circle cx="290" cy="160" r="5" fill="#1A73E8" opacity="0">
            <animate attributeName="opacity" values="0;1;1" dur="0.3s" begin="0.8s" fill="freeze"/>
          </circle>
          <circle cx="360" cy="100" r="3" fill="#F29900" opacity="0">
            <animate attributeName="opacity" values="0;1;1" dur="0.3s" begin="0.8s" fill="freeze"/>
          </circle>
          <circle cx="440" cy="160" r="3" fill="#C5221F" opacity="0">
            <animate attributeName="opacity" values="0;1;1" dur="0.3s" begin="1s" fill="freeze"/>
          </circle>
        </svg>

        <!-- Pills overlay -->
        <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem;">
          <div class="hero-pills-container" style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; justify-content: center; padding: 1rem;">
            {
              [
                { label: 'AI Agents', sub: '8 especializados · 14 integraciones', color: '#1A73E8', delay: '0.3s', active: false },
                { label: 'AWS', sub: 'EKS · RDS · ECR · VPC', color: '#137333', delay: '0.5s', active: false },
                { label: 'Kubernetes', sub: 'kubeadm · Calico · ArgoCD', color: '#1A73E8', delay: '0.7s', active: true },
                { label: 'Terraform', sub: '7 módulos · dev/prod', color: '#F29900', delay: '0.9s', active: false },
                { label: 'GitOps', sub: 'ArgoCD · Helm · sync', color: '#C5221F', delay: '1.1s', active: false },
              ].map(({ label, sub, color, delay, active }) => (
                <div
                  style={`
                    background: #FFFFFF;
                    border: ${active ? '2px solid #1A73E8' : '1px solid #DADCE0'};
                    border-radius: 10px;
                    padding: 0.625rem 1rem;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 0.2rem;
                    box-shadow: ${active ? '0 4px 16px rgba(26,115,232,0.2)' : '0 1px 4px rgba(0,0,0,0.06)'};
                    opacity: 0;
                    transform: translateY(8px);
                    animation: pillEnter 0.4s ease-out ${delay} forwards;
                    cursor: default;
                    transition: box-shadow 200ms ease, transform 200ms ease;
                    min-width: 90px;
                  `}
                  class="hero-pill"
                >
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <span style={`width: 7px; height: 7px; border-radius: 50%; background: ${color}; ${active ? 'animation: pulse-dot 2s infinite;' : ''} flex-shrink: 0;`}></span>
                    <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; white-space: nowrap;">{label}</span>
                  </div>
                  <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.6875rem; color: #9AA0A6; white-space: nowrap;">{sub}</span>
                </div>
              ))
            }
          </div>

          <!-- GitHub stats line -->
          <div class="hero-github-stats" style="display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; padding: 0.5rem 1rem;">
            <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener"
              style="display: flex; align-items: center; gap: 0.375rem; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; text-decoration: none; transition: color 150ms ease;"
              onmouseover="this.style.color='#1A73E8'"
              onmouseout="this.style.color='#5F6368'"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              github.com/lra-cloud-ops
            </a>
            <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6;">·</span>
            <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;">4 repos</span>
            <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6;">·</span>
            <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;">Python · Terraform · Bash · HCL</span>
          </div>
        </div>

        <!-- Real scan result badge -->
        <div style="position: absolute; top: 1rem; right: 1rem; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 6px; padding: 0.5rem 0.875rem; display: flex; align-items: center; gap: 0.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: #137333;"></span>
          <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.6875rem; color: #5F6368;">último scan: 4.2s · 0 críticos</span>
        </div>

        <!-- Status bar -->
        <div class="hero-status-bar" style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border-top: 1px solid #DADCE0; padding: 0.5rem 1rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
          <span style="display: flex; align-items: center; gap: 0.375rem; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #137333;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: #137333; animation: pulse-dot 2s infinite;"></span>
            Todos los sistemas operativos
          </span>
          <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;">último scan: 4.2s · 0 críticos</span>
          <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; margin-left: auto;">33/33 tests pasando</span>
        </div>
      </div>

      <!-- Mobile hero visual — only visible on mobile -->
      <div class="hero-mobile-only" style="
        background: #FFFFFF;
        border: 1px solid #DADCE0;
        border-radius: 12px;
        overflow: hidden;
        margin-top: 1rem;
        display: none;
      ">
        <!-- Status indicator -->
        <div style="
          background: #F8F9FA;
          border-bottom: 1px solid #DADCE0;
          padding: 0.625rem 1rem;
          display: flex;
          align-items: center;
          gap: 0.5rem;
        ">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: #137333; animation: pulse-dot 2s infinite;"></span>
          <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #137333; font-weight: 500;">Todos los sistemas operativos</span>
          <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6; margin-left: auto;">33/33 ✓</span>
        </div>

        <!-- Pills grid 2x3 -->
        <div style="padding: 0.875rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
          {
            [
              { label: 'AI Agents', sub: '8 especializados · 14 integraciones', color: '#1A73E8', active: true },
              { label: 'AWS', sub: 'EKS · RDS · ECR · VPC', color: '#137333', active: false },
              { label: 'Kubernetes', sub: 'kubeadm · Calico · ArgoCD', color: '#1A73E8', active: false },
              { label: 'Terraform', sub: '7 módulos · dev/prod', color: '#F29900', active: false },
              { label: 'GitOps', sub: 'ArgoCD · Helm · sync', color: '#C5221F', active: false },
            ].map(({ label, sub, color, active }) => (
              <div style={`
                background: ${active ? '#E8F0FE' : '#F8F9FA'};
                border: 1px solid ${active ? '#1A73E8' : '#DADCE0'};
                border-radius: 8px;
                padding: 0.625rem 0.75rem;
                display: flex;
                flex-direction: column;
                gap: 0.2rem;
                ${label === 'GitOps' ? 'grid-column: 1 / -1;' : ''}
              `}>
                <div style="display: flex; align-items: center; gap: 0.375rem;">
                  <span style={`width: 6px; height: 6px; border-radius: 50%; background: ${color}; flex-shrink: 0;`}></span>
                  <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; font-weight: 600; color: #202124;">{label}</span>
                </div>
