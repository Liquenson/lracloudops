---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

export const prerender = true

const heroTech = [
  'AWS · EKS',
  'Terraform',
  'Kubernetes',
  'ArgoCD',
  'GitOps',
  'Prometheus',
  'Ansible',
  'Python',
]

const stats = [
  ['4+', 'Años en producción', 'Entornos reales, no sandbox'],
  ['3', 'Clouds soportados', 'AWS · Azure · GCP'],
  ['100%', 'Infraestructura como código', 'Cero cambios manuales'],
  ['0', 'Deploys manuales', 'GitOps con ArgoCD'],
]

const projects = [
  {
    name: 'aws-terraform-devops',
    desc: 'Infraestructura AWS completa con EKS 1.31, RDS PostgreSQL 15, ArgoCD, Prometheus/Grafana. Módulos Terraform listos para producción.',
    tags: ['AWS', 'EKS', 'Terraform', 'ArgoCD'],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
  },
  {
    name: 'gitops-stack',
    desc: 'Pipeline GitOps con ArgoCD en AWS EKS. Cero kubectl manual en producción. Cada cambio pasa por Git.',
    tags: ['ArgoCD', 'GitOps', 'Kubernetes', 'Helm'],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/gitops-stack',
  },
  {
    name: 'k8s-devops-platform',
    desc: 'Plataforma Kubernetes con KinD, ArgoCD, Prometheus, Grafana. Entorno de desarrollo local que replica producción.',
    tags: ['Kubernetes', 'KinD', 'Prometheus', 'Grafana'],
    status: 'Reference',
    href: 'https://github.com/lra-cloud-ops/k8s-devops-platform',
  },
  {
    name: 'linux-fleet-manager',
    desc: 'Scripts de gestión de flota validados 100% con ShellCheck. Operaciones idempotentes en hosts Linux vía SSH.',
    tags: ['Bash', 'SSH', 'Ansible', 'Linux'],
    status: 'Production',
    href: 'https://github.com/lra-cloud-ops/linux-fleet-manager',
  },
]
---

<Layout
  title="Ruben Liquenson — Ingeniero DevOps & Especialista AWS"
  description="Ingeniero DevOps con más de 4 años diseñando infraestructuras cloud en producción en AWS. Kubernetes, Terraform, GitOps, ArgoCD."
  lang="es"
>
  <Header />

  <!-- HERO -->
  <section
    class="bg-dark on-dark section hero"
    style="min-height: 90vh; display: flex; align-items: center; position: relative; overflow: hidden;"
  >
    <div class="hero-dots"></div>
    <div class="hero-glow"></div>

    <div class="container" style="position: relative; z-index: 1;">
      <div style="max-width: 760px;">
        <div class="status-pill">
          <span class="status-pill-dot"></span>
          Disponible para trabajar · Abierto a remoto
        </div>

        <h1 style="color: #FFFFFF; margin-bottom: 1.5rem; line-height: 1.1;">
          Ingeniero DevOps<br />
          <span style="color: #60A5FA;">&amp; Especialista AWS</span>
        </h1>

        <p
          style="font-size: 1.125rem; color: #94A3B8; max-width: 580px; margin-bottom: 2.5rem; line-height: 1.7;"
        >
          Diseño y opero infraestructura cloud de nivel producción en AWS.
          Kubernetes, Terraform, GitOps con ArgoCD — construido para durar, no
          para impresionar en demos.
        </p>

        <div
          style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 3rem;"
        >
          {heroTech.map((tech) => <span class="tech-pill">{tech}</span>)}
        </div>

        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/es/proyectos" class="btn btn-primary btn-lg btn-pill"
            >Ver proyectos →</a
          >
          <a href="/es/sobre-mi" class="btn btn-outline-white btn-lg btn-pill"
            >Sobre mí</a
          >
          <a
            href="https://www.linkedin.com/in/rubenliquenson-490961269"
            target="_blank"
            rel="noopener"
            class="btn btn-ghost btn-lg btn-pill"
            style="border-color: rgba(255,255,255,0.15); color: #94A3B8;"
            >LinkedIn ↗</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="bg-subtle section-sm">
    <div class="container">
      <div class="stats-grid">
        {
          stats.map(([num, label, desc], i) => (
            <div class={`stat-item ${i < 3 ? 'stat-border' : ''}`}>
              <div class="stat-num">{num}</div>
              <div class="stat-label">{label}</div>
              <div class="stat-desc">{desc}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="bg-light section">
    <div class="container">
      <div class="about-grid">
        <div>
          <div class="eyebrow">Sobre mí</div>
          <h2 style="margin-bottom: 1.5rem;">
            Construyendo infraestructura en la que los ingenieros confían
          </h2>
          <p style="margin-bottom: 1.5rem;">
            Soy Ruben, Ingeniero DevOps con base en Las Palmas de Gran Canaria,
            España. Durante los últimos 4+ años he diseñado y operado
            infraestructura de producción — automatizada, monitorizada y
            construida para sobrevivir tráfico real, no solo demos.
          </p>
          <p style="margin-bottom: 2rem;">
            Me especializo en AWS EKS, Terraform y GitOps con ArgoCD. Cada
            entorno que construyo es reproducible, automatizado y monitorizado
            desde el primer día.
          </p>
          <a href="/es/sobre-mi" class="btn btn-secondary btn-pill"
            >Leer bio completa →</a
          >
        </div>

        <div class="code-block fade-up terminal-preview">
          <div class="code-block-header">
            <span class="code-dot code-dot-red"></span>
            <span class="code-dot code-dot-yellow"></span>
            <span class="code-dot code-dot-green"></span>
            <span
              style="margin-left: 0.5rem; font-size: 0.75rem; color: #8B949E; font-family: var(--font-mono);"
              >ruben@aws-production ~ main</span
            >
          </div>
          <div class="code-block-content">
            <div>
              <span class="code-comment"># Deploy a producción EKS</span>
            </div>
            <div>
              <span class="code-command">$ terraform apply -auto-approve</span>
            </div>
            <div style="color: #8B949E;">
              Plan: 14 to add, 0 to change, 0 to destroy.
            </div>
            <div><span class="code-string">✓ aws_vpc.main</span></div>
            <div><span class="code-string">✓ aws_eks_cluster.main</span></div>
            <div><span class="code-string">✓ aws_rds_cluster.db</span></div>
            <div><span class="code-string">✓ module.alb.aws_lb.main</span></div>
            <div style="color: #4ADE80;">
              Apply complete! Resources: 14 added.
            </div>
            <div style="margin-top: 1rem;">
              <span class="code-command">$ kubectl get pods -n production</span>
            </div>
            <div>
              <span class="code-key">webapp-7d4b9f</span>
              <span class="code-string">2/2 Running</span>
            </div>
            <div>
              <span class="code-key">api-6c8d2e</span>
              <span class="code-string">2/2 Running</span>
            </div>
            <div>
              <span class="code-key">worker-9a1f3b</span>
              <span class="code-string">2/2 Running</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS PREVIEW -->
  <section class="bg-subtle section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 4rem;">
        <div class="eyebrow">Open Source</div>
        <h2>Proyectos en GitHub</h2>
        <p style="max-width: 500px; margin: 1rem auto 0;">
          Proyectos de infraestructura reales — nivel producción, documentados y
          open source.
        </p>
      </div>

      <div class="projects-grid">
        {
          projects.map((project) => (
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="project-card"
            >
              <div style="display: flex; align-items: start; justify-content: space-between; margin-bottom: 0.75rem;">
                <span style="font-family: var(--font-mono); font-size: 0.9375rem; font-weight: 600; color: var(--color-primary);">
                  {project.name}
                </span>
                <span
                  class={`badge ${project.status === 'Production' ? 'badge-green' : 'badge-blue'}`}
                >
                  {project.status}
                </span>
              </div>
              <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.6;">
                {project.desc}
              </p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
                {project.tags.map((tag) => (
                  <span class="tech-pill" style="font-size: 0.6875rem;">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))
        }
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/es/proyectos" class="btn btn-secondary btn-pill"
          >Ver todos los proyectos →</a
        >
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-dark on-dark section" style="text-align: center;">
    <div class="container">
      <div style="max-width: 600px; margin: 0 auto;">
        <div class="eyebrow">Trabajemos juntos</div>
        <h2
          style="color: #FFF; margin-bottom: 1rem; font-size: clamp(2rem, 4vw, 3rem);"
        >
          ¿Buscas un Ingeniero DevOps?
        </h2>
        <p style="color: #94A3B8; margin-bottom: 2.5rem; font-size: 1.125rem;">
          Actualmente abierto a nuevas oportunidades — tiempo completo, contrato
          o freelance. Hablemos de tus retos de infraestructura.
        </p>
        <div
          style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;"
        >
          <a href="/es/contacto" class="btn btn-primary btn-lg btn-pill"
            >Contactar →</a
          >
          <a href="/es/sobre-mi" class="btn btn-outline-white btn-lg btn-pill"
            >Ver mi CV</a
          >
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle at 1px 1px,
      rgba(255, 255, 255, 0.05) 1px,
      transparent 0
    );
    background-size: 32px 32px;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 40%;
    background: radial-gradient(
      ellipse at center,
      rgba(30, 111, 255, 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.25);
    color: #4ade80;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }
  .status-pill-dot {
    width: 8px;
    height: 8px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .stat-item {
    text-align: center;
    padding: 2rem 1rem;
  }
  .stat-border {
    border-right: 1px solid var(--border-light);
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .stat-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 0.375rem;
  }
  .stat-desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }
  .project-card {
    display: block;
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: all var(--transition);
  }
  .project-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .terminal-preview {
      display: none;
    }
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat-border {
      border-right: none;
    }
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
