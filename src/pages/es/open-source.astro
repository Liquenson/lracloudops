---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import Section from '../../components/ui/Section.astro'
import SectionHeader from '../../components/ui/SectionHeader.astro'
---
<Layout
  title="Repositorios Open Source — LRA CloudOps"
  description="Siete repositorios open source que cubren el stack completo de Platform Engineering. Inspecciona el código, ejecuta las herramientas, construye sobre la base."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <Section bg="soft" border="bottom">
    <SectionHeader
      as="h1"
      tag="Open Source"
      title="El stack completo de la plataforma."
      subtitle="Siete repositorios. Cada capa de un stack moderno de Platform Engineering — inspecciona el código, ejecuta las herramientas, construye sobre la base."
    />
    <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener noreferrer"
      style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-mono);font-size:0.875rem;font-weight:600;color:var(--color-primary);text-decoration:none;"
    >
      github.com/lra-cloud-ops →
    </a>
  </Section>

  <section style="background:var(--color-bg);padding:3rem 1.5rem;">
    <div style="max-width:1280px;margin:0 auto;">

      <!-- Plataforma Core -->
      <div style="margin-bottom:3rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
          <span style="font-family:var(--font-mono);font-size:0.75rem;font-weight:700;color:var(--color-success);background:var(--color-success-light);border:1px solid #137333;padding:0.25rem 0.625rem;border-radius:3px;">Plataforma Core</span>
          <span style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);">Grado producción. Probado. Documentado.</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;" class="grid-2">
          {[
            {
              name: 'lra-ai-platform',
              layer: 'Orquestación IA',
              desc: '8 agentes especializados con gobernanza RBAC de 5 niveles — escaneo de seguridad, revisión de infraestructura, documentación, CI/CD y orquestación de despliegues.',
              tags: ['Python', 'FastAPI', 'Trivy', 'Checkov', 'Anthropic SDK'],
              href: '/es/proyectos/lra-ai-platform',
              github: 'https://github.com/lra-cloud-ops/lra-ai-platform',
              stats: '8 agentes · 14 integraciones · 33 tests',
            },
            {
              name: 'aws-terraform-devops',
              layer: 'Infraestructura Cloud',
              desc: '7 módulos Terraform que aprovisionan un entorno AWS completo — VPC multi-AZ, EKS 1.31, RDS PostgreSQL 15, ECR, IAM, CloudWatch, S3.',
              tags: ['Terraform', 'AWS', 'EKS', 'RDS', 'ArgoCD'],
              href: '/es/proyectos/aws-terraform-devops',
              github: 'https://github.com/lra-cloud-ops/aws-terraform-devops',
              stats: '7 módulos Terraform · 18 tests',
            },
          ].map(({ name, layer, desc, tags, href, github, stats }) => (
            <div style="background:var(--color-bg-soft);border:1px solid var(--color-border);border-top:3px solid #137333;border-radius:var(--radius-lg);padding:1.5rem;" class="card-premium">
              <div style="display:flex;align-items:start;justify-content:space-between;margin-bottom:0.5rem;flex-wrap:wrap;gap:0.5rem;">
                <div>
                  <p style="font-family:var(--font-mono);font-size:0.6875rem;color:var(--color-text-muted);margin:0 0 0.25rem;text-transform:uppercase;letter-spacing:0.04em;">{layer}</p>
                  <h3 style="font-family:var(--font-display);font-size:1.125rem;font-weight:700;color:var(--color-text);margin:0;">{name}</h3>
                </div>
              </div>
              <p style="font-family:var(--font-body);font-size:0.9375rem;color:var(--color-text-secondary);line-height:1.6;margin:0.75rem 0;">{desc}</p>
              <p style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-success);margin:0 0 0.875rem;">{stats}</p>
              <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-bottom:1.25rem;">
                {tags.map(tag => (
                  <span style="font-family:var(--font-mono);font-size:0.6875rem;color:var(--color-success);background:var(--color-success-light);border:1px solid #A8D5B5;padding:0.125rem 0.5rem;border-radius:3px;">{tag}</span>
                ))}
              </div>
              <div style="display:flex;gap:1rem;">
                <a href={href} style="font-family:var(--font-body);font-size:0.875rem;font-weight:600;color:var(--color-primary);text-decoration:none;">Ver detalles →</a>
                <a href={github} target="_blank" rel="noopener noreferrer" style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);text-decoration:none;">GitHub ↗</a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Soporte -->
      <div style="margin-bottom:3rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
          <span style="font-family:var(--font-mono);font-size:0.75rem;font-weight:700;color:var(--color-primary);background:var(--color-primary-light);border:1px solid #1A73E8;padding:0.25rem 0.625rem;border-radius:3px;">Soporte</span>
          <span style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);">Estable. Complementa los proyectos Core.</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;" class="grid-2">
          {[
            {
              name: 'k8s-on-premise',
              layer: 'Runtime de Contenedores',
              desc: 'Kubernetes desde cero con kubeadm — 1 master, 2 workers sobre Vagrant/VirtualBox. Calico CNI, NGINX Ingress, add-ons de Helm, GitOps con ArgoCD.',
              tags: ['Kubernetes', 'kubeadm', 'Calico', 'ArgoCD', 'Helm'],
              href: '/es/proyectos/k8s-on-premise',
              github: 'https://github.com/lra-cloud-ops/k8s-on-premise',
              stats: '3 nodos · 25 commits',
            },
            {
              name: 'aws-devops-agent',
              layer: 'Automatización Cloud',
              desc: 'Agente CLI con un bucle real de tool-use — 31 funciones boto3 que cubren 24 servicios AWS en lenguaje natural. Prueba de concepto de operaciones cloud nativas en IA.',
              tags: ['Python', 'Anthropic SDK', 'boto3', 'AWS'],
              href: '/es/proyectos/aws-devops-agent',
              github: 'https://github.com/lra-cloud-ops/aws-devops-agent',
              stats: '31 herramientas · 24 servicios AWS',
            },
          ].map(({ name, layer, desc, tags, href, github, stats }) => (
            <div style="background:var(--color-bg-soft);border:1px solid var(--color-border);border-top:3px solid #1A73E8;border-radius:var(--radius-lg);padding:1.5rem;" class="card-premium">
              <div style="margin-bottom:0.5rem;">
                <p style="font-family:var(--font-mono);font-size:0.6875rem;color:var(--color-text-muted);margin:0 0 0.25rem;text-transform:uppercase;letter-spacing:0.04em;">{layer}</p>
                <h3 style="font-family:var(--font-display);font-size:1.125rem;font-weight:700;color:var(--color-text);margin:0;">{name}</h3>
              </div>
              <p style="font-family:var(--font-body);font-size:0.9375rem;color:var(--color-text-secondary);line-height:1.6;margin:0.75rem 0;">{desc}</p>
              <p style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-primary);margin:0 0 0.875rem;">{stats}</p>
              <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-bottom:1.25rem;">
                {tags.map(tag => (
                  <span style="font-family:var(--font-mono);font-size:0.6875rem;color:var(--color-primary);background:var(--color-primary-light);border:1px solid #C5D8F8;padding:0.125rem 0.5rem;border-radius:3px;">{tag}</span>
                ))}
              </div>
              <div style="display:flex;gap:1rem;">
                <a href={href} style="font-family:var(--font-body);font-size:0.875rem;font-weight:600;color:var(--color-primary);text-decoration:none;">Ver detalles →</a>
                <a href={github} target="_blank" rel="noopener noreferrer" style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);text-decoration:none;">GitHub ↗</a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Lab -->
      <div>
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span style="font-family:var(--font-mono);font-size:0.75rem;font-weight:700;color:var(--color-warning);background:var(--color-warning-light);border:1px solid #F29900;padding:0.25rem 0.625rem;border-radius:3px;">Lab</span>
          <span style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);">Exploración activa. No apto para producción todavía.</span>
        </div>
        <p style="font-family:var(--font-body);font-size:0.9375rem;color:var(--color-text-secondary);margin-bottom:1.5rem;max-width:640px;line-height:1.6;">Los repositorios Lab representan exploración técnica activa. Demuestran patrones y enfoques en desarrollo — no productos terminados.</p>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;" class="grid-3">
          {[
            {
              name: 'gitops-stack',
              layer: 'CI/CD',
              desc: 'Pipeline Jenkins con asunción de roles IAM y acceso vía SSM — sin credenciales estáticas, sin bastión SSH.',
              github: 'https://github.com/Liquenson/gitops-stack',
            },
            {
              name: 'linux-fleet-manager',
              layer: 'Automatización de Flota',
              desc: 'Framework de automatización Bash 4.0+ para gestión de flotas Linux. Limpio con ShellCheck, CI en Ubuntu, macOS y Windows Git Bash.',
              github: 'https://github.com/Liquenson/linux-fleet-manager',
            },
            {
              name: 'k8s-devops-platform',
              layer: 'Plataforma GitOps',
              desc: 'Plataforma Kubernetes solo-GitOps — ArgoCD vigila el repositorio, kubectl apply nunca se usa directamente. Patrón Kustomize base/overlays.',
              github: 'https://github.com/Liquenson/k8s-devops-platform',
            },
          ].map(({ name, layer, desc, github }) => (
            <div style="background:var(--color-bg-soft);border:1px solid var(--color-border);border-top:3px solid #F29900;border-radius:var(--radius-lg);padding:1.25rem;" class="card-premium">
              <p style="font-family:var(--font-mono);font-size:0.6875rem;color:var(--color-text-muted);margin:0 0 0.25rem;text-transform:uppercase;letter-spacing:0.04em;">{layer}</p>
              <h3 style="font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--color-text);margin:0 0 0.5rem;">{name}</h3>
              <p style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);line-height:1.6;margin:0 0 1rem;">{desc}</p>
              <a href={github} target="_blank" rel="noopener noreferrer"
                style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);text-decoration:none;"
              >GitHub ↗</a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 767px) {
    .grid-2 {
      grid-template-columns: 1fr !important;
    }
    .grid-3 {
      grid-template-columns: 1fr !important;
    }
  }
</style>
