---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Proyectos Open Source · LRA Cloud Operations"
  descripcion="Herramientas open source de nivel producción e implementaciones de referencia por LRA Cloud Ops. Libres para usar, bifurcar y adaptar."
  keywords="open source DevOps, Kubernetes GitOps, Terraform AWS, gestión flota Linux, FastAPI Docker, agente Claude AI"
>
  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.2) 0%, transparent 65%);"
    ></div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <span
        class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        Open Source
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Proyectos Open Source
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        Herramientas de nivel producción e implementaciones de referencia. Libres para usar, bifurcar y adaptar.
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.5);">
        Licencia MIT &middot; github.com/Liquenson
      </p>
    </div>
  </section>

  <section class="py-20" style="background: #F8FAFC;">
    <div class="text-center py-24">
      <p class="text-[#64748b] text-lg">New projects coming soon.</p>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 32px 32px;"
    ></div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2
        class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
        style="letter-spacing: -0.02em;"
      >
        ¿Necesitas una implementación personalizada?
      </h2>
      <p class="text-base mb-8 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        Nuestros repositorios open source son el punto de partida. Construimos infraestructura de producción adaptada a tu organización.
      </p>
      <a
        href="/es/contacto"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02]"
        style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 24px rgba(30,111,255,0.4);"
      >
        Agendar consulta gratuita
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
