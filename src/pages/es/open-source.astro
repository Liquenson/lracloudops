              <svg
                class="w-5 h-5 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold" style="color: #0A2540;">
                aws-devops-agent
              </h3>
              <p class="text-sm" style="color: #64748b;">
                IA & Automatización Cloud
              </p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span
              class="text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
              >En Desarrollo</span
            >
            <span
              class="text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;"
              >Activo</span
            >
          </div>
        </div>
        <p class="text-base leading-relaxed mb-5" style="color: #334155;">
          Agente CLI con IA para gestionar más de 25 servicios AWS en lenguaje
          natural. Claude Sonnet como capa de razonamiento, boto3 como capa de
          ejecución — consulta infraestructura, despliega workloads y gestiona
          recursos sin salir del terminal.
        </p>
        <div class="flex flex-wrap gap-2 mb-6">
          {
            [
              'Python',
              'Claude Sonnet',
              'boto3',
              'AWS',
              'Anthropic API',
              'CLI',
            ].map((tag) => (
              <span
                class="text-xs px-2.5 py-1 rounded-full font-medium"
                style="background: #f8fafc; color: #475569; border: 1px solid #e2e8f0;"
              >
                {tag}
              </span>
            ))
          }
        </div>
        <a
          href="https://github.com/lra-cloud-ops/aws-devops-agent"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all hover:opacity-90"
          style="background: #0A2540; color: white;"
        >
          <svg
            class="w-4 h-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
            ><path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
