---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

export const prerender = true

const stackGroups = [
  {
    title: 'Cloud',
    items: [
      'AWS EKS',
      'AWS RDS',
      'AWS VPC / ALB',
      'CloudFront',
      'Azure',
      'GCP',
    ],
  },
  {
    title: 'Infraestructura como código',
    items: ['Terraform', 'Ansible', 'Helm'],
  },
  { title: 'Kubernetes y GitOps', items: ['Kubernetes', 'ArgoCD', 'KinD'] },
  {
    title: 'Observabilidad',
    items: ['Prometheus', 'Grafana', 'Alertmanager', 'CloudWatch'],
  },
  { title: 'CI/CD', items: ['GitHub Actions', 'Jenkins'] },
  { title: 'Lenguajes', items: ['Python', 'Bash', 'HCL'] },
]

const focus = [
  {
    title: 'Infraestructura como código',
    desc: 'Cada entorno que construyo está definido en Terraform — reproducible, versionado, revisado vía pull requests. Sin cambios manuales en la consola.',
  },
  {
    title: 'Entrega GitOps',
    desc: 'ArgoCD vigila el repositorio Git y reconcilia el estado del cluster automáticamente. Los deploys ocurren por commits, no por kubectl.',
  },
  {
    title: 'Observabilidad desde el día uno',
    desc: 'Prometheus y Grafana forman parte de la configuración inicial, no una idea tardía. Si corre en producción, emite métricas.',
  },
]
---

<Layout
  title="Sobre mí — Ruben Liquenson"
  description="Ingeniero DevOps & Especialista AWS con base en Las Palmas de Gran Canaria, España. Infraestructura cloud, Kubernetes, GitOps."
  lang="es"
>
  <Header />

  <section class="bg-dark on-dark section-sm">
    <div class="container">
      <div class="about-hero">
        <img
          src="/team/ruben-liquenson.png"
          alt="Ruben Liquenson"
          class="about-photo"
        />
        <div>
          <div class="eyebrow">Sobre mí</div>
          <h1 style="color: #FFF; margin-bottom: 0.75rem;">Ruben Liquenson</h1>
          <p style="color: #94A3B8; font-size: 1.125rem; max-width: 560px;">
            Ingeniero DevOps & Especialista AWS con base en Las Palmas de Gran
            Canaria, España. Construyo y opero infraestructura cloud de nivel
            producción — Kubernetes, Terraform, GitOps.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-light section">
    <div class="container" style="max-width: 800px;">
      <h2 style="margin-bottom: 1.5rem;">Bio</h2>
      <p style="margin-bottom: 1.25rem;">
        Trabajo como Ingeniero DevOps, diseñando y operando infraestructura
        cloud en AWS. Mi enfoque está en sistemas de nivel producción:
        infraestructura reproducible, automatizada y monitorizada — no
        configuraciones puntuales que solo funcionan en una demo.
      </p>
      <p style="margin-bottom: 1.25rem;">
        La mayor parte de mi trabajo se centra en AWS EKS, Terraform y entrega
        GitOps con ArgoCD. Me importa eliminar pasos manuales del despliegue:
        cada cambio en infraestructura o en el estado de la aplicación debe ser
        visible en Git y aplicarse automáticamente.
      </p>
      <p>
        Fuera del trabajo con clientes, mantengo un conjunto de proyectos de
        infraestructura open source bajo{' '}
        <a
          href="https://github.com/lra-cloud-ops"
          target="_blank"
          rel="noopener"
          style="color: var(--color-primary); font-weight: 600;"
          >github.com/lra-cloud-ops</a
        > — visita la página de <a
          href="/es/proyectos"
          style="color: var(--color-primary); font-weight: 600;">Proyectos</a
        > para más detalles.
      </p>
    </div>
  </section>

  <section class="bg-subtle section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <div class="eyebrow">Cómo trabajo</div>
        <h2>Principios de ingeniería</h2>
      </div>
      <div class="focus-grid">
        {
          focus.map((f) => (
            <div class="focus-card">
              <h3 style="margin-bottom: 0.75rem; font-size: 1.125rem;">
                {f.title}
              </h3>
              <p style="font-size: 0.9375rem;">{f.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-light section">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <div class="eyebrow">Stack</div>
        <h2>Herramientas que uso en producción</h2>
      </div>
      <div class="stack-grid">
        {
          stackGroups.map((group) => (
            <div class="stack-group">
              <p class="stack-group-title">{group.title}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                {group.items.map((item) => (
                  <span class="tech-pill">{item}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-dark on-dark section" style="text-align: center;">
    <div class="container">
      <div style="max-width: 600px; margin: 0 auto;">
        <h2 style="color: #FFF; margin-bottom: 1rem;">Hablemos</h2>
        <p style="color: #94A3B8; margin-bottom: 2.5rem; font-size: 1.125rem;">
          Abierto a puestos de tiempo completo, contratos y trabajo freelance en
          infraestructura.
        </p>
        <div
          style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;"
        >
          <a href="/es/contacto" class="btn btn-primary btn-lg btn-pill"
            >Contactar →</a
          >
          <a href="/es/proyectos" class="btn btn-outline-white btn-lg btn-pill"
            >Ver proyectos</a
          >
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .about-hero {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .about-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .focus-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 1.75rem;
  }
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .stack-group-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  @media (max-width: 768px) {
    .about-hero {
      flex-direction: column;
      text-align: center;
    }
    .focus-grid,
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
