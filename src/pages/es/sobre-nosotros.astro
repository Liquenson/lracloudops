---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'

const skills = [
  {
    category: 'Cloud AWS',
    skills:
      'EC2 · EKS · ECS · ECR · RDS · S3 · VPC · Route 53 · CloudFront · ELB · IAM · CloudWatch',
  },
  { category: 'IaC', skills: 'Terraform · Ansible' },
  { category: 'Contenedores', skills: 'Docker · Kubernetes · Helm · ArgoCD' },
  {
    category: 'CI/CD',
    skills: 'Jenkins · GitHub Actions · Maven · SonarQube · Nexus',
  },
  { category: 'Observabilidad', skills: 'Prometheus · Grafana · CloudWatch' },
  { category: 'Linux', skills: 'RHEL · CentOS · Ubuntu · Debian · Alpine' },
  {
    category: 'Redes',
    skills: 'VPC · NAT · HAProxy · DNS · TCP/IP · Route 53',
  },
  { category: 'Scripting', skills: 'Bash · Python' },
  {
    category: 'Almacenamiento',
    skills: 'RDS · S3 · EFS · EBS · LVM · Glacier',
  },
  { category: 'Virtualización', skills: 'VMware vSphere' },
]

const experience = [
  {
    company: 'Nibble Tech LLC',
    role: 'Ingeniero DevOps',
    period: 'Mayo 2026 – Actualidad',
    highlights: [
      'Plataforma de entrega continua sobre AWS EKS — totalmente como código, patrón GitOps',
      'Pipeline CI/CD: Jenkins → Docker → ECR → Kubernetes (actualización sin downtime)',
      'Terraform: VPC multi-AZ, EKS, ECR, RDS, S3, IAM, CloudWatch (DEV/PROD)',
      'Ansible + AWS SSM para configuración automática de nodos (sin bastión SSH)',
      'ArgoCD + Helm Charts con values por entorno',
      'Observabilidad: Prometheus + Grafana + CloudWatch Container Insights',
    ],
  },
  {
    company: 'iCareMedical',
    role: 'Ingeniero DevOps',
    period: 'Mayo 2022 – Mayo 2026',
    highlights: [
      '4 años en infraestructura AWS del sector salud (entorno regulado)',
      'CI/CD: Jenkins + Maven + SonarQube + Ansible + Kubernetes',
      'AWS multi-AZ: VPC, EC2, RDS, EFS, S3, CloudFront, Route 53, ELB',
      'Kubernetes + Helm Charts para despliegue, versionado y rollback',
      'Prometheus + Grafana — alertas proactivas, menor tiempo de detección de incidentes',
      'IAM: roles, políticas y grupos de seguridad con mínimo privilegio en entorno regulado',
    ],
  },
  {
    company: 'DR Financial Services',
    role: 'Administrador de sistemas Linux',
    period: 'Feb 2021 – Abr 2022',
    highlights: [
      'RHEL, CentOS, Ubuntu, Debian y Alpine en producción',
      'VMware vSphere — aprovisionamiento de VMs, snapshots, optimización de recursos',
      'LVM — gestión de volúmenes, extensión en caliente, snapshots',
      'Bash scripting — automatización, gestión de usuarios, rotación de logs, backups',
      'SLA 24/7 en entorno financiero regulado',
    ],
  },
]

const education = [
  {
    institution: 'ITLA — Instituto Tecnológico de las Américas',
    degree: 'IT Essentials — Acción Formativa',
    period: 'Oct 2018 – Dic 2018',
  },
  {
    institution: 'INFOTEP — Instituto Tecnológico de las Américas',
    degree: 'HP Information Technology Essential 1 · 80 horas · ISO 9001',
    period: 'Diciembre 2018',
  },
  {
    institution: 'Cisco Networking Academy',
    degree: 'IT Essentials — Hardware, OS & Networks',
    period: '2016–2017',
  },
]

const certifications = [
  { name: 'ITLA', detail: 'HP Information Technology — Grado Superior', color: '#1A73E8', icon: '🎓' },
]
---

<Layout
  title="Sobre nosotros — LRA CloudOps"
  description="Ruben Liquenson — Platform Engineer construyendo plataformas cloud con Infrastructure as Code, Kubernetes, GitOps e IA. Con sede en Las Palmas de Gran Canaria."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Perfil de Ingeniería
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        Ruben Liquenson
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368;"
      >
        Platform Engineer con 4+ años entregando infraestructura en
        producción sobre AWS — EKS, RDS, Terraform, ArgoCD, Prometheus.
        Actualmente construyendo el ecosistema open source de LRA CloudOps.
      </p>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; margin-top: 0.5rem;"
      >
        📍 Las Palmas de Gran Canaria, Canarias, España
      </p>
    </div>
  </section>

  <section style="background: #FFFFFF; padding: 3rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; align-items: start;"
        class="about-grid"
      >
        <!-- Left: profile -->
        <div>
          <div
            style="width: 120px; height: 120px; border-radius: 50%; background: #E8F0FE; border: 3px solid #DADCE0; margin-bottom: 1.5rem; overflow: hidden;"
          >
            <img
              src="/devruben.png"
              alt="Ruben Liquenson"
              style="width: 100%; height: 100%; object-fit: cover;"
              onerror="this.style.display='none'"
            />
          </div>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 700; color: #202124; margin-bottom: 0.25rem;"
          >
            Ruben Liquenson
          </h2>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; margin-bottom: 1.25rem;"
          >
            DevOps Engineer · Especialista AWS
          </p>
          <div style="display: flex; flex-direction: column; gap: 0.625rem;">
            <a
              href="https://www.linkedin.com/in/ruben-liquenson-490961269/"
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #1A73E8; text-decoration: none;"
            >
              LinkedIn →
            </a>
            <a
              href="https://github.com/lra-cloud-ops"
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #1A73E8; text-decoration: none;"
            >
              GitHub →
            </a>
            <a
              href="mailto:liquenson.cloud@gmail.com"
              style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #1A73E8; text-decoration: none;"
            >
              liquenson.cloud@gmail.com
            </a>
            <p
              style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; margin-top: 0.5rem;"
            >
              📍 Las Palmas de Gran Canaria<br />Canarias, España
            </p>
          </div>
        </div>

        <!-- Right: bio + experiencia + skills + educación + idiomas -->
        <div>
          <h3
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; margin-bottom: 0.875rem;"
          >
            Trayectoria
          </h3>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1rem;"
          >
            Ingeniero DevOps con más de 4 años diseñando infraestructuras cloud
            en AWS de nivel productivo. Especializado en Kubernetes (EKS),
            Terraform, CI/CD y GitOps con ArgoCD.
          </p>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1rem;"
          >
            Experiencia más reciente en Nibble Tech LLC construyendo plataformas
            de entrega continua sobre AWS EKS — infraestructura completamente
            como código, configuración automatizada de nodos via Ansible y AWS
            SSM, y despliegue GitOps con ArgoCD y Helm.
          </p>
          <p
            style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; line-height: 1.7; margin-bottom: 1.5rem;"
          >
            Anteriormente, 4 años en iCareMedical diseñando infraestructura AWS
            de alta disponibilidad para el sector salud — entorno regulado con
            requisitos estrictos de IAM, cumplimiento de SLA y despliegues sin
            downtime.
          </p>

          <h3
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; margin-bottom: 1.25rem;"
          >
            Experiencia
          </h3>
          <div
            data-animate="stagger"
            style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2rem;"
          >
            {
              experience.map((exp) => (
                <div data-animate-child class="card-premium" style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.25rem;">
                  <div style="display: flex; align-items: start; justify-content: space-between; margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.5rem;">
                    <div>
                      <p style="font-family: 'Red Hat Display', sans-serif; font-size: 1rem; font-weight: 700; color: #202124;">
                        {exp.company}
                      </p>
                      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #1A73E8; font-weight: 500;">
                        {exp.role}
                      </p>
                    </div>
                    <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; color: #5F6368; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.2rem 0.625rem; border-radius: 4px; white-space: nowrap;">
                      {exp.period}
                    </span>
                  </div>
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.375rem;">
                    {exp.highlights.map((h) => (
                      <li style="display: flex; align-items: start; gap: 0.625rem;">
                        <span style="color: #1A73E8; flex-shrink: 0; margin-top: 1px;">
                          →
                        </span>
                        <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; line-height: 1.5;">
                          {h}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>

          <h3
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; margin-bottom: 0.875rem;"
          >
            Habilidades principales
          </h3>
          <div
            data-animate="stagger"
            style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 2rem;"
            class="skills-grid"
          >
            {
              skills.map(({ category, skills }) => (
                <div data-animate-child class="card-premium" style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 6px; padding: 0.875rem;">
                  <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.25rem;">
                    {category}
                  </p>
                  <p style="font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; color: #5F6368;">
                    {skills}
                  </p>
                </div>
              ))
            }
          </div>

          <div style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; margin-top: 2rem; margin-bottom: 2rem;">
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;">Trabajo Open Source</p>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368; line-height: 1.7; margin-bottom: 1rem;">
              La experiencia anterior se refleja en el ecosistema open source
              de LRA CloudOps — cuatro repositorios que cubren el stack
              completo de Platform Engineering.
            </p>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              {[
                { name: 'lra-ai-platform', label: 'Plataforma Core' },
                { name: 'aws-terraform-devops', label: 'Plataforma Core' },
                { name: 'k8s-on-premise', label: 'Soporte' },
                { name: 'aws-devops-agent', label: 'Lab' },
              ].map(({ name, label }) => (
                <a href={`/es/proyectos/${name}`} title={label}
                  style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #1A73E8; text-decoration: none; background: #E8F0FE; border: 1px solid #C5D8F8; padding: 0.25rem 0.625rem; border-radius: 4px;"
                  onmouseover="this.style.background='#C5D8F8'"
                  onmouseout="this.style.background='#E8F0FE'"
                >{name}</a>
              ))}
            </div>
          </div>

          <h3
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; margin-bottom: 1rem;"
          >
            Educación
          </h3>
          <div
            style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem;"
          >
            {
              education.map((edu) => (
                <div style="display: flex; align-items: start; justify-content: space-between; padding: 0.875rem 1rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 6px; flex-wrap: wrap; gap: 0.5rem;">
                  <div>
                    <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #202124;">
                      {edu.institution}
                    </p>
                    <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">
                      {edu.degree}
                    </p>
                  </div>
                  <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.8125rem; color: #5F6368; white-space: nowrap;">
                    {edu.period}
                  </span>
                </div>
              ))
            }
          </div>

          <h3
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; margin-bottom: 1rem;"
          >
            Certificaciones
          </h3>
          <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem;">
            {certifications.map(cert => (
              <div style="display: flex; align-items: center; gap: 1rem; padding: 0.875rem 1rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 6px;">
                <div style={`width: 36px; height: 36px; border-radius: 6px; background: ${cert.color}15; display: flex; align-items: center; justify-content: center; font-size: 1.125rem; flex-shrink: 0;`}>{cert.icon}</div>
                <div>
                  <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #202124;">{cert.name}</p>
                  <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368;">{cert.detail}</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: #137333; margin-left: auto; flex-shrink: 0;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            ))}
          </div>

          <h3
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; margin-bottom: 1rem;"
          >
            Idiomas
          </h3>
          <div
            style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;"
          >
            <div
              style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 6px; padding: 0.75rem 1.25rem;"
            >
              <p
                style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124;"
              >
                Español
              </p>
              <p
                style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;"
              >
                Nativo
              </p>
            </div>
            <div
              style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 6px; padding: 0.75rem 1.25rem;"
            >
              <p
                style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124;"
              >
                English
              </p>
              <p
                style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368;"
              >
                B1 — En progreso
              </p>
            </div>
          </div>

          <h3
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.125rem; font-weight: 700; color: #202124; margin-bottom: 0.875rem;"
          >
            Afiliaciones
          </h3>
          <div
            style="display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;"
          >
            <a
              href="https://www.linkedin.com/company/nibble-tech-llc/"
              target="_blank"
              rel="noopener noreferrer"
              style="opacity: 0.7; transition: opacity 150ms;"
              onmouseover="this.style.opacity='1'"
              onmouseout="this.style.opacity='0.7'"
            >
              <img
                src="/nibble-logo.jpg"
                alt="Nibble Tech LLC"
                style="height: 36px; width: auto; border-radius: 4px;"
              />
            </a>
            <a
              href="https://www.linkedin.com/school/itla/"
              target="_blank"
              rel="noopener noreferrer"
              style="opacity: 0.7; transition: opacity 150ms;"
              onmouseover="this.style.opacity='1'"
              onmouseout="this.style.opacity='0.7'"
            >
              <img
                src="/itla-logo.jpg"
                alt="ITLA"
                style="height: 36px; width: auto; border-radius: 4px;"
              />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 767px) {
    .about-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
    .skills-grid {
      grid-template-columns: 1fr !important;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .about-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    .skills-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>
