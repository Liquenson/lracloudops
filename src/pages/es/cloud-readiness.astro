---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Evaluación de Preparación Cloud | LRA Cloud Operations"
  descripcion="8 preguntas para evaluar si tu aplicación está lista para un despliegue AWS de producción. Obtén una hoja de ruta de migración personalizada."
  keywords="evaluación preparación cloud, migración AWS, checklist despliegue cloud, AWS production readiness"
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"></div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6" style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);">
        Herramienta Gratuita
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6" style="letter-spacing: -0.02em;">
        Evaluación de Preparación Cloud
      </h1>
      <p class="text-lg leading-relaxed max-w-2xl mx-auto mb-4" style="color: rgba(147,184,255,0.8);">
        ¿Está tu aplicación lista para el despliegue en producción en AWS?
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.6);">
        8 preguntas &middot; 5 minutos &middot; Informe personalizado gratuito
      </p>
    </div>
  </section>

  <!-- ASSESSMENT -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-6">

      <div class="mb-10">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold" style="color: #64748b;" id="progress-label">Pregunta 1 de 8</span>
          <span class="text-xs font-semibold" style="color: #1E6FFF;" id="score-display">Puntuación: 0 / 24</span>
        </div>
        <div class="h-2 rounded-full overflow-hidden" style="background: #e2e8f0;">
          <div id="progress-bar" class="h-full rounded-full transition-all duration-500" style="width: 12.5%; background: linear-gradient(90deg, #1E6FFF, #60A5FA);"></div>
        </div>
      </div>

      <div id="question-container"></div>
      <div id="result-container" class="hidden"></div>

    </div>
  </section>

</Layout>

<script>
const CAL = 'https://cal.com/ruben-alexis-h6qkjk/30min'
const questions = [
  {
    q: '¿Cómo está desplegada actualmente tu aplicación?',
    options: [
      { label: 'Servidores on-premise', pts: 0 },
      { label: 'VM única en cloud', pts: 1 },
      { label: 'Contenedorizada con Docker', pts: 2 },
      { label: 'Kubernetes o ECS Fargate', pts: 3 },
    ],
  },
  {
    q: '¿Cómo gestionas la configuración de la aplicación?',
    options: [
      { label: 'Hardcodeada en el código', pts: 0 },
      { label: 'Archivos de configuración por entorno', pts: 1 },
      { label: 'Variables de entorno', pts: 2 },
      { label: 'AWS Parameter Store o Secrets Manager', pts: 3 },
    ],
  },
  {
    q: '¿Cuál es tu estrategia actual de backups?',
    options: [
      { label: 'Sin backups', pts: 0 },
      { label: 'Backups periódicos manuales', pts: 1 },
      { label: 'Backups diarios automatizados', pts: 2 },
      { label: 'Backup continuo con recuperación a un punto en el tiempo', pts: 3 },
    ],
  },
  {
    q: '¿Cómo gestionas el escalado de la aplicación?',
    options: [
      { label: 'Manual — reiniciar servidor cuando va lento', pts: 0 },
      { label: 'Escalado vertical manual', pts: 1 },
      { label: 'Auto Scaling Groups', pts: 2 },
      { label: 'HPA con Kubernetes o ECS Service Auto Scaling', pts: 3 },
    ],
  },
  {
    q: '¿Cuál es tu proceso actual de despliegue?',
    options: [
      { label: 'FTP o copia manual de archivos', pts: 0 },
      { label: 'SSH y scripts', pts: 1 },
      { label: 'Pipeline CI/CD básico', pts: 2 },
      { label: 'Pipeline automatizado con tests y rollback', pts: 3 },
    ],
  },
  {
    q: '¿Cómo monitorizas la salud de la aplicación?',
    options: [
      { label: 'Sin monitorización', pts: 0 },
      { label: 'Comprobaciones manuales', pts: 1 },
      { label: 'Monitorización básica de disponibilidad', pts: 2 },
      { label: 'Métricas, logs y trazas completos con alertas', pts: 3 },
    ],
  },
  {
    q: '¿Cómo gestionas los cambios en la base de datos?',
    options: [
      { label: 'Scripts SQL manuales', pts: 0 },
      { label: 'Scripts versionados', pts: 1 },
      { label: 'Herramienta de migración (Flyway/Liquibase)', pts: 2 },
      { label: 'Migraciones automatizadas en pipeline CI/CD', pts: 3 },
    ],
  },
  {
    q: '¿Cuál es tu postura de seguridad?',
    options: [
      { label: 'Configuración por defecto, sin hardening', pts: 0 },
      { label: 'Reglas de firewall básicas', pts: 1 },
      { label: 'Roles IAM, grupos de seguridad definidos', pts: 2 },
      { label: 'Zero trust, mínimo privilegio, OIDC, WAF', pts: 3 },
    ],
  },
]

const results = [
  { range: [0,8],   title: 'No preparada — Trabajo significativo necesario', desc: 'Tu aplicación necesita trabajo fundamental antes del despliegue cloud. Recomendamos empezar con contenedorización y CI/CD básico.', cta: 'Obtener una revisión de arquitectura gratuita', color: '#DC2626', bg: '#FEF2F2', border: '#FECACA' },
  { range: [9,16],  title: 'Parcialmente preparada — Buena base', desc: 'Tienes lo básico en su lugar. Enfócate en automatización, hardening de seguridad y monitorización adecuada antes de salir a producción.', cta: 'Obtener una hoja de ruta de migración cloud', color: '#D97706', bg: '#FFFBEB', border: '#FDE68A' },
  { range: [17,22], title: 'Casi preparada — Optimizaciones finales', desc: 'Base sólida. Aborda las brechas restantes en seguridad y observabilidad para un despliegue de nivel producción.', cta: 'Programar una revisión de preparación para producción', color: '#1E6FFF', bg: '#EEF4FF', border: '#C7D7FD' },
  { range: [23,24], title: 'Lista para cloud — Nivel producción', desc: '¡Excelente! Tu aplicación sigue las mejores prácticas cloud-native. Hablemos de optimización avanzada.', cta: 'Hablar con nuestros arquitectos senior', color: '#059669', bg: '#F0FDF4', border: '#BBF7D0' },
]

let current = 0, score = 0
const total = questions.length, maxScore = total * 3

function render() {
  const el = (id: string) => document.getElementById(id)!
  el('progress-label').textContent = `Pregunta ${current + 1} de ${total}`
  el('score-display').textContent = `Puntuación: ${score} / ${maxScore}`
  ;(el('progress-bar') as HTMLElement).style.width = `${(current / total) * 100}%`
  const q = questions[current]
  el('question-container').innerHTML = `
    <div class="bg-white rounded-2xl p-8" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(10,37,64,0.04),0 4px 16px rgba(10,37,64,0.06);">
      <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color:#1E6FFF;">Pregunta ${current + 1} de ${total}</p>
      <h2 class="text-xl font-bold mb-7" style="color:#0A2540;letter-spacing:-0.01em;">${q.q}</h2>
      <div class="space-y-3">${q.options.map((opt, i) => `
        <button onclick="selectAnswer(${opt.pts})" class="w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all hover:-translate-y-0.5"
          style="background:#F8FAFC;border:1.5px solid #e2e8f0;color:#0A2540;"
          onmouseover="this.style.borderColor='#1E6FFF';this.style.background='#EEF4FF';"
          onmouseout="this.style.borderColor='#e2e8f0';this.style.background='#F8FAFC';">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold mr-3" style="background:#EEF4FF;color:#1E6FFF;">${'ABCD'[i]}</span>${opt.label}
        </button>`).join('')}
      </div>
    </div>`
}

function selectAnswer(pts: number) {
  score += pts
  current++
  if (current < total) { render() } else { showResult() }
}

function showResult() {
  const el = (id: string) => document.getElementById(id)!
  ;(el('progress-bar') as HTMLElement).style.width = '100%'
  el('progress-label').textContent = 'Evaluación completada'
  el('score-display').textContent = `Puntuación final: ${score} / ${maxScore}`
  const r = results.find(x => score >= x.range[0] && score <= x.range[1]) ?? results[0]
  const pct = Math.round((score / maxScore) * 100)
  el('question-container').classList.add('hidden')
  el('result-container').classList.remove('hidden')
  if (typeof window !== 'undefined' && (window as any).cf) {
    (window as any).cf.track('assessment_completed', { type: 'cloud-readiness-es', score })
  }
  el('result-container').innerHTML = `
    <div class="rounded-2xl p-8 mb-6" style="background:${r.bg};border:1px solid ${r.border};">
      <div class="flex items-start gap-5 mb-6">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0 text-white font-black text-lg" style="background:${r.color};">${pct}%</div>
        <div>
          <h2 class="text-xl font-bold mb-2" style="color:#0A2540;">${r.title}</h2>
          <p class="text-sm leading-relaxed" style="color:#64748b;">${r.desc}</p>
        </div>
      </div>

      <div id="email-capture" style="margin: 1.5rem 0; padding: 1.5rem; background: #EEF4FF; border-radius: 12px; border: 1px solid #C7D7FD;">
        <p style="font-weight: 600; color: #0A2540; margin-bottom: 0.5rem;">Recibe tu plan de acción personalizado por email</p>
        <p style="font-size: 0.875rem; color: #64748b; margin-bottom: 1rem;">Te enviaremos una hoja de ruta detallada basada en tu puntuación. Sin spam.</p>
        <form id="assessment-email-form" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <input type="hidden" name="access_key" value="e8aaab4e-270c-4163-bb76-6a8dfc247485">
          <input type="hidden" name="subject" id="assessment-subject">
          <input type="hidden" name="assessment_score" id="assessment-score-field">
          <input type="hidden" name="assessment_level" id="assessment-level-field">
          <input type="email" name="email" placeholder="tu@empresa.com" required
            style="flex: 1; min-width: 200px; padding: 0.75rem 1rem; border: 1px solid #C7D7FD; border-radius: 8px; font-size: 0.875rem;">
          <button type="submit"
            style="padding: 0.75rem 1.5rem; background: #1E6FFF; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">
            Enviarme mi plan →
          </button>
        </form>
        <p id="email-success" style="display:none; color: #16a34a; font-size: 0.875rem; margin-top: 0.75rem;">✓ ¡Revisa tu bandeja de entrada! Te enviaremos tu plan en 24 horas.</p>
      </div>

      <a href="${CAL}" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-bold px-6 py-3.5 rounded-xl transition-all hover:opacity-90 hover:-translate-y-px"
        style="background:${r.color};color:white;box-shadow:0 4px 16px rgba(0,0,0,0.15);">
        ${r.cta} →
      </a>
    </div>
    <button onclick="location.reload()" class="text-sm font-medium hover:opacity-70 transition-opacity" style="color:#64748b;">← Repetir evaluación</button>`

  // Email capture setup
  const subjEl = document.getElementById('assessment-subject') as HTMLInputElement
  const scoreEl2 = document.getElementById('assessment-score-field') as HTMLInputElement
  const levelEl = document.getElementById('assessment-level-field') as HTMLInputElement
  if (subjEl) subjEl.value = `Evaluación Preparación Cloud — Puntuación ${score}/${maxScore} (${r.title})`
  if (scoreEl2) scoreEl2.value = String(score)
  if (levelEl) levelEl.value = r.title
  const emailForm = document.getElementById('assessment-email-form') as HTMLFormElement
  emailForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const fd = new FormData(emailForm)
    try {
      const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: fd })
      if (res.ok) {
        emailForm.style.display = 'none'
        const ok = document.getElementById('email-success')
        if (ok) ok.style.display = 'block'
      }
    } catch {}
  })
}

;(window as any).selectAnswer = selectAnswer
render()

if (typeof window !== 'undefined' && (window as any).cf) {
  (window as any).cf.track('assessment_started', { type: 'cloud-readiness-es' })
}
</script>
