                }
              </div>
              <div class="flex flex-wrap gap-2">
                {
                  [
                    { cert: 'ITIL 4 Foundation', color: '#6B21A8' },
                    {
                      cert: 'CCNA — Cisco Networking Academy',
                      color: '#1BA0D7',
                    },
                    {
                      cert: 'Fortinet Certified Associate Cybersecurity',
                      color: '#EE3124',
