                    >
                      <svg
                        class="w-3 h-3 flex-shrink-0"
                        style={`color: ${color};`}
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
