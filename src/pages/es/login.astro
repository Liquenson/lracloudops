---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  title="Login — LRA CloudOps"
  description="El acceso a la plataforma está actualmente en beta privada."
  lang="es"
>
  <section
    style="min-height: 70vh; display: flex; align-items: center; justify-content: center; background: #F8F9FA; padding: 2rem;"
  >
    <div style="text-align: center; max-width: 400px;">
      <img
        src="/lracloudops-icon.svg"
        alt="LRA CloudOps"
        width="48"
        height="48"
        style="margin: 0 auto 1.5rem;"
      />
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: 1.75rem; font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        Acceso a la plataforma
      </h1>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem; line-height: 1.6;"
      >
        El dashboard está actualmente en beta privada. Solicita acceso para
        empezar.
      </p>
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        style="display: flex; flex-direction: column; gap: 0.875rem; max-width: 320px; margin: 0 auto;"
      >
        <input
          type="hidden"
          name="access_key"
          value="e8aaab4e-270c-4163-bb76-6a8dfc247485"
        />
        <input
          type="hidden"
          name="subject"
          value="LRA CloudOps — Lista de espera"
        />
        <input
          type="email"
          name="email"
          required
          placeholder="tu@email.com"
          style="padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; width: 100%; box-sizing: border-box;"
        />
        <button
          type="submit"
          style="display: inline-flex; align-items: center; justify-content: center; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; border: none; cursor: pointer; width: 100%;"
        >
          Unirse a la lista de espera →
        </button>
      </form>
    </div>
  </section>
</Layout>
