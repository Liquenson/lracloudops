<script>
  const TOTAL = 47
  const catTotals: Record<string, number> = {
    security: 10,
    reliability: 10,
    performance: 8,
    observability: 8,
    costs: 6,
    cicd: 5,
  }
  const catCounts: Record<string, number> = {
    security: 0,
    reliability: 0,
    performance: 0,
    observability: 0,
    costs: 0,
    cicd: 0,
  }

  function updateUI() {
    const total = Object.values(catCounts).reduce((a, b) => a + b, 0)
    const pct = Math.round((total / TOTAL) * 100)
    ;(document.getElementById('progress-bar') as HTMLDivElement).style.width =
      pct + '%'
    ;(
      document.getElementById('progress-label') as HTMLSpanElement
    ).textContent = `${total} de ${TOTAL} completados`
    ;(document.getElementById('progress-pct') as HTMLSpanElement).textContent =
      pct + '%'
    for (const cat of Object.keys(catTotals)) {
      const el = document.getElementById(`cat-${cat}-count`)
      if (el) el.textContent = `${catCounts[cat]}/${catTotals[cat]}`
    }
  }

  document.querySelectorAll('.checklist-item').forEach((item) => {
    const checkbox = item.querySelector(
      'input[type="checkbox"]'
    ) as HTMLInputElement
    const cat = (item as HTMLElement).dataset.cat as string
    item.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName !== 'INPUT') {
        checkbox.checked = !checkbox.checked
      }
      catCounts[cat] = document.querySelectorAll(
        `.checklist-item[data-cat="${cat}"] input:checked`
      ).length
      updateUI()
    })
  })

  updateUI()
</script>

