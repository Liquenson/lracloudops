        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
            style="background: linear-gradient(135deg, #7B42BC 0%, #5B2E9E 100%);"
