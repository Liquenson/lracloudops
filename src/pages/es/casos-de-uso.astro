---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import Section from '../../components/ui/Section.astro'
import SectionHeader from '../../components/ui/SectionHeader.astro'
---
<Layout
  title="Casos de Uso — LRA CloudOps"
  description="Resultados reales de auditorías de infraestructura e implementaciones de Platform Engineering. Hallazgos verificados sobre repositorios open source."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <Section bg="soft" border="bottom">
    <SectionHeader
      as="h1"
      tag="Casos de Uso"
      title="Resultados reales. Código verificable."
      subtitle="Cada caso de uso está respaldado por código open source que puedes inspeccionar. Sin métricas inventadas, sin afirmaciones anónimas."
    />
  </Section>

  <!-- Caso de uso 1 — auditoría aws-terraform-devops -->
  <section style="background:var(--color-bg);padding:3rem 1.5rem;border-bottom:1px solid #DADCE0;">
    <div style="max-width:1280px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:4rem;align-items:start;" class="two-col-grid">

        <!-- Izquierda: metadatos -->
        <div>
          <span style="font-family:var(--font-mono);font-size:0.6875rem;font-weight:600;color:var(--color-success);background:var(--color-success-light);border:1px solid #137333;padding:0.25rem 0.625rem;border-radius:3px;">Auditoría de Infraestructura</span>
          <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--color-text);margin:1rem 0 0.5rem;">Infraestructura AWS Terraform — baseline de seguridad</h2>
          <p style="font-family:var(--font-body);font-size:0.9375rem;color:var(--color-text-secondary);margin-bottom:1.5rem;line-height:1.6;">Output real de lra scan — 263 checks superados, 53 misconfiguraciones identificadas.</p>

          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            {[
              { label: 'Repositorio', value: 'lra-cloud-ops/aws-terraform-devops', color: '#202124', weight: 500 },
              { label: 'Stack', value: 'Terraform, AWS, Kubernetes', color: '#202124', weight: 500 },
              { label: 'Herramientas de escaneo', value: 'Trivy, Checkov', color: '#202124', weight: 500 },
              { label: 'Duración', value: '~60s', color: '#202124', weight: 500 },
              { label: 'Resultado', value: 'FAIL', color: '#F29900', weight: 700 },
            ].map(({ label, value, color, weight }) => (
              <div style="display:flex;flex-direction:column;gap:0.125rem;">
                <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.04em;">{label}</span>
                <span style={`font-family:var(--font-body);font-size:0.9375rem;font-weight:${weight};color:${color};`}>{value}</span>
              </div>
            ))}
          </div>

          <a href="https://github.com/lra-cloud-ops/aws-terraform-devops" target="_blank" rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:0.375rem;margin-top:1.5rem;font-family:var(--font-body);font-size:0.875rem;font-weight:600;color:var(--color-primary);text-decoration:none;"
            onmouseover="this.style.textDecoration='underline'"
            onmouseout="this.style.textDecoration='none'"
          >
            Ver repositorio →
          </a>
        </div>

        <!-- Derecha: resultados -->
        <div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem;">
            {[
              { value: '0', label: 'Críticas', color: '#137333' },
              { value: '0', label: 'Altas', color: '#137333' },
              { value: '2', label: 'Medias', color: '#F29900' },
              { value: '263', label: 'Checks superados', color: '#137333' },
              { value: '53', label: 'Checks fallidos', color: '#F29900' },
            ].map(({ value, label, color }) => (
              <div style="background:var(--color-bg-soft);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:1rem;text-align:center;">
                <div style={`font-family:var(--font-display);font-size:1.75rem;font-weight:900;color:${color};`}>{value}</div>
                <div style="font-family:var(--font-body);font-size:0.75rem;color:var(--color-text-secondary);margin-top:0.25rem;">{label}</div>
              </div>
            ))}
          </div>

          <h3 style="font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--color-text);margin-bottom:1rem;">Hallazgos principales</h3>
          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            {[
              { severity: 'WARN', text: '25 misconfiguraciones en Terraform — configuración de logging CloudWatch y controles del registro de contenedores ECR.', color: '#F29900', bg: '#FFF8E1' },
              { severity: 'WARN', text: '28 brechas de seguridad en despliegues Kubernetes — políticas de seguridad de pods, límites de recursos, permisos de runtime.', color: '#F29900', bg: '#FFF8E1' },
              { severity: 'PASS', text: 'Seguridad de Dockerfile: todos los checks superados.', color: '#137333', bg: '#E6F4EA' },
            ].map(({ severity, text, color, bg }) => (
              <div style="display:flex;align-items:start;gap:0.75rem;padding:0.875rem;background:var(--color-bg-soft);border:1px solid var(--color-border);border-radius:var(--radius-md);">
                <span style={`font-family:var(--font-mono);font-size:0.6875rem;font-weight:700;padding:0.125rem 0.5rem;border-radius:3px;flex-shrink:0;color:${color};background:${bg};border:1px solid ${color};`}>{severity}</span>
                <p style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);margin:0;line-height:1.6;">{text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--color-bg-soft);padding:3rem 1.5rem;">
    <div style="max-width:720px;margin:0 auto;text-align:center;">
      <h2 style="font-family:var(--font-display);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:var(--color-text);margin-bottom:0.75rem;">Ejecuta el mismo análisis en tu infraestructura.</h2>
      <p style="font-family:var(--font-body);font-size:1rem;color:var(--color-text-secondary);margin-bottom:2rem;">Gratuito. Sin compromiso. Informe en menos de 24 horas.</p>
      <a href="/es/auditoria" style="display:inline-flex;align-items:center;gap:0.5rem;background:#1A73E8;color:#FFFFFF;padding:0.875rem 2rem;border-radius:var(--radius-md);font-family:var(--font-body);font-size:1rem;font-weight:600;text-decoration:none;transition:background 150ms ease;"
        onmouseover="this.style.background='#1557B0'"
        onmouseout="this.style.background='#1A73E8'"
      >
        Solicitar auditoría gratuita →
      </a>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 767px) {
    .two-col-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
