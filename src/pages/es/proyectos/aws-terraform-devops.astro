---
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/layout/Header.astro'
import Footer from '../../../components/layout/Footer.astro'
import { getTagClass } from '../../../lib/tagColors'
---

<Layout
  title="aws-terraform-devops — LRA CloudOps"
  description="Infraestructura AWS completa con 7 módulos Terraform. EKS 1.31, RDS PostgreSQL 15, ECR, app Flask desplegada vía Helm. GitOps con ArgoCD. Quality gate SonarCloud."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- HERO -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem;">
        <a href="/es/" style="color: #5F6368; text-decoration: none;">Inicio</a>
        <span style="color: #DADCE0;">/</span>
        <a href="/es/proyectos" style="color: #5F6368; text-decoration: none;">Proyectos</a>
        <span style="color: #DADCE0;">/</span>
        <span style="color: #202124; font-weight: 500;">aws-terraform-devops</span>
      </div>

      <div style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;" class="hero-project-grid">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E6F4EA; color: #137333; padding: 0.25rem 0.75rem; border-radius: 4px; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;">
            <span style="width: 6px; height: 6px; background: #137333; border-radius: 50%;"></span>
            Activo
          </div>

          <h1 style="font-family: 'Red Hat Mono', monospace; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;">aws-terraform-devops</h1>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; line-height: 1.7; max-width: 620px; margin-bottom: 1.5rem;">
            Infraestructura AWS lista para producción con 7 módulos Terraform. VPC multi-AZ, EKS 1.31, RDS PostgreSQL 15, registro ECR. App Flask desplegada vía Helm, gestionada por ArgoCD, con quality gate de SonarCloud.
          </p>

          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;">
            {['Terraform', 'AWS EKS 1.31', 'RDS PostgreSQL 15', 'Helm', 'ArgoCD', 'GitHub Actions', 'Jenkins', 'SonarCloud'].map(tag => (
              <span class={getTagClass(tag)} style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.2rem 0.625rem; border-radius: 4px;">{tag}</span>
            ))}
          </div>

          <div style="display: flex; gap: 0.875rem; flex-wrap: wrap;">
            <a href="https://github.com/lra-cloud-ops/aws-terraform-devops" target="_blank" rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem; background: #202124; color: #FFFFFF; padding: 0.625rem 1.25rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
              class="btn-premium"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              Ver en GitHub
            </a>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; min-width: 240px;">
          {[
            { value: '7', label: 'Módulos TF' },
            { value: '26', label: 'Archivos TF' },
            { value: '18', label: 'Tests' },
            { value: '71', label: 'Commits' },
          ].map(({ value, label }) => (
            <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1rem; text-align: center;">
              <div style="font-family: 'Red Hat Display', sans-serif; font-size: 2rem; font-weight: 900; color: #1A73E8; line-height: 1;">{value}</div>
              <div style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368; margin-top: 0.25rem;">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- MÓDULOS TERRAFORM -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Infraestructura</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 2rem;">7 módulos Terraform</h2>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem;" class="modules-grid" data-animate="stagger">
        {[
          { name: 'vpc', desc: 'VPC multi-AZ, subnets públicas/privadas, NAT, IGW', detail: '10.0.0.0/16 · eu-west-1a/b/c' },
          { name: 'eks', desc: 'Clúster EKS 1.31 con node groups gestionados', detail: 'Auto-scaling · t3.medium' },
          { name: 'rds', desc: 'RDS PostgreSQL 15, Multi-AZ, cifrado', detail: 'Backups automáticos · failover' },
          { name: 'ecr', desc: 'Registro ECR con políticas de ciclo de vida', detail: 'Escaneo de imágenes activado' },
          { name: 'iam', desc: 'Roles y políticas con mínimo privilegio', detail: 'OIDC · service accounts' },
          { name: 'cloudwatch', desc: 'Métricas, logs, alarmas y dashboards', detail: 'Container Insights activado' },
          { name: 's3_bucket', desc: 'Backend de estado de Terraform, versionado', detail: 'Tabla de lock en DynamoDB' },
        ].map(mod => (
          <div style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.25rem;" class="card-premium" data-animate-child>
            <p style="font-family: 'Red Hat Mono', monospace; font-size: 0.9375rem; font-weight: 700; color: #1A73E8; margin-bottom: 0.5rem;">module.{mod.name}</p>
            <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368; line-height: 1.5; margin-bottom: 0.5rem;">{mod.desc}</p>
            <p style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #9AA0A6;">{mod.detail}</p>
          </div>
        ))}
      </div>

      <!-- Architecture flow -->
      <div style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem; font-family: 'Red Hat Mono', monospace; font-size: 0.875rem; color: #5F6368; line-height: 2;">
        <div style="color: #202124; font-weight: 600; margin-bottom: 0.5rem;">Pipeline de despliegue:</div>
        <div>GitHub push → <span style="color: #1A73E8;">GitHub Actions</span> (lint + validate + plan) → <span style="color: #137333;">SonarCloud</span> (quality gate) → <span style="color: #1A73E8;">ECR</span> (image push) → <span style="color: #137333;">ArgoCD</span> (sync a EKS)</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; text-align: center;" data-animate="fade-up">
    <div style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #202124; margin-bottom: 1rem;">26 archivos Terraform. Todo público.</h2>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;">7 módulos, 2 entornos (dev/prod), CI/CD completo.</p>
      <a href="https://github.com/lra-cloud-ops/aws-terraform-devops" target="_blank" rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; text-decoration: none;"
        class="btn-premium"
      >
        Ver en GitHub →
      </a>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
@media (max-width: 1199px) {
  .modules-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
@media (max-width: 767px) {
  .hero-project-grid { grid-template-columns: 1fr !important; }
  .modules-grid { grid-template-columns: 1fr !important; }
}
</style>
