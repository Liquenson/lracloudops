---
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/layout/Header.astro'
import Footer from '../../../components/layout/Footer.astro'
import { getTagClass } from '../../../lib/tagColors'
---

<Layout
  title="aws-devops-agent — LRA CloudOps"
  description="Agente CLI que usa un modelo de IA en un bucle real de tool-use. 31 funciones boto3 que cubren 24 servicios AWS. Pregunta en lenguaje natural."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- HERO -->
  <section
    style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-family: var(--font-body); font-size: 0.875rem;"
      >
        <a href="/es/" style="color: var(--color-text-secondary); text-decoration: none;">Inicio</a>
        <span style="color: #DADCE0;">/</span>
        <a href="/es/proyectos" style="color: var(--color-text-secondary); text-decoration: none;"
          >Proyectos</a
        >
        <span style="color: #DADCE0;">/</span>
        <span style="color: var(--color-text); font-weight: 500;">aws-devops-agent</span>
      </div>

      <div
        style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;"
        class="hero-project-grid"
      >
        <div>
          <div
            style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-primary-light); color: var(--color-primary); padding: 0.25rem 0.75rem; border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;"
          >
            PoC — Prueba de concepto
          </div>

          <h1
            style="font-family: var(--font-mono); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;"
          >
            aws-devops-agent<span style="font-family:var(--font-mono);font-size:0.75rem;font-weight:600;color:var(--color-warning);background:var(--color-warning-light);border:1px solid #F29900;padding:0.25rem 0.75rem;border-radius:var(--radius-sm);margin-left:1rem;">Lab</span>
          </h1>
          <p
            style="font-family: var(--font-body); font-size: 1.0625rem; color: var(--color-text-secondary); line-height: 1.7; max-width: 620px; margin-bottom: 1.5rem;"
          >
            aws-devops-agent es una herramienta CLI que implementa un bucle
            de tool-use de IA usando la Anthropic Messages API. El agente
            mantiene un contexto de conversación y selecciona entre 31
            funciones boto3 — que cubren EC2, EKS, RDS, IAM, S3, CloudWatch,
            Lambda y otros 17 servicios AWS — para responder a consultas en
            lenguaje natural con datos de API en tiempo real. La arquitectura
            es un patrón de tool-use de un solo turno: el modelo recibe la
            consulta y las definiciones de herramientas, devuelve bloques
            tool_use, el executor invoca la función boto3 correspondiente, y
            el resultado se retroalimenta al modelo para la respuesta final.
          </p>

          <div
            style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;"
          >
            {
              [
                'Python 3.11+',
                'Modelo de IA',
                'boto3',
                'Anthropic SDK',
                'tool-use',
              ].map((tag) => (
                <span class={getTagClass(tag)} style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-secondary); background: var(--color-bg); border: 1px solid var(--color-border); padding: 0.2rem 0.625rem; border-radius: var(--radius-sm);">
                  {tag}
                </span>
              ))
            }
          </div>

          <div style="display: flex; gap: 0.875rem; flex-wrap: wrap;">
            <a
              href="https://github.com/lra-cloud-ops/aws-devops-agent"
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem; background: #202124; color: #FFFFFF; padding: 0.625rem 1.25rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
              class="btn-premium"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                ></path></svg
              >
              Ver en GitHub
            </a>
          </div>
        </div>

        <div
          style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; min-width: 240px;"
        >
          {
            [
              { value: '24', label: 'Servicios AWS' },
              { value: '31', label: 'Tools boto3' },
              { value: '593', label: 'Líneas de código' },
              { value: 'IA', label: 'Modelo' },
            ].map(({ value, label }) => (
              <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1rem; text-align: center;">
                <div style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; color: var(--color-primary); line-height: 1;">
                  {value}
                </div>
                <div style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--color-text-secondary); margin-top: 0.25rem;">
                  {label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- CÓMO FUNCIONA -->
  <section
    style="background: var(--color-bg); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
    data-animate="fade-up"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;"
        class="two-col-grid"
      >
        <div>
          <p
            style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;"
          >
            Cómo funciona
          </p>
          <h2
            style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 1rem; line-height: 1.2;"
          >
            Preguntas. La IA decide. AWS responde.
          </h2>
          <p
            style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 1.5rem;"
          >
            Describes lo que necesitas en lenguaje natural. Un modelo de IA
            entra en un bucle de tool-use — selecciona la función boto3
            correcta, la ejecuta contra tu cuenta AWS y devuelve una respuesta
            estructurada.
          </p>

          <div style="display: flex; flex-direction: column; gap: 1rem;">
            {
              [
                {
                  step: '01',
                  title: 'Preguntas',
                  desc: 'Escribe en español o inglés natural. No se requiere sintaxis de CLI.',
                },
                {
                  step: '02',
                  title: 'La IA selecciona',
                  desc: 'El modelo elige entre 31 funciones respaldadas por boto3 según tu intención.',
                },
                {
                  step: '03',
                  title: 'AWS ejecuta',
                  desc: 'La función se ejecuta contra tu cuenta real. Datos reales, respuesta real.',
                },
              ].map(({ step, title, desc }) => (
                <div style="display: flex; gap: 1rem; align-items: start;">
                  <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-primary); background: var(--color-primary-light); padding: 0.25rem 0.5rem; border-radius: var(--radius-sm); flex-shrink: 0; margin-top: 2px;">
                    {step}
                  </span>
                  <div>
                    <p style="font-family: var(--font-display); font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.25rem;">
                      {title}
                    </p>
                    <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.5;">
                      {desc}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Terminal -->
        <div
          style="background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; font-family: var(--font-mono); font-size: 0.8125rem; line-height: 1.9; color: var(--color-text-secondary);"
        >
          <div
            style="color: var(--color-text-muted); font-style: italic; margin-bottom: 0.75rem;"
          >
            # aws-devops-agent · bucle de tool-use IA
          </div>
          <div style="margin-bottom: 0.75rem;">
            <span style="color: var(--color-text-secondary);">Tu:</span>
            <span style="color: var(--color-text); font-weight: 500;">
              ¿Qué instancias EC2 están corriendo?</span
            >
          </div>
          <div style="margin-bottom: 0.25rem;">
            <span style="color: var(--color-primary); font-weight: 600;">IA</span>
            <span style="color: var(--color-text-secondary);"> → calling list_ec2_instances()</span>
          </div>
          <div
            style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0.75rem; margin-bottom: 0.75rem;"
          >
            <div style="color: var(--color-success);">
              i-0a1b2c3d · t3.medium · running · prod-api
            </div>
            <div style="color: var(--color-success);">
              i-0e4f5a6b · t3.small · running · staging
            </div>
          </div>
          <div style="margin-bottom: 0.75rem;">
            <span style="color: var(--color-text-secondary);">Tu:</span>
            <span style="color: var(--color-text); font-weight: 500;">
              ¿Hay security groups peligrosos?</span
            >
          </div>
          <div style="margin-bottom: 0.25rem;">
            <span style="color: var(--color-primary); font-weight: 600;">IA</span>
            <span style="color: var(--color-text-secondary);">
              → calling check_security_groups()</span
            >
          </div>
          <div
            style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0.75rem;"
          >
            <div style="color: var(--color-success);">✓ No critical 0.0.0.0/0 rules</div>
            <div style="color: var(--color-warning);">⚠ sg-0a1b: port 22 open — review</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS AWS -->
  <section
    style="background: var(--color-bg-soft); padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
    data-animate="fade-up"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Cobertura
      </p>
      <h2
        style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: var(--color-text); margin-bottom: 2rem;"
      >
        24 servicios AWS
      </h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        {
          [
            'EC2',
            'S3',
            'RDS',
            'EKS',
            'ECS',
            'Lambda',
            'IAM',
            'SNS',
            'SQS',
            'CloudFormation',
            'Route53',
            'CloudWatch',
            'ALB/ELB',
            'ECR',
            'DynamoDB',
            'ElastiCache',
            'API Gateway',
            'CodePipeline',
            'CodeBuild',
            'CloudFront',
            'SSM',
            'EventBridge',
            'GuardDuty',
            'Cost Explorer',
          ].map((service) => (
            <span style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-text); background: var(--color-bg); border: 1px solid var(--color-border); padding: 0.375rem 0.75rem; border-radius: var(--radius-sm);">
              {service}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section
    style="background: var(--color-bg); padding: 3rem 1.5rem; text-align: center;"
    data-animate="fade-up"
  >
    <div style="max-width: 560px; margin: 0 auto;">
      <h2
        style="font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--color-text); margin-bottom: 1rem;"
      >
        Explorar el código
      </h2>
      <p
        style="font-family: var(--font-body); font-size: 1rem; color: var(--color-text-secondary); margin-bottom: 2rem;"
      >
        593 líneas. Un archivo. Tool-use real con IA.
      </p>
      <a
        href="https://github.com/lra-cloud-ops/aws-devops-agent"
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-weight: 600; text-decoration: none;"
        class="btn-premium"
      >
        Ver en GitHub →
      </a>
    </div>
  </section>

  <!-- ECOSISTEMA -->
  <section style="background:var(--color-bg-soft);padding:3rem 1.5rem;border-top:1px solid #DADCE0;">
    <div style="max-width:1280px;margin:0 auto;">
      <p style="font-family:var(--font-body);font-size:0.75rem;font-weight:600;color:var(--color-primary);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.5rem;">Ecosistema</p>
      <h2 style="font-family:var(--font-display);font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:700;color:var(--color-text);margin-bottom:0.5rem;">Rol en la plataforma</h2>
      <p style="font-family:var(--font-body);font-size:1rem;color:var(--color-text-secondary);margin-bottom:2rem;max-width:640px;">aws-devops-agent es un proyecto Lab que explora operaciones cloud con IA — el patrón de tool-use evolucionó hasta la arquitectura multi-agente de lra-ai-platform.</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="grid-2">
        {[
          { action:'Consulta infraestructura de', target:'aws-terraform-devops', desc:'Lee recursos EC2, EKS, RDS e IAM aprovisionados por los módulos Terraform.', href:'/es/proyectos/aws-terraform-devops' },
          { action:'Predecesor de', target:'lra-ai-platform', desc:'El patrón de agente único con tool-use evolucionó a la arquitectura gobernada de 8 agentes de lra-ai-platform.', href:'/es/proyectos/lra-ai-platform' },
        ].map(({ action, target, desc, href }) => (
          <div style="background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:1.25rem;">
            <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
              <span style="font-family:var(--font-body);font-size:0.8125rem;color:var(--color-text-muted);">{action}</span>
              <a href={href} style="font-family:var(--font-mono);font-size:0.8125rem;font-weight:600;color:var(--color-primary);text-decoration:none;">{target} →</a>
            </div>
            <p style="font-family:var(--font-body);font-size:0.875rem;color:var(--color-text-secondary);margin:0;line-height:1.6;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  @media (max-width: 767px) {
    .hero-project-grid {
      grid-template-columns: 1fr !important;
    }
    .two-col-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
