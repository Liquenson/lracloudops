---
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/layout/Header.astro'
import Footer from '../../../components/layout/Footer.astro'
import { getTagClass } from '../../../lib/tagColors'
---

<Layout
  title="k8s-on-premise — LRA CloudOps"
  description="Clúster Kubernetes multi-nodo desde cero con kubeadm. 1 master + 2 workers sobre Vagrant/VirtualBox. Calico CNI, NGINX Ingress, Helm, GitOps con ArgoCD."
  lang="es"
>
  <Header lang="es" currentPath={Astro.url.pathname} />

  <!-- HERO -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem;">
        <a href="/es/" style="color: #5F6368; text-decoration: none;">Inicio</a>
        <span style="color: #DADCE0;">/</span>
        <a href="/es/proyectos" style="color: #5F6368; text-decoration: none;">Proyectos</a>
        <span style="color: #DADCE0;">/</span>
        <span style="color: #202124; font-weight: 500;">k8s-on-premise</span>
      </div>

      <div style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;" class="hero-project-grid">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E6F4EA; color: #137333; padding: 0.25rem 0.75rem; border-radius: 4px; font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;">
            <span style="width: 6px; height: 6px; background: #137333; border-radius: 50%;"></span>
            Activo
          </div>

          <h1 style="font-family: 'Red Hat Mono', monospace; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;">k8s-on-premise<span style="font-family:'Red Hat Mono',monospace;font-size:0.75rem;font-weight:600;color:#1A73E8;background:#E8F0FE;border:1px solid #1A73E8;padding:0.25rem 0.75rem;border-radius:4px;margin-left:1rem;">Soporte</span></h1>
          <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; line-height: 1.7; max-width: 620px; margin-bottom: 1.5rem;">
            Clúster Kubernetes multi-nodo construido desde cero con kubeadm. Ni k3s. Ni minikube. Un control-plane real con 2 workers sobre Vagrant/VirtualBox — Calico CNI, NGINX Ingress, add-ons de Helm y una demo de ArgoCD GitOps funcionando.
          </p>

          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;">
            {['kubeadm', 'Calico CNI', 'NGINX Ingress', 'Helm', 'ArgoCD', 'Vagrant', 'VirtualBox', 'Metrics Server'].map(tag => (
              <span class={getTagClass(tag)} style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.2rem 0.625rem; border-radius: 4px;">{tag}</span>
            ))}
          </div>

          <a href="https://github.com/lra-cloud-ops/k8s-on-premise" target="_blank" rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.5rem; background: #202124; color: #FFFFFF; padding: 0.625rem 1.25rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; text-decoration: none;"
            class="btn-premium"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            Ver en GitHub
          </a>
        </div>

        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; min-width: 240px;">
          {[
            { value: '3', label: 'Nodos' },
            { value: '6', label: 'Scripts' },
            { value: '25', label: 'Commits' },
            { value: 'Calico', label: 'CNI' },
          ].map(({ value, label }) => (
            <div style="background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 8px; padding: 1rem; text-align: center;">
              <div style="font-family: 'Red Hat Display', sans-serif; font-size: 2rem; font-weight: 900; color: #1A73E8; line-height: 1;">{value}</div>
              <div style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #5F6368; margin-top: 0.25rem;">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ARQUITECTURA DEL CLÚSTER -->
  <section style="background: #FFFFFF; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;" data-animate="fade-up">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">Arquitectura</p>
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #202124; margin-bottom: 2rem;">Topología del clúster</h2>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem;" class="nodes-grid" data-animate="stagger">
        {[
          {
            name: 'control-plane',
            ip: '192.168.56.10',
            color: '#1A73E8',
            components: ['kube-apiserver', 'etcd', 'kube-scheduler', 'controller-manager', 'CoreDNS'],
          },
          {
            name: 'worker-1',
            ip: '192.168.56.11',
            color: '#137333',
            components: ['kubelet', 'containerd', 'Calico CNI', 'ArgoCD', 'kube-proxy'],
          },
          {
            name: 'worker-2',
            ip: '192.168.56.12',
            color: '#137333',
            components: ['kubelet', 'containerd', 'Calico CNI', 'NGINX Ingress', 'kube-proxy'],
          },
        ].map(node => (
          <div style={`background: #F8F9FA; border: 1px solid #DADCE0; border-top: 3px solid ${node.color}; border-radius: 8px; padding: 1.5rem;`} class="card-premium" data-animate-child>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
              <h3 style="font-family: 'Red Hat Mono', monospace; font-size: 0.9375rem; font-weight: 700; color: #202124;">{node.name}</h3>
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; color: #5F6368; background: #FFFFFF; border: 1px solid #DADCE0; padding: 0.125rem 0.5rem; border-radius: 3px;">{node.ip}</span>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.375rem;">
              {node.components.map(comp => (
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                  <span style={`width: 6px; height: 6px; border-radius: 50%; background: ${node.color}; flex-shrink: 0;`}></span>
                  <span style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #5F6368;">{comp}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Bootstrap steps -->
      <div style="background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px; padding: 1.5rem;">
        <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 1rem;">Secuencia de bootstrap — 6 scripts idempotentes (set -euo pipefail)</p>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;" class="bootstrap-grid">
          {[
            { step: '01', name: '01-prerequisites.sh', desc: 'Deshabilita swap, configura módulos del kernel, sysctl' },
            { step: '02', name: '02-container-runtime.sh', desc: 'Instala containerd, configura el cgroup driver' },
            { step: '03', name: '03-kubernetes.sh', desc: 'Instala kubeadm, kubelet, kubectl' },
            { step: '04', name: '04-init-master.sh', desc: 'kubeadm init, configura kubectl, aplica Calico' },
            { step: '05', name: '05-join-workers.sh', desc: 'Genera el token, une los workers al clúster' },
            { step: '06', name: '06-addons.sh', desc: 'Instala Helm, NGINX Ingress, Metrics Server, ArgoCD' },
          ].map(({ step, name, desc }) => (
            <div style="display: flex; gap: 0.75rem; align-items: start;">
              <span style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 700; color: #1A73E8; background: #E8F0FE; padding: 0.125rem 0.375rem; border-radius: 3px; flex-shrink: 0;">{step}</span>
              <div>
                <p style="font-family: 'Red Hat Mono', monospace; font-size: 0.75rem; font-weight: 600; color: #202124; margin-bottom: 0.125rem;">{name}</p>
                <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; color: #5F6368;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: #F8F9FA; padding: 3rem 1.5rem; text-align: center;" data-animate="fade-up">
    <div style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #202124; margin-bottom: 1rem;">Bootstrap completo con kubeadm. Sin atajos.</h2>
      <p style="font-family: 'Red Hat Text', sans-serif; font-size: 1rem; color: #5F6368; margin-bottom: 2rem;">6 scripts. 3 nodos. Sync GitOps con ArgoCD habilitado.</p>
      <a href="https://github.com/lra-cloud-ops/k8s-on-premise" target="_blank" rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; text-decoration: none;"
        class="btn-premium"
      >
        Ver en GitHub →
      </a>
    </div>
  </section>

  <!-- ECOSISTEMA -->
  <section style="background:#F8F9FA;padding:3rem 1.5rem;border-top:1px solid #DADCE0;">
    <div style="max-width:1280px;margin:0 auto;">
      <p style="font-family:'Red Hat Text',sans-serif;font-size:0.75rem;font-weight:600;color:#1A73E8;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.5rem;">Ecosistema</p>
      <h2 style="font-family:'Red Hat Display',sans-serif;font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:700;color:#202124;margin-bottom:0.5rem;">Rol en la plataforma</h2>
      <p style="font-family:'Red Hat Text',sans-serif;font-size:1rem;color:#5F6368;margin-bottom:2rem;max-width:640px;">k8s-on-premise es la capa de runtime — demuestra que la plataforma funciona por debajo de la nube gestionada, desde bootstrap kubeadm hasta GitOps con ArgoCD.</p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="grid-2">
        {[
          { action:'Monitorizado por', target:'lra-ai-platform', desc:'SREAgent verifica el estado del clúster, nodos y sincronización GitOps.', href:'/es/proyectos/lra-ai-platform' },
          { action:'Complementa', target:'aws-terraform-devops', desc:'Kubernetes bare-metal vs EKS gestionado — los mismos patrones GitOps en distintas capas de despliegue.', href:'/es/proyectos/aws-terraform-devops' },
        ].map(({ action, target, desc, href }) => (
          <div style="background:#FFFFFF;border:1px solid #DADCE0;border-radius:8px;padding:1.25rem;">
            <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
              <span style="font-family:'Red Hat Text',sans-serif;font-size:0.8125rem;color:#9AA0A6;">{action}</span>
              <a href={href} style="font-family:'Red Hat Mono',monospace;font-size:0.8125rem;font-weight:600;color:#1A73E8;text-decoration:none;">{target} →</a>
            </div>
            <p style="font-family:'Red Hat Text',sans-serif;font-size:0.875rem;color:#5F6368;margin:0;line-height:1.6;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
@media (max-width: 1199px) {
  .nodes-grid { grid-template-columns: 1fr !important; }
  .bootstrap-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
@media (max-width: 767px) {
  .hero-project-grid { grid-template-columns: 1fr !important; }
  .bootstrap-grid { grid-template-columns: 1fr !important; }
}
</style>
