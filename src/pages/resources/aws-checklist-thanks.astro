---
import Layout from '../../layouts/Layout.astro'

const sections = [
  {
    id: 'iam',
    title: 'IAM & Access Control',
    color: '#7C3AED',
    bg: 'rgba(124,58,237,0.08)',
    border: 'rgba(124,58,237,0.2)',
    items: [
      { check: 'Root account MFA enabled and root access keys deleted', remediation: 'Enable MFA in IAM console. Delete any root access keys.' },
      { check: 'All IAM users have MFA enabled', remediation: 'Enforce via IAM policy condition: `aws:MultiFactorAuthPresent`.' },
      { check: 'Roles use least-privilege IAM policies (no *:*)', remediation: 'Use AWS Access Analyzer to generate scoped policies from CloudTrail.' },
      { check: 'No long-lived IAM access keys (rotate or delete)', remediation: 'Audit with `aws iam generate-credential-report`. Rotate keys older than 90 days.' },
      { check: 'OIDC federation used for CI/CD (GitHub Actions, etc.)', remediation: 'Replace static AWS keys with GitHub OIDC + IAM role assumption.' },
      { check: 'Service accounts use IRSA (not EC2 instance profiles)', remediation: 'Associate IAM roles with Kubernetes service accounts via IRSA.' },
      { check: 'AWS Organizations SCPs enforce guardrails', remediation: 'Create SCPs to deny: disable CloudTrail, leave Org, create root access keys.' },
      { check: 'IAM Permission Boundaries set for delegated admin accounts', remediation: 'Apply permission boundary policies to IAM entities in member accounts.' },
    ],
  },
  {
    id: 'networking',
    title: 'VPC & Networking',
    color: '#0284C7',
    bg: 'rgba(2,132,199,0.08)',
    border: 'rgba(2,132,199,0.2)',
    items: [
      { check: 'Compute runs in private subnets', remediation: 'Move EC2/ECS/EKS nodes to private subnets. Use NAT Gateway or VPC endpoints for egress.' },
      { check: 'Security groups follow least-privilege (no 0.0.0.0/0 ingress on port 22/3389)', remediation: 'Restrict SSH/RDP to bastion host or use AWS Systems Manager Session Manager.' },
      { check: 'VPC Flow Logs enabled and shipped to CloudWatch / S3', remediation: '`aws ec2 create-flow-logs --resource-type VPC --traffic-type ALL`.' },
      { check: 'NACLs configured as secondary defense layer', remediation: 'Block unused port ranges at NACL level in addition to security groups.' },
      { check: 'VPC endpoints for S3 and DynamoDB (avoid NAT for AWS traffic)', remediation: 'Create Gateway VPC endpoints — zero cost, eliminates NAT charge for these services.' },
      { check: 'No overlapping CIDR ranges between VPCs / on-prem', remediation: 'Plan CIDR allocation before peering. Use Transit Gateway for complex topologies.' },
      { check: 'DNS resolution and hostnames enabled in VPC', remediation: 'Required for EKS CoreDNS and service discovery to work correctly.' },
    ],
  },
  {
    id: 'eks',
    title: 'EKS & Compute',
    color: '#0A2540',
    bg: 'rgba(10,37,64,0.06)',
    border: 'rgba(10,37,64,0.15)',
    items: [
      { check: 'EKS control plane logs enabled (api, audit, authenticator)', remediation: 'Enable via eksctl or Terraform `enabled_cluster_log_types`.' },
      { check: 'Managed node groups used (not self-managed)', remediation: 'Managed node groups handle AMI patching and draining automatically.' },
      { check: 'Nodes run in private subnets with NAT egress', remediation: 'Nodes must reach ECR, S3, and EKS API — NAT Gateway or VPC endpoints required.' },
      { check: 'PodDisruptionBudgets defined for all critical workloads', remediation: 'Set `minAvailable: 1` or `maxUnavailable: 1` to protect during node drains.' },
      { check: 'Resource requests and limits set on all containers', remediation: 'Without limits, noisy-neighbor containers cause OOMKills on other pods.' },
      { check: 'Cluster Autoscaler or Karpenter configured', remediation: 'Karpenter is preferred for faster provisioning and cost-optimized instance selection.' },
      { check: 'RBAC roles follow least-privilege (no cluster-admin for apps)', remediation: 'Audit: `kubectl get clusterrolebindings -o json | jq` for cluster-admin subjects.' },
      { check: 'Container images scanned before deployment', remediation: 'Enable ECR image scanning on push. Block images with CRITICAL vulnerabilities in CI.' },
      { check: 'Network policies defined (default-deny + explicit allow)', remediation: 'Install Calico or use EKS native NetworkPolicy support. Start with deny-all.' },
    ],
  },
  {
    id: 'observability',
    title: 'Observability',
    color: '#047857',
    bg: 'rgba(4,120,87,0.08)',
    border: 'rgba(4,120,87,0.2)',
    items: [
      { check: 'CloudWatch Alarms on p99 latency, error rate, and saturation', remediation: 'Follow USE (Utilization, Saturation, Errors) method per resource type.' },
      { check: 'Structured JSON logging from all services', remediation: 'JSON logs enable CloudWatch Insights queries and log-based metrics.' },
      { check: 'Distributed tracing implemented (AWS X-Ray or OpenTelemetry)', remediation: 'Instrument SDKs in application code. Visualize service maps in X-Ray console.' },
      { check: 'Dashboard per service showing RED metrics (Rate, Errors, Duration)', remediation: 'Create CloudWatch dashboards or use Grafana with CloudWatch data source.' },
      { check: 'On-call runbook linked from every alarm', remediation: 'Each alarm description should contain a runbook URL as a field.' },
      { check: 'Log retention policies configured (not indefinite)', remediation: 'Set retention (e.g. 30/90/365 days) on every CloudWatch Log Group.' },
      { check: 'CloudTrail enabled in all regions with multi-region trail', remediation: '`aws cloudtrail create-trail --is-multi-region-trail`. Send to S3 with integrity validation.' },
      { check: 'Alerting tested: verify alerts fire and route to correct channel', remediation: 'Run a chaos drill (e.g. kill pods, spike CPU) and confirm alert fires within SLO.' },
    ],
  },
  {
    id: 'cost',
    title: 'Cost Optimization',
    color: '#B45309',
    bg: 'rgba(180,83,9,0.08)',
    border: 'rgba(180,83,9,0.2)',
    items: [
      { check: 'AWS Cost Anomaly Detection configured with email/SNS notification', remediation: 'Set up a cost monitor per service. Alert threshold: 20% above baseline.' },
      { check: 'Reserved Instances or Savings Plans purchased for stable workloads', remediation: '1-year Compute Savings Plans for EKS nodes yield ~40% savings over On-Demand.' },
      { check: 'S3 Lifecycle policies defined (tiering to IA/Glacier)', remediation: 'Transition objects to S3-IA after 30 days, Glacier after 90 days where applicable.' },
      { check: 'Compute rightsizing review done (Compute Optimizer)', remediation: 'Enable AWS Compute Optimizer. Review recommendations for EC2, ECS, Lambda.' },
      { check: 'Idle or unattached resources identified and terminated', remediation: 'Look for unattached EBS volumes, idle load balancers, and unused Elastic IPs.' },
      { check: 'Data transfer costs reviewed (inter-AZ, cross-region)', remediation: 'Use VPC endpoints for S3/DynamoDB. Co-locate services in same AZ where latency-sensitive.' },
    ],
  },
  {
    id: 'security',
    title: 'Security Hardening',
    color: '#BE123C',
    bg: 'rgba(190,18,60,0.08)',
    border: 'rgba(190,18,60,0.2)',
    items: [
      { check: 'Amazon GuardDuty enabled in all regions', remediation: 'Enable via AWS Organizations for automatic coverage of all member accounts.' },
      { check: 'AWS Config enabled with required rules (e.g. encrypted EBS, public S3 check)', remediation: 'Enable Config recorder. Attach managed rules: `encrypted-volumes`, `s3-bucket-public-read-prohibited`.' },
      { check: 'Secrets Manager (or Parameter Store) used — no secrets in env vars or code', remediation: 'Audit for secret patterns in code: `git secrets --scan`. Rotate any exposed secrets immediately.' },
      { check: 'S3 buckets: public access blocked at account level', remediation: 'Enable S3 Block Public Access at account level in S3 > Block Public Access settings.' },
      { check: 'ECR image scanning on push enabled', remediation: 'Enable in ECR repository settings. Integrate scan results into CI/CD gate.' },
      { check: 'Encryption at rest enabled for EBS, RDS, S3, and DynamoDB', remediation: 'Enable AWS-managed or CMK encryption. Existing unencrypted volumes require snapshot + re-creation.' },
      { check: 'AWS WAF attached to public-facing ALBs', remediation: 'Enable AWS Managed Rules for OWASP protection. Add rate-based rules to prevent DDoS.' },
    ],
  },
]
---

<Layout
  titulo="AWS Production Readiness Checklist — Your Copy"
  descripcion="Your 45-point AWS production readiness checklist from LRA Cloud Operations. Covers IAM, networking, EKS, observability, cost optimization and security hardening."
>
  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none opacity-30"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-16 sm:py-20 text-center">
      <div
        class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-6"
        style="background: rgba(16,185,129,0.2); border: 1px solid rgba(16,185,129,0.3);"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#6EE7B7;" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h1
        class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
        style="letter-spacing: -0.02em;"
      >
        Your checklist is ready
      </h1>
      <p class="text-base mb-8" style="color: rgba(147,184,255,0.75);">
        Bookmark this page or use <kbd class="px-2 py-0.5 rounded text-sm font-mono" style="background:rgba(255,255,255,0.1); color:white;">Ctrl+P</kbd> to save as PDF.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <button
          onclick="window.print()"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all hover:-translate-y-px"
          style="background:white; color:#0A2540; box-shadow:0 4px 16px rgba(0,0,0,0.2);"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          Save as PDF
        </button>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all hover:-translate-y-px"
          style="background:rgba(30,111,255,0.2); color:#93b8ff; border:1px solid rgba(30,111,255,0.3);"
        >
          Need help implementing this? →
        </a>
      </div>
    </div>
  </section>

  <!-- CHECKLIST CONTENT -->
  <main id="main-content">
    <div class="max-w-4xl mx-auto px-5 sm:px-6 py-14 space-y-10">

      <!-- Quick jump -->
      <div class="rounded-2xl p-5" style="background:#F8FAFC; border:1px solid #E2E8F0;">
        <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color:#94A3B8;">Jump to section</p>
        <div class="flex flex-wrap gap-2">
          {sections.map(s => (
            <a
              href={`#${s.id}`}
              class="text-xs font-semibold px-3 py-1.5 rounded-full transition-colors hover:text-white"
              style={`background:${s.bg}; color:${s.color}; border:1px solid ${s.border};`}
            >
              {s.title}
            </a>
          ))}
        </div>
      </div>

      {sections.map(section => (
        <section id={section.id}>
          <div class="flex items-center gap-3 mb-5">
            <div
              class="w-2 h-8 rounded-full flex-shrink-0"
              style={`background:${section.color};`}
              aria-hidden="true"
            ></div>
            <h2 class="text-xl font-bold" style={`color:${section.color};`}>
              {section.title}
            </h2>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full ml-auto" style={`background:${section.bg}; color:${section.color}; border:1px solid ${section.border};`}>
              {section.items.length} items
            </span>
          </div>

          <div class="space-y-3">
            {section.items.map((item, idx) => (
              <div
                class="rounded-xl p-4 flex gap-4"
                style={`background:${section.bg}; border:1px solid ${section.border};`}
              >
                <div class="flex-shrink-0 mt-0.5">
                  <div
                    class="w-6 h-6 rounded-full border-2 flex items-center justify-center text-xs font-bold"
                    style={`border-color:${section.color}; color:${section.color};`}
                    aria-label={`Checkpoint ${idx + 1}`}
                  >
                    {idx + 1}
                  </div>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-semibold mb-1" style="color:#0F172A;">{item.check}</p>
                  <p class="text-xs" style="color:#64748b;">
                    <span class="font-semibold" style={`color:${section.color};`}>Fix: </span>
                    {item.remediation}
                  </p>
                </div>
                <div class="flex-shrink-0 ml-auto">
                  <div
                    class="w-5 h-5 rounded border-2 mt-0.5 print:border-gray-400"
                    style="border-color:#CBD5E1;"
                    aria-label="Checkbox — mark when complete"
                    role="presentation"
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}

      <!-- CTA bottom -->
      <div
        class="rounded-2xl p-8 text-center"
        style="background: linear-gradient(135deg, #0A2540 0%, #0F3460 100%); border: 1px solid rgba(30,111,255,0.2);"
      >
        <h3 class="text-xl font-bold text-white mb-2">Need help running through this?</h3>
        <p class="text-sm mb-6" style="color:rgba(147,184,255,0.8);">
          LRA Cloud Operations runs this checklist on every engagement and
          delivers a remediation plan with prioritized Terraform modules.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 text-sm font-semibold text-white px-6 py-3 rounded-xl transition-all hover:-translate-y-px"
          style="background:#1E6FFF; box-shadow:0 4px 16px rgba(30,111,255,0.4);"
        >
          Schedule a free 30-min assessment →
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  @media print {
    header, footer, button, nav { display: none !important; }
    body { background: white; }
    section { break-inside: avoid; }
  }
</style>
