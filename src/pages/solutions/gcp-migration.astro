---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Google Cloud Migration — LRA Cloud Operations"
  descripcion="Migrate your infrastructure to Google Cloud with GKE, Cloud Run and modular Terraform. Global scalability, native observability and multi-cloud strategy."
>
  <!-- Hero -->
  <section
    style="background: linear-gradient(135deg, #0A2540 0%, #0d2a3a 100%); padding: 100px 24px 80px;"
  >
    <div class="max-w-4xl mx-auto text-center">
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8"
        style="background: rgba(66,133,244,0.2); color: #93C5FD; border: 1px solid rgba(66,133,244,0.35);"
      >
        Solution · Google Cloud Migration
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6 leading-tight">
        GCP infrastructure with<br />native global scalability.
      </h1>
      <p
        class="text-lg sm:text-xl max-w-2xl mx-auto mb-10"
        style="color: rgba(148,163,184,0.9);"
      >
        Migration to Google Cloud with GKE, Cloud Run, modular Terraform and
        native observability with Cloud Operations Suite. Global scalability
        without operational complexity.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/en/contact"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-white transition-all hover:-translate-y-px"
          style="background: #4285F4; box-shadow: 0 4px 20px rgba(66,133,244,0.4);"
        >
          Start GCP migration
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
        <a
          href="/en/projects"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl font-semibold transition-all hover:bg-white/10"
          style="color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.15);"
        >
          View use cases
        </a>
      </div>
    </div>
  </section>

  <!-- Key points -->
  <section style="background: #F8FAFC; padding: 80px 24px;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold mb-4" style="color: #0A2540;">
          Production-ready GCP infrastructure
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          Google Cloud as a global scalability platform with managed Kubernetes,
          serverless and native observability from day one.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {
          [
            {
              title: 'Modular Terraform for GCP',
              desc: 'Terraform modules for GKE, Cloud SQL, Cloud Storage, VPC and IAM. Remote state in Cloud Storage with Firestore locking. Project organization with folder hierarchy and hierarchical IAM.',
              icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
            },
            {
              title: 'GKE Autopilot and Standard',
              desc: 'GKE clusters in Autopilot mode for minimal management or Standard for maximum control. Workload Identity for secure GCP API access without service account keys. Multi-zone by default.',
              icon: 'M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9',
            },
            {
              title: 'Cloud Run for serverless workloads',
              desc: 'Deploy containerized applications on Cloud Run with automatic scale-to-zero. Ideal for APIs, microservices and batch jobs. Integrated with Cloud Build for complete CI/CD.',
              icon: 'M13 10V3L4 14h7v7l9-11h-7z',
            },
            {
              title: 'Cloud Operations Suite',
              desc: 'Centralized metrics, logs and traces in Cloud Monitoring and Cloud Logging. Dashboards and alerts from first deploy. Integration with Prometheus and Grafana for unified ecosystem.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
          ].map(({ title, desc, icon }) => (
            <div
              class="bg-white rounded-2xl p-7"
              style="border: 1px solid rgba(15,23,42,0.06); box-shadow: 0 2px 12px rgba(15,23,42,0.04);"
            >
              <div
                class="w-10 h-10 rounded-xl flex items-center justify-center mb-5"
                style="background: rgba(66,133,244,0.08);"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  style="color: #4285F4;"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={icon}
                  />
                </svg>
              </div>
              <h3 class="text-lg font-semibold mb-3" style="color: #0A2540;">
                {title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">
                {desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: #0A2540; padding: 80px 24px;">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">
        Ready to migrate to Google Cloud?
      </h2>
      <p class="text-lg mb-10" style="color: rgba(148,163,184,0.85);">
        Schedule a 30-minute architecture review. We assess your current state
        and design a GCP strategy tailored to your workload.
      </p>
      <a
        href="/en/contact"
        class="inline-flex items-center gap-2 px-10 py-4 rounded-xl font-semibold text-white transition-all hover:-translate-y-px"
        style="background: #4285F4; box-shadow: 0 4px 24px rgba(66,133,244,0.45);"
      >
        Schedule architecture review
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
        >
      </a>
    </div>
  </section>
</Layout>
