---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Automatizamos tu infraestructura en la nube"
  descripcion="Soluciones de Cloud Operations para equipos que quieren moverse rápido sin romper nada."
>
  <section class="max-w-5xl mx-auto px-6 py-24 text-center">
    <span class="inline-flex items-center gap-2 text-xs font-medium text-teal-700 bg-teal-50 px-3 py-1 rounded-full mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
      Cloud · DevOps · Automatización
    </span>
    <h1 class="text-4xl sm:text-5xl font-medium text-gray-900 leading-tight max-w-2xl mx-auto mb-6">
      Automatizamos y escalamos tu
      <span class="text-teal-600"> infraestructura en la nube</span>
    </h1>
    <p class="text-lg text-gray-500 max-w-xl mx-auto mb-10">
      Soluciones de Cloud Operations para equipos que quieren moverse rápido sin romper nada.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/servicios" class="bg-teal-600 text-white text-sm font-medium px-6 py-3 rounded-md hover:bg-teal-700 transition-colors">
        Ver servicios
      </a>
      <a href="/blog" class="border border-gray-200 text-gray-700 text-sm px-6 py-3 rounded-md hover:bg-gray-50 transition-colors">
        Leer el blog
      </a>
    </div>
  </section>
</Layout>
