---
import TechIcon from '../components/TechIcon.astro'
import FlowDiagram from '../components/FlowDiagram.astro'
import ProjectsGrid from '../components/ProjectsGrid.astro'
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3)

const professionalServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://lracloudops.com/en/#service',
  name: 'LRA Cloud Operations',
  url: 'https://lracloudops.com/en/',
  description:
    'Platform Engineering consultancy specialized in AWS, Kubernetes, Terraform and GitOps. Infrastructure designed for reliability and automated delivery.',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: ['Spain', 'United States', 'Latin America', 'European Union'],
  serviceType: [
    'Platform Engineering',
    'Cloud Infrastructure',
    'DevOps Automation',
    'Kubernetes',
    'Observability & SRE',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Las Palmas de Gran Canaria',
    addressCountry: 'ES',
  },
  sameAs: [
    'https://github.com/lra-cloud-ops',
    'https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/',
  ],
}
---

<Layout
  titulo="Platform Engineering & DevOps Consulting | LRA Cloud Operations"
  descripcion="Expert DevOps team specializing in Kubernetes, AWS infrastructure and GitOps. We design and operate cloud-native platforms that scale."
  keywords="DevOps consulting Spain, Kubernetes consultant AWS, platform engineering consulting, Terraform expert Spain, GitOps implementation, cloud infrastructure team Las Palmas, DevOps freelance España, AWS EKS specialist"
  schema={professionalServiceSchema}
>
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 5. PLATFORM ARCHITECTURE                                            -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    class="py-24 relative overflow-hidden"
    style="background: #0B1220;"
    aria-labelledby="architecture-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none opacity-20"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.15) 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.18) 0%, transparent 70%);"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 animate-fade-up">
        <span
          class="inline-flex items-center text-[10px] font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5"
          style="background: rgba(37,99,235,0.18); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
        >
          Platform Architecture
        </span>
        <h2
          id="architecture-heading"
          class="text-4xl sm:text-5xl font-bold text-white mt-2 mb-5"
          style="letter-spacing: -0.025em;"
        >
          The platform stack,<br />layer by layer.
        </h2>
        <p
          class="text-lg max-w-2xl mx-auto"
          style="color: rgba(148,163,184,0.8);"
        >
          Six layers that form an auditable, repeatable infrastructure operating
          model. Each one is version-controlled and recoverable.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Architecture stack diagram -->
        <div
          class="animate-fade-left"
          role="img"
          aria-label="Architecture layers: AWS, Terraform, Kubernetes v1.31, ArgoCD + Jenkins, Flask Python Claude AI, CloudWatch + Prometheus"
        >
          <div class="space-y-0">
            {
              [
                {
                  label: 'AWS',
                  sub: 'EKS · RDS Multi-AZ · ECR · CloudTrail · IAM OIDC',
                  color: '#FF9900',
                  icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
                },
                {
                  label: 'Terraform',
                  sub: 'Modular IaC · S3 Remote State · DynamoDB Lock · Multi-env',
                  color: '#7B42BC',
                  icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
                },
                {
                  label: 'Kubernetes v1.31',
                  sub: 'EKS Production · Bare Metal (kubeadm) · Calico v3.27 · NGINX Ingress',
                  color: '#326CE5',
                  icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
                },
                {
                  label: 'ArgoCD + Jenkins',
                  sub: 'GitOps Auto-sync · Dual CI/CD · SonarCloud Gate · Ansible Config',
                  color: '#EF7B4D',
                  icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
                },
                {
                  label: 'Flask · Python · Claude AI',
                  sub: 'Docker · boto3 · Anthropic API · 25+ AWS Services',
                  color: '#2563EB',
                  icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
                },
                {
                  label: 'CloudWatch + Prometheus',
                  sub: 'CloudTrail Audit · Grafana · Alertmanager · SSM Session Manager',
                  color: '#E5421E',
                  icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
                },
              ].map(({ label, sub, color, icon }, i, arr) => (
                <div>
                  <div
                    class="flex items-center gap-4 p-4 rounded-xl transition-all hover:-translate-x-1 cursor-default"
                    style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);"
                  >
                    <div
                      class="w-10 h-10 flex items-center justify-center rounded-xl flex-shrink-0"
                      style={`background: ${color}22; border: 1px solid ${color}44;`}
                      aria-hidden="true"
                    >
                      <svg
                        class="w-5 h-5"
                        style={`color: ${color};`}
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d={icon}
                        />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-bold text-white">{label}</div>
                      <div
                        class="text-xs mt-0.5"
                        style="color: rgba(148,163,184,0.6);"
                      >
                        {sub}
                      </div>
                    </div>
                    <div
                      class="w-2 h-2 rounded-full flex-shrink-0"
                      style={`background: ${color};`}
                      aria-hidden="true"
                    />
                  </div>
                  {i < arr.length - 1 && (
                    <div
                      class="flex justify-start ml-9 my-1"
                      aria-hidden="true"
                    >
                      <svg
                        width="16"
                        height="20"
                        viewBox="0 0 16 20"
                        fill="none"
                      >
                        <path
                          d="M8 0 L8 14 M4 10 L8 14 L12 10"
                          stroke="#2563EB"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </div>
                  )}
                </div>
              ))
            }
          </div>
        </div>

        <!-- Architecture benefits -->
        <div class="animate-fade-up delay-200">
          <h3 class="text-2xl font-bold text-white mb-8">
            What makes this model work
          </h3>
          <div class="space-y-6">
            {
              [
                {
                  title: 'Immutable infrastructure',
                  desc: 'Every change goes through Terraform and Git. The aws-terraform-devops modules deploy VPC, EKS and RDS with zero manual operations. Remote state in S3 with DynamoDB locking prevents conflicts.',
                  icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
                },
                {
                  title: 'GitOps delivery model',
                  desc: 'ArgoCD uses Git as the single source of truth — k8s-on-premise has auto-sync enabled from Phase 3. gitops-stack uses Jenkins CI with GitHub for full pipeline automation.',
                  icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
                },
                {
                  title: 'Instrumented from day one',
                  desc: 'gitops-stack includes CloudWatch and CloudTrail from first deploy. k8s-on-premise roadmap: Prometheus (Phase 6) and Grafana (Phase 7) before first production workload.',
                  icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
                },
                {
                  title: 'Designed for failure',
                  desc: 'RDS Multi-AZ with automatic failover in aws-terraform-devops. Calico CNI network policies in k8s-on-premise. HPA in the kubernetes roadmap — reliability built in, not bolted on.',
                  icon: 'M13 10V3L4 14h7v7l9-11h-7z',
                },
              ].map(({ title, desc, icon }) => (
                <div class="flex gap-4">
                  <div
                    class="w-9 h-9 flex items-center justify-center rounded-xl flex-shrink-0 mt-0.5"
                    style="background: rgba(37,99,235,0.15); border: 1px solid rgba(37,99,235,0.3);"
                    aria-hidden="true"
                  >
                    <svg
                      class="w-4 h-4"
                      style="color: #60A5FA;"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d={icon}
                      />
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-bold text-white mb-1">{title}</div>
                    <div
                      class="text-sm leading-relaxed"
                      style="color: rgba(148,163,184,0.7);"
                    >
                      {desc}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 4. ENTERPRISE METRICS                                               -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-white" aria-labelledby="metrics-heading">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="text-center mb-14 animate-fade-up">
        <span class="section-label">By the numbers</span>
        <h2
          id="metrics-heading"
          class="text-4xl sm:text-5xl font-bold mt-5 mb-4"
          style="color: #0F172A; letter-spacing: -0.025em;"
        >
          Platform reliability at scale
        </h2>
        <p class="text-lg max-w-xl mx-auto" style="color: #64748B;">
          Real production metrics from infrastructure we design, build and
          operate.
        </p>
      </div>

      <div
        class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-px rounded-2xl overflow-hidden animate-fade-up"
        style="background: #E5E7EB;"
      >
        {
          [
            {
              value: '6+',
              label: 'Open Source Projects',
              sub: 'github.com/lra-cloud-ops',
            },
            {
              value: '18',
              label: 'K8s Roadmap Phases',
              sub: 'k8s-on-premise platform',
            },
            {
              value: '100%',
              label: 'Infrastructure as Code',
              sub: 'Zero manual changes',
            },
            {
              value: '25+',
              label: 'AWS Services',
              sub: 'Via aws-devops-agent',
            },
            {
              value: '4+',
              label: 'Years in Production',
              sub: 'Real environments',
            },
            { value: '24h', label: 'Response Time', sub: 'Support SLA' },
          ].map(({ value, label, sub }) => (
            <div class="flex flex-col items-center justify-center text-center px-6 py-12 bg-white hover:bg-blue-50 transition-colors cursor-default">
              <div
                class="text-3xl sm:text-4xl font-black mb-2 leading-none"
                style="color: #1E6FFF; letter-spacing: -0.04em;"
              >
                {value}
              </div>
              <div class="text-sm font-bold mb-1" style="color: #0A2540;">
                {label}
              </div>
              <div class="text-xs" style="color: #94A3B8;">
                {sub}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 2. TRUST BAR — Technologies                                          -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    style="background: #F8FAFC; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB;"
    aria-label="Technologies we operate in production"
  >
    <div class="max-w-7xl mx-auto px-6 py-16">
      <p
        class="text-center text-[11px] font-bold uppercase tracking-widest mb-12"
        style="color: #94A3B8;"
      >
        Trusted technologies we operate in production
      </p>
      <div class="grid grid-cols-4 sm:grid-cols-5 lg:grid-cols-10 gap-5">
        {
          [
            {
              name: 'AWS',
              path: 'M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z',
            },
            { name: 'Terraform', slug: 'terraform' },
            { name: 'Kubernetes', slug: 'kubernetes' },
            { name: 'Docker', slug: 'docker' },
            { name: 'GitHub Actions', slug: 'githubactions' },
            { name: 'ArgoCD', slug: 'argo' },
            { name: 'Helm', slug: 'helm' },
            { name: 'Jenkins', slug: 'jenkins' },
            { name: 'Ansible', slug: 'ansible' },
            {
              name: 'KinD',
              path: 'M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 004.5 9v.878m13.5-3A2.25 2.25 0 0119.5 9v.878m0 0a2.246 2.246 0 00-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0121 12v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6c0-.98.626-1.813 1.5-2.122',
            },
            {
              name: 'CloudWatch',
              path: 'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605',
            },
            { name: 'Prometheus', slug: 'prometheus' },
            { name: 'Grafana', slug: 'grafana' },
            {
              name: 'Alertmanager',
              path: 'M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0M10.5 8.25h3l-3 4.5h3',
            },
            {
              name: 'CloudTrail',
              path: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
            },
            { name: 'SonarCloud', slug: 'sonarcloud' },
            { name: 'ShellCheck', slug: 'gnubash' },
            { name: 'containerd', slug: 'containerd' },
            { name: 'Vagrant', slug: 'vagrant' },
            { name: 'Linux', slug: 'linux' },
          ].map(({ name, slug, path }) => (
            <div
              class="flex flex-col items-center gap-3 group cursor-default"
              title={name}
            >
              <div
                class="w-14 h-14 flex items-center justify-center rounded-2xl bg-white transition-all group-hover:shadow-md group-hover:border-blue-200"
                style="border: 1px solid #E5E7EB;"
              >
                {slug && (
                  <TechIcon
                    slug={slug}
                    class="w-7 h-7"
                    style="color: #1E6FFF;"
                  />
                )}
                {path && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-7 h-7"
                    style="color: #1E6FFF;"
                    aria-hidden="true"
                  >
                    <path d={path} />
                  </svg>
                )}
              </div>
              <span
                class="text-[11px] font-semibold text-center leading-tight"
                style="color: #64748B;"
              >
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 3. CASE STUDIES PREVIEW                                             -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    class="py-24 bg-white border-t border-gray-100"
    aria-labelledby="case-studies-heading"
  >
    <div class="max-w-7xl mx-auto px-6">
      <div
        class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14"
      >
        <div class="animate-fade-up">
          <span class="section-label">Case Studies</span>
          <h2
            id="case-studies-heading"
            class="text-4xl sm:text-5xl font-bold mt-5"
            style="color: #0F172A; letter-spacing: -0.025em;"
          >
            Production workloads.<br />Documented outcomes.
          </h2>
        </div>
        <a
          href="/projects"
          class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold transition-colors animate-fade"
          style="color: #2563EB;"
        >
          View all projects
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      <ProjectsGrid lang="en" />

      <div class="text-center mt-12">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-sm font-semibold px-7 py-3.5 rounded-xl border transition-all hover:bg-gray-50"
          style="color: #0F172A; border-color: #E5E7EB;"
        >
          View all case studies
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 4. SERVICES OVERVIEW                                                -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    style="background: #F8FAFC; border-top: 1px solid #E5E7EB;"
    aria-labelledby="services-heading"
  >
    <div class="max-w-7xl mx-auto px-6 py-24">
      <div class="text-center mb-16 animate-fade-up">
        <span class="section-label">Services</span>
        <h2
          id="services-heading"
          class="text-4xl sm:text-5xl font-bold mt-5 mb-5"
          style="color: #0F172A; letter-spacing: -0.025em;"
        >
          What we build and operate
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          Six engineering disciplines. One unified platform operating model
          designed for production reliability.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          [
            {
              icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
              title: 'Cloud Infrastructure',
              href: '/cloud-infrastructure',
              desc: 'Codified AWS environments with defined networking, security boundaries and access policies. Terraform modules that can be audited, version-controlled and reproduced across accounts.',
            },
            {
              icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
              title: 'Kubernetes Platforms',
              href: '/platform-engineering',
              desc: 'Production EKS clusters operated as internal platforms. GitOps delivery via ArgoCD. Development teams deploy without raising infrastructure tickets.',
            },
            {
              icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
              title: 'DevOps Automation',
              href: '/devops-automation',
              desc: 'End-to-end pipelines that enforce tests, security scans and policy gates before reaching a cluster. Every release is traceable. Every rollback takes one command.',
            },
            {
              icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
              title: 'Platform Engineering',
              href: '/platform-engineering',
              desc: 'Building internal developer platforms that reduce cognitive load and accelerate delivery for engineering teams, from golden paths to self-service portals.',
