---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3)
---

<Layout
  titulo="Cloud Infrastructure & Platform Engineering"
  descripcion="Cloud infrastructure and platform engineering. Kubernetes, Terraform and AWS — designed for operational reliability and automated delivery."
>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 1. HERO ENTERPRISE                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden hero-gradient" aria-labelledby="hero-heading">

    <!-- Dot grid -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.14) 1px, transparent 1px); background-size: 30px 30px;"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
      style="background: radial-gradient(ellipse 90% 60% at 50% 115%, rgba(37,99,235,0.22) 0%, transparent 65%);"></div>
    <!-- Top edge line -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-px pointer-events-none" aria-hidden="true"
      style="background: linear-gradient(90deg, transparent, rgba(96,165,250,0.4), transparent);"></div>

    <div class="relative max-w-7xl mx-auto px-5 sm:px-6 py-24 sm:py-32 grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-center">

      <!-- Left: Copy -->
      <div class="animate-fade-left">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full mb-8 text-xs font-semibold"
          style="background: rgba(37,99,235,0.15); border: 1px solid rgba(96,165,250,0.3); color: #93C5FD;">
          <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0 animate-pulse-soft" aria-hidden="true"></span>
          Cloud Infrastructure &middot; Platform Engineering
        </div>

        <h1 id="hero-heading"
          class="text-[44px] sm:text-[58px] lg:text-[68px] font-extrabold text-white leading-[1.04] mb-7"
          style="letter-spacing: -0.035em;">
          Platform engineering<br />for infrastructure<br />
          <span style="color: #60A5FA;">that has to work.</span>
        </h1>

        <p class="text-lg sm:text-xl leading-relaxed mb-10 max-w-[520px]" style="color: rgba(148,163,184,0.85);">
          Repeatable infrastructure. Automated delivery. Operational resilience from day one. No manual provisioning, no improvised architecture, no untracked changes.
        </p>

        <div class="flex flex-wrap gap-4 mb-12">
          <a href="/contact"
            class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
            style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.45);">
            Start an infrastructure review
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/services"
            class="inline-flex items-center gap-2.5 text-sm font-semibold px-7 py-4 rounded-xl border transition-all hover:bg-white/10"
            style="color: rgba(148,163,184,0.9); border-color: rgba(148,163,184,0.25);">
            See how we work
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Hero metrics -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {[
            { value: '3+', label: 'Years in production' },
            { value: '20+', label: 'Tools managed as code' },
            { value: '99.9%', label: 'Uptime design target' },
            { value: 'IaC', label: 'No manual provisioning' },
          ].map(({ value, label }) => (
            <div class="text-center px-3 py-4 rounded-xl"
              style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <div class="text-xl sm:text-2xl font-extrabold text-white mb-1" style="letter-spacing: -0.03em;">{value}</div>
              <div class="text-[10px] font-semibold uppercase tracking-wider" style="color: rgba(148,163,184,0.55);">{label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Terminal mockup -->
      <div class="relative flex justify-center lg:justify-end animate-fade-up delay-200">
        <div class="relative w-full max-w-[510px]">

          <div class="absolute -inset-6 rounded-3xl pointer-events-none" aria-hidden="true"
            style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.25) 0%, transparent 70%); filter: blur(24px);"></div>

          <div class="relative rounded-2xl overflow-hidden"
            style="background: #0d1117; border: 1px solid rgba(255,255,255,0.09); box-shadow: 0 40px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.04);">

            <!-- Chrome bar -->
            <div class="flex items-center gap-2 px-4 py-3.5"
              style="background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.07);">
              <div class="w-3 h-3 rounded-full" style="background: #FF5F57;" aria-hidden="true"></div>
              <div class="w-3 h-3 rounded-full" style="background: #FEBC2E;" aria-hidden="true"></div>
              <div class="w-3 h-3 rounded-full" style="background: #28C840;" aria-hidden="true"></div>
              <div class="flex-1 text-center">
                <span class="text-xs font-mono" style="color: rgba(255,255,255,0.25);">aws-production &middot; main</span>
              </div>
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400" aria-hidden="true"></span>
              <span class="text-xs font-mono" style="color: rgba(255,255,255,0.25);">live</span>
            </div>

            <!-- Terminal body -->
            <div class="p-5 font-mono text-xs sm:text-sm leading-relaxed space-y-1" aria-label="Terminal output showing Terraform and Kubernetes commands">
              <div class="flex items-center gap-2">
                <span style="color: #79C0FF;">❯</span>
                <span class="text-white">terraform apply --auto-approve</span>
              </div>
              <div class="mt-2 text-[0.68rem]" style="color: rgba(255,255,255,0.35);">Plan: 14 to add, 0 to change, 0 to destroy.</div>
              <div class="space-y-0.5 mt-2">
                {[
                  ['aws_vpc.main', '6s'],
                  ['aws_eks_cluster.main', '2m 18s'],
                  ['aws_rds_cluster.db', '1m 44s'],
                  ['aws_cloudfront_distribution.cdn', '47s'],
                  ['module.alb.aws_lb.main', '52s'],
                ].map(([res, time]) => (
                  <div class="text-xs">
                    <span style="color: #3FB950;">✓</span>{' '}
                    <span style="color: rgba(255,255,255,0.5);">{res}</span>{' '}
                    <span style="color: rgba(255,255,255,0.22); font-size: 0.65rem;">({time})</span>
                  </div>
                ))}
              </div>
              <div class="mt-2.5 text-xs font-semibold" style="color: #3FB950;">Apply complete! Resources: 14 added.</div>

              <div class="mt-5 flex items-center gap-2">
                <span style="color: #79C0FF;">❯</span>
                <span class="text-white">kubectl get pods -n production</span>
              </div>
              <div class="space-y-0.5 mt-1">
                {['webapp-7d4b9f-x2k9p', 'webapp-7d4b9f-m8n3q', 'webapp-7d4b9f-p9l1w'].map(pod => (
                  <div style="font-size: 0.68rem;">
                    <span style="color: rgba(255,255,255,0.5);">{pod}&nbsp;&nbsp;</span>
                    <span style="color: rgba(255,255,255,0.4);">2/2&nbsp;&nbsp;</span>
                    <span style="color: #3FB950;">Running</span>
                  </div>
                ))}
              </div>
              <div class="mt-4 flex items-center gap-1.5">
                <span style="color: #79C0FF;">❯</span>
                <span class="terminal-cursor w-1.5 h-4 inline-block rounded-sm" style="background: rgba(255,255,255,0.6);" aria-hidden="true"></span>
              </div>
            </div>

            <!-- CI/CD strip -->
            <div class="px-5 pb-4 pt-2.5" style="border-top: 1px solid rgba(255,255,255,0.06);">
              <div class="flex items-center gap-0.5" aria-label="All CI/CD stages passed">
                {['Build', 'Test', 'Security', 'Docker', 'Deploy'].map((step, i) => (
                  <div class="flex items-center">
                    <div class="flex items-center gap-1 text-xs font-mono">
                      <span style="color: #3FB950;" aria-hidden="true">✓</span>
                      <span style="color: rgba(255,255,255,0.4); font-size: 0.62rem;">{step}</span>
                    </div>
                    {i < 4 && <div class="w-4 h-px mx-1" style="background: rgba(63,185,80,0.3);" aria-hidden="true"></div>}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Floating badge: Deploy success -->
          <div class="absolute -top-5 -right-2 sm:-right-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-400"
            style="border: 1px solid rgba(15,23,42,0.07);">
            <div class="flex items-center gap-2 mb-0.5">
              <span class="w-2 h-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
              <span class="text-xs font-bold text-gray-800">Deploy successful</span>
            </div>
            <p class="text-[10px]" style="color: #64748B;">aws-production &middot; 2m ago</p>
          </div>

          <!-- Floating badge: K8s -->
          <div class="absolute -bottom-5 -left-2 sm:-left-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-500"
            style="border: 1px solid rgba(15,23,42,0.07);">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-3.5 h-3.5" style="color: #2563EB;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
              </svg>
              <span class="text-xs font-bold text-gray-800">EKS Cluster</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400" aria-hidden="true"></span>
              <span class="text-[10px]" style="color: #64748B;">3/3 nodes healthy</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 2. TRUSTED TECHNOLOGIES                                             -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-white" style="border-bottom: 1px solid #E5E7EB;" aria-label="Technologies we work with">
    <div class="max-w-7xl mx-auto px-6 py-14">
      <p class="text-center text-[10px] font-bold uppercase tracking-widest mb-10" style="color: #94A3B8;">
        Core platform technologies
      </p>
      <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 gap-4 items-center">
        {[
          { name: 'AWS',        icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/amazonaws.svg' },
          { name: 'Kubernetes', icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/kubernetes.svg' },
          { name: 'Docker',     icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/docker.svg' },
          { name: 'Terraform',  icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/terraform.svg' },
          { name: 'GitHub',     icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/github.svg' },
          { name: 'Jenkins',    icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/jenkins.svg' },
          { name: 'ArgoCD',     icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/argo.svg' },
          { name: 'Prometheus', icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/prometheus.svg' },
          { name: 'Grafana',    icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/grafana.svg' },
        ].map(({ name, icon }) => (
          <div class="tech-logo-item group" title={name}>
            <div class="w-10 h-10 flex items-center justify-center rounded-xl transition-colors group-hover:bg-blue-50"
              style="background: white; border: 1px solid #E5E7EB;">
              <img src={icon} alt={name} class="w-6 h-6" style="filter: brightness(0) opacity(0.5);" loading="lazy" />
            </div>
            <span class="text-[10px] font-semibold text-gray-600">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 3. SOLUTIONS                                                         -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-white" aria-labelledby="solutions-heading">
    <div class="max-w-7xl mx-auto px-6">

      <div class="text-center mb-16 animate-fade-up">
        <span class="section-label">Solutions</span>
        <h2 id="solutions-heading" class="text-4xl sm:text-5xl font-bold mt-5 mb-5" style="color: #0F172A; letter-spacing: -0.025em;">
          Four platform disciplines.<br />One operating model.
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          Each layer reduces the operational surface your teams manage. Together, they form a repeatable delivery platform.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
            title: 'Cloud Infrastructure',
            desc: 'Codified AWS environments with defined networking, security boundaries and access policies. Terraform modules that can be audited, version-controlled and reproduced across accounts.',
            tags: ['AWS', 'VPC', 'EKS', 'RDS'],
          },
          {
            icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
            title: 'Platform Engineering',
            desc: 'Kubernetes clusters operated as internal platforms. GitOps delivery through ArgoCD. Development teams deploy without raising infrastructure tickets.',
            tags: ['Kubernetes', 'ArgoCD', 'Helm'],
          },
          {
            icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
            title: 'DevOps Automation',
            desc: 'End-to-end pipelines that enforce tests, security scans and policy gates before reaching a cluster. Every release is traceable. Every rollback takes one command.',
            tags: ['GitHub Actions', 'Jenkins', 'OIDC'],
          },
          {
            icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            title: 'Observability',
            desc: 'Instrumented from day one, not after the first incident. Prometheus metrics, structured logs and alerting thresholds configured before the first user hits production.',
            tags: ['Prometheus', 'Grafana', 'SRE'],
          },
        ].map(({ icon, title, desc, tags }, i) => (
          <div class={`card card-accent flex flex-col p-7 animate-fade-up ${['delay-100','delay-200','delay-300','delay-400'][i]}`}>
            <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-6 flex-shrink-0" style="background: #EFF6FF;" aria-hidden="true">
              <svg class="w-5 h-5" style="color: #2563EB;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed flex-1 mb-5" style="color: #64748B;">{desc}</p>
            <div class="flex flex-wrap gap-1.5 mb-5">
              {tags.map(tag => <span class="stack-tag">{tag}</span>)}
            </div>
            <a href="/services" class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors mt-auto" style="color: #2563EB;">
              Learn more
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>

      <div class="text-center mt-12 animate-fade-up">
        <a href="/services"
          class="inline-flex items-center gap-2 text-sm font-semibold px-7 py-3.5 rounded-xl border transition-all hover:bg-gray-50"
          style="color: #0F172A; border-color: #E5E7EB;">
          View all solutions
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 4. PLATFORM ARCHITECTURE                                            -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 relative overflow-hidden" style="background: #0B1220;" aria-labelledby="architecture-heading">
    <div class="absolute inset-0 pointer-events-none opacity-20" aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.15) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] pointer-events-none" aria-hidden="true"
      style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.18) 0%, transparent 70%);"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 animate-fade-up">
        <span class="inline-flex items-center text-[10px] font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5"
          style="background: rgba(37,99,235,0.18); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);">
          Platform Architecture
        </span>
        <h2 id="architecture-heading" class="text-4xl sm:text-5xl font-bold text-white mt-2 mb-5" style="letter-spacing: -0.025em;">
          The platform stack,<br />layer by layer.
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: rgba(148,163,184,0.8);">
          Six layers that form an auditable, repeatable infrastructure operating model. Each one is version-controlled and recoverable.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Architecture stack diagram -->
        <div class="animate-fade-left" role="img" aria-label="Architecture layers: AWS, Terraform, Kubernetes EKS, ArgoCD, Applications, Prometheus and Grafana">
          <div class="space-y-0">
            {[
              { label: 'AWS', sub: 'Cloud Provider · Multi-AZ · 99.99% SLA', color: '#FF9900', icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6' },
              { label: 'Terraform', sub: 'Infrastructure as Code · Modular', color: '#7B42BC', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4' },
              { label: 'Kubernetes (EKS)', sub: 'Container Orchestration · HPA · Auto-scaling', color: '#326CE5', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2' },
              { label: 'ArgoCD', sub: 'GitOps · Continuous Delivery · Drift detection', color: '#EF7B4D', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
              { label: 'Applications', sub: 'Spring Boot · FastAPI · React · Docker', color: '#10B981', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
              { label: 'Prometheus + Grafana', sub: 'Observability · Alerting · Real-time dashboards', color: '#E5421E', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            ].map(({ label, sub, color, icon }, i, arr) => (
              <div>
                <div class="flex items-center gap-4 p-4 rounded-xl transition-all hover:-translate-x-1 cursor-default"
                  style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                  <div class="w-10 h-10 flex items-center justify-center rounded-xl flex-shrink-0"
                    style={`background: ${color}22; border: 1px solid ${color}44;`} aria-hidden="true">
                    <svg class="w-5 h-5" style={`color: ${color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-bold text-white">{label}</div>
                    <div class="text-xs mt-0.5" style="color: rgba(148,163,184,0.6);">{sub}</div>
                  </div>
                  <div class="w-2 h-2 rounded-full flex-shrink-0" style={`background: ${color};`} aria-hidden="true"></div>
                </div>
                {i < arr.length - 1 && (
                  <div class="flex justify-start ml-9 my-1" aria-hidden="true">
                    <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
                      <path d="M8 0 L8 14 M4 10 L8 14 L12 10" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- Architecture benefits -->
        <div class="animate-fade-up delay-200">
