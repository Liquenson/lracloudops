    href: 'https://github.com/lra-cloud-ops/aws-devops-agent',
    maturity: 'Lab',
  },
  {
    color: '#F29900',
    category: 'Infrastructure',
    title: 'aws-terraform-devops — VPC, EKS, RDS, ECR with Terraform',
