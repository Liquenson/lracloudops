              { value: '100%', label: 'IaC coverage after' },
              { value: 'Weekly', label: 'Release cadence (was monthly)' },
              { value: 'OIDC', label: 'No static credentials remaining' },
            ],
            highlights: ['ShellCheck CI across 3 platforms', 'Configuration drift eliminated', 'Rollback tested before production'],
          },
        ].map((eng, i) => (
          <div class={`bg-white rounded-2xl p-8 animate-fade-up ${['delay-100','delay-200','delay-300','delay-400'][i]}`}
            style="border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06);">
            <div class="flex items-start justify-between mb-5">
              <div>
                <span class="text-xs font-semibold uppercase tracking-widest mb-1 block" style="color: #94a3b8;">{eng.type}</span>
                <h3 class="text-lg font-bold" style="color: #0A2540;">{eng.industry}</h3>
              </div>
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0 ml-3" style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;">Production</span>
            </div>
            <p class="text-sm leading-relaxed mb-6" style="color: #64748b;">{eng.description}</p>
            <div class="grid grid-cols-2 gap-3 mb-6">
              {eng.metrics.map(m => (
                <div class="rounded-xl p-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                  <div class="text-base font-bold mb-0.5" style="color: #0A2540;">{m.value}</div>
                  <div class="text-xs" style="color: #64748b;">{m.label}</div>
                </div>
              ))}
            </div>
            <ul class="space-y-2">
              {eng.highlights.map(h => (
                <li class="flex items-center gap-2.5 text-xs" style="color: #64748b;">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/projects" class="inline-flex items-center gap-2 text-sm font-semibold transition-colors" style="color: #2563EB;">
          View all implementations
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 8. BLOG                                                              -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-white" aria-labelledby="blog-heading">
    <div class="max-w-7xl mx-auto px-6">

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14">
        <div class="animate-fade-up">
          <span class="section-label">Technical Blog</span>
          <h2 id="blog-heading" class="text-4xl sm:text-5xl font-bold mt-5" style="color: #0F172A; letter-spacing: -0.025em;">
            Engineering notes.
          </h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold transition-colors animate-fade" style="color: #2563EB;">
          All articles
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentPosts.length > 0 ? recentPosts.map((post, i) => (
          <article class={`card card-accent flex flex-col p-7 animate-fade-up ${['delay-100','delay-200','delay-300'][i]}`}>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {post.data.tags?.slice(0, 2).map((tag: string) => (
                <span class="stack-tag">{tag}</span>
              ))}
            </div>
            <h3 class="text-base font-bold mb-3 flex-1" style="color: #0F172A; line-height: 1.4;">
              <a href={`/blog/${post.id}`} class="hover:text-blue-600 transition-colors">
                {post.data.titulo}
              </a>
            </h3>
            <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">
              {post.data.descripcion?.slice(0, 110)}{post.data.descripcion && post.data.descripcion.length > 110 ? '…' : ''}
            </p>
            <div class="flex items-center justify-between pt-4 border-t border-gray-100 mt-auto">
              <time class="text-xs" style="color: #94A3B8;">
                {new Date(post.data.fecha).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
              <a href={`/blog/${post.id}`} class="text-xs font-semibold" style="color: #2563EB;"
                aria-label={`Read: ${post.data.titulo}`}>
                Read more &rarr;
              </a>
            </div>
          </article>
        )) : (
          [{
            title: 'GitOps with ArgoCD: Production patterns',
            tags: ['GitOps', 'ArgoCD'],
            date: 'Jun 2026',
            desc: 'How to implement GitOps workflows with ArgoCD for zero-downtime deployments in Kubernetes.',
            href: '/blog',
          }, {
            title: 'Kubernetes Production Checklist',
            tags: ['Kubernetes', 'SRE'],
            date: 'May 2026',
            desc: 'Everything you need before going live: security, autoscaling, observability and disaster recovery.',
            href: '/blog',
          }, {
            title: 'Terraform Enterprise Patterns',
            tags: ['Terraform', 'IaC'],
            date: 'Apr 2026',
            desc: 'Modular Terraform for multi-environment, multi-account AWS infrastructure at scale.',
            href: '/blog',
          }].map(({ title, tags, date, desc, href }, i) => (
            <article class={`card card-accent flex flex-col p-7 animate-fade-up ${['delay-100','delay-200','delay-300'][i]}`}>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {tags.map(t => <span class="stack-tag">{t}</span>)}
              </div>
              <h3 class="text-base font-bold mb-3 flex-1" style="color: #0F172A; line-height: 1.4;">{title}</h3>
              <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">{desc}</p>
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <span class="text-xs" style="color: #94A3B8;">{date}</span>
                <a href={href} class="text-xs font-semibold" style="color: #2563EB;">Read more &rarr;</a>
              </div>
            </article>
          ))
        )}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 8. CTA FINAL                                                         -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" aria-labelledby="cta-heading">
    <div class="py-24 px-6 relative" style="background: linear-gradient(90deg, #1D4ED8 0%, #2563EB 55%, #60A5FA 100%);">
      <!-- Dot overlay -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
        style="background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px); background-size: 28px 28px;"></div>

      <div class="relative max-w-4xl mx-auto text-center animate-fade-up">
        <h2 id="cta-heading"
          class="text-4xl sm:text-5xl lg:text-[56px] font-extrabold text-white mb-6"
          style="letter-spacing: -0.03em; line-height: 1.06;">
          Start with an<br />infrastructure review.
        </h2>
        <p class="text-xl mb-10 max-w-2xl mx-auto leading-relaxed" style="color: rgba(255,255,255,0.8);">
          Bring your current architecture. We identify gaps in resilience, delivery automation and observability — and outline a concrete path forward.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
          <a href="/contact"
            class="inline-flex items-center gap-2.5 text-base font-bold px-8 py-4 rounded-xl transition-all hover:bg-blue-50 hover:-translate-y-px active:scale-[0.98] shadow-xl"
            style="background: white; color: #1D4ED8;">
            Book a technical review
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/projects"
            class="inline-flex items-center gap-2 text-base font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
            style="color: rgba(255,255,255,0.9); border-color: rgba(255,255,255,0.3);">
            View our work
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3" style="color: rgba(255,255,255,0.6);">
          {['30 minutes. No sales deck.', 'Response within 24 hours.', 'Architecture assessment included.'].map(item => (
            <span class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 flex-shrink-0" style="color: rgba(255,255,255,0.8);" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

</Layout>

