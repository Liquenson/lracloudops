---
import Layout from '../layouts/Layout.astro'
import HeroSection from '../components/home/HeroSection.astro'
import ArchitectureSection from '../components/home/ArchitectureSection.astro'
import MetricsSection from '../components/home/MetricsSection.astro'
import ServicesSection from '../components/home/ServicesSection.astro'
import ProjectsSection from '../components/home/ProjectsSection.astro'
import TrustBadgeSection from '../components/home/TrustBadgeSection.astro'
import WhySection from '../components/home/WhySection.astro'
import IndustriesSection from '../components/home/IndustriesSection.astro'
import EngagementSection from '../components/home/EngagementSection.astro'
import TestimonialsSection from '../components/home/TestimonialsSection.astro'
import TechStackSection from '../components/home/TechStackSection.astro'
import BlogSection from '../components/home/BlogSection.astro'
import ChecklistCTA from '../components/home/ChecklistCTA.astro'
import CommunitySection from '../components/home/CommunitySection.astro'
import FinalCTASection from '../components/home/FinalCTASection.astro'

const professionalServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://lracloudops.com/#service',
  name: 'LRA Cloud Operations',
  url: 'https://lracloudops.com',
  description:
    'Platform Engineering consultancy specialized in AWS, Kubernetes, Terraform and GitOps. Infrastructure designed for reliability and automated delivery.',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: ['Spain', 'United States', 'Latin America', 'European Union'],
  serviceType: [
    'Platform Engineering',
    'Cloud Infrastructure',
    'DevOps Automation',
    'Kubernetes',
    'Observability & SRE',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Las Palmas de Gran Canaria',
    addressCountry: 'ES',
  },
  sameAs: [
    'https://github.com/lra-cloud-ops',
    'https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/',
    'https://www.instagram.com/lracloudops/',
  ],
}
---

<Layout
  titulo="Infraestructura Cloud y Platform Engineering"
  descripcion="Consultora DevOps especializada en AWS, Azure y GCP. Infraestructura cloud, Kubernetes y GitOps para empresas en sectores regulados."
  schema={professionalServiceSchema}
>
  <HeroSection lang="es" />
  <MetricsSection lang="es" />
  <ArchitectureSection lang="es" />
  <ServicesSection lang="es" />
  <ProjectsSection lang="es" />
  <TrustBadgeSection lang="es" />
  <WhySection lang="es" />
  <IndustriesSection lang="es" />
  <EngagementSection lang="es" />
  <TestimonialsSection lang="es" />
  <TechStackSection lang="es" />
  <BlogSection lang="es" />
  <ChecklistCTA lang="es" />
  <CommunitySection lang="es" />
  <FinalCTASection lang="es" />
</Layout>
