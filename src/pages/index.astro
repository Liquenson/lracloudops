---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 2)
---

<Layout
  titulo="Ingenieros DevOps AWS · Kubernetes · Terraform"
  descripcion="Equipo de ingenieros DevOps especializados en AWS, Kubernetes y Terraform. Diseñamos infraestructura cloud escalable, automatizamos pipelines CI/CD y gestionamos plataformas de producción."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">

    <!-- Grid dot background -->
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"></div>

    <div class="relative max-w-7xl mx-auto px-5 sm:px-6 py-20 sm:py-28 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text Content -->
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-7 text-xs font-semibold" style="background: rgba(30,111,255,0.15); border: 1px solid rgba(30,111,255,0.3); color: #93b8ff;">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
          Somos un equipo de ingenieros · Disponibles para proyectos
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-extrabold text-white leading-[1.1] mb-6" style="letter-spacing: -0.02em;">
          Diseñamos, automatizamos<br />y escalamos
          <span style="color: #5B9BFF;">infraestructura cloud enterprise</span>
        </h1>

        <p class="text-lg leading-relaxed mb-9 max-w-lg" style="color: rgba(147,184,255,0.8);">
          Nuestro equipo de ingenieros DevOps especialistas en AWS, Kubernetes y Terraform lleva tu infraestructura al siguiente nivel.
        </p>

        <div class="flex gap-3.5 flex-wrap mb-9">
          <a
            href="/contacto"
            class="inline-flex items-center gap-2 text-sm font-semibold text-white px-6 py-3.5 rounded-xl transition-all hover:scale-[1.02] hover:shadow-xl active:scale-[0.98]"
            style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 20px rgba(30,111,255,0.4);"
          >
            Solicitar evaluación técnica
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/proyectos"
            class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3.5 rounded-xl border transition-all hover:bg-white/10"
            style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);"
          >
            Ver casos de estudio
          </a>
        </div>

        <!-- Tech badges -->
        <div class="flex flex-wrap gap-2">
          {['AWS EKS', 'Terraform', 'Kubernetes', 'GitHub Actions', 'ArgoCD', 'Prometheus'].map(tag => (
            <span class="inline-flex items-center text-xs font-medium px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: rgba(147,184,255,0.7);">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: Terminal Mockup -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-full max-w-[520px]">

          <!-- Glow behind terminal -->
          <div class="absolute -inset-4 rounded-3xl pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(30,111,255,0.2) 0%, transparent 70%); filter: blur(20px);"></div>

          <!-- Terminal window -->
          <div class="relative rounded-2xl overflow-hidden" style="background: #0d1117; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 32px 64px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05);">

            <!-- Terminal chrome -->
            <div class="flex items-center gap-2 px-4 py-3" style="background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.07);">
              <div class="w-3 h-3 rounded-full flex-shrink-0" style="background: #ff5f57;"></div>
              <div class="w-3 h-3 rounded-full flex-shrink-0" style="background: #febc2e;"></div>
              <div class="w-3 h-3 rounded-full flex-shrink-0" style="background: #28c840;"></div>
              <div class="flex-1 text-center">
                <span class="text-xs font-mono" style="color: rgba(255,255,255,0.28);">aws-production · main</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                <span class="text-xs font-mono" style="color: rgba(255,255,255,0.28);">live</span>
              </div>
            </div>

            <!-- Terminal body -->
            <div class="p-5 font-mono text-xs sm:text-sm leading-relaxed space-y-1 overflow-hidden">
              <div class="flex items-center gap-2">
                <span style="color: #79c0ff;">❯</span>
                <span class="text-white">terraform apply --auto-approve</span>
              </div>
              <div class="mt-1.5" style="color: rgba(255,255,255,0.4); font-size: 0.7rem;">Plan: 12 to add, 0 to change, 0 to destroy.</div>
              <div class="space-y-0.5 mt-2">
                <div class="text-xs"><span style="color: #3fb950;">✓</span> <span style="color: rgba(255,255,255,0.55);">aws_vpc.main</span> <span style="color: rgba(255,255,255,0.25); font-size: 0.68rem;">(8s)</span></div>
                <div class="text-xs"><span style="color: #3fb950;">✓</span> <span style="color: rgba(255,255,255,0.55);">aws_eks_cluster.main</span> <span style="color: rgba(255,255,255,0.25); font-size: 0.68rem;">(2m 15s)</span></div>
                <div class="text-xs"><span style="color: #3fb950;">✓</span> <span style="color: rgba(255,255,255,0.55);">aws_rds_cluster.db</span> <span style="color: rgba(255,255,255,0.25); font-size: 0.68rem;">(1m 42s)</span></div>
                <div class="text-xs"><span style="color: #3fb950;">✓</span> <span style="color: rgba(255,255,255,0.55);">aws_cloudfront_distribution.cdn</span> <span style="color: rgba(255,255,255,0.25); font-size: 0.68rem;">(45s)</span></div>
              </div>
              <div class="mt-2 text-xs" style="color: #3fb950;">Apply complete! Resources: 12 added.</div>

              <div class="mt-4 flex items-center gap-2">
                <span style="color: #79c0ff;">❯</span>
                <span class="text-white">kubectl get pods -n production</span>
              </div>
              <div class="text-xs mt-1" style="color: rgba(255,255,255,0.3); font-size: 0.68rem;">NAME&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;READY &nbsp;STATUS</div>
              <div class="space-y-0.5">
                <div class="text-xs" style="font-size: 0.7rem;"><span style="color: rgba(255,255,255,0.55);">webapp-7d4b9f-x2k9p&nbsp;&nbsp;&nbsp;</span><span style="color: rgba(255,255,255,0.5);">2/2&nbsp;&nbsp;&nbsp;</span><span style="color: #3fb950;">Running</span></div>
                <div class="text-xs" style="font-size: 0.7rem;"><span style="color: rgba(255,255,255,0.55);">webapp-7d4b9f-m8n3q&nbsp;&nbsp;</span><span style="color: rgba(255,255,255,0.5);">2/2&nbsp;&nbsp;&nbsp;</span><span style="color: #3fb950;">Running</span></div>
                <div class="text-xs" style="font-size: 0.7rem;"><span style="color: rgba(255,255,255,0.55);">webapp-7d4b9f-p9l1w&nbsp;&nbsp;&nbsp;</span><span style="color: rgba(255,255,255,0.5);">2/2&nbsp;&nbsp;&nbsp;</span><span style="color: #3fb950;">Running</span></div>
              </div>
              <div class="mt-3 flex items-center gap-1.5">
                <span style="color: #79c0ff;">❯</span>
                <span class="terminal-cursor w-1.5 h-4 inline-block rounded-sm" style="background: rgba(255,255,255,0.65);"></span>
              </div>
            </div>

            <!-- CI/CD pipeline strip -->
            <div class="px-5 pb-4 pt-2" style="border-top: 1px solid rgba(255,255,255,0.06);">
              <div class="flex items-center gap-0">
                {[
                  { label: 'Build', done: true },
                  { label: 'Test', done: true },
                  { label: 'Security', done: true },
                  { label: 'Docker', done: true },
                  { label: 'Deploy', done: true },
                ].map((step, i) => (
                  <div class="flex items-center">
                    <div class="flex items-center gap-1 text-xs font-mono">
                      <span style={`color: ${step.done ? '#3fb950' : 'rgba(255,255,255,0.3)'};`}>{step.done ? '✓' : '○'}</span>
                      <span style="color: rgba(255,255,255,0.4); font-size: 0.65rem;">{step.label}</span>
                    </div>
                    {i < 4 && <div class="w-4 h-px mx-1" style="background: rgba(63,185,80,0.35);"></div>}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Floating badge: Deploy -->
          <div class="absolute -top-4 -right-2 sm:-right-6 bg-white rounded-xl px-3.5 py-2.5 shadow-xl" style="border: 1px solid rgba(10,37,64,0.08);">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0"></span>
              <span class="text-xs font-semibold text-gray-800">Deploy exitoso</span>
            </div>
            <p class="text-xs mt-0.5" style="color: #64748b;">aws-production · hace 2m</p>
          </div>

          <!-- Floating badge: K8s -->
          <div class="absolute -bottom-4 -left-2 sm:-left-6 bg-white rounded-xl px-3.5 py-2.5 shadow-xl" style="border: 1px solid rgba(10,37,64,0.08);">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-3.5 h-3.5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
              </svg>
              <span class="text-xs font-semibold text-gray-800">K8s Cluster</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
              <span class="text-xs" style="color: #64748b;">3/3 pods running</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── STATS STRIP ───────────────────────────────────────────────────── -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {[
          { count: 11, suffix: '+', label: 'Proyectos cloud', sub: 'Infraestructura cloud en producción' },
          { count: 50, suffix: '+', label: 'Tecnologías dominadas', sub: 'Stack DevOps enterprise completo' },
          { count: 4,  suffix: '',  label: 'Ingenieros especializados', sub: 'Arquitectura, IaC y automatización' },
          { count: 100, suffix: '%', label: 'IaC Puro', sub: 'Infraestructura versionada y auditable' },
        ].map(({ count, suffix, label, sub }) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold mb-1" style="color: #0A2540; letter-spacing: -0.02em;">
              <span class="counter-value" data-count={count} data-suffix={suffix}>0{suffix}</span>
            </div>
            <div class="text-sm font-semibold text-gray-800 mb-0.5">{label}</div>
            <div class="text-xs" style="color: #64748b;">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── POR QUÉ ELEGIRNOS ───────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6">

      <div class="text-center mb-14">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
          Por qué elegirnos
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">Ingeniería que genera confianza</h2>
        <p class="text-base max-w-2xl mx-auto" style="color: #64748b;">
          Tres razones por las que los equipos eligen trabajar con nosotros.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl p-8 group hover:-translate-y-1 transition-all duration-200" style="border: 1px solid #e2e8f0; box-shadow: 0 4px 24px rgba(10,37,64,0.08);">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-6" style="background: #EEF4FF;">
            <svg class="w-6 h-6" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-3" style="color: #0A2540;">Ingeniería orientada a producción</h3>
          <p class="text-sm leading-relaxed" style="color: #64748b;">
            Desarrollamos plataformas cloud-native aplicando prácticas modernas de Platform Engineering, automatización de infraestructura, Kubernetes, observabilidad y despliegues continuos sobre AWS.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 group hover:-translate-y-1 transition-all duration-200" style="border: 1px solid #e2e8f0; box-shadow: 0 4px 24px rgba(10,37,64,0.08);">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-6" style="background: #EEF4FF;">
            <svg class="w-6 h-6" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-3" style="color: #0A2540;">Stack enterprise</h3>
          <p class="text-sm leading-relaxed" style="color: #64748b;">
            Trabajamos con las mismas herramientas que usan empresas como Airbnb, Netflix y Spotify: Terraform, ArgoCD, Prometheus y GitHub Actions.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 group hover:-translate-y-1 transition-all duration-200" style="border: 1px solid #e2e8f0; box-shadow: 0 4px 24px rgba(10,37,64,0.08);">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl mb-6" style="background: #EEF4FF;">
            <svg class="w-6 h-6" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-3" style="color: #0A2540;">Entrega rápida</h3>
          <p class="text-sm leading-relaxed" style="color: #64748b;">
            Nuestra infraestructura como código permite desplegar entornos completos en minutos, no semanas. Todo versionado, todo reproducible.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── SERVICIOS ─────────────────────────────────────────────────────── -->
  <section style="background-color: #0A2540;" class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-30" style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20">

      <div class="text-center mb-14">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4" style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);">
          Servicios
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">¿Qué podemos hacer por tu infraestructura?</h2>
        <p class="max-w-2xl mx-auto text-base" style="color: rgba(147,184,255,0.75);">
          Soluciones cloud de nivel enterprise adaptadas a las necesidades reales de tu negocio.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        {[
          {
            icon: 'M3 15a4 4 0 004 4h10a4 4 0 001-7.9A5 5 0 106 6.6',
            title: 'Cloud Architecture',
            desc: 'Diseño e implementación de arquitecturas AWS resilientes, escalables y de alta disponibilidad con VPC, EKS, RDS y CloudFront.',
            tags: ['AWS', 'VPC', 'EKS', 'RDS', 'CloudFront'],
          },
          {
            icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
            title: 'Infrastructure as Code',
            desc: 'Terraform modular multi-entorno con state remoto, módulos reutilizables y Ansible para configuración de servidores.',
            tags: ['Terraform', 'Ansible', 'IaC', 'Módulos'],
          },
          {
            icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2',
            title: 'Kubernetes & GitOps',
            desc: 'Orquestación de contenedores con EKS, ArgoCD como controlador GitOps, Helm charts y autoscaling horizontal.',
            tags: ['Kubernetes', 'ArgoCD', 'Helm', 'EKS'],
          },
          {
            icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
            title: 'CI/CD Pipelines',
            desc: 'Pipelines end-to-end con GitHub Actions, Jenkins y ArgoCD. Build, test, security scan y deploy automatizados.',
            tags: ['GitHub Actions', 'Jenkins', 'Docker', 'OIDC'],
          },
          {
            icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            title: 'Observabilidad & SRE',
            desc: 'Stacks de monitoreo con Prometheus y Grafana, alertas proactivas con Alertmanager y dashboards en tiempo real.',
            tags: ['Prometheus', 'Grafana', 'CloudWatch', 'SRE'],
          },
          {
            icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            title: 'Linux & Automatización',
            desc: 'Administración de flotas Linux, scripts Bash y Python para eliminar tareas manuales y reducir errores operativos.',
            tags: ['Bash', 'Python', 'Linux', 'SSH', 'Scripts'],
          },
        ].map(({ icon, title, desc, tags }) => (
          <div
            class="bg-white flex flex-col p-7 group transition-all duration-200 hover:-translate-y-1"
            style="border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.18);"
          >
            <div class="w-11 h-11 flex items-center justify-center rounded-xl mb-5 transition-colors" style="background-color: #EEF4FF;">
              <svg class="w-5 h-5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-base font-bold text-gray-900 mb-2.5">{title}</h3>
            <p class="text-sm leading-relaxed mb-5 flex-1" style="color: #64748b;">{desc}</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {tags.map(tag => (
                <span class="text-xs px-2.5 py-1 rounded-full" style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0;">{tag}</span>
              ))}
            </div>
          </div>
        ))}

      </div>

      <div class="text-center mt-10">
        <a href="/servicios" class="inline-flex items-center gap-2 text-sm font-semibold px-6 py-3 rounded-xl border transition-all hover:bg-white/10" style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);">
          Ver todos los servicios
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── TECNOLOGÍAS ────────────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6">

      <div class="text-center mb-12">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;">
          Stack Tecnológico
        </span>
        <h2 class="text-3xl font-bold mb-3" style="color: #0A2540;">Herramientas que dominamos</h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">El stack completo para construir plataformas cloud modernas, seguras y escalables.</p>
      </div>

      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-4">
        {[
          { name: 'AWS', icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/amazonaws.svg', category: 'Cloud' },
          { name: 'Kubernetes', icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/kubernetes.svg', category: 'Orquestación' },
          { name: 'Terraform', icon: 'https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/terraform.svg', category: 'IaC' },
