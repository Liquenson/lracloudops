<script>
  const form = document.getElementById(
    'checklist-form'
  ) as HTMLFormElement | null
  const btn = document.getElementById(
    'checklist-btn'
  ) as HTMLButtonElement | null
  const statusEl = document.getElementById(
    'checklist-status'
  ) as HTMLDivElement | null

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!btn || !statusEl) return
    btn.textContent = 'Sending...'
    btn.disabled = true

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      })
      const data = await res.json()
      if (data.success) {
        statusEl.textContent =
          'Subscribed! We will send the checklist to your inbox shortly.'
        statusEl.style.cssText =
          'display:inline-block; background: rgba(16,185,129,0.15); color: #34D399; border: 1px solid rgba(52,211,153,0.3);'
        form.reset()
      } else {
        statusEl.textContent = 'Something went wrong. Please try again.'
        statusEl.style.cssText =
          'display:inline-block; background: rgba(239,68,68,0.15); color: #F87171; border: 1px solid rgba(248,113,113,0.3);'
      }
    } catch {
      statusEl.textContent = 'Connection error. Please try again.'
      statusEl.style.cssText =
        'display:inline-block; background: rgba(239,68,68,0.15); color: #F87171; border: 1px solid rgba(248,113,113,0.3);'
    }

    btn.textContent = 'Download free →'
    btn.disabled = false
    statusEl.classList.remove('hidden')
  })
</script>
