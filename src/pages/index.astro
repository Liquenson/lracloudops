---
import Layout from '../layouts/Layout.astro'
---

<Layout title="LRA CloudOps" description="LRA CloudOps — Coming soon">
  <main
    style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #FFFFFF;"
  >
    <div style="text-align: center; padding: 2rem;">
      <div class="hero-logo" style="display: inline-flex; margin-bottom: 3rem;">
        <div style="display: inline-flex; align-items: center; gap: 0.75rem;">
          <img
            src="/lracloudops-icon.svg"
            alt="LRA CloudOps"
            style="height: 40px; width: auto;"
          />
          <span style="font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 700; color: #111827; letter-spacing: -0.01em;">
            LRA CloudOps
          </span>
        </div>
      </div>

      <h1 style="color: #111827; font-family: 'Red Hat Display', sans-serif; font-weight: 900; font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 1rem;">
        Something new is coming.
      </h1>
      <p style="color: #6B7280; font-family: 'Red Hat Text', sans-serif; font-weight: 400; font-size: 1.125rem; max-width: 480px; margin: 0 auto 2.5rem;">
        We're rebuilding from the ground up. A new vision for cloud infrastructure is on the way.
      </p>

      <a
        href="mailto:info@lracloudops.com"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #111827; color: #FFF; padding: 0.875rem 2rem; border-radius: 9999px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 1rem; text-decoration: none;"
      >
        Get in touch →
      </a>

      <div style="display: flex; gap: 1.5rem; justify-content: center; margin-top: 1.5rem;">
        <a
          href="https://www.linkedin.com/in/ruben-liquenson-490961269/"
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-flex; align-items: center; gap: 0.375rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; font-weight: 500; color: #0A66C2; text-decoration: none;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a
          href="https://github.com/lra-cloud-ops/lra-ai-platform"
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-flex; align-items: center; gap: 0.375rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; font-weight: 500; color: #111827; text-decoration: none;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          LRA AI Platform
        </a>
      </div>

      <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #E5E7EB; text-align: center;">
        <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #111827; margin-bottom: 0.5rem;">
          DevOps Engineer · Cloud Engineer · AWS · Kubernetes · Terraform · GitOps
        </p>
        <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #6B7280; margin-bottom: 0.25rem;">
          📍 Las Palmas de Gran Canaria, Canarias, España
        </p>
        <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; color: #6B7280; display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
          <a
            href="https://www.linkedin.com/company/nibble-tech-llc/posts/?feedView=all"
            target="_blank"
            rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.3rem; color: #0A66C2; text-decoration: none; font-weight: 500;"
            onmouseover="this.style.textDecoration='underline'"
            onmouseout="this.style.textDecoration='none'"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Nibble Tech LLC
          </a>
          ·
          <a
            href="https://www.linkedin.com/school/itla/posts/?feedView=all"
            target="_blank"
            rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.3rem; color: #0A66C2; text-decoration: none; font-weight: 500;"
            onmouseover="this.style.textDecoration='underline'"
            onmouseout="this.style.textDecoration='none'"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            ITLA
          </a>
        </p>
      </div>
    </div>
  </main>
</Layout>
