---
import TechIcon from '../components/TechIcon.astro'
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const recentPosts = (await getCollection('esBlog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3)

const allProjects = await getCollection('projects', ({ data }) => !data.draft)
const displayProjects = allProjects

const professionalServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://lracloudops.com/#service',
  name: 'LRA Cloud Operations',
  url: 'https://lracloudops.com',
  description: 'Platform Engineering consultancy specialized in AWS, Kubernetes, Terraform and GitOps. Infrastructure designed for reliability and automated delivery.',
  provider: { '@id': 'https://lracloudops.com/#organization' },
  areaServed: ['Spain', 'United States', 'Latin America', 'European Union'],
  serviceType: ['Platform Engineering', 'Cloud Infrastructure', 'DevOps Automation', 'Kubernetes', 'Observability & SRE'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Las Palmas de Gran Canaria',
    addressCountry: 'ES',
  },
  sameAs: [
    'https://github.com/lra-cloud-ops',
    'https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/',
    'https://www.instagram.com/lracloudops/',
  ],
}
---

<Layout
  titulo="Infraestructura Cloud y Platform Engineering"
  descripcion="Infraestructura cloud y platform engineering. Kubernetes, Terraform y AWS — diseñados para fiabilidad operacional y entrega automatizada."
  schema={professionalServiceSchema}
>
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 1. HERO ENTERPRISE                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden hero-gradient"
    aria-labelledby="hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.14) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 90% 60% at 50% 115%, rgba(37,99,235,0.22) 0%, transparent 65%);"
    >
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-px pointer-events-none"
      aria-hidden="true"
      style="background: linear-gradient(90deg, transparent, rgba(96,165,250,0.4), transparent);"
    >
    </div>

    <div
      class="relative max-w-7xl mx-auto px-5 sm:px-6 py-14 sm:py-24 lg:py-32 grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-14 lg:gap-20 items-center"
    >
      <!-- Izquierda: Copy -->
      <div class="animate-fade-left">
        <div
          class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full mb-8 text-xs font-semibold"
          style="background: rgba(37,99,235,0.15); border: 1px solid rgba(96,165,250,0.3); color: #93C5FD;"
        >
          <span
            class="w-2 h-2 rounded-full flex-shrink-0 animate-pulse-soft"
            style="background: #60A5FA;"
            aria-hidden="true"></span>
          Platform Engineering &middot; AWS &middot; Kubernetes
        </div>

        <h1
          id="hero-heading"
          class="text-[34px] sm:text-[52px] lg:text-[68px] font-extrabold text-white leading-[1.04] mb-7"
          style="letter-spacing: -0.035em;"
        >
          Ingeniería de plataformas<br />para infraestructuras<br />
          <span style="color: #60A5FA;">que deben funcionar.</span>
        </h1>

        <p
          class="text-lg sm:text-xl leading-relaxed mb-10 max-w-[520px]"
          style="color: rgba(148,163,184,0.85);"
        >
          Infraestructura reproducible. Entrega automatizada. Resiliencia
          operacional desde el primer día. Sin aprovisionamiento manual, sin
          arquitectura improvisada, sin cambios sin trazabilidad.
        </p>

        <div class="flex flex-wrap gap-4 mb-6">
          <a
            href="/contacto"
            class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
            style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.45);"
          >
            Solicitar revisión de infraestructura
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/proyectos"
            class="inline-flex items-center gap-2.5 text-sm font-semibold px-7 py-4 rounded-xl border transition-all hover:bg-white/10"
            style="color: rgba(148,163,184,0.9); border-color: rgba(148,163,184,0.25);"
          >
            Ver casos de estudio
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <p style="font-size: 0.875rem; color: rgba(255,255,255,0.7); margin-top: 1rem;">
          Infraestructura de producción en salud, fintech y plataformas cloud en España y LATAM
        </p>

        <!-- Franja de sectores -->
        <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:1.25rem;" role="list" aria-label="Industrias atendidas">
          {[
            { label: 'Salud', path: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z' },
            { label: 'Fintech', path: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z' },
            { label: 'SaaS', path: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z' },
            { label: 'Enterprise', path: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z' },
          ].map(({ label, path }) => (
            <span
              role="listitem"
              style="display:inline-flex; align-items:center; gap:0.375rem; font-size:0.7rem; font-weight:500; color:rgba(148,163,184,0.8); background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-radius:100px; padding:0.3rem 0.75rem;"
            >
              <svg style="width:0.875rem; height:0.875rem; flex-shrink:0; color:rgba(96,165,250,0.8);" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={path} />
              </svg>
              {label}
            </span>
          ))}
        </div>

        <!-- Indicadores de confianza -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
          {
            ['Respuesta en 24h', 'Sin contratos de permanencia'].map((item) => (
              <span class="flex items-center gap-1.5 text-xs font-medium" style="color: rgba(148,163,184,0.65);">
                <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: #60A5FA;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </span>
            ))
          }
          <a
            href="/assessment"
            class="flex items-center gap-1.5 text-xs font-medium transition-colors hover:opacity-80"
            style="color: rgba(148,163,184,0.65);"
          >
            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: #60A5FA;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
            </svg>
            Assessment DevOps gratuito
          </a>
        </div>
      </div>

      <!-- Derecha: Terminal mockup -->
      <div
        class="relative flex justify-center lg:justify-end animate-fade-up delay-200"
      >
        <div class="relative w-full max-w-[510px]">
          <div
            class="absolute -inset-6 rounded-3xl pointer-events-none"
            aria-hidden="true"
            style="background: radial-gradient(ellipse at center, rgba(37,99,235,0.25) 0%, transparent 70%); filter: blur(24px);"
          >
          </div>

          <div
            class="relative rounded-2xl overflow-hidden"
            style="background: #0d1117; border: 1px solid rgba(255,255,255,0.09); box-shadow: 0 40px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.04);"
          >
            <!-- Chrome bar -->
            <div
              class="flex items-center gap-2 px-4 py-3.5"
              style="background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.07);"
            >
              <div
                class="w-3 h-3 rounded-full"
                style="background: #FF5F57;"
                aria-hidden="true"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full"
                style="background: #FEBC2E;"
                aria-hidden="true"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full"
                style="background: #28C840;"
                aria-hidden="true"
              >
              </div>
              <div class="flex-1 text-center">
                <span
                  class="text-xs font-mono"
                  style="color: rgba(255,255,255,0.25);"
                  >aws-production &middot; main</span
                >
              </div>
              <span
                class="w-1.5 h-1.5 rounded-full bg-emerald-400"
                aria-hidden="true"></span>
              <span
                class="text-xs font-mono"
                style="color: rgba(255,255,255,0.25);">live</span
              >
            </div>

            <!-- Terminal body -->
            <div
              class="p-5 font-mono text-xs sm:text-sm leading-relaxed space-y-1"
              aria-label="Terminal mostrando comandos de Terraform y Kubernetes"
            >
              <div class="flex items-center gap-2">
                <span style="color: #79C0FF;">❯</span>
                <span class="text-white">terraform apply --auto-approve</span>
              </div>
              <div
                class="mt-2 text-[0.68rem]"
                style="color: rgba(255,255,255,0.35);"
              >
                Plan: 14 to add, 0 to change, 0 to destroy.
              </div>
              <div class="space-y-0.5 mt-2">
                {
                  [
                    ['aws_vpc.main', '6s'],
                    ['aws_eks_cluster.main', '2m 18s'],
                    ['aws_rds_cluster.db', '1m 44s'],
                    ['aws_cloudfront_distribution.cdn', '47s'],
                    ['module.alb.aws_lb.main', '52s'],
                  ].map(([res, time]) => (
                    <div class="text-xs">
                      <span style="color: #3FB950;">✓</span>{' '}
                      <span style="color: rgba(255,255,255,0.5);">{res}</span>{' '}
                      <span style="color: rgba(255,255,255,0.22); font-size: 0.65rem;">
                        ({time})
                      </span>
                    </div>
                  ))
                }
              </div>
              <div class="mt-2.5 text-xs font-semibold" style="color: #3FB950;">
                Apply complete! Resources: 14 added.
              </div>

              <div class="mt-5 flex items-center gap-2">
                <span style="color: #79C0FF;">❯</span>
                <span class="text-white">kubectl get pods -n production</span>
              </div>
              <div class="space-y-0.5 mt-1">
                {
                  [
                    'webapp-7d4b9f-x2k9p',
                    'webapp-7d4b9f-m8n3q',
                    'webapp-7d4b9f-p9l1w',
                  ].map((pod) => (
                    <div style="font-size: 0.68rem;">
                      <span style="color: rgba(255,255,255,0.5);">
                        {pod}&nbsp;&nbsp;
                      </span>
                      <span style="color: rgba(255,255,255,0.4);">
                        2/2&nbsp;&nbsp;
                      </span>
                      <span style="color: #3FB950;">Running</span>
                    </div>
                  ))
                }
              </div>
              <div class="mt-4 flex items-center gap-1.5">
                <span style="color: #79C0FF;">❯</span>
                <span
                  class="terminal-cursor w-1.5 h-4 inline-block rounded-sm"
                  style="background: rgba(255,255,255,0.6);"
                  aria-hidden="true"></span>
              </div>
            </div>

            <!-- CI/CD strip -->
            <div
              class="px-5 pb-4 pt-2.5"
              style="border-top: 1px solid rgba(255,255,255,0.06);"
            >
              <div
                class="flex items-center gap-0.5"
                aria-label="Todas las etapas CI/CD completadas"
              >
                {
                  ['Build', 'Test', 'Security', 'Docker', 'Deploy'].map(
                    (step, i) => (
                      <div class="flex items-center">
                        <div class="flex items-center gap-1 text-xs font-mono">
                          <span style="color: #3FB950;" aria-hidden="true">
                            ✓
                          </span>
                          <span style="color: rgba(255,255,255,0.4); font-size: 0.62rem;">
                            {step}
                          </span>
                        </div>
                        {i < 4 && (
                          <div
                            class="w-4 h-px mx-1"
                            style="background: rgba(63,185,80,0.3);"
                            aria-hidden="true"
                          />
                        )}
                      </div>
                    )
                  )
                }
              </div>
            </div>
          </div>

          <!-- Badge: Deploy -->
          <div
            class="absolute -top-5 -right-2 sm:-right-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-400"
            style="border: 1px solid rgba(15,23,42,0.07);"
          >
            <div class="flex items-center gap-2 mb-0.5">
              <span
                class="w-2 h-2 rounded-full bg-emerald-400"
                aria-hidden="true"></span>
              <span class="text-xs font-bold text-gray-800"
                >Despliegue exitoso</span
              >
            </div>
            <p class="text-[10px]" style="color: #64748B;">
              aws-production &middot; hace 2m
            </p>
          </div>

          <!-- Badge: K8s -->
          <div
            class="absolute -bottom-5 -left-2 sm:-left-8 bg-white rounded-2xl px-4 py-3 shadow-xl animate-fade-up delay-500"
            style="border: 1px solid rgba(15,23,42,0.07);"
          >
            <div class="flex items-center gap-2 mb-1">
              <svg
                class="w-3.5 h-3.5"
                style="color: #2563EB;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"
                ></path>
              </svg>
              <span class="text-xs font-bold text-gray-800">EKS Cluster</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span
                class="w-1.5 h-1.5 rounded-full bg-emerald-400"
                aria-hidden="true"></span>
              <span class="text-[10px]" style="color: #64748B;"
                >3/3 nodos saludables</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 1B. BANDA DE CREDENCIALES — Certificaciones y señales de confianza   -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    style="background: white; border-bottom: 1px solid #E2E8F0; padding: 12px 0;"
    aria-label="Certificaciones del equipo y señales de confianza"
  >
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full"
          style="background: #F5F0FF; color: #7B42BC; border: 1px solid #D6B9F5;"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
            ></path></svg
          >
          HashiCorp Certified
        </span>
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full"
          style="background: #EFF8FF; color: #049FD9; border: 1px solid #BAE6FD;"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path></svg
          >
          Cisco Cybersecurity
        </span>
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full"
          style="background: #FFF5F5; color: #EE3124; border: 1px solid #FCA5A5;"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path></svg
          >
          Fortinet Certified ×2
        </span>
        <a
          href="/certificaciones"
          class="text-xs font-semibold transition-colors hover:opacity-80"
          style="color: #1E6FFF;">Ver todas las credenciales →</a
        >
        <span class="hidden sm:block w-px h-4 bg-gray-200" aria-hidden="true"></span>
        <span class="text-xs font-medium" style="color: #64748b;"
          >Solo credenciales OIDC · Sin claves AWS estáticas</span
        >
        <span class="hidden sm:block w-px h-4 bg-gray-200" aria-hidden="true"></span>
        <span class="text-xs font-medium" style="color: #64748b;"
          >NDA disponible · Conforme con GDPR</span
        >
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- 2. TECNOLOGÍAS                                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section
    style="background: #F8FAFC; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB;"
    aria-label="Tecnologías que operamos en producción"
  >
    <div class="max-w-7xl mx-auto px-6 py-16">
      <p
        class="text-center text-[11px] font-bold uppercase tracking-widest mb-12"
        style="color: #94A3B8;"
      >
        Tecnologías de producción en las que confiamos
      </p>
      <div class="grid grid-cols-4 sm:grid-cols-5 lg:grid-cols-10 gap-5">
        {
          [
            { name: 'AWS', path: 'M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z' },
            { name: 'Terraform', slug: 'terraform' },
            { name: 'Kubernetes', slug: 'kubernetes' },
            { name: 'Docker', slug: 'docker' },
            { name: 'GitHub Actions', slug: 'githubactions' },
            { name: 'ArgoCD', slug: 'argo' },
            { name: 'Helm', slug: 'helm' },
            { name: 'Jenkins', slug: 'jenkins' },
            { name: 'Ansible', slug: 'ansible' },
            { name: 'KinD', path: 'M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 004.5 9v.878m13.5-3A2.25 2.25 0 0119.5 9v.878m0 0a2.246 2.246 0 00-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0121 12v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6c0-.98.626-1.813 1.5-2.122' },
