---
import Layout from '../layouts/Layout.astro'
import Logo from '../components/ui/Logo.astro'
---

<Layout title="LRA CloudOps" description="LRA CloudOps — Coming soon">
  <main
    style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #FFFFFF;"
  >
    <div style="text-align: center; padding: 2rem;">
      <div class="hero-logo" style="display: inline-flex; margin-bottom: 3rem;">
        <Logo href="/" />
      </div>

      <h1 style="color: #111827; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; margin-bottom: 1rem;">
        Something new is coming.
      </h1>
      <p style="color: #6B7280; font-size: 1.125rem; max-width: 480px; margin: 0 auto 2.5rem;">
        We're rebuilding from the ground up. A new vision for cloud infrastructure is on the way.
      </p>

      <a
        href="mailto:info@lracloudops.com"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #111827; color: #FFF; padding: 0.875rem 2rem; border-radius: 9999px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 1rem; text-decoration: none;"
      >
        Get in touch →
      </a>
    </div>
  </main>
</Layout>

<style>
  .hero-logo :global(.logo-text) {
    color: #111827;
  }
</style>
