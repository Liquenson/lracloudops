---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Message sent — LRA Cloud Operations"
  descripcion="Thank you for contacting LRA Cloud Operations. We will respond within 24 hours."
>
  <section class="min-h-screen flex items-center justify-center px-4 py-20" style="background: #F8FAFF;">
    <div class="max-w-lg w-full text-center">
      <!-- Icon -->
      <div class="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-8" style="background: #EEF4FF;">
        <svg class="w-10 h-10" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <!-- Content card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider mb-6" style="background: #EEF4FF; color: #1E6FFF;">
          Message received
        </div>

        <h1 class="text-3xl font-bold mb-4" style="color: #0A2540;">
          Thank you for reaching out
        </h1>

        <p class="text-lg mb-6" style="color: #64748b;">
          We have received your message and will reply within <strong style="color: #0A2540;">24 hours</strong>.
        </p>

        <div class="rounded-xl p-5 mb-8 text-left" style="background: #F8FAFF; border: 1px solid #C7D7FD;">
          <p class="text-sm font-semibold mb-2" style="color: #0A2540;">What happens next?</p>
          <ul class="space-y-2 text-sm" style="color: #64748b;">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              We review your inquiry and prepare a tailored response.
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              If applicable, we will propose a free initial assessment call.
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              We will send our reply to your email address.
            </li>
          </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/en"
            class="px-6 py-3 rounded-xl font-semibold text-white text-sm transition-all"
            style="background: #1E6FFF;"
          >
            Back to home
          </a>
          <a
            href="/en/projects"
            class="px-6 py-3 rounded-xl font-semibold text-sm transition-all border"
            style="color: #1E6FFF; border-color: #C7D7FD; background: white;"
          >
            View projects
          </a>
        </div>
      </div>

      <p class="mt-8 text-sm" style="color: #94a3b8;">
        Prefer to write directly? <a href="mailto:info@lracloudops.com" style="color: #1E6FFF;">info@lracloudops.com</a>
      </p>
    </div>
  </section>
</Layout>
