---
import Layout from '../../../layouts/Layout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'AWS Production Readiness Checklist — Free Download',
  description:
    'A 45-point checklist used by LRA Cloud Operations on every AWS engagement. Covers IAM, networking, compute, storage, observability, cost and security.',
  url: 'https://lracloudops.com/resources/aws-checklist',
  author: { '@type': 'Organization', name: 'LRA Cloud Ops' },
}
---

<Layout
  titulo="AWS Production Readiness Checklist"
  descripcion="Free 45-point AWS production readiness checklist used on every LRA Cloud Operations engagement. Covers IAM, networking, EKS, observability, cost optimization and security hardening."
  schema={schema}
>
  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none opacity-30"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div class="relative max-w-5xl mx-auto px-5 sm:px-6 py-20 sm:py-24">
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-6">
            <span
              class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
            >
              Free Resource
            </span>
            <span
              class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: rgba(16,185,129,0.15); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.25);"
            >
              45 checkpoints
            </span>
          </div>
          <h1
            class="text-4xl sm:text-5xl font-extrabold text-white mb-5"
            style="letter-spacing: -0.02em; line-height: 1.08;"
          >
            AWS Production<br />Readiness Checklist
          </h1>
          <p class="text-lg mb-8" style="color: rgba(147,184,255,0.8);">
            The same 45-point checklist we run on every AWS engagement before
            any workload goes live. Covers IAM, networking, EKS, observability,
            cost and security hardening.
          </p>
          <div class="flex flex-wrap gap-3 text-sm" style="color: rgba(147,184,255,0.7);">
            {['IAM & Access Control', 'VPC & Networking', 'EKS & Compute', 'Observability', 'Cost Optimization', 'Security Hardening'].map(tag => (
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" style="color:#1E6FFF;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- FORM -->
        <div
          class="w-full lg:w-[400px] flex-shrink-0 rounded-2xl p-8"
          style="background: white; box-shadow: 0 8px 40px rgba(0,0,0,0.25);"
        >
          <h2 class="text-xl font-bold mb-1" style="color: #0A2540;">
            Get instant access
          </h2>
          <p class="text-sm mb-6" style="color: #64748b;">
            No spam. One email with your checklist link.
          </p>

          <form id="checklist-form" class="space-y-4">
            <input type="hidden" name="access_key" value="e8aaab4e-270c-4163-bb76-6a8dfc247485" />
            <input type="hidden" name="subject" value="AWS Checklist download — lracloudops.com" />
            <input type="hidden" name="from_name" value="LRA Cloud Operations" />
            <input type="hidden" name="redirect" value="https://lracloudops.com/resources/aws-checklist-thanks" />

            <div>
              <label for="name" class="block text-sm font-medium mb-1.5" style="color: #0F172A;">
                Full name <span aria-hidden="true" style="color:#EF4444;">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder="Ruben Liquenson"
                class="w-full rounded-xl px-4 py-3 text-sm transition-all outline-none"
                style="border: 1.5px solid #E2E8F0; color: #0F172A; background: #FAFAFA;"
                onfocus="this.style.borderColor='#2563EB'; this.style.background='white';"
                onblur="this.style.borderColor='#E2E8F0'; this.style.background='#FAFAFA';"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium mb-1.5" style="color: #0F172A;">
                Business email <span aria-hidden="true" style="color:#EF4444;">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="you@company.com"
                class="w-full rounded-xl px-4 py-3 text-sm transition-all outline-none"
                style="border: 1.5px solid #E2E8F0; color: #0F172A; background: #FAFAFA;"
                onfocus="this.style.borderColor='#2563EB'; this.style.background='white';"
                onblur="this.style.borderColor='#E2E8F0'; this.style.background='#FAFAFA';"
              />
            </div>

            <div>
              <label for="role" class="block text-sm font-medium mb-1.5" style="color: #0F172A;">
                Your role
              </label>
              <select
                id="role"
                name="role"
                class="w-full rounded-xl px-4 py-3 text-sm outline-none"
                style="border: 1.5px solid #E2E8F0; color: #0F172A; background: #FAFAFA; appearance: none;"
                onfocus="this.style.borderColor='#2563EB';"
                onblur="this.style.borderColor='#E2E8F0';"
                aria-label="Your role"
              >
                <option value="">Select...</option>
                <option value="cto-vp">CTO / VP Engineering</option>
                <option value="devops-engineer">DevOps / Platform Engineer</option>
                <option value="cloud-architect">Cloud Architect</option>
                <option value="sre">SRE</option>
                <option value="developer">Software Developer</option>
                <option value="other">Other</option>
              </select>
            </div>

            <button
              type="submit"
              id="checklist-submit"
              class="w-full py-3.5 rounded-xl text-sm font-semibold text-white transition-all hover:-translate-y-px active:scale-[0.98]"
              style="background: #2563EB; box-shadow: 0 4px 16px rgba(37,99,235,0.35);"
            >
              Send me the checklist →
            </button>

            <p class="text-xs text-center" style="color: #94A3B8;">
              By submitting you agree to our <a href="/privacy" style="color:#1E6FFF;">Privacy Policy</a>.
              Unsubscribe anytime.
            </p>
          </form>

          <div id="checklist-success" class="hidden text-center py-6">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4" style="background:#DCFCE7;">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#16A34A;" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="font-semibold mb-1" style="color:#0A2540;">Redirecting you now…</p>
            <p class="text-sm" style="color:#64748b;">Your checklist is ready.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PREVIEW of what's inside -->
  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <div class="text-center mb-12">
        <span class="section-label mb-4">What's inside</span>
        <h2 class="text-3xl font-extrabold mt-4" style="color: #0A2540; letter-spacing: -0.02em;">
          45 production-grade checkpoints
        </h2>
        <p class="text-base mt-3 max-w-xl mx-auto" style="color: #64748b;">
          Structured into 6 domains. Each checkpoint has a pass/fail criterion
          and a remediation note.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
            title: 'IAM & Access Control',
            count: 8,
            items: ['Root account MFA enforced', 'IAM roles — least privilege', 'No long-lived access keys', 'SCPs configured in AWS Org'],
          },
          {
            icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
            title: 'VPC & Networking',
            count: 7,
            items: ['Private subnets for compute', 'NAT Gateway vs VPC endpoints', 'Security groups — no 0.0.0.0/0', 'VPC Flow Logs enabled'],
          },
          {
            icon: 'M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9',
            title: 'EKS & Compute',
            count: 9,
            items: ['Managed node groups', 'IRSA (not EC2 instance profiles)', 'Cluster autoscaler configured', 'PodDisruptionBudgets set'],
          },
          {
            icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            title: 'Observability',
            count: 8,
            items: ['CloudWatch alarms on p99 latency', 'Structured logging (JSON)', 'Distributed tracing (X-Ray)', 'On-call runbooks per alert'],
          },
          {
            icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
            title: 'Cost Optimization',
            count: 6,
            items: ['AWS Cost Anomaly Detection', 'Reserved Instances / Savings Plans', 'S3 lifecycle policies', 'Compute rightsizing review'],
          },
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: 'Security Hardening',
            count: 7,
            items: ['GuardDuty enabled', 'Secrets Manager (no env secrets)', 'ECR image scanning on push', 'Encryption at rest + in transit'],
          },
        ].map(({ icon, title, count, items }) => (
          <div
            class="rounded-2xl p-6"
            style="background: #F8FAFC; border: 1px solid #E2E8F0;"
          >
            <div class="flex items-center gap-3 mb-4">
              <div
                class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0"
                style="background: #EEF4FF;"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#2563EB;" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                </svg>
              </div>
              <div>
                <div class="text-sm font-bold" style="color:#0A2540;">{title}</div>
                <div class="text-xs" style="color:#94A3B8;">{count} checkpoints</div>
              </div>
            </div>
            <ul class="space-y-1.5">
              {items.map(item => (
                <li class="flex items-start gap-2 text-xs" style="color:#64748b;">
                  <svg class="w-3 h-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#2563EB;" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
              <li class="text-xs italic" style="color:#94A3B8;">+ more…</li>
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a
          href="#checklist-form"
          class="inline-flex items-center gap-2 text-sm font-semibold text-white px-7 py-3.5 rounded-xl transition-all hover:-translate-y-px"
          style="background:#2563EB; box-shadow:0 4px 16px rgba(37,99,235,0.3);"
        >
          Get the full checklist — free
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('checklist-form') as HTMLFormElement
  const successDiv = document.getElementById('checklist-success')
  const submitBtn = document.getElementById('checklist-submit') as HTMLButtonElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    submitBtn.disabled = true
    submitBtn.textContent = 'Sending…'

    const data = Object.fromEntries(new FormData(form))
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      })
      if (res.ok) {
        form.classList.add('hidden')
        successDiv?.classList.remove('hidden')
        setTimeout(() => {
          window.location.href = '/resources/aws-checklist-thanks'
        }, 1200)
      } else {
        submitBtn.disabled = false
        submitBtn.textContent = 'Send me the checklist →'
        alert('Something went wrong. Please try again.')
      }
    } catch {
      submitBtn.disabled = false
      submitBtn.textContent = 'Send me the checklist →'
      alert('Network error. Please try again.')
    }
  })
</script>
