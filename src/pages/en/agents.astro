---
import Layout from '../../layouts/Layout.astro'

const agents = [
  {
    num: '01',
    name: 'DevOps Advisor',
    desc: '24/7 floating chat with production context',
    status: 'Active',
    href: '/en/',
    iconPath:
      'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z',
  },
  {
    num: '02',
    name: 'Multi-Agent Orchestrator',
    desc: 'Delegates to specialist agents based on context',
    status: 'Active',
    href: '/api/multi-advisor',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    num: '03',
    name: 'Infrastructure Review',
    desc: 'AI-powered cloud architecture audit',
    status: 'Active',
    href: '/en/infrastructure-review',
    iconPath:
      'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    num: '04',
    name: 'Proposal Generator',
    desc: 'Automatic technical proposals in seconds',
    status: 'Active',
    href: '/en/proposal',
    iconPath:
      'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
  },
  {
    num: '05',
    name: 'Cost Optimizer',
    desc: 'AI-powered cloud cost optimization',
    status: 'Active',
    href: '/en/cost-optimizer',
    iconPath:
      'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    num: '06',
    name: 'Learning Agent',
    desc: 'Virtual DevOps and cloud teacher with AI',
    status: 'Active',
    href: '/en/learn',
    iconPath:
      'M12 14l9-5-9-5-9 5 9 5zm0 7v-4m0 0l-3.536-1.768M12 17l3.536-1.768',
  },
  {
    num: '07',
    name: 'Daily Maintenance',
    desc: 'Automated blog and daily maintenance at 9am UTC',
    status: 'Active',
    href: null,
    iconPath: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    num: '08',
    name: 'Security Agent',
    desc: 'AI-powered cloud security vulnerability scanner',
    status: 'Active',
    href: '/en/security-audit',
    iconPath:
      'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
  },
  {
    num: '09',
    name: 'AWS Architect',
    desc: 'AWS architecture design with Well-Architected Framework',
    status: 'Active',
    href: '/en/aws-architect',
    iconPath:
      'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  },
  {
    num: '10',
    name: 'Incident Response',
    desc: 'Diagnose and resolve cloud incidents instantly',
    status: 'Active',
    href: '/en/incident-response',
    iconPath:
      'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  },
  {
    num: '11',
    name: 'Documentation Agent',
    desc: 'Generate README, ADR, Runbooks and SOPs instantly',
    status: 'Active',
    href: '/en/documentation',
    iconPath:
      'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    num: '12',
    name: 'DevOps Interview',
    desc: 'Practice DevOps interviews with AI and get instant feedback',
    status: 'Active',
    href: '/en/interview',
    iconPath:
      'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    num: '13',
    name: 'Resume Review',
    desc: 'Optimize your DevOps resume for ATS with AI feedback',
    status: 'Active',
    href: '/en/resume-review',
    iconPath:
      'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
  },
  {
    num: '14',
    name: 'AI AWS CLI Agent',
    desc: 'Natural language to AWS CLI commands instantly',
    status: 'Active',
    href: '/en/aws-cli',
    iconPath:
      'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    num: '15',
    name: 'Orchestrator Agent',
    desc: 'Autonomous maintenance 3 times per day',
    status: 'Active',
    href: null,
    iconPath:
      'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
]

const systemAgents = [
  {
    name: 'LRA Orchestrator',
    schedule: '3× per day (9am, 3pm, 9pm UTC)',
    desc: 'Full health check: build, links, ES/EN parity',
  },
  {
    name: 'Health Check',
    schedule: 'Every 6 hours',
    desc: 'Verifies build and TypeScript without errors',
  },
  {
    name: 'Weekly Sync',
    schedule: 'Monday 8am UTC',
    desc: 'Weekly audit with scored report',
  },
  {
    name: 'Daily Blog',
    schedule: 'Daily 9am UTC',
    desc: 'New technical article in ES and EN automatically',
  },
]
---

<Layout
  titulo="LRA AI Agents · Autonomous AI Ecosystem"
  descripcion="15 AI agents working continuously to maintain, improve and scale the LRA Cloud Operations platform. DevOps Advisor, multi-agent orchestration and autonomous automation."
  keywords="LRA AI agents, DevOps AI agents, autonomous automation, multi-agent AI, Claude Sonnet DevOps, orchestrator agent, autonomous infrastructure"
>
  <!-- ── HERO ── -->
  <section
    class="relative overflow-hidden"
    style="background: #0a0a0a;"
    aria-labelledby="agents-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.06) 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.15) 0%, transparent 60%);"
    >
    </div>

    <div
      class="relative max-w-5xl mx-auto px-5 sm:px-6 py-24 sm:py-32 text-center"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold mb-8"
        style="background: rgba(30,111,255,0.12); border: 1px solid rgba(96,165,250,0.25); color: #93C5FD;"
      >
        <span
          class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0 animate-pulse"
          aria-hidden="true"></span>
        15 Agents · Autonomous System
      </div>

      <h1
        id="agents-hero-heading"
        class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.04em; line-height: 1.05;"
      >
        LRA AI Agents
      </h1>

      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-10"
        style="color: rgba(147,184,255,0.8);"
      >
        An ecosystem of AI agents that work continuously to maintain and improve
        the platform. From 24/7 consulting to autonomous orchestration.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <button
          onclick="document.getElementById('lra-chat-toggle')?.click()"
          class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
          style="background: #2563EB; box-shadow: 0 4px 24px rgba(37,99,235,0.5);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
            ></path>
          </svg>
          Talk to the DevOps Advisor
        </button>
        <a
          href="#agents"
          class="inline-flex items-center gap-2 text-sm font-semibold px-8 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.2);"
        >
          See all agents
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── METRICS ── -->
  <section
    style="background: #0f0f0f; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06);"
    aria-label="System metrics"
  >
    <div class="max-w-5xl mx-auto px-6 py-14">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {
          [
            { value: '15', label: 'Active agents', sub: 'in production' },
            { value: '24/7', label: 'Availability', sub: 'no interruptions' },
            {
              value: '3×/day',
              label: 'Autonomous orchestration',
              sub: 'automated maintenance',
            },
            {
              value: '0',
              label: 'Manual interventions',
              sub: 'in routine maintenance',
            },
          ].map(({ value, label, sub }) => (
            <div class="text-center">
              <div
                class="text-4xl sm:text-5xl font-extrabold mb-2"
                style="color: #1E6FFF; letter-spacing: -0.04em;"
              >
                {value}
              </div>
              <div class="text-sm font-medium text-white mb-1">{label}</div>
              <div class="text-xs" style="color: rgba(147,184,255,0.5);">
                {sub}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── AGENT GRID ── -->
  <section
    id="agents"
    style="background: #0a0a0a;"
    aria-labelledby="agents-grid-heading"
  >
    <div class="max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="text-center mb-16">
        <span
          class="inline-flex items-center text-xs font-bold px-3 py-1.5 rounded-full mb-4 uppercase tracking-widest"
          style="background: rgba(30,111,255,0.15); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
          >Ecosystem</span
        >
        <h2
          id="agents-grid-heading"
          class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
          style="letter-spacing: -0.03em;"
        >
          LRA's 15 agents
        </h2>
        <p
          class="text-lg max-w-xl mx-auto"
          style="color: rgba(147,184,255,0.7);"
        >
          Each agent has a specific specialty and works in a coordinated way
          with the rest of the system.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          agents.map(({ num, name, desc, status, href, iconPath }) => (
            <div
              class="rounded-2xl p-6 flex flex-col gap-4 group transition-all"
              style="background: #141414; border: 1px solid rgba(255,255,255,0.07);"
            >
              <div class="flex items-start justify-between gap-3">
                <div class="flex items-center gap-3">
                  <div
                    class="w-10 h-10 flex items-center justify-center rounded-xl flex-shrink-0"
                    style="background: rgba(37,99,235,0.15);"
                    aria-hidden="true"
                  >
                    <svg
                      class="w-5 h-5"
                      style="color: #60A5FA;"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d={iconPath}
                      />
                    </svg>
                  </div>
                  <span
                    class="text-xs font-mono"
                    style="color: rgba(96,165,250,0.5);"
                  >
                    {num}
                  </span>
                </div>
                <span
                  class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0"
                  style="background: rgba(16,185,129,0.12); color: #34D399; border: 1px solid rgba(16,185,129,0.2);"
                >
                  <span
                    class="w-1 h-1 rounded-full bg-emerald-400 flex-shrink-0"
                    aria-hidden="true"
                  />
                  {status}
                </span>
              </div>

              <div class="flex-1">
                <h3 class="text-base font-bold text-white mb-1.5">{name}</h3>
                <p
                  class="text-sm leading-relaxed"
                  style="color: rgba(147,184,255,0.65);"
                >
                  {desc}
                </p>
              </div>

              {href ? (
                <a
                  href={href}
                  class="inline-flex items-center gap-1.5 text-xs font-semibold transition-colors mt-auto"
                  style="color: #60A5FA;"
                >
                  Open agent
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </a>
              ) : (
                <span
                  class="inline-flex items-center gap-1.5 text-xs font-semibold mt-auto"
                  style="color: rgba(96,165,250,0.4);"
                >
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                  GitHub Actions
                </span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── SYSTEM AGENTS ── -->
  <section
    style="background: #0f0f0f; border-top: 1px solid rgba(255,255,255,0.06);"
    aria-labelledby="system-agents-heading"
  >
    <div class="max-w-6xl mx-auto px-6 py-20 sm:py-24">
      <div class="text-center mb-14">
        <span
          class="inline-flex items-center text-xs font-bold px-3 py-1.5 rounded-full mb-4 uppercase tracking-widest"
          style="background: rgba(30,111,255,0.15); color: #93C5FD; border: 1px solid rgba(96,165,250,0.25);"
          >Autonomous workflows</span
        >
        <h2
          id="system-agents-heading"
          class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
          style="letter-spacing: -0.03em;"
        >
          System agents
        </h2>
        <p
          class="text-lg max-w-xl mx-auto"
          style="color: rgba(147,184,255,0.7);"
        >
          Automated processes running on GitHub Actions without human
          intervention.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {
          systemAgents.map(({ name, schedule, desc }) => (
            <div
              class="rounded-2xl p-6"
              style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);"
            >
              <div
                class="w-2 h-2 rounded-full bg-emerald-400 mb-4"
                aria-hidden="true"
              />
              <h3 class="text-sm font-bold text-white mb-1">{name}</h3>
              <p
                class="text-xs font-mono mb-3"
                style="color: rgba(96,165,250,0.7);"
              >
                {schedule}
              </p>
              <p
                class="text-xs leading-relaxed"
                style="color: rgba(147,184,255,0.6);"
              >
                {desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section
    class="relative overflow-hidden"
    style="background: #0a0a0a; border-top: 1px solid rgba(255,255,255,0.06);"
    aria-labelledby="agents-cta-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div class="relative max-w-3xl mx-auto px-6 py-24 text-center">
      <h2
        id="agents-cta-heading"
        class="text-3xl sm:text-4xl font-extrabold text-white mb-5"
        style="letter-spacing: -0.03em;"
      >
        Talk to the DevOps Advisor now
      </h2>
      <p
        class="text-lg mb-8 max-w-xl mx-auto"
        style="color: rgba(147,184,255,0.75);"
      >
        The most accessible agent in the ecosystem. Available 24/7 to answer any
        question about cloud, Kubernetes or infrastructure.
      </p>
      <button
        onclick="document.getElementById('lra-chat-toggle')?.click()"
        class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
        style="background: #2563EB; box-shadow: 0 4px 24px rgba(37,99,235,0.5);"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
          ></path>
        </svg>
        Open DevOps Advisor · AI
      </button>
    </div>
  </section>
</Layout>
