---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Resume Review Agent · Optimize Your DevOps Resume for ATS · AI-Powered · Free"
  descripcion="Optimize your DevOps resume for ATS. ATS score, missing keywords, concrete improvements with examples and role fit (DevOps, Platform, Cloud, SRE)."
>
  <!-- HERO -->
  <section
    class="relative overflow-hidden"
    style="background: #0A2540;"
    aria-labelledby="rr-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.1) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-7 text-xs font-bold tracking-widest uppercase"
        style="background: rgba(37,99,235,0.25); border: 1px solid rgba(96,165,250,0.35); color: #93C5FD;"
      >
        <span
          class="w-2 h-2 rounded-full flex-shrink-0"
          style="background: #60A5FA; animation: pulse 2s infinite;"
          aria-hidden="true"></span>
        AI-Powered · ATS · Free
      </div>
      <h1
        id="rr-hero-heading"
        class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight"
        style="letter-spacing: -0.035em;"
      >
        Resume Review Agent
      </h1>
      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto"
        style="color: rgba(147,184,255,0.85);"
      >
        Optimize your DevOps resume for ATS. ATS score, missing keywords and
        concrete improvements with examples.
      </p>
    </div>
  </section>

  <!-- FORM + RESULTS -->
  <section class="bg-white py-16" aria-label="Resume review form">
    <div class="max-w-3xl mx-auto px-6">
      <form id="rr-form" class="space-y-6" novalidate>
        <div>
          <label
            for="rr-role"
            class="block text-sm font-semibold mb-2"
            style="color: #0F172A;">Target role</label
          >
          <select
            id="rr-role"
            class="w-full px-4 py-3 rounded-xl text-sm border focus:outline-none"
            style="border-color: #E2E8F0; color: #0F172A;"
          >
            <option value="DevOps Engineer" selected>DevOps Engineer</option>
            <option value="Platform Engineer">Platform Engineer</option>
            <option value="Cloud Engineer">Cloud Engineer</option>
            <option value="SRE">Site Reliability Engineer (SRE)</option>
          </select>
        </div>
        <div>
          <label
            for="rr-cv"
            class="block text-sm font-semibold mb-2"
            style="color: #0F172A;"
          >
            Paste your resume here (plain text)
            <span class="font-normal text-xs ml-1" style="color: #64748B;"
              >(required)</span
            >
          </label>
          <textarea
            id="rr-cv"
            rows="14"
            placeholder="Copy and paste your resume content as plain text. Include experience, skills, education, projects and certifications..."
            class="w-full px-4 py-3 rounded-xl text-sm border resize-none focus:outline-none focus:ring-2"
            style="border-color: #E2E8F0; color: #0F172A;"></textarea>
        </div>
        <button
          type="submit"
          id="rr-submit"
          class="w-full inline-flex items-center justify-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.01]"
          style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.4);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
            ></path>
          </svg>
          <span id="rr-btn-text">Analyze my resume →</span>
        </button>
        <p id="rr-error" class="hidden text-sm text-red-600 text-center"></p>
      </form>

      <!-- Loading -->
      <div id="rr-loading" class="hidden text-center py-16">
        <div
          class="inline-flex items-center gap-3 px-6 py-4 rounded-2xl"
          style="background: #EEF4FF; border: 1px solid #93C5FD;"
        >
          <svg
            class="w-5 h-5 animate-spin"
            style="color: #2563EB;"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="text-sm font-medium" style="color: #2563EB;"
            >Analyzing your resume...</span
          >
        </div>
      </div>

      <!-- Results -->
      <div id="rr-results" class="hidden mt-10 space-y-6">
        <div class="rounded-2xl p-8" style="background: #0A2540;">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
            <div>
              <p
                class="text-xs font-bold uppercase tracking-widest mb-2"
                style="color: #93C5FD;"
              >
                ATS Score
              </p>
              <div class="flex items-end gap-1">
                <span
                  id="rr-ats"
                  class="text-5xl font-extrabold"
                  style="color: #60A5FA;"></span>
                <span class="text-lg mb-1" style="color: rgba(147,184,255,0.5);"
                  >/100</span
                >
              </div>
            </div>
            <div class="text-right">
              <p
                class="text-xs font-semibold uppercase tracking-widest mb-1"
                style="color: #93C5FD;"
              >
                Overall rating
              </p>
              <div
                id="rr-rating"
                class="text-4xl font-extrabold"
                style="color: #60A5FA;"
              >
              </div>
              <p class="text-xs" style="color: rgba(147,184,255,0.6);">/10</p>
            </div>
          </div>
          <p
            id="rr-summary"
            class="text-sm leading-relaxed"
            style="color: rgba(147,184,255,0.85);"
          >
          </p>
        </div>

        <div
          class="rounded-2xl p-6"
          style="background: #F0FDF4; border: 1px solid #BBF7D0;"
        >
          <h2 class="text-sm font-bold mb-3" style="color: #15803D;">
            Strengths
          </h2>
          <ul id="rr-strengths" class="space-y-2"></ul>
        </div>

        <div
          id="rr-issues-section"
          class="hidden rounded-2xl p-6"
          style="background: #FFF5F5; border: 1px solid #FCA5A5;"
        >
          <h2 class="text-sm font-bold mb-3" style="color: #DC2626;">
            Critical issues
          </h2>
          <ul id="rr-issues" class="space-y-2"></ul>
        </div>

        <div
          id="rr-keywords-section"
          class="hidden rounded-2xl p-6"
          style="border: 1px solid #E5E7EB;"
        >
          <h2 class="text-sm font-bold mb-3" style="color: #0F172A;">
            Missing keywords
          </h2>
          <div id="rr-keywords" class="flex flex-wrap gap-2"></div>
        </div>

        <div
          class="rounded-2xl p-6"
          style="background: #F8FAFF; border: 1px solid #DBEAFE;"
        >
          <h2 class="text-sm font-bold mb-4" style="color: #1E40AF;">
            Improvements by section
          </h2>
          <div id="rr-improvements" class="space-y-4"></div>
        </div>

        <div class="rounded-2xl p-6" style="border: 1px solid #E5E7EB;">
          <h2 class="text-sm font-bold mb-4" style="color: #0F172A;">
            Role fit
          </h2>
          <div id="rr-roles" class="space-y-3"></div>
        </div>

        <div
          class="rounded-2xl p-6"
          style="background: #EEF4FF; border: 1px solid #BFDBFE;"
        >
          <h2 class="text-sm font-bold mb-3" style="color: #1E40AF;">
            LinkedIn tips
          </h2>
          <ul id="rr-linkedin" class="space-y-2"></ul>
        </div>

        <div class="text-center pt-4 pb-2">
          <p class="text-base font-semibold mb-4" style="color: #0F172A;">
            Looking for cloud/DevOps work?
          </p>
          <a
            href="/en/contact"
            class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02]"
            style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.35);"
          >
            Talk to LRA →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('rr-form') as HTMLFormElement
  const loading = document.getElementById('rr-loading')!
  const results = document.getElementById('rr-results')!
  const errorEl = document.getElementById('rr-error')!
  const btnText = document.getElementById('rr-btn-text')!
  const submitBtn = document.getElementById('rr-submit') as HTMLButtonElement

  interface Improvement {
    section: string
    issue: string
    suggestion: string
    example?: string
  }

  function atsColor(score: number): string {
    if (score >= 80) return '#16A34A'
    if (score >= 60) return '#2563EB'
    if (score >= 40) return '#D97706'
    return '#DC2626'
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    const cv = (document.getElementById('rr-cv') as HTMLTextAreaElement).value
    const role = (document.getElementById('rr-role') as HTMLSelectElement).value

    if (cv.trim().length < 50) {
      errorEl.textContent =
        'Please paste your full resume (minimum 50 characters).'
      errorEl.classList.remove('hidden')
      return
    }

    form.classList.add('hidden')
    loading.classList.remove('hidden')
    submitBtn.disabled = true
    btnText.textContent = 'Analyzing...'

    try {
      const res = await fetch('/api/resume-review', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ resume_text: cv, target_role: role }),
      })
      const json = (await res.json()) as {
        review?: Record<string, unknown>
        error?: string
      }
      if (json.error) throw new Error(json.error)
      const r = json.review ?? {}

      const ats = typeof r.ats_score === 'number' ? r.ats_score : 0
      const atsEl = document.getElementById('rr-ats')!
      atsEl.textContent = String(ats)
      atsEl.style.color = atsColor(ats)

      const rating = typeof r.overall_rating === 'number' ? r.overall_rating : 0
      const ratingEl = document.getElementById('rr-rating')!
      ratingEl.textContent = String(rating)
      ratingEl.style.color = atsColor(rating * 10)

      document.getElementById('rr-summary')!.textContent =
        typeof r.summary === 'string' ? r.summary : ''

      const strengths = Array.isArray(r.strengths)
        ? (r.strengths as string[])
        : []
      document.getElementById('rr-strengths')!.innerHTML = strengths
        .map(
          (s) =>
            `<li class="flex gap-2.5 text-sm" style="color:#15803D;"><span style="flex-shrink:0;">✓</span><span>${s}</span></li>`
        )
        .join('')

      const issues = Array.isArray(r.critical_issues)
        ? (r.critical_issues as string[])
        : []
      const issuesSection = document.getElementById('rr-issues-section')!
      if (issues.length > 0) {
        issuesSection.classList.remove('hidden')
        document.getElementById('rr-issues')!.innerHTML = issues
          .map(
            (i) =>
              `<li class="flex gap-2.5 text-sm" style="color:#DC2626;"><span style="flex-shrink:0;">✗</span><span>${i}</span></li>`
          )
          .join('')
      }

      const keywords = Array.isArray(r.missing_keywords)
        ? (r.missing_keywords as string[])
        : []
      const kwSection = document.getElementById('rr-keywords-section')!
      if (keywords.length > 0) {
        kwSection.classList.remove('hidden')
        document.getElementById('rr-keywords')!.innerHTML = keywords
          .map(
            (k) =>
              `<span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background:#FEF3C7; color:#92400E; border:1px solid #FDE68A;">${k}</span>`
          )
          .join('')
      }

      const improvements = Array.isArray(r.improvements)
        ? (r.improvements as Improvement[])
        : []
      document.getElementById('rr-improvements')!.innerHTML = improvements
        .map(
          (imp) =>
            `<div class="rounded-xl p-4" style="background:white; border:1px solid #DBEAFE;">
            <div class="text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#2563EB;">${imp.section}</div>
            <div class="text-sm font-semibold mb-1" style="color:#DC2626;">${imp.issue}</div>
            <div class="text-sm mb-2" style="color:#475569;">${imp.suggestion}</div>
            ${imp.example ? `<div class="text-xs rounded-lg px-3 py-2" style="background:#F0FDF4; color:#15803D; border:1px solid #BBF7D0;">"${imp.example}"</div>` : ''}
          </div>`
        )
        .join('')

      const roleFit = (
        r.role_fit && typeof r.role_fit === 'object' ? r.role_fit : {}
      ) as Record<string, number>
      document.getElementById('rr-roles')!.innerHTML = Object.entries(roleFit)
        .map(([r2, pct]) => {
          const color = atsColor(pct)
          return `<div>
            <div class="flex justify-between text-sm mb-1.5">
              <span style="color:#0F172A; font-weight:600;">${r2}</span>
              <span style="color:${color}; font-weight:700;">${pct}%</span>
            </div>
            <div class="h-2 rounded-full overflow-hidden" style="background:#F1F5F9;">
              <div class="h-full rounded-full" style="width:${pct}%; background:${color};"></div>
            </div>
          </div>`
        })
        .join('')

      const linkedin = Array.isArray(r.linkedin_tips)
        ? (r.linkedin_tips as string[])
        : []
      document.getElementById('rr-linkedin')!.innerHTML = linkedin
        .map(
          (t) =>
            `<li class="flex gap-2.5 text-sm" style="color:#1E40AF;"><span style="flex-shrink:0;">→</span><span>${t}</span></li>`
        )
        .join('')

      loading.classList.add('hidden')
      results.classList.remove('hidden')
    } catch (err) {
      loading.classList.add('hidden')
      form.classList.remove('hidden')
      submitBtn.disabled = false
      btnText.textContent = 'Analyze my resume →'
      errorEl.textContent =
        err instanceof Error
          ? err.message
          : 'Error analyzing resume. Please try again.'
      errorEl.classList.remove('hidden')
    }
  })
</script>
