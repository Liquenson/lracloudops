---
import Layout from '../../../layouts/Layout.astro'
---

<Layout
  titulo="Healthcare Cloud Infrastructure"
  descripcion="HIPAA-compliant cloud infrastructure for healthcare organizations. Encrypted data pipelines, audit logging, VPC isolation, and compliant Kubernetes platforms on AWS."
>
  <!-- Hero -->
  <section
    style="background: linear-gradient(135deg, #0A2540 0%, #0d2f50 100%); padding: 100px 24px 80px;"
  >
    <div class="max-w-4xl mx-auto text-center">
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8"
        style="background: rgba(30,111,255,0.15); color: #60A5FA; border: 1px solid rgba(30,111,255,0.25);"
      >
        Industry · Healthcare
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6 leading-tight">
        HIPAA-compliant infrastructure<br />built for healthcare at scale.
      </h1>
      <p
        class="text-lg sm:text-xl max-w-2xl mx-auto mb-10"
        style="color: rgba(148,163,184,0.9);"
      >
        Cloud infrastructure designed for the security, auditability, and uptime
        requirements of healthcare organizations — without slowing down your
        engineering team.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-white transition-all hover:-translate-y-px"
          style="background: #1E6FFF; box-shadow: 0 4px 20px rgba(30,111,255,0.4);"
        >
          Schedule compliance review
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
        <a
          href="/cloud-infrastructure"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl font-semibold transition-all hover:bg-white/10"
          style="color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.15);"
        >
          View infrastructure services
        </a>
      </div>
    </div>
  </section>

  <!-- Key points -->
  <section style="background: #F8FAFC; padding: 80px 24px;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold mb-4" style="color: #0A2540;">
          Infrastructure that meets healthcare compliance requirements
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          Compliance is an architecture decision, not a checkbox exercise.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {
          [
            {
              title: 'HIPAA-aligned AWS architecture',
              desc: 'Dedicated VPCs with private subnets for PHI workloads, AWS KMS encryption at rest and in transit, CloudTrail with tamper-proof logging, and AWS Macie for PHI detection.',
              icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
            },
            {
              title: 'Audit logging and access controls',
              desc: 'Every API call logged to immutable CloudTrail. IAM policies with least-privilege access. Role-based access enforced through IRSA for Kubernetes workloads. Full audit trail for compliance reviews.',
              icon: 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z',
            },
            {
              title: 'High availability and disaster recovery',
              desc: 'Multi-AZ RDS with automated backups, EKS with cross-AZ node groups, and Route 53 health-check failover. RTO and RPO targets defined and tested, not assumed.',
              icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
            },
            {
              title: 'Secure CI/CD for regulated environments',
              desc: 'Container image signing with Cosign, mandatory vulnerability scanning before any image reaches production, and environment-specific approval workflows for PHI-adjacent deployments.',
              icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
            },
          ].map(({ title, desc, icon }) => (
            <div
              class="bg-white rounded-2xl p-7"
              style="border: 1px solid rgba(15,23,42,0.06); box-shadow: 0 2px 12px rgba(15,23,42,0.04);"
            >
              <div
                class="w-10 h-10 rounded-xl flex items-center justify-center mb-5"
                style="background: #EEF4FF;"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  style="color: #1E6FFF;"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={icon}
                  />
                </svg>
              </div>
              <h3 class="text-lg font-semibold mb-3" style="color: #0A2540;">
                {title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">
                {desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: #0A2540; padding: 80px 24px;">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">
        Need HIPAA-compliant cloud infrastructure?
      </h2>
      <p class="text-lg mb-10" style="color: rgba(148,163,184,0.85);">
        Schedule a compliance architecture review. We'll assess your current
        posture and design an infrastructure that passes your next audit.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-10 py-4 rounded-xl font-semibold text-white transition-all hover:-translate-y-px"
        style="background: #1E6FFF; box-shadow: 0 4px 24px rgba(30,111,255,0.45);"
      >
        Schedule compliance review
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
        >
      </a>
    </div>
  </section>
</Layout>
