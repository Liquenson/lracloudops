---
import Layout from '../../layouts/Layout.astro'
import { Image } from 'astro:assets'
---

<Layout
  titulo="Our Team | DevOps Engineers & Cloud Architects | LRA Cloud Operations"
  descripcion="The LRA Cloud Operations team. Platform engineers specializing in AWS, Kubernetes, Terraform and GitOps. Production workloads delivered as code."
  keywords="DevOps engineers Spain, AWS certified team Las Palmas, Kubernetes specialists Canary Islands, cloud infrastructure consultants Spain, HashiCorp certified Terraform, DevOps team hire Spain"
>
  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>

    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <span
        class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        About
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Infrastructure built for production.
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        Platform engineers focused on cloud infrastructure, automation and
        operational reliability. We design and operate AWS environments,
        Kubernetes platforms and delivery pipelines — as code, from day one.
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.6);">
        AWS · Kubernetes · Terraform · GitOps · Platform Engineering ·
        Observability
      </p>
    </div>
  </section>

  <!-- ─── TEAM ───────────────────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span
          class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
          style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
        >
          Team
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">
          The team
        </h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          Solo-founded, with a trusted collaborator network
        </p>
      </div>

      <div class="space-y-10">
        <!-- ── LIQUENSON RUBEN ── -->
        <div
          class="bg-white rounded-2xl p-8 sm:p-10 transition-all duration-200 hover:-translate-y-1"
          style="border: 1px solid #e2e8f0; border-left: 3px solid #1E6FFF; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 8px 32px rgba(10,37,64,0.09); border-radius: 16px;"
        >
          <div class="flex justify-center sm:justify-start mb-6">
            <span
              class="inline-flex items-center gap-2 text-xs font-semibold px-4 py-2 rounded-full"
              style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;"
            >
              <span
                class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0 animate-pulse"
              ></span>
              Accepting new projects
            </span>
          </div>

          <div class="flex flex-col sm:flex-row gap-8 items-start">
            <div class="flex-shrink-0">
              <Image
                src="/devruben.png"
                alt="Ruben Liquenson — DevOps Engineer"
                width={400}
                height={400}
                format="webp"
                quality={85}
                loading="lazy"
                decoding="async"
                class="w-32 h-32 rounded-full object-cover"
                style="border: 3px solid #c3d9ff;"
              />
            </div>
            <div class="flex-1 min-w-0">
              <div
                class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4"
              >
                <div>
                  <h3 class="text-2xl font-bold mb-1" style="color: #0A2540;">
                    Ruben Liquenson
                  </h3>
                  <p class="text-sm font-semibold mb-1" style="color: #1E6FFF;">
                    DevOps Engineer | Cloud Engineer | AWS | Kubernetes |
                    Terraform | GitOps
                  </p>
                  <div
                    class="flex items-center gap-1.5 text-sm"
                    style="color: #64748b;"
                  >
                    <svg
                      class="w-4 h-4 flex-shrink-0"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                      ></path>
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    Las Palmas de Gran Canaria, Spain
                  </div>
                </div>
                <div class="flex flex-wrap gap-2">
                  <a
                    href="https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-semibold text-white px-4 py-2.5 rounded-xl flex-shrink-0 transition-all hover:opacity-90 hover:scale-[1.02]"
                    style="background: linear-gradient(135deg, #0A66C2 0%, #004182 100%); box-shadow: 0 2px 10px rgba(10,102,194,0.3);"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path
                        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                      ></path>
                    </svg>
                    LinkedIn
                    <svg
                      class="w-3.5 h-3.5 opacity-70"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      ></path>
                    </svg>
                  </a>
                  <a
                    href="https://www.instagram.com/lracloudops/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-2.5 rounded-xl flex-shrink-0 transition-all hover:opacity-90 hover:scale-[1.02]"
                    style="background: linear-gradient(135deg, #E1306C 0%, #C13584 100%); color: white; box-shadow: 0 2px 10px rgba(225,48,108,0.3);"
                  >
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                      <circle cx="12" cy="12" r="4"/>
                      <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
                    </svg>
                    @lracloudops
                  </a>
                </div>
              </div>
              <div class="flex flex-wrap gap-2 mb-5">
                {
                  [
                    'DevOps Engineer',
                    'Cloud Engineer',
                    'Kubernetes',
                    'Terraform',
                    'GitOps',
                  ].map((role) => (
                    <span
                      class="text-xs font-semibold px-3 py-1.5 rounded-full"
                      style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
                    >
                      {role}
                    </span>
                  ))
                }
              </div>
              <p class="text-sm leading-relaxed mb-5" style="color: #64748b;">
                DevOps Lead Engineer with 4+ years designing and operating
                production-grade cloud infrastructure on AWS. Specialized in
                Kubernetes (EKS), GitOps with ArgoCD, Terraform IaC and CI/CD
                automation. Proven experience in regulated environments —
                healthcare and financial services. Advocate for infrastructure
                immutability: no manual changes in production, ever.
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                <a href="/projects/aws-terraform-devops" class="text-xs px-2.5 py-1 rounded-full font-medium transition-colors" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #C7D7FD;">aws-terraform-devops</a>
                <a href="/projects/gitops-stack" class="text-xs px-2.5 py-1 rounded-full font-medium transition-colors" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #C7D7FD;">gitops-stack</a>
                <a href="/projects/aws-devops-agent" class="text-xs px-2.5 py-1 rounded-full font-medium transition-colors" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #C7D7FD;">aws-devops-agent</a>
                <a href="/projects/k8s-on-premise" class="text-xs px-2.5 py-1 rounded-full font-medium transition-colors" style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #C7D7FD;">k8s-on-premise</a>
              </div>
              <div
                class="flex flex-wrap gap-1.5 mb-5 pb-5 border-b border-gray-100"
              >
                {
                  [
                    'AWS',
                    'Kubernetes',
                    'EKS',
                    'Terraform',
                    'Docker',
                    'ArgoCD',
                    'Helm',
                    'Jenkins',
                    'Ansible',
                    'Prometheus',
                    'Grafana',
                    'CloudWatch',
                    'Python',
                    'Bash',
                    'Linux',
                    'SonarQube',
                    'GitHub Actions',
                    'IAM',
                    'ECR',
                    'RDS',
                  ].map((tag) => (
                    <span
                      class="text-xs px-2.5 py-1 rounded-full"
                      style="background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0;"
                    >
                      {tag}
                    </span>
                  ))
                }
              </div>
              <div
                class="flex items-center gap-2 text-xs font-medium px-4 py-2.5 rounded-xl inline-flex w-fit"
                style="background: #EEF4FF; color: #0A2540; border: 1px solid #c3d9ff;"
              >
                <svg
                  class="w-3.5 h-3.5 flex-shrink-0"
                  style="color: #1E6FFF;"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                Available · Remote · Las Palmas de Gran Canaria
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Extended Network -->
      <div class="mt-12 p-6 rounded-2xl border border-blue-100 bg-[#EEF4FF]">
        <h3 class="text-lg font-semibold text-[#0A2540] mb-2">Extended Network</h3>
        <p class="text-[#64748b] text-sm leading-relaxed">LRA Cloud Operations is a solo-founded consultancy led by Ruben Liquenson. For engagements requiring additional capacity, we collaborate with a trusted network of certified engineers and architects across AWS, Kubernetes, and security domains — scaling without compromising on quality or accountability.</p>
      </div>
    </div>
  </section>

  <!-- ─── ENGINEERING PHILOSOPHY ───────────────────────────────────────────── -->
  <section class="py-20 border-t border-gray-100" style="background: #F8FAFC;">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span
          class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
          style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
        >
          Our Philosophy
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">
          Our Engineering Philosophy
        </h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          The principles that guide every infrastructure decision we make in
          production.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {
          [
            {
              icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
              title: 'Infrastructure Immutability',
              desc: 'No manual changes in production. Every change is versioned, reviewed and automated.',
            },
            {
              icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
              title: 'GitOps First',
              desc: 'Git is the single source of truth. Every deployment is auditable and reversible.',
            },
            {
              icon: 'M13 10V3L4 14h7v7l9-11h-7z',
              title: 'Reliability by Design',
              desc: 'We build for failure. Multi-AZ, circuit breakers, health checks — from day one.',
            },
          ].map(({ icon, title, desc }) => (
            <div
              class="bg-white rounded-2xl p-8 text-center hover:-translate-y-1 transition-all duration-200"
              style="border: 1px solid #e2e8f0; border-top: 3px solid #1E6FFF; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.08);"
            >
              <div
                class="w-14 h-14 flex items-center justify-center rounded-2xl mx-auto mb-5"
                style="background: #EEF4FF;"
              >
                <svg
                  class="w-6 h-6"
                  style="color: #1E6FFF;"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={icon}
                  />
                </svg>
              </div>
              <h3 class="text-base font-bold mb-3" style="color: #0A2540;">
                {title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: #64748b;">
                {desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─── TECHNOLOGY EXPERTISE ──────────────────────────────────────────────── -->
  <section class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span
          class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
          style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
        >
          Expertise
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">
          Technology Expertise
        </h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          Proficiency levels across our core platform engineering stack.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {
          [
            { name: 'AWS', level: 'Expert', pct: 95 },
            { name: 'Kubernetes', level: 'Expert', pct: 95 },
            { name: 'Docker', level: 'Expert', pct: 95 },
            { name: 'Terraform', level: 'Expert', pct: 90 },
            { name: 'Jenkins / GitHub Actions', level: 'Expert', pct: 90 },
            { name: 'ArgoCD / GitOps', level: 'Advanced', pct: 85 },
            { name: 'Prometheus / Grafana', level: 'Advanced', pct: 85 },
            { name: 'Ansible', level: 'Advanced', pct: 80 },
          ].map(({ name, level, pct }) => (
            <div
              class="bg-white rounded-2xl p-6"
              style="border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 12px rgba(10,37,64,0.06);"
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-bold" style="color: #0A2540;">
                  {name}
                </span>
                <span
                  class="text-xs font-semibold px-2.5 py-1 rounded-full"
                  style={
                    level === 'Expert'
                      ? 'background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;'
                      : 'background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;'
                  }
                >
                  {level}
                </span>
              </div>
              <div
                class="h-2 rounded-full overflow-hidden"
                style="background: #e2e8f0;"
              >
                <div
                  class="h-full rounded-full"
                  style={`width: ${pct}%; background: linear-gradient(90deg, #1E6FFF, #60A5FA);`}
                />
              </div>
              <div class="text-right mt-1.5">
                <span class="text-xs font-semibold" style="color: #1E6FFF;">
                  {pct}%
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─── EXPERIENCIA ───────────────────────────────────────────────────── -->
  <section style="background-color: #EEF4FF;" class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span
          class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
          style="background: white; color: #1E6FFF; border: 1px solid #c3d9ff;"
        >
          Professional experience
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: #0A2540;">
          Experience
        </h2>
        <p class="text-base max-w-xl mx-auto" style="color: #64748b;">
          Production environments. Infrastructure operated under real
          constraints.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <div
          class="absolute left-6 sm:left-8 top-0 bottom-0 w-px"
          style="background: linear-gradient(180deg, #1E6FFF 0%, #c3d9ff 100%);"
        >
        </div>

        <div class="space-y-10">
          <!-- ══════════════════════════════════════ RUBEN ALEXIS LIQUENSON -->
          <div class="relative flex gap-6 sm:gap-10 items-center">
            <div class="flex-shrink-0 w-12 sm:w-16 flex justify-center z-10">
              <Image
                src="/devruben.png"
                alt="Ruben Liquenson — DevOps Engineer"
                width={40}
                height={40}
                loading="lazy"
                decoding="async"
                class="w-10 h-10 rounded-full object-cover"
                style="border: 2px solid #1E6FFF; box-shadow: 0 0 0 3px rgba(30,111,255,0.2);"
              />
            </div>
            <h3 class="text-base font-bold" style="color: #0A2540;">
              Ruben Liquenson
            </h3>
          </div>

          <!-- Nibble Tech LLC (actual) -->
          <div class="relative flex gap-6 sm:gap-10">
            <div class="flex-shrink-0 w-12 sm:w-16 flex justify-center">
              <div class="relative mt-1">
                <div
                  class="w-4 h-4 rounded-full border-2 border-white z-10 relative"
                  style="background: #1E6FFF; box-shadow: 0 0 0 3px rgba(30,111,255,0.2);"
                >
                </div>
              </div>
            </div>
            <div class="flex-1 pb-2">
              <div
                class="bg-white rounded-2xl p-6 sm:p-8 transition-all duration-200 hover:-translate-y-0.5"
                style="border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.06); border-radius: 16px;"
              >
                <div
                  class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4"
                >
                  <div>
                    <h3 class="text-lg font-bold" style="color: #0A2540;">
                      Nibble Tech LLC
                    </h3>
                    <p
                      class="text-sm font-semibold mt-0.5"
                      style="color: #1E6FFF;"
                    >
                      DevOps Engineer
                    </p>
                    <p
                      class="text-xs mt-0.5 flex items-center gap-1"
                      style="color: #64748b;"
                    >
                      <svg
                        class="w-3.5 h-3.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                        ></path>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      New York, NY · Remote
                    </p>
                  </div>
                  <div class="flex flex-col items-start sm:items-end gap-1.5">
                    <div class="flex items-center gap-2">
                      <span
                        class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0 animate-pulse"
                      ></span>
                      <span
                        class="text-xs font-medium px-3 py-1.5 rounded-full whitespace-nowrap"
                        style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;"
                        >Currently</span
                      >
                    </div>
                    <span
                      class="text-xs font-medium px-3 py-1.5 rounded-full whitespace-nowrap"
                      style="background: #f3f4f6; color: #4b5563; border: 1px solid #e5e7eb;"
                      >May 2026 – present</span
                    >
                    <span
                      class="text-xs font-medium px-3 py-1 rounded-full"
                      style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
                      >2 months</span
                    >
                  </div>
                </div>
                <ul class="space-y-2.5">
                  {
                    [
                      'Design and maintain continuous delivery platforms on AWS EKS following the GitOps pattern — infrastructure fully defined as code with automated node configuration.',
                      'End-to-end CI/CD pipeline with Jenkins + Docker + ECR + Kubernetes — from commit to production deployment with rolling updates and zero downtime.',
                      'Multi-AZ infrastructure on AWS with modular Terraform: VPC, EKS, ECR, RDS, S3, IAM, CloudWatch — remote backend on S3 with separate DEV/PROD environments.',
                      'Automated EKS node configuration via Ansible + AWS SSM — SSH hardening, firewalld, dnf-automatic and CloudWatch agent.',
                      'GitOps deployments with ArgoCD and Helm Charts with per-environment values files. No manual apply, no configuration drift.',
                      'Observability with Prometheus + Grafana and infrastructure metrics via CloudWatch Container Insights.',
                      'Centralized identity management with IAM as code in Terraform — users, groups and least-privilege policies.',
                      'Static code analysis with SonarQube integrated into the CI pipeline.',
                    ].map((bullet) => (
                      <li
                        class="flex items-start gap-3 text-sm leading-relaxed"
