                    'AWS',
                    'Kubernetes',
                    'EKS',
                    'Terraform',
                    'Docker',
                    'ArgoCD',
                    'Helm',
                    'Jenkins',
                    'Ansible',
                    'Prometheus',
                    'Grafana',
                    'CloudWatch',
                    'Python',
                    'Bash',
                    'Linux',
                    'SonarQube',
