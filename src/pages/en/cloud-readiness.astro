---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="Cloud Readiness Assessment | LRA Cloud Operations"
  descripcion="8-question assessment to evaluate if your application is ready for production AWS deployment. Get a personalized cloud migration roadmap."
  keywords="cloud readiness assessment, AWS migration readiness, cloud deployment checklist, AWS production readiness"
>
  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.18) 0%, transparent 65%);"
    >
    </div>
    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <span
        class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        Free Tool
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Cloud Readiness Assessment
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        Is your application ready for production AWS deployment?
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.6);">
        8 questions &middot; 5 minutes &middot; Free personalized report
      </p>
    </div>
  </section>

  <!-- ASSESSMENT -->
  <section class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-6">
      <div class="mb-10">
        <div class="flex items-center justify-between mb-2">
          <span
            class="text-xs font-semibold"
            style="color: #64748b;"
            id="progress-label">Question 1 of 8</span
          >
          <span
            class="text-xs font-semibold"
            style="color: #1E6FFF;"
            id="score-display">Score: 0 / 24</span
          >
        </div>
        <div
          class="h-2 rounded-full overflow-hidden"
          style="background: #e2e8f0;"
        >
          <div
            id="progress-bar"
            class="h-full rounded-full transition-all duration-500"
            style="width: 12.5%; background: linear-gradient(90deg, #1E6FFF, #60A5FA);"
          >
          </div>
        </div>
      </div>

      <div id="question-container"></div>
      <div id="result-container" class="hidden"></div>
    </div>
  </section>
</Layout>

<script>
  const CAL = 'https://cal.com/ruben-alexis-h6qkjk/30min'
  const questions = [
    {
      q: 'How is your application currently deployed?',
      options: [
        { label: 'On-premise servers', pts: 0 },
        { label: 'Single cloud VM', pts: 1 },
        { label: 'Containerized with Docker', pts: 2 },
        { label: 'Kubernetes or ECS Fargate', pts: 3 },
      ],
    },
    {
      q: 'How do you manage application configuration?',
      options: [
        { label: 'Hardcoded in code', pts: 0 },
        { label: 'Config files per environment', pts: 1 },
        { label: 'Environment variables', pts: 2 },
        { label: 'AWS Parameter Store or Secrets Manager', pts: 3 },
      ],
    },
    {
      q: 'What is your current backup strategy?',
      options: [
        { label: 'No backups', pts: 0 },
        { label: 'Manual periodic backups', pts: 1 },
        { label: 'Automated daily backups', pts: 2 },
        { label: 'Continuous backup with point-in-time recovery', pts: 3 },
      ],
    },
    {
      q: 'How do you handle application scaling?',
      options: [
        { label: 'Manual — restart server when slow', pts: 0 },
        { label: 'Vertical scaling manually', pts: 1 },
        { label: 'Auto Scaling Groups', pts: 2 },
        { label: 'HPA with Kubernetes or ECS Service Auto Scaling', pts: 3 },
      ],
    },
    {
      q: 'What is your current deployment process?',
      options: [
        { label: 'FTP or manual file copy', pts: 0 },
        { label: 'SSH and scripts', pts: 1 },
        { label: 'Basic CI/CD pipeline', pts: 2 },
        { label: 'Automated pipeline with tests and rollback', pts: 3 },
      ],
    },
    {
      q: 'How do you monitor application health?',
      options: [
        { label: 'No monitoring', pts: 0 },
        { label: 'Manual checks', pts: 1 },
        { label: 'Basic uptime monitoring', pts: 2 },
        { label: 'Full metrics, logs and traces with alerts', pts: 3 },
      ],
    },
    {
      q: 'How do you manage database changes?',
      options: [
        { label: 'Manual SQL scripts', pts: 0 },
        { label: 'Version controlled scripts', pts: 1 },
        { label: 'Migration tool (Flyway/Liquibase)', pts: 2 },
        { label: 'Automated migrations in CI/CD pipeline', pts: 3 },
      ],
    },
    {
      q: 'What is your security posture?',
      options: [
        { label: 'Default settings, no hardening', pts: 0 },
        { label: 'Basic firewall rules', pts: 1 },
        { label: 'IAM roles, security groups defined', pts: 2 },
        { label: 'Zero trust, least privilege, OIDC, WAF', pts: 3 },
      ],
    },
  ]

  const results = [
    {
      range: [0, 8],
      title: 'Not Ready — Significant work needed',
      desc: 'Your application needs foundational work before cloud deployment. We recommend starting with containerization and basic CI/CD.',
      cta: 'Get a free architecture review',
      color: '#DC2626',
      bg: '#FEF2F2',
      border: '#FECACA',
    },
    {
      range: [9, 16],
      title: 'Partially Ready — Good foundation',
      desc: 'You have the basics in place. Focus on automation, security hardening and proper monitoring before going live.',
      cta: 'Get a cloud migration roadmap',
      color: '#D97706',
      bg: '#FFFBEB',
      border: '#FDE68A',
    },
    {
      range: [17, 22],
      title: 'Nearly Ready — Final optimizations',
      desc: 'Strong foundation. Address the remaining gaps in security and observability for a production-grade deployment.',
      cta: 'Schedule a production readiness review',
      color: '#1E6FFF',
      bg: '#EEF4FF',
      border: '#C7D7FD',
    },
    {
      range: [23, 24],
      title: 'Cloud Ready — Production grade',
      desc: "Excellent! Your application follows cloud-native best practices. Let's discuss advanced optimization.",
      cta: 'Talk to our senior architects',
      color: '#059669',
      bg: '#F0FDF4',
      border: '#BBF7D0',
    },
  ]

  let current = 0,
    score = 0
  const total = questions.length,
    maxScore = total * 3

  function render() {
    const el = (id: string) => document.getElementById(id)!
    el('progress-label').textContent = `Question ${current + 1} of ${total}`
    el('score-display').textContent = `Score: ${score} / ${maxScore}`
    ;(el('progress-bar') as HTMLElement).style.width =
      `${(current / total) * 100}%`
    const q = questions[current]
    el('question-container').innerHTML = `
    <div class="bg-white rounded-2xl p-8" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(10,37,64,0.04),0 4px 16px rgba(10,37,64,0.06);">
      <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color:#1E6FFF;">Question ${current + 1} of ${total}</p>
      <h2 class="text-xl font-bold mb-7" style="color:#0A2540;letter-spacing:-0.01em;">${q.q}</h2>
      <div class="space-y-3">${q.options
        .map(
          (opt, i) => `
        <button onclick="selectAnswer(${opt.pts})" class="w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all hover:-translate-y-0.5"
          style="background:#F8FAFC;border:1.5px solid #e2e8f0;color:#0A2540;"
          onmouseover="this.style.borderColor='#1E6FFF';this.style.background='#EEF4FF';"
          onmouseout="this.style.borderColor='#e2e8f0';this.style.background='#F8FAFC';">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold mr-3" style="background:#EEF4FF;color:#1E6FFF;">${'ABCD'[i]}</span>${opt.label}
        </button>`
        )
        .join('')}
      </div>
    </div>`
  }

  function selectAnswer(pts: number) {
    score += pts
    current++
    if (current < total) {
      render()
    } else {
      showResult()
    }
  }

  function showResult() {
    const el = (id: string) => document.getElementById(id)!
    ;(el('progress-bar') as HTMLElement).style.width = '100%'
    el('progress-label').textContent = 'Assessment complete'
    el('score-display').textContent = `Final score: ${score} / ${maxScore}`
    const r =
      results.find((x) => score >= x.range[0] && score <= x.range[1]) ??
      results[0]
    const pct = Math.round((score / maxScore) * 100)
    el('question-container').classList.add('hidden')
    el('result-container').classList.remove('hidden')
    if (typeof window !== 'undefined' && (window as any).cf) {
      ;(window as any).cf.track('assessment_completed', {
        type: 'cloud-readiness',
        score,
      })
    }
    el('result-container').innerHTML = `
    <div class="rounded-2xl p-8 mb-6" style="background:${r.bg};border:1px solid ${r.border};">
      <div class="flex items-start gap-5 mb-6">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0 text-white font-black text-lg" style="background:${r.color};">${pct}%</div>
        <div>
          <h2 class="text-xl font-bold mb-2" style="color:#0A2540;">${r.title}</h2>
          <p class="text-sm leading-relaxed" style="color:#64748b;">${r.desc}</p>
        </div>
      </div>

      <div id="email-capture" style="margin: 1.5rem 0; padding: 1.5rem; background: #EEF4FF; border-radius: 12px; border: 1px solid #C7D7FD;">
        <p style="font-weight: 600; color: #0A2540; margin-bottom: 0.5rem;">Get your personalized action plan by email</p>
        <p style="font-size: 0.875rem; color: #64748b; margin-bottom: 1rem;">We\'ll send you a detailed roadmap based on your score. No spam.</p>
        <form id="assessment-email-form" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <input type="hidden" name="access_key" value="e8aaab4e-270c-4163-bb76-6a8dfc247485">
          <input type="hidden" name="subject" id="assessment-subject">
          <input type="hidden" name="assessment_score" id="assessment-score-field">
          <input type="hidden" name="assessment_level" id="assessment-level-field">
          <input type="email" name="email" placeholder="your@email.com" required
            style="flex: 1; min-width: 200px; padding: 0.75rem 1rem; border: 1px solid #C7D7FD; border-radius: 8px; font-size: 0.875rem;">
          <button type="submit"
            style="padding: 0.75rem 1.5rem; background: #1E6FFF; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">
            Send my plan →
          </button>
        </form>
        <p id="email-success" style="display:none; color: #16a34a; font-size: 0.875rem; margin-top: 0.75rem;">✓ Check your inbox! We\'ll send your plan within 24 hours.</p>
      </div>

      <a href="${CAL}" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-bold px-6 py-3.5 rounded-xl transition-all hover:opacity-90 hover:-translate-y-px"
        style="background:${r.color};color:white;box-shadow:0 4px 16px rgba(0,0,0,0.15);">
        ${r.cta} →
      </a>
    </div>
    <button onclick="location.reload()" class="text-sm font-medium hover:opacity-70 transition-opacity" style="color:#64748b;">← Retake assessment</button>`
  }

  // Email capture setup
  const subjEl = document.getElementById(
    'assessment-subject'
  ) as HTMLInputElement
  const scoreEl2 = document.getElementById(
    'assessment-score-field'
  ) as HTMLInputElement
  const levelEl = document.getElementById(
    'assessment-level-field'
  ) as HTMLInputElement
  if (subjEl)
    subjEl.value = `Cloud Readiness Assessment — Score ${score}/${maxScore} (${r.title})`
  if (scoreEl2) scoreEl2.value = String(score)
  if (levelEl) levelEl.value = r.title
  const emailForm = document.getElementById(
    'assessment-email-form'
  ) as HTMLFormElement
  emailForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const fd = new FormData(emailForm)
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: fd,
      })
      if (res.ok) {
        emailForm.style.display = 'none'
        const ok = document.getElementById('email-success')
        if (ok) ok.style.display = 'block'
      }
    } catch {}
  })
  ;(window as any).selectAnswer = selectAnswer
  render()

  if (typeof window !== 'undefined' && (window as any).cf) {
    ;(window as any).cf.track('assessment_started', { type: 'cloud-readiness' })
  }
</script>
