---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'

const allProjects = (await getCollection('projects')).filter(p => !p.data.draft)

function badgeStyle(madurez: string) {
  const map: Record<string, string> = {
    "Production":     "background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;",
    "In Development": "background:#fffbeb; color:#b45309; border:1px solid #fde68a;",
    "Reference":      "background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb;",
    "Starter":        "background:#EEF4FF; color:#1E6FFF; border:1px solid #c3d9ff;",
  }
  return map[madurez] ?? map["Reference"]
}

const statusBar: Record<string, string> = {
  "Production":     "background: linear-gradient(90deg, #16a34a, #22c55e);",
  "In Development": "background: linear-gradient(90deg, #d97706, #f59e0b);",
  "Reference":      "background: linear-gradient(90deg, #6b7280, #9ca3af);",
  "Starter":        "background: linear-gradient(90deg, #1E6FFF, #5B9BFF);",
}

const production    = allProjects.filter(p => p.data.madurez === "Production")
const inDevelopment = allProjects.filter(p => p.data.madurez === "In Development")
const reference     = allProjects.filter(p => p.data.madurez === "Reference")
const starters      = allProjects.filter(p => p.data.madurez === "Starter")

const defaultIconPath = "M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"
---

<Layout
  titulo="Case Studies | Cloud Infrastructure Projects | LRA Cloud Operations"
  descripcion="Production AWS environments, platform engineering implementations and reference GitOps architectures. Real workloads, documented outcomes."
  keywords="DevOps case studies Spain, Kubernetes production projects AWS, Terraform infrastructure implementations, GitOps ArgoCD examples, ECS Fargate projects"
>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none opacity-40" style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6" style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);">
          {allProjects.length} implementation{allProjects.length !== 1 ? 's' : ''} · Production workloads documented
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-5 animate-fade-left" style="letter-spacing: -0.02em;">Reference Architectures</h1>
        <p class="text-lg max-w-2xl animate-fade-up delay-200" style="color: rgba(147,184,255,0.8);">
          Production platforms, GitOps implementations and infrastructure automation. Real workloads, not demos.
        </p>
      </div>
    </div>
  </section>

  <!-- LEGEND -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-wrap gap-3 items-center">
      <span class="text-xs font-semibold uppercase tracking-widest mr-1" style="color: #94a3b8;">Status:</span>
      {[
        { label: "Production",     style: "background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;" },
        { label: "In Development", style: "background:#fffbeb; color:#b45309; border:1px solid #fde68a;" },
        { label: "Reference",      style: "background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb;" },
        { label: "Starter",        style: "background:#EEF4FF; color:#1E6FFF; border:1px solid #c3d9ff;" },
      ].map(b => (
        <span class="text-xs font-medium px-3 py-1 rounded-full" style={b.style}>{b.label}</span>
      ))}
      <span class="hidden sm:block w-px h-4 bg-gray-200 mx-1"></span>
      <span class="inline-flex items-center gap-1.5 text-xs font-medium" style="color: #64748b;">
        <span class="w-2 h-2 rounded-full bg-green-400"></span>CI/CD active
      </span>
    </div>
  </section>

  <!-- GRID -->
  <section class="py-16" style="background: #f8fafc;">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Summary counts -->
      <div class="flex flex-wrap gap-3 mb-10">
        {[
          { count: production.length,    label: 'Production',     color: '#15803d', bg: '#f0fdf4', border: '#bbf7d0' },
          { count: inDevelopment.length, label: 'In Development', color: '#b45309', bg: '#fffbeb', border: '#fde68a' },
          { count: reference.length,     label: 'Reference',      color: '#4b5563', bg: '#f3f4f6', border: '#e5e7eb' },
          { count: starters.length,      label: 'Starters',       color: '#1E6FFF', bg: '#EEF4FF', border: '#c3d9ff' },
        ].map(({ count, label, color, bg, border }) => (
          <div class="px-4 py-2.5 rounded-xl flex items-center gap-2.5" style={`background: ${bg}; border: 1px solid ${border};`}>
            <span class="text-lg font-bold" style={`color: ${color};`}>{count}</span>
            <span class="text-xs font-medium" style={`color: ${color}; opacity: 0.8;`}>{label}</span>
          </div>
        ))}
      </div>

      {allProjects.length === 0 ? (
        <div class="text-center py-24">
          <p class="text-[#64748b] text-lg">Projects coming soon. Follow <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener noreferrer" class="font-semibold underline" style="color: #1E6FFF;">github.com/lra-cloud-ops</a> for updates.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {allProjects.map((project, i) => {
            const p = project.data
            const slug = project.id
            const icon = p.iconPath ?? defaultIconPath
            const firstMetric = p.metricas?.[0]
            return (
              <div
                class={`bg-white rounded-2xl flex flex-col group hover:-translate-y-1 transition-all duration-200 animate-fade-up ${['delay-100','delay-200','delay-300','delay-400','delay-500','delay-500'][i] ?? 'delay-500'}`}
                style="box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.07); border: 1px solid #e8eef4; transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;"
                onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 10px 28px rgba(10,37,64,0.10)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04), 0 4px 16px rgba(10,37,64,0.07)'; this.style.borderColor='#e8eef4';"
              >
                <!-- Status bar -->
                <div class="h-1 rounded-t-2xl" style={statusBar[p.madurez] ?? statusBar["Reference"]}></div>

                <div class="p-7 flex flex-col flex-1">
                  <div class="flex items-start justify-between mb-5">
                    <div class="w-11 h-11 flex items-center justify-center rounded-xl flex-shrink-0" style="background-color: #EEF4FF;">
                      <svg class="w-5 h-5" style="color: #1E6FFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                      </svg>
                    </div>
                    <div class="flex flex-col items-end gap-1.5">
                      <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style={badgeStyle(p.madurez)}>
                        {p.madurez}
                      </span>
                      {p.cicd && (
                        <span class="inline-flex items-center gap-1.5 text-xs font-medium" style="color: #64748b;">
                          <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>CI/CD
                        </span>
                      )}
                    </div>
                  </div>

                  <div class="mb-1.5">
                    <span class="text-xs font-semibold uppercase tracking-wider" style="color: #94a3b8;">{p.categoria}</span>
                  </div>
                  <h2 class="text-lg font-bold mb-3 group-hover:text-blue-700 transition-colors" style="color: #0A2540;">{p.titulo}</h2>
                  <p class="text-sm leading-relaxed mb-4 flex-1" style="color: #64748b;">{p.descripcion}</p>

                  {firstMetric && (
                    <div class="flex items-baseline gap-2 mb-4 px-4 py-3 rounded-xl" style="background: #EEF4FF; border: 1px solid #c3d9ff;">
                      <span class="text-2xl font-black" style="color: #1E6FFF; letter-spacing: -0.04em;">{firstMetric.value}</span>
                      <span class="text-xs font-medium" style="color: #3b5bdb;">{firstMetric.label}</span>
                    </div>
                  )}

                  <div class="flex flex-wrap gap-1.5 mb-5">
                    {p.stack.slice(0, 5).map(t => (
                      <span class="text-xs font-medium px-2.5 py-1 rounded-full" style="background: #f8fafc; color: #374151; border: 1px solid #e2e8f0;">{t}</span>
                    ))}
                    {p.stack.length > 5 && (
                      <span class="text-xs px-2 py-1 rounded-full" style="background: #f8fafc; color: #94a3b8; border: 1px solid #e2e8f0;">+{p.stack.length - 5} more</span>
                    )}
                  </div>

                  <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
                    <a
                      href={`/projects/${slug}`}
                      aria-label={`Architecture detail: ${p.titulo}`}
                      class="flex-1 inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2.5 rounded-xl transition-all hover:-translate-y-px"
                      style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
                    >
                      Architecture detail
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                    {p.github && (
                      <a
                        href={p.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 flex items-center justify-center rounded-xl border border-gray-200 hover:border-gray-300 transition-colors"
                        style="color: #64748b;"
                        aria-label={`${p.titulo} on GitHub`}
                      >
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      )}

      <!-- Coming soon footer -->
      <div class="mt-12 rounded-2xl p-8 text-center" style="background: #EEF4FF; border: 1px dashed #c3d9ff;">
        <p class="text-base font-medium mb-1" style="color: #0A2540;">More case studies being documented.</p>
        <p class="text-sm" style="color: #64748b;">
          Follow <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener noreferrer" class="font-semibold underline" style="color: #1E6FFF;">github.com/lra-cloud-ops</a> for new projects as they ship.
        </p>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4" style="letter-spacing: -0.02em;">
        Need production-grade infrastructure?
      </h2>
      <p class="text-base mb-8 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        These implementations are the baseline. We build and operate cloud infrastructure tailored to your organization's requirements.
      </p>
      <a
        href="/en/contact"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02]"
        style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 24px rgba(30,111,255,0.4);"
      >
        Schedule free consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
