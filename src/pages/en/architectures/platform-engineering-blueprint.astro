---
import Layout from '../../../layouts/Layout.astro'
import ArchitectureDiagram from '../../../components/ArchitectureDiagram.astro'
---

<Layout
  titulo="Platform Engineering Blueprint | LRA Cloud Operations"
  descripcion="Internal Developer Platform architecture for reducing developer cognitive load. Golden paths, self-service infrastructure APIs, reusable CI/CD templates and DORA metrics."
  keywords="platform engineering blueprint, internal developer platform, IDP AWS, golden paths DevOps, DORA metrics platform engineering"
>
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-16 sm:py-20">
      <div
        class="flex items-center gap-2 text-xs mb-8"
        style="color: rgba(147,184,255,0.5);"
      >
        <a
          href="/"
          class="hover:text-white transition-colors"
          style="color: rgba(147,184,255,0.5);">Home</a
        >
        <span>/</span>
        <a
          href="/architectures"
          class="hover:text-white transition-colors"
          style="color: rgba(147,184,255,0.5);">Architectures</a
        >
        <span>/</span>
        <span style="color: rgba(147,184,255,0.9);"
          >Platform Engineering Blueprint</span
        >
      </div>
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span
          class="text-xs font-semibold px-3 py-1.5 rounded-full"
          style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
          >Reference</span
        >
        <span
          class="text-xs font-semibold px-3 py-1.5 rounded-full"
          style="background: rgba(123,66,188,0.15); color: #7B42BC; border: 1px solid rgba(123,66,188,0.3);"
          >Platform Engineering</span
        >
      </div>
      <h1
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4"
        style="letter-spacing: -0.02em;"
      >
        Platform Engineering Blueprint
      </h1>
      <p class="text-lg max-w-2xl" style="color: rgba(147,184,255,0.8);">
        Building Internal Developer Platforms on AWS. Reduce developer cognitive
        load, increase deployment frequency and measure what matters.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-10">
          <div>
            <h2 class="text-2xl font-bold mb-4" style="color: #0A2540;">
              Overview
            </h2>
            <p class="text-base leading-relaxed mb-4" style="color: #64748b;">
              Platform Engineering is the practice of building and running an
              Internal Developer Platform (IDP) that enables product teams to
              self-serve their infrastructure needs. The platform team builds
              the infrastructure layer; product teams consume it through
              well-defined APIs.
            </p>
            <p class="text-base leading-relaxed" style="color: #64748b;">
              The result: developers deploy to production without opening an ops
              ticket. New services are scaffolded in minutes. CI/CD pipelines
              are inherited, not written. Security controls are built into the
              platform, not added after. DORA metrics track whether the platform
              is actually improving developer velocity.
            </p>
          </div>

          <div>
            <h2 class="text-2xl font-bold mb-4" style="color: #0A2540;">
              Architecture Diagram
            </h2>
            <ArchitectureDiagram
              title="Platform Engineering Blueprint — IDP Architecture"
              description="How the platform team enables product teams to self-serve infrastructure without operational bottlenecks."
              archId="platform-eng"
            >
              <svg
                viewBox="0 0 720 360"
                xmlns="http://www.w3.org/2000/svg"
                class="w-full"
                style="min-width: 520px; font-family: Inter, system-ui, sans-serif;"
              >
                <!-- Platform Team -->
                <rect
                  x="10"
                  y="140"
                  width="110"
                  height="60"
                  rx="8"
                  fill="#7B42BC"
                  fill-opacity="0.1"
                  stroke="#7B42BC"
                  stroke-width="1.5"></rect>
                <text
                  x="65"
                  y="162"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="10"
                  font-weight="700">Platform Team</text
                >
                <text
                  x="65"
                  y="177"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Builds &amp; operates</text
                >
                <text
                  x="65"
                  y="190"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">the IDP</text
                >

                <!-- Arrow: Platform Team → IDP -->
                <line
                  x1="120"
                  y1="170"
                  x2="155"
                  y2="170"
                  stroke="#7B42BC"
                  stroke-width="1.5"
                  marker-end="url(#ap2)"></line>

                <!-- IDP box -->
                <rect
                  x="155"
                  y="60"
                  width="360"
                  height="260"
                  rx="10"
                  fill="#EEF4FF"
                  fill-opacity="0.4"
                  stroke="#1E6FFF"
                  stroke-width="1.5"
                  stroke-dasharray="5,3"></rect>
                <text
                  x="335"
                  y="85"
                  text-anchor="middle"
                  fill="#1E6FFF"
                  font-size="12"
                  font-weight="700">Internal Developer Platform</text
                >

                <!-- IDP Components -->
                <rect
                  x="170"
                  y="100"
                  width="155"
                  height="55"
                  rx="6"
                  fill="white"
                  stroke="#7B42BC"
                  stroke-width="1"></rect>
                <text
                  x="247"
                  y="120"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="9"
                  font-weight="700">Service Templates</text
                >
                <text
                  x="247"
                  y="134"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Cookiecutter / Backstage</text
                >
                <text
                  x="247"
                  y="146"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">One-click: repo + pipeline + infra</text
                >

                <rect
                  x="340"
                  y="100"
                  width="155"
                  height="55"
                  rx="6"
                  fill="white"
                  stroke="#059669"
                  stroke-width="1"></rect>
                <text
                  x="417"
                  y="120"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="9"
                  font-weight="700">Infrastructure APIs</text
                >
                <text
                  x="417"
                  y="134"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Terraform modules as APIs</text
                >
                <text
                  x="417"
                  y="146"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">VPC · EKS · RDS · S3 on demand</text
                >

                <rect
                  x="170"
                  y="175"
                  width="155"
                  height="55"
                  rx="6"
                  fill="white"
                  stroke="#FF6C37"
                  stroke-width="1"></rect>
                <text
                  x="247"
                  y="195"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="9"
                  font-weight="700">CI/CD Templates</text
                >
                <text
                  x="247"
                  y="209"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Reusable GitHub Actions</text
                >
                <text
                  x="247"
                  y="221"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Test → Build → Push → Deploy</text
                >

                <rect
                  x="340"
                  y="175"
                  width="155"
                  height="55"
                  rx="6"
                  fill="white"
                  stroke="#F97316"
                  stroke-width="1"></rect>
                <text
                  x="417"
                  y="195"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="9"
                  font-weight="700">Observability</text
                >
                <text
                  x="417"
                  y="209"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Auto dashboards per service</text
                >
                <text
                  x="417"
                  y="221"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Alerts pre-configured</text
                >

                <!-- Paved Roads -->
                <rect
                  x="170"
                  y="250"
                  width="325"
                  height="40"
                  rx="6"
                  fill="#0A2540"
                  fill-opacity="0.06"
                  stroke="#0A2540"
                  stroke-width="1"></rect>
                <text
                  x="332"
                  y="268"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="9"
                  font-weight="700"
                  >Golden Paths — Paved Roads for common workload types</text
                >
                <text
                  x="332"
                  y="281"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8"
                  >API service · Static frontend · Background worker · Scheduled
                  job</text
                >

                <!-- Arrow: Dev Team → IDP -->
                <line
                  x1="562"
                  y1="200"
                  x2="600"
                  y2="200"
                  stroke="#1E6FFF"
                  stroke-width="1.5"
                  stroke-dasharray="4,3"
                  marker-end="url(#ab2)"></line>

                <!-- Dev Team -->
                <rect
                  x="600"
                  y="175"
                  width="110"
                  height="50"
                  rx="8"
                  fill="#EEF4FF"
                  stroke="#1E6FFF"
                  stroke-width="1.5"></rect>
                <text
                  x="655"
                  y="197"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="10"
                  font-weight="700">Dev Teams</text
                >
                <text
                  x="655"
                  y="212"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">self-serve</text
                >

                <!-- Arrow: IDP → AWS -->
                <line
                  x1="335"
                  y1="320"
                  x2="335"
                  y2="345"
                  stroke="#1E6FFF"
                  stroke-width="1.5"
                  marker-end="url(#ab2)"></line>
                <rect
                  x="240"
                  y="345"
                  width="190"
                  height="32"
                  rx="6"
                  fill="#F8FAFC"
                  stroke="#FF9900"
                  stroke-width="1.5"></rect>
                <text
                  x="335"
                  y="361"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="9"
                  font-weight="600">AWS Production Environment</text
                >
                <text
                  x="335"
                  y="372"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">EKS · RDS · S3 · CloudFront</text
                >

                <!-- DORA metrics box -->
                <rect
                  x="600"
                  y="260"
                  width="110"
                  height="75"
                  rx="8"
                  fill="#F8FAFC"
                  stroke="#e2e8f0"
                  stroke-width="1.5"></rect>
                <text
                  x="655"
                  y="282"
                  text-anchor="middle"
                  fill="#0A2540"
                  font-size="9"
                  font-weight="700">DORA Metrics</text
                >
                <text
                  x="655"
                  y="297"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Deploy freq.</text
                >
                <text
                  x="655"
                  y="310"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">Lead time</text
                >
                <text
                  x="655"
                  y="323"
                  text-anchor="middle"
                  fill="#64748b"
                  font-size="8">MTTR · CFR</text
                >

                <defs>
                  <marker
                    id="ap2"
                    markerWidth="6"
                    markerHeight="6"
                    refX="5"
                    refY="3"
                    orient="auto"
                    ><path d="M0,0 L0,6 L6,3 z" fill="#7B42BC"></path></marker
                  >
                  <marker
                    id="ab2"
                    markerWidth="6"
                    markerHeight="6"
                    refX="5"
                    refY="3"
                    orient="auto"
                    ><path d="M0,0 L0,6 L6,3 z" fill="#1E6FFF"></path></marker
                  >
                </defs>
              </svg>
            </ArchitectureDiagram>
          </div>

          <div>
            <h2 class="text-2xl font-bold mb-5" style="color: #0A2540;">
              Platform Pillars
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {
                [
                  {
                    title: 'Golden Paths',
                    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
                    detail:
                      'Standardized ways to build, deploy and operate. Developers follow the path — platform team maintains it. Paved roads for API service, frontend SPA, background worker and scheduled job patterns.',
                    color: '#7B42BC',
                  },
                  {
                    title: 'Self-Service Infra',
                    icon: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6z',
                    detail:
                      'Developers provision a new database, S3 bucket or EKS namespace without an ops ticket. Terraform modules exposed as APIs. Guardrails built in — only allowed configurations are possible.',
                    color: '#059669',
                  },
                  {
                    title: 'CI/CD Templates',
                    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
                    detail:
                      'Reusable GitHub Actions workflows for every service type. Build, test, scan, push, deploy — inherited from the platform. Teams get production-grade pipelines from day one without writing YAML.',
                    color: '#FF6C37',
                  },
                  {
                    title: 'DORA Metrics',
                    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75',
                    detail:
                      'Deployment frequency, lead time for changes, mean time to recovery and change failure rate. The platform exists to improve these numbers — not to add process. Measured weekly.',
                    color: '#1E6FFF',
                  },
                ].map(({ title, icon, detail, color }) => (
                  <div
                    class="p-6 rounded-2xl"
                    style="background: #F8FAFC; border: 1px solid #e2e8f0;"
                  >
                    <div class="flex items-center gap-3 mb-3">
                      <div
                        class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0"
                        style={`background: ${color}1a;`}
                      >
                        <svg
                          class="w-5 h-5"
                          style={`color: ${color};`}
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1.5"
                            d={icon}
                          />
                        </svg>
                      </div>
                      <h3 class="text-sm font-bold" style="color: #0A2540;">
                        {title}
                      </h3>
                    </div>
                    <p class="text-sm leading-relaxed" style="color: #64748b;">
                      {detail}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-5">
            <div
              class="rounded-2xl p-6"
              style="background: #F8FAFC; border: 1px solid #e2e8f0;"
            >
              <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">
                Stack
              </h3>
              <div class="flex flex-wrap gap-1.5">
                {
                  [
                    'Backstage (optional)',
                    'Terraform Modules',
                    'GitHub Actions',
                    'AWS',
                    'EKS',
                    'ArgoCD',
                    'DORA Metrics',
                    'Prometheus',
                  ].map((tag) => (
                    <span
                      class="text-xs px-2.5 py-1 rounded-full"
                      style="background: white; color: #64748b; border: 1px solid #e2e8f0;"
                    >
                      {tag}
                    </span>
                  ))
                }
              </div>
            </div>
            <div
              class="rounded-2xl p-6"
              style="background: #EEF4FF; border: 1px solid #c3d9ff;"
            >
              <h3 class="text-sm font-bold mb-2" style="color: #0A2540;">
                Ready to build an IDP?
              </h3>
              <p class="text-xs leading-relaxed mb-4" style="color: #64748b;">
                We design and implement Internal Developer Platforms that
                measurably improve engineering velocity.
              </p>
              <a
                href="/contact"
                class="flex items-center justify-center gap-2 text-sm font-bold text-white py-3 rounded-xl hover:opacity-90 transition-opacity"
                style="background: #1E6FFF;">Start a conversation →</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  if (typeof window !== 'undefined' && (window as any).cf) {
    ;(window as any).cf.track('architecture_viewed', {
      architecture: 'platform-engineering-blueprint',
    })
  }
</script>
