---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  titulo="AI-Powered DevOps · Claude Sonnet in Production"
  descripcion="Combine real platform engineering with applied AI. DevOps Advisor available 24/7, automated AWS agents and AI-assisted architecture reviews powered by Claude Sonnet."
  keywords="AI DevOps, artificial intelligence DevOps, Claude Sonnet infrastructure, AIOps, AWS DevOps agent, AI Kubernetes automation, DevOps advisor AI, platform engineering AI"
>
  <!-- ── HERO ── -->
  <section
    class="relative overflow-hidden"
    style="background-color: #0A2540;"
    aria-labelledby="ai-hero-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background-image: radial-gradient(circle, rgba(96,165,250,0.14) 1px, transparent 1px); background-size: 30px 30px;"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.2) 0%, transparent 65%);"
    >
    </div>

    <div
      class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-7 text-xs font-bold tracking-widest uppercase"
        style="background: rgba(30,111,255,0.2); border: 1px solid rgba(96,165,250,0.35); color: #93C5FD;"
      >
        <span
          class="w-2 h-2 rounded-full flex-shrink-0"
          style="background: #60A5FA; animation: pulse 2s infinite;"
          aria-hidden="true"></span>
        Applied Artificial Intelligence
      </div>

      <h1
        id="ai-hero-heading"
        class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight"
        style="letter-spacing: -0.035em;"
      >
        DevOps powered by AI.
      </h1>

      <p
        class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-8"
        style="color: rgba(147,184,255,0.85);"
      >
        We combine real platform engineering with Claude Sonnet to automate
        decisions, accelerate diagnostics and reduce operational overhead. AI as
        an engineering tool, not a substitute for technical judgement.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <button
          onclick="document.getElementById('lra-chat-toggle')?.click()"
          class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-7 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
          style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.45);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
            ></path>
          </svg>
          Talk to the DevOps Advisor
        </button>
        <a
          href="/en/contact"
          class="inline-flex items-center gap-2.5 text-sm font-semibold px-7 py-4 rounded-xl border transition-all hover:bg-white/10"
          style="color: rgba(147,184,255,0.9); border-color: rgba(147,184,255,0.25);"
        >
          Request a technical demo
        </a>
      </div>
    </div>
  </section>

  <!-- ── 3 FEATURE CARDS ── -->
  <section class="bg-white py-20" aria-labelledby="ai-features-heading">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <span
          class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
          style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
        >
          Capabilities
        </span>
        <h2
          id="ai-features-heading"
          class="text-3xl sm:text-4xl font-bold mb-4"
          style="color: #0F172A; letter-spacing: -0.025em;"
        >
          AI across every platform layer
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          Three concrete ways AI accelerates our engineering practice.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1: DevOps Advisor -->
        <div
          class="bg-white rounded-2xl p-8 flex flex-col"
          style="border-left: 4px solid #1E6FFF; border-top: 1px solid #E5E7EB; border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06);"
        >
          <div
            class="w-12 h-12 flex items-center justify-center rounded-xl mb-6 flex-shrink-0"
            style="background: #EFF6FF;"
            aria-hidden="true"
          >
            <svg
              class="w-6 h-6"
              style="color: #2563EB;"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
              ></path>
            </svg>
          </div>
          <div
            class="text-xs font-bold uppercase tracking-widest mb-3"
            style="color: #1E6FFF;"
          >
            Available 24/7
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: #0F172A;">
            DevOps Advisor AI
          </h3>
          <p
            class="text-sm leading-relaxed flex-1 mb-6"
            style="color: #64748B;"
          >
            Technical assistant specialized in cloud infrastructure, Kubernetes,
            CI/CD pipelines and cost optimization. Answers technical questions,
            evaluates architectures and guides platform best practices —
            available directly on this site.
          </p>
          <button
            onclick="document.getElementById('lra-chat-toggle')?.click()"
            class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
            style="color: #2563EB; background: none; border: none; cursor: pointer; padding: 0;"
          >
            Open the Advisor
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </button>
        </div>

        <!-- Card 2: AWS DevOps Agent -->
        <div
          class="bg-white rounded-2xl p-8 flex flex-col"
          style="border-left: 4px solid #1E6FFF; border-top: 1px solid #E5E7EB; border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06);"
        >
          <div
            class="w-12 h-12 flex items-center justify-center rounded-xl mb-6 flex-shrink-0"
            style="background: #EFF6FF;"
            aria-hidden="true"
          >
            <svg
              class="w-6 h-6"
              style="color: #2563EB;"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div
            class="text-xs font-bold uppercase tracking-widest mb-3"
            style="color: #1E6FFF;"
          >
            Open Source
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: #0F172A;">
            AWS DevOps Agent
          </h3>
          <p
            class="text-sm leading-relaxed flex-1 mb-6"
            style="color: #64748B;"
          >
            Python agent combining Claude with boto3 to automate AWS tasks: cost
            analysis, security group review, idle resource detection and status
            report generation. Designed to run in CI/CD pipelines or from the
            command line.
          </p>
          <a
            href="https://github.com/lra-cloud-ops"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
            style="color: #2563EB;"
          >
            View on GitHub
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path>
            </svg>
          </a>
        </div>

        <!-- Card 3: AI Architecture Review -->
        <div
          class="bg-white rounded-2xl p-8 flex flex-col"
          style="border-left: 4px solid #1E6FFF; border-top: 1px solid #E5E7EB; border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04), 0 4px 16px rgba(15,23,42,0.06);"
        >
          <div
            class="w-12 h-12 flex items-center justify-center rounded-xl mb-6 flex-shrink-0"
            style="background: #EFF6FF;"
            aria-hidden="true"
          >
            <svg
              class="w-6 h-6"
              style="color: #2563EB;"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <div
            class="text-xs font-bold uppercase tracking-widest mb-3"
            style="color: #1E6FFF;"
          >
            Premium Service
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: #0F172A;">
            AI-Assisted Architecture Review
          </h3>
          <p
            class="text-sm leading-relaxed flex-1 mb-6"
            style="color: #64748B;"
          >
            We combine expert manual analysis with AI to review your AWS or
            Kubernetes architecture: anti-pattern detection, security risks,
            cost optimization opportunities and prioritized recommendations.
            Delivered as a structured technical report.
          </p>
          <a
            href="/en/pricing"
            class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
            style="color: #2563EB;"
          >
            View engagement models
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHY AI + HUMAN ── -->
  <section
    style="background: #F8FAFC; border-top: 1px solid #E5E7EB;"
    aria-labelledby="ai-why-heading"
  >
    <div class="max-w-4xl mx-auto px-6 py-20">
      <div class="text-center mb-12">
        <span
          class="inline-flex items-center text-xs font-semibold px-3 py-1.5 rounded-full mb-4"
          style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
        >
          Philosophy
        </span>
        <h2
          id="ai-why-heading"
          class="text-3xl sm:text-4xl font-bold mb-4"
          style="color: #0F172A; letter-spacing: -0.025em;"
        >
          Why AI + human engineering
        </h2>
        <p class="text-lg max-w-xl mx-auto" style="color: #64748B;">
          AI accelerates the diagnosis. The engineer makes the decision.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {
          [
            {
              icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Full transparency',
              desc: 'Every AI-generated recommendation is documented with its reasoning. The client always knows what the model decided and what the engineer validated.',
            },
            {
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title: 'Mandatory human validation',
              desc: 'No infrastructure change is executed based solely on AI output. The engineer reviews, validates and approves before any production application.',
            },
            {
              icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
              title: 'No model vendor lock-in',
              desc: 'We build on standard APIs. If Claude Sonnet stops being the best option, we can migrate to another model without redesigning the platform.',
            },
            {
              icon: 'M13 10V3L4 14h7v7l9-11h-7z',
              title: 'AI where it adds real value',
              desc: 'We use AI for log analysis, runbook generation and initial diagnosis. Not to replace technical judgement on critical architecture decisions.',
            },
          ].map(({ icon, title, desc }) => (
            <div
              class="flex gap-4 p-6 bg-white rounded-2xl"
              style="border: 1px solid #E5E7EB; box-shadow: 0 1px 3px rgba(15,23,42,0.04);"
            >
              <div
                class="w-10 h-10 flex items-center justify-center rounded-xl flex-shrink-0"
                style="background: #EFF6FF;"
                aria-hidden="true"
              >
                <svg
                  class="w-5 h-5"
                  style="color: #2563EB;"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={icon}
                  />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-bold mb-1.5" style="color: #0F172A;">
                  {title}
                </h3>
                <p class="text-sm leading-relaxed" style="color: #64748B;">
                  {desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── AI STACK ── -->
  <section class="bg-white py-16" aria-labelledby="ai-stack-heading">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2
        id="ai-stack-heading"
        class="text-2xl font-bold mb-3"
        style="color: #0F172A; letter-spacing: -0.02em;"
      >
        AI Stack
      </h2>
      <p class="text-base mb-10" style="color: #64748B;">
        The tools we use to build AI capabilities in production.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {
          [
            {
              name: 'Claude Sonnet',
              role: 'Language model',
              note: 'by Anthropic',
            },
            { name: 'boto3', role: 'AWS SDK Python', note: 'For AWS agents' },
            {
              name: 'Cloudflare Workers',
              role: 'Edge Functions',
              note: 'Advisor API',
            },
            {
              name: 'Python 3.12',
              role: 'Agent runtime',
              note: 'Scripting & CLI',
            },
          ].map(({ name, role, note }) => (
            <div
              class="p-5 rounded-2xl text-center"
              style="background: #F8FAFC; border: 1px solid #E5E7EB;"
            >
              <div class="text-sm font-bold mb-1" style="color: #0A2540;">
                {name}
              </div>
              <div class="text-xs font-semibold mb-0.5" style="color: #1E6FFF;">
                {role}
              </div>
              <div class="text-xs" style="color: #94A3B8;">
                {note}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ── -->
  <section
    class="relative overflow-hidden"
    style="background-color: #0A2540;"
    aria-labelledby="ai-cta-heading"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(30,111,255,0.2) 0%, transparent 65%);"
    >
    </div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2
        id="ai-cta-heading"
        class="text-3xl sm:text-4xl font-extrabold text-white mb-5"
        style="letter-spacing: -0.03em;"
      >
        Try the DevOps Advisor now
      </h2>
      <p
        class="text-lg mb-8 max-w-xl mx-auto"
        style="color: rgba(147,184,255,0.8);"
      >
        Ask about your AWS architecture, a Kubernetes problem or how to reduce
        cloud costs. The Advisor responds in seconds.
      </p>
      <button
        onclick="document.getElementById('lra-chat-toggle')?.click()"
        class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]"
        style="background: #2563EB; box-shadow: 0 4px 20px rgba(37,99,235,0.45);"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
          ></path>
        </svg>
        Open DevOps Advisor · AI
      </button>
    </div>
  </section>
</Layout>
