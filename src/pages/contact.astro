---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Contact"
  descripcion="Contact LRA Cloud Operations about your cloud infrastructure, platform engineering or DevOps project. Initial assessment included."
>
  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none opacity-40"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 sm:py-24">
      <div class="max-w-2xl">
        <span
          class="inline-flex items-center text-xs font-semibold px-4 py-2 rounded-full mb-6"
          style="background: rgba(30,111,255,0.15); color: #93b8ff; border: 1px solid rgba(30,111,255,0.3);"
        >
          Contact
        </span>
        <h1
          class="text-4xl sm:text-5xl font-extrabold text-white mb-5"
          style="letter-spacing: -0.02em;"
        >
          Let's talk.
        </h1>
        <p class="text-lg" style="color: rgba(147,184,255,0.8);">
          Describe what you are building and we will design the infrastructure
          you need.
        </p>
      </div>
    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section class="bg-white border-b border-gray-100 py-10">
    <div class="max-w-5xl mx-auto px-6">
      <div
        class="rounded-2xl px-8 py-7 flex flex-col sm:flex-row items-start sm:items-center gap-6 justify-between"
        style="background: #EEF4FF; border: 1px solid #c3d9ff;"
      >
        <div>
          <div
            class="text-xs font-bold uppercase tracking-wider mb-1"
            style="color: #1E6FFF;"
          >
            Prefer to talk directly?
          </div>
          <h2 class="text-lg font-bold mb-1" style="color: #0A2540;">
            Schedule a free 30-min consultation
          </h2>
          <p class="text-sm" style="color: #64748b;">
            No sales deck, no commitment — just a technical conversation about
            your infrastructure.
          </p>
        </div>
        <a
          href="https://cal.com/ruben-alexis-h6qkjk/devops-consultation"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 text-sm font-semibold text-white px-6 py-3.5 rounded-xl flex-shrink-0 transition-all hover:-translate-y-px active:scale-[0.98]"
          style="background: #1E6FFF; box-shadow: 0 4px 16px rgba(30,111,255,0.35);"
        >
          Book a call
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- TRUST SIGNALS -->
  <section
    style="background: #F8FAFC; border-bottom: 1px solid #E2E8F0;"
    class="py-10"
  >
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {
          [
            {
              icon: '🔒',
              title: 'NDA available before first call',
              desc: 'Signed before any technical discussion',
            },
            {
              icon: '⚡',
              title: 'Response within 24 hours',
              desc: 'Weekdays · Monday to Friday',
            },
            {
              icon: '✓',
              title: 'OIDC-only credentials',
              desc: 'We never store your AWS keys',
            },
            {
              icon: '📋',
              title: 'Free initial assessment',
              desc: 'Architecture review at no charge',
            },
          ].map(({ icon, title, desc }) => (
            <div
              class="rounded-xl p-4"
              style="background: white; border: 1px solid #e2e8f0; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
            >
              <div class="text-xl mb-2" aria-hidden="true">
                {icon}
              </div>
              <div class="text-xs font-semibold mb-1" style="color: #0A2540;">
                {title}
              </div>
              <div class="text-xs leading-relaxed" style="color: #64748b;">
                {desc}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FORM + INFO -->
  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Contact form -->
        <div>
          <h2 class="text-2xl font-bold mb-2" style="color: #0A2540;">
            Send us a message
          </h2>
          <p class="text-sm mb-8" style="color: #64748b;">
            We respond within 24 hours · Initial assessment at no charge.
          </p>

          <form id="contact-form" class="space-y-5">
            <input
              type="hidden"
              name="access_key"
              value="e8aaab4e-270c-4163-bb76-6a8dfc247485"
            />
            <input
              type="hidden"
              name="subject"
              value="New engagement inquiry — lracloudops.com"
            />
            <input
              type="hidden"
              name="from_name"
              value="LRA Cloud Operations"
            />

            <div>
              <label
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: #94a3b8;">Full name</label
              >
              <input
                type="text"
                name="name"
                required
                placeholder="Your full name"
                class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200"
                style="color: #111827; border-color: #e2e8f0; background: #fafbfc;"
                onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"
              />
            </div>

            <div>
              <label
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: #94a3b8;">Business email</label
              >
              <input
                type="email"
                name="email"
                required
                placeholder="you@company.com"
                class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200"
                style="color: #111827; border-color: #e2e8f0; background: #fafbfc;"
                onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"
              />
            </div>

            <div>
              <label
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: #94a3b8;">Company Size</label
              >
              <div class="relative">
                <select
                  name="company_size"
                  class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 appearance-none"
                  style="color: #111827; background-color: #fafbfc; cursor: pointer; border-color: #e2e8f0;"
                  onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                  onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"
                >
                  <option value="">Select company size</option>
                  <option value="1-10">1–10 employees</option>
                  <option value="11-50">11–50 employees</option>
                  <option value="51-200">51–200 employees</option>
                  <option value="200+">200+ employees</option>
                </select>
                <div
                  class="absolute inset-y-0 right-4 flex items-center pointer-events-none"
                >
                  <svg
                    class="w-4 h-4"
                    style="color: #64748b;"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: #94a3b8;">Primary Challenge</label
              >
              <div class="relative">
                <select
                  name="primary_challenge"
                  class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 appearance-none"
                  style="color: #111827; background-color: #fafbfc; cursor: pointer; border-color: #e2e8f0;"
                  onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                  onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"
                >
                  <option value="">Select your main challenge</option>
                  <option value="kubernetes-aws"
                    >We need Kubernetes on AWS</option
                  >
                  <option value="automate-deployments"
                    >We need to automate our deployments</option
                  >
                  <option value="infrastructure-as-code"
                    >We need infrastructure as code</option
                  >
                  <option value="observability"
                    >We need better observability</option
                  >
                  <option value="reduce-aws-costs"
                    >We need to reduce AWS costs</option
                  >
                  <option value="other">Other</option>
                </select>
                <div
                  class="absolute inset-y-0 right-4 flex items-center pointer-events-none"
                >
                  <svg
                    class="w-4 h-4"
                    style="color: #64748b;"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: #94a3b8;">Estimated scope</label
              >
              <div class="relative">
                <select
                  name="budget"
                  class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 appearance-none"
                  style="color: #111827; background-color: #fafbfc; cursor: pointer; border-color: #e2e8f0;"
                  onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                  onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"
                >
                  <option value="">Select a range</option>
                  <option value="Under $5,000">Under $5,000</option>
                  <option value="$5,000 – $15,000">$5,000 – $15,000</option>
                  <option value="$15,000 – $50,000">$15,000 – $50,000</option>
                  <option value="Over $50,000">Over $50,000</option>
                  <option value="To be defined">To be defined</option>
                </select>
                <div
                  class="absolute inset-y-0 right-4 flex items-center pointer-events-none"
                >
                  <svg
                    class="w-4 h-4"
                    style="color: #64748b;"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: #94a3b8;">Timeline</label
              >
              <div class="relative">
                <select
                  name="timeline"
                  class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 appearance-none"
                  style="color: #111827; background-color: #fafbfc; cursor: pointer; border-color: #e2e8f0;"
                  onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                  onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"
                >
                  <option value="">Select a timeline</option>
                  <option value="This week">This week</option>
                  <option value="This month">This month</option>
                  <option value="Next quarter">Next quarter</option>
                  <option value="No specific deadline"
                    >No specific deadline</option
                  >
                </select>
                <div
                  class="absolute inset-y-0 right-4 flex items-center pointer-events-none"
                >
                  <svg
                    class="w-4 h-4"
                    style="color: #64748b;"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: #94a3b8;">Message</label
              >
              <textarea
                name="message"
                required
                rows="5"
                placeholder="Describe your project, current infrastructure, or what you need to automate..."
                class="w-full px-4 py-3.5 text-sm rounded-xl border outline-none transition-all duration-200 resize-none"
                style="color: #111827; border-color: #e2e8f0; background: #fafbfc;"
                onfocus="this.style.borderColor='#1E6FFF'; this.style.boxShadow='0 0 0 3px rgba(30,111,255,0.1)'; this.style.background='white';"
                onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'; this.style.background='#fafbfc';"
              ></textarea>
            </div>

            <div
              class="cf-turnstile"
              data-sitekey="0x4AAAAAADdu7unfdfZeg_dX"
              data-theme="light"
            >
            </div>
            <script
              src="https://challenges.cloudflare.com/turnstile/v0/api.js"
              async
              defer></script>

            <button
              type="submit"
              id="btn-submit"
              class="w-full text-sm font-semibold text-white py-4 rounded-xl transition-all duration-200 hover:-translate-y-px active:scale-[0.99]"
              style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 16px rgba(30,111,255,0.35), 0 1px 3px rgba(30,111,255,0.2);"
            >
              Send message
            </button>

            <p class="text-xs text-center" style="color: #94a3b8;">
              🔒 Your information is confidential. We respond within 24 hours.
              No spam, ever.
            </p>

            <div
              id="form-status"
              class="hidden text-sm text-center py-3 rounded-xl"
            >
            </div>
          </form>
        </div>

        <!-- Contact info -->
        <div class="flex flex-col gap-8">
          <div>
            <h2 class="text-2xl font-bold mb-6" style="color: #0A2540;">
              Other ways to reach us
            </h2>

            <div class="space-y-4">
              <a
                href="mailto:info@lracloudops.com"
                class="flex items-center gap-4 p-5 rounded-2xl transition-all duration-200 group hover:-translate-y-1"
                style="background: #fafbfc; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
                onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 8px 24px rgba(10,37,64,0.08)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';"
              >
                <div
                  class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                  style="background: #EEF4FF;"
                >
                  <svg
                    class="w-5 h-5"
                    style="color: #1E6FFF;"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div
                    class="text-xs font-semibold uppercase tracking-wider mb-1"
                    style="color: #94a3b8;"
                  >
                    Email
                  </div>
                  <div
                    class="text-sm font-medium group-hover:text-[#1E6FFF] transition-colors"
                    style="color: #0A2540;"
                  >
                    info@lracloudops.com
                  </div>
                </div>
              </a>

              <a
                href="https://www.linkedin.com/in/ruben-alexis-liquenson-490961269/"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-5 rounded-2xl transition-all duration-200 group hover:-translate-y-1"
                style="background: #fafbfc; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
                onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 8px 24px rgba(10,37,64,0.08)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';"
              >
                <div
                  class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                  style="background: #EEF4FF;"
                >
                  <svg
                    class="w-5 h-5"
                    style="color: #1E6FFF;"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div
                    class="text-xs font-semibold uppercase tracking-wider mb-1"
                    style="color: #94a3b8;"
                  >
                    LinkedIn
                  </div>
                  <div
                    class="text-sm font-medium group-hover:text-[#1E6FFF] transition-colors"
                    style="color: #0A2540;"
                  >
                    LRA Cloud Operations
                  </div>
                </div>
              </a>

              <a
                href="https://github.com/Liquenson"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-5 rounded-2xl transition-all duration-200 group hover:-translate-y-1"
                style="background: #fafbfc; border: 1px solid #e8eef4; box-shadow: 0 1px 3px rgba(10,37,64,0.04);"
                onmouseenter="this.style.boxShadow='0 2px 6px rgba(10,37,64,0.06), 0 8px 24px rgba(10,37,64,0.08)'; this.style.borderColor='rgba(30,111,255,0.2)';"
                onmouseleave="this.style.boxShadow='0 1px 3px rgba(10,37,64,0.04)'; this.style.borderColor='#e8eef4';"
              >
                <div
                  class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                  style="background: #EEF4FF;"
                >
                  <svg
                    class="w-5 h-5"
                    style="color: #1E6FFF;"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div
                    class="text-xs font-semibold uppercase tracking-wider mb-1"
                    style="color: #94a3b8;"
                  >
                    GitHub
                  </div>
                  <div
                    class="text-sm font-medium group-hover:text-[#1E6FFF] transition-colors"
                    style="color: #0A2540;"
                  >
                    github.com/Liquenson
                  </div>
                </div>
              </a>

              <div
                class="flex items-center gap-3 px-4 py-3 rounded-xl"
                style="background: #F0FDF4; border: 1px solid #BBF7D0;"
              >
                <svg
                  class="w-4 h-4 flex-shrink-0"
                  style="color: #15803D;"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-xs font-semibold" style="color: #15803D;">
                    Available for calls
                  </div>
                  <div class="text-xs" style="color: #166534;">
                    Mon–Fri · 9:00–18:00 CET
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- What we can do -->
          <div
            class="rounded-2xl p-6"
            style="background: #EEF4FF; border: 1px solid #c3d9ff;"
          >
            <h3 class="text-sm font-bold mb-4" style="color: #0A2540;">
              What we can do for you
            </h3>
            <ul class="space-y-2.5">
              {
                [
                  'Design your AWS cloud architecture',
                  'Implement infrastructure with Terraform',
                  'Configure end-to-end CI/CD pipelines',
                  'Migrate to Kubernetes / ECS Fargate',
                  'Optimize AWS costs and rightsizing',
                  'Configure observability with Prometheus + Grafana',
                ].map((item) => (
                  <li
                    class="flex items-center gap-2.5 text-sm"
                    style="color: #334155;"
                  >
                    <svg
                      class="w-4 h-4 flex-shrink-0"
                      style="color: #1E6FFF;"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Response time -->
          <div
            class="rounded-2xl p-5 flex items-start gap-4"
            style="background: white; border: 1px solid #e2e8f0;"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
              style="background: #f0fdf4;"
            >
              <svg
                class="w-5 h-5"
                style="color: #15803d;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: #0A2540;">
                Response within 24 hours
              </p>
              <p class="text-xs" style="color: #64748b;">
                Every inquiry receives an initial assessment at no charge. We
                will outline a concrete approach before any commitment is made.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const btn = document.getElementById('btn-submit') as HTMLButtonElement
  const status = document.getElementById('form-status') as HTMLDivElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.textContent = 'Sending...'
    btn.disabled = true
    btn.style.opacity = '0.8'
    status.classList.add('hidden')

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      })
      const data = await res.json()
      if (data.success) {
        status.textContent = 'Message sent. We will respond within 24 hours.'
        status.style.cssText =
          'display:block; background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;'
        form.reset()
      } else {
        status.textContent =
          'There was an error sending your message. Please try again.'
        status.style.cssText =
          'display:block; background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;'
      }
    } catch {
      status.textContent = 'Connection error. Please try again.'
      status.style.cssText =
        'display:block; background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;'
    }

    btn.textContent = 'Send message'
    btn.disabled = false
    btn.style.opacity = '1'
    status.classList.remove('hidden')
  })
</script>
