---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
---

<Layout
  title="Contact — LRA CloudOps"
  description="Get in touch with LRA CloudOps. Questions about the platform, pricing or DevOps consulting."
  lang="en"
>
  <Header lang="en" currentPath={Astro.url.pathname} />

  <section
    style="background: #F8F9FA; padding: 3rem 1.5rem; border-bottom: 1px solid #DADCE0;"
  >
    <div style="max-width: 1280px; margin: 0 auto;">
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 0.75rem; font-weight: 600; color: #1A73E8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;"
      >
        Contact
      </p>
      <h1
        style="font-family: 'Red Hat Display', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #202124; margin-bottom: 0.75rem;"
      >
        Get in touch
      </h1>
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #E6F4EA; color: #137333; padding: 0.375rem 0.875rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 500; margin-top: 1rem;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: #137333;"></span>
        We respond within 24 hours
      </div>
      <p
        style="font-family: 'Red Hat Text', sans-serif; font-size: 1.0625rem; color: #5F6368; max-width: 480px;"
      >
        Questions about the platform, pricing or consulting? Send a message and
        we'll respond within 24 hours.
      </p>
    </div>
  </section>

  <section style="background: #FFFFFF; padding: 3rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div
        data-animate="fade-up"
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;"
        class="contact-grid"
      >
        <!-- Contact form -->
        <div>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 700; color: #202124; margin-bottom: 1.5rem;"
          >
            Send a message
          </h2>
          <form
            style="display: flex; flex-direction: column; gap: 1.25rem;"
            action="https://api.web3forms.com/submit"
            method="POST"
          >
            <input
              type="hidden"
              name="access_key"
              value="e8aaab4e-270c-4163-bb76-6a8dfc247485"
            />
            <input
              type="hidden"
              name="subject"
              value="LRA CloudOps — Contact form"
            />

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Name
              </label>
              <input
                type="text"
                name="name"
                required
                placeholder="Your name"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              />
            </div>

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Email
              </label>
              <input
                type="email"
                name="email"
                required
                placeholder="you@company.com"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              />
            </div>

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Topic
              </label>
              <select
                name="topic"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
              >
                <option value="">Select a topic</option>
                <option value="audit">Free infrastructure audit</option>
                <option value="platform">Platform access</option>
                <option value="consulting">DevOps consulting</option>
                <option value="pricing">Pricing question</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;">
                GitHub repository URL <span style="color: #9AA0A6; font-weight: 400;">(optional)</span>
              </label>
              <input type="url" name="github_repo" placeholder="https://github.com/your-org/your-repo"
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              />
              <p style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #9AA0A6; margin-top: 0.375rem;">
                If you want a free lra scan audit, paste your repo URL here.
              </p>
            </div>

            <div>
              <label
                style="display: block; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.375rem;"
              >
                Message
              </label>
              <textarea
                name="message"
                required
                rows="5"
                placeholder="Describe what you need..."
                style="width: 100%; padding: 0.625rem 0.875rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #202124; background: #FFFFFF; border: 1px solid #DADCE0; border-radius: 4px; outline: none; resize: vertical; box-sizing: border-box;"
                onfocus="this.style.borderColor='#1A73E8'; this.style.boxShadow='0 0 0 3px rgba(26,115,232,0.12)'"
                onblur="this.style.borderColor='#DADCE0'; this.style.boxShadow='none'"
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-premium"
              style="display: inline-flex; align-items: center; justify-content: center; background: #1A73E8; color: #FFFFFF; padding: 0.75rem 1.5rem; border-radius: 4px; font-family: 'Red Hat Text', sans-serif; font-weight: 600; font-size: 0.9375rem; border: none; cursor: pointer;"
            >
              Send message →
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div>
          <h2
            style="font-family: 'Red Hat Display', sans-serif; font-size: 1.25rem; font-weight: 700; color: #202124; margin-bottom: 1.5rem;"
          >
            Direct contact
          </h2>
          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div
              style="display: flex; align-items: start; gap: 1rem; padding: 1.25rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px;"
            >
              <div
                style="width: 40px; height: 40px; background: #E8F0FE; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#1A73E8"
                  stroke-width="2"
                >
                  <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </div>
              <div>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;"
                >
                  Email
                </p>
                <a
                  href="mailto:info@lracloudops.com"
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #1A73E8; text-decoration: none;"
                >
                  info@lracloudops.com
                </a>
              </div>
            </div>
            <div
              style="display: flex; align-items: start; gap: 1rem; padding: 1.25rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px;"
            >
              <div
                style="width: 40px; height: 40px; background: #E8F0FE; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1A73E8">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </div>
              <div>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;"
                >
                  LinkedIn
                </p>
                <a
                  href="https://www.linkedin.com/in/ruben-liquenson-490961269/"
                  target="_blank"
                  rel="noopener"
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #1A73E8; text-decoration: none;"
                >
                  Ruben Liquenson →
                </a>
              </div>
            </div>
            <div
              style="display: flex; align-items: start; gap: 1rem; padding: 1.25rem; background: #F8F9FA; border: 1px solid #DADCE0; border-radius: 8px;"
            >
              <div
                style="width: 40px; height: 40px; background: #E8F0FE; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#1A73E8"
                  stroke-width="2"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 600; color: #202124; margin-bottom: 0.25rem;"
                >
                  Location
                </p>
                <p
                  style="font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; color: #5F6368;"
                >
                  Las Palmas de Gran Canaria<br />Canarias, España · Remote
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
