---
import Layout from '../layouts/Layout.astro'

const assessments = [
  {
    title: 'Evaluación de Madurez DevOps',
    href: '/assessment',
    description:
      '10 preguntas sobre IaC, CI/CD, secretos, Kubernetes, observabilidad y seguridad.',
    badge: '10 preguntas · 3 min',
    iconPath:
      'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
  },
  {
    title: 'Evaluación de Preparación Cloud',
    href: '/cloud-readiness',
    description:
      '8 preguntas para determinar si tu aplicación está lista para producción en AWS.',
    badge: '8 preguntas · 2 min',
    iconPath:
      'M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z',
  },
  {
    title: 'Evaluación de Preparación Kubernetes',
    href: '/kubernetes-readiness',
    description:
      '8 preguntas para evaluar la preparación de tu equipo para Kubernetes en producción.',
    badge: '8 preguntas · 2 min',
    iconPath:
      'M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9',
  },
]
---

<Layout
  titulo="Evaluaciones DevOps"
  descripcion="Evalúa tu madurez DevOps con nuestras herramientas gratuitas de assessment."
  keywords="evaluación DevOps, preparación cloud, madurez Kubernetes, evaluación infraestructura, herramienta madurez DevOps"
>
  <!-- Hero -->
  <section
    style="background: linear-gradient(135deg, #0A2540 0%, #0d3060 100%); padding: 80px 24px 72px;"
  >
    <div style="max-width: 720px; margin: 0 auto; text-align: center;">
      <div
        style="display: inline-flex; align-items: center; gap: 8px; background: rgba(30,111,255,0.15); border: 1px solid rgba(30,111,255,0.3); border-radius: 100px; padding: 6px 16px; margin-bottom: 24px;"
      >
        <svg
          style="width: 14px; height: 14px; color: #1E6FFF;"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span
          style="font-size: 12px; font-weight: 600; color: #93C5FD; letter-spacing: 0.05em; text-transform: uppercase;"
          >Herramientas gratuitas</span
        >
      </div>
      <h1
        style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; color: white; margin: 0 0 20px; line-height: 1.15;"
      >
        Herramientas de Evaluación
      </h1>
      <p
        style="font-size: 1.125rem; color: rgba(148,163,184,0.9); max-width: 560px; margin: 0 auto; line-height: 1.7;"
      >
        Evalúa tu madurez DevOps, preparación cloud y Kubernetes en menos de 3
        minutos — sin registro.
      </p>
    </div>
  </section>

  <!-- Cards -->
  <section style="background: #EEF4FF; padding: 64px 24px 80px;">
    <div
      style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px;"
    >
      {
        assessments.map(({ title, href, description, badge, iconPath }) => (
          <a
            href={href}
            style="display: flex; flex-direction: column; background: white; border-radius: 16px; padding: 32px 28px; box-shadow: 0 2px 12px rgba(10,37,64,0.07); border: 1px solid rgba(10,37,64,0.07); text-decoration: none; transition: transform 0.18s ease, box-shadow 0.18s ease;"
            onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 32px rgba(10,37,64,0.13)';"
            onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 12px rgba(10,37,64,0.07)';"
          >
            <div style="width: 48px; height: 48px; border-radius: 12px; background: #EEF4FF; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; flex-shrink: 0;">
              <svg
                style="width: 24px; height: 24px; color: #1E6FFF;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={iconPath}
                />
              </svg>
            </div>
            <h2 style="font-size: 1.125rem; font-weight: 700; color: #0A2540; margin: 0 0 10px; line-height: 1.3;">
              {title}
            </h2>
            <p style="font-size: 0.9rem; color: #64748b; line-height: 1.65; flex: 1; margin: 0 0 20px;">
              {description}
            </p>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: auto;">
              <span style="font-size: 11px; font-weight: 600; color: #1E6FFF; background: rgba(30,111,255,0.1); border-radius: 100px; padding: 4px 12px; letter-spacing: 0.02em;">
                {badge}
              </span>
              <svg
                style="width: 18px; height: 18px; color: #1E6FFF;"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
