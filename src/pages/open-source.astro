---
import Layout from '../layouts/Layout.astro'

const repos = [
  {
    name: 'gitops-stack',
    url: 'https://github.com/Liquenson/gitops-stack',
    description:
      'Complete GitOps pipeline with Jenkins, ArgoCD, Kubernetes and Terraform. Production-tested architecture.',
    stack: ['Jenkins', 'ArgoCD', 'Kubernetes', 'Terraform', 'Ansible'],
  },
  {
    name: 'aws-terraform-devops',
    url: 'https://github.com/Liquenson/aws-terraform-devops',
    description:
      'AWS EKS platform with Terraform modules, CI/CD pipeline, HPA and CloudWatch observability.',
    stack: ['Terraform', 'EKS', 'GitHub Actions', 'Helm', 'SonarCloud'],
  },
  {
    name: 'linux-fleet-manager',
    url: 'https://github.com/Liquenson/linux-fleet-manager',
    description:
      'Enterprise Bash framework for Linux fleet management. Cross-platform: Linux, macOS, Windows Git Bash.',
    stack: ['Bash', 'ShellCheck', 'SSH', 'GitHub Actions'],
  },
  {
    name: 'aws-devops-agent',
    url: 'https://github.com/Liquenson/aws-devops-agent',
    description:
      'Natural language AWS operations agent powered by Claude AI and boto3.',
    stack: ['Python', 'Claude AI', 'boto3', 'AWS'],
  },
  {
    name: 'k8s-devops-platform',
    url: 'https://github.com/Liquenson/k8s-devops-platform',
    description:
      'Kubernetes platform with ArgoCD GitOps, KinD local cluster and production manifests.',
    stack: ['Kubernetes', 'ArgoCD', 'KinD', 'Helm'],
  },
  {
    name: 'docker-devops-platform',
    url: 'https://github.com/Liquenson/docker-devops-platform',
    description:
      'FastAPI microservices platform with PostgreSQL, Docker Compose and multi-stage builds.',
    stack: ['FastAPI', 'PostgreSQL', 'Docker', 'Python'],
  },
]
---

<Layout
  titulo="Open Source Projects · LRA Cloud Operations"
  descripcion="Production-grade open source tools and reference implementations by LRA Cloud Ops. Free to use, fork and adapt."
  keywords="open source DevOps, Kubernetes GitOps, Terraform AWS, Linux fleet management, FastAPI Docker, Claude AI agent"
>
  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.2) 0%, transparent 65%);"
    ></div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <span
        class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        Open Source
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Open Source Projects
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        Production-grade tools and reference implementations. Free to use, fork and adapt.
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.5);">
        MIT License &middot; 6 repositories &middot; github.com/Liquenson
      </p>
    </div>
  </section>

  <!-- ─── REPOS GRID ───────────────────────────────────────────────────── -->
  <section class="py-20" style="background: #F8FAFC;">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        {
          repos.map((repo) => (
            <div
              class="bg-white flex flex-col hover:-translate-y-1 transition-all duration-200"
              style="border-radius: 16px; border: 1px solid #e2e8f0; border-left: 4px solid #1E6FFF; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 4px 20px rgba(10,37,64,0.08); padding: 28px;"
            >
              <!-- Header: GitHub icon + Open Source badge -->
              <div class="flex items-start justify-between mb-5">
                <div
                  class="w-10 h-10 flex items-center justify-center rounded-xl flex-shrink-0"
                  style="background: #0A2540;"
                >
                  <svg
                    class="w-5 h-5 text-white"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                    />
                  </svg>
                </div>
                <span
                  class="text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0"
                  style="background: rgba(16,185,129,0.1); color: #059669; border: 1px solid rgba(16,185,129,0.3);"
                >
                  Open Source
                </span>
              </div>

              <!-- Title -->
              <h2 class="text-base font-bold mb-2" style="color: #0A2540; font-family: 'JetBrains Mono', monospace;">
                {repo.name}
              </h2>

              <!-- Description -->
              <p class="text-sm leading-relaxed mb-5 flex-1" style="color: #64748b;">
                {repo.description}
              </p>

              <!-- Stack tags -->
              <div class="flex flex-wrap gap-1.5 mb-5">
                {repo.stack.map((tech) => (
                  <span
                    class="text-xs font-medium px-2.5 py-1 rounded-full"
                    style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
                  >
                    {tech}
                  </span>
                ))}
              </div>

              <!-- GitHub link -->
              <a
                href={repo.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-5 py-3 rounded-xl w-full transition-all hover:opacity-90"
                style="background: #0A2540; color: white; text-decoration: none;"
              >
                <svg
                  class="w-4 h-4"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  />
                </svg>
                View on GitHub →
              </a>
            </div>
          ))
        }
      </div>

      <!-- ─── CONTRIBUTE CTA ───────────────────────────────────────────── -->
      <div
        class="rounded-2xl p-10 text-center"
        style="background: white; border: 1px solid #e2e8f0; box-shadow: 0 4px 24px rgba(10,37,64,0.08);"
      >
        <div
          class="w-14 h-14 flex items-center justify-center rounded-2xl mx-auto mb-5"
          style="background: #EEF4FF;"
        >
          <svg
            class="w-6 h-6"
            style="color: #1E6FFF;"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
            />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3" style="color: #0A2540;">
          Want to contribute or use our modules?
        </h3>
        <p class="text-sm mb-7 max-w-md mx-auto" style="color: #64748b;">
          All repositories are MIT licensed. Fork them, adapt them to your infrastructure, or open a pull request with improvements.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="https://github.com/Liquenson"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-6 py-3 rounded-xl transition-all hover:opacity-90"
            style="background: #0A2540; color: white; text-decoration: none;"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            View all on GitHub
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 text-sm font-semibold px-6 py-3 rounded-xl transition-all hover:opacity-90"
            style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff; text-decoration: none;"
          >
            Contact us →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 32px 32px;"
    ></div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2
        class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
        style="letter-spacing: -0.02em;"
      >
        Need a custom implementation?
      </h2>
      <p class="text-base mb-8 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        Our open source repos are a starting point. We build production-grade infrastructure tailored to your organization.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02]"
        style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 24px rgba(30,111,255,0.4);"
      >
        Schedule free consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
