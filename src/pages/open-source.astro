---
import Layout from '../layouts/Layout.astro'
---

<Layout
  titulo="Open Source Projects · LRA Cloud Operations"
  descripcion="Production-grade open source tools and reference implementations by LRA Cloud Ops. Free to use, fork and adapt."
  keywords="open source DevOps, Kubernetes GitOps, Terraform AWS, Linux fleet management, FastAPI Docker, Claude AI agent"
>
  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,111,255,0.2) 0%, transparent 65%);"
    ></div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <span
        class="inline-flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
        style="background: rgba(30,111,255,0.2); color: #93b8ff; border: 1px solid rgba(30,111,255,0.25);"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        Open Source
      </span>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white mb-6"
        style="letter-spacing: -0.02em;"
      >
        Open Source Projects
      </h1>
      <p
        class="text-lg leading-relaxed max-w-2xl mx-auto mb-4"
        style="color: rgba(147,184,255,0.8);"
      >
        Production-grade tools and reference implementations. Free to use, fork and adapt.
      </p>
      <p class="text-sm font-medium" style="color: rgba(147,184,255,0.5);">
        MIT License &middot; github.com/lra-cloud-ops
      </p>
    </div>
  </section>

  <section class="py-20" style="background: #F8FAFC;">
    <div class="max-w-5xl mx-auto px-6">
      <!-- k8s-on-premise card -->
      <div
        class="bg-white rounded-2xl p-8 mb-8 hover:-translate-y-1 transition-all duration-200"
        style="border: 1px solid #e2e8f0; border-left: 4px solid #1E6FFF; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 8px 32px rgba(10,37,64,0.09);"
      >
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
              style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%);"
            >
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-7-9v18" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold" style="color: #0A2540;">k8s-on-premise</h3>
              <p class="text-sm" style="color: #64748b;">Kubernetes & GitOps</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span
              class="text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: #EEF4FF; color: #1E6FFF; border: 1px solid #c3d9ff;"
            >In Development</span>
            <span
              class="text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;"
            >Active</span>
          </div>
        </div>

        <p class="text-base leading-relaxed mb-5" style="color: #334155;">
          Production-grade Kubernetes cluster on bare metal. Automated with Vagrant + VirtualBox + kubeadm.
          ArgoCD GitOps, NGINX Ingress, Calico CNI. Phase 3/18 — full cluster from scratch with a single command: <code class="font-mono text-sm px-1.5 py-0.5 rounded" style="background: #EEF4FF; color: #1E6FFF;">vagrant up</code>.
        </p>

        <div class="flex flex-wrap gap-2 mb-6">
          {['Kubernetes v1.31.14', 'ArgoCD', 'Helm v3.21.0', 'Calico v3.27.0', 'NGINX Ingress', 'Vagrant', 'VirtualBox'].map(tag => (
            <span
              class="text-xs px-2.5 py-1 rounded-full font-medium"
              style="background: #f8fafc; color: #475569; border: 1px solid #e2e8f0;"
            >{tag}</span>
          ))}
        </div>

        <a
          href="https://github.com/lra-cloud-ops/k8s-on-premise"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all hover:opacity-90"
          style="background: #0A2540; color: white;"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- gitops-stack card -->
      <div
        class="bg-white rounded-2xl p-8 mb-8 hover:-translate-y-1 transition-all duration-200"
        style="border: 1px solid #e2e8f0; border-left: 4px solid #1E6FFF; box-shadow: 0 1px 3px rgba(10,37,64,0.04), 0 8px 32px rgba(10,37,64,0.09);"
      >
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
              style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%);"
            >
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold" style="color: #0A2540;">gitops-stack</h3>
              <p class="text-sm" style="color: #64748b;">GitOps & CI/CD</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span
              class="text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;"
            >Production</span>
            <span
              class="text-xs font-semibold px-3 py-1.5 rounded-full"
              style="background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;"
            >Active</span>
          </div>
        </div>

        <p class="text-base leading-relaxed mb-5" style="color: #334155;">
          Production-grade GitOps pipeline on AWS EKS. Terraform infrastructure, Jenkins CI, Ansible configuration,
          CloudWatch observability — full DevOps lifecycle from commit to production. Zero static credentials via IAM roles.
        </p>

        <div class="flex flex-wrap gap-2 mb-6">
          {['AWS EKS', 'Terraform', 'Jenkins', 'Ansible', 'Docker', 'Kubernetes', 'CloudWatch', 'AWS IAM'].map(tag => (
            <span
              class="text-xs px-2.5 py-1 rounded-full font-medium"
              style="background: #f8fafc; color: #475569; border: 1px solid #e2e8f0;"
            >{tag}</span>
          ))}
        </div>

        <a
          href="https://github.com/lra-cloud-ops/gitops-stack"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl transition-all hover:opacity-90"
          style="background: #0A2540; color: white;"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- More coming soon -->
      <div
        class="rounded-2xl p-8 text-center"
        style="background: #EEF4FF; border: 1px dashed #c3d9ff;"
      >
        <p class="text-base font-medium mb-1" style="color: #0A2540;">More repositories coming soon.</p>
        <p class="text-sm" style="color: #64748b;">
          Follow <a href="https://github.com/lra-cloud-ops" target="_blank" rel="noopener noreferrer" class="font-semibold underline" style="color: #1E6FFF;">github.com/lra-cloud-ops</a> for updates.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background-color: #0A2540;">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(147,184,255,0.12) 1px, transparent 1px); background-size: 32px 32px;"
    ></div>
    <div class="relative max-w-3xl mx-auto px-6 py-20 text-center">
      <h2
        class="text-3xl sm:text-4xl font-extrabold text-white mb-4"
        style="letter-spacing: -0.02em;"
      >
        Need a custom implementation?
      </h2>
      <p class="text-base mb-8 max-w-xl mx-auto" style="color: rgba(147,184,255,0.8);">
        Our open source repos are a starting point. We build production-grade infrastructure tailored to your organization.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white px-8 py-4 rounded-xl transition-all hover:scale-[1.02]"
        style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 4px 24px rgba(30,111,255,0.4);"
      >
        Schedule free consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
