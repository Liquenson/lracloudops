---
import '../styles/global.css'

const { titulo, descripcion } = Astro.props
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titulo} | LRA Cloud Operations</title>
    <meta name="description" content={descripcion} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content="https://lracloudops.com" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-gray-900 antialiased">

    <header class="sticky top-0 bg-white z-50 border-b border-gray-100 shadow-sm">
      <nav class="max-w-7xl mx-auto px-6 h-[70px] grid grid-cols-3 items-center">
        <a href="/" class="justify-self-start">
          <img src="/logo.svg" alt="LRA Cloud Operations" class="h-[50px] w-auto" />
        </a>
        <div class="flex items-center justify-center gap-7">
          <a href="/" class="text-sm font-medium text-gray-800 hover:text-[#0A2540] transition-colors">Inicio</a>
          <a href="/servicios" class="text-sm text-gray-600 hover:text-[#0A2540] transition-colors">Servicios</a>
          <a href="/soluciones" class="text-sm text-gray-600 hover:text-[#0A2540] transition-colors">Soluciones</a>
          <a href="/sobre-mi" class="text-sm text-gray-600 hover:text-[#0A2540] transition-colors">Sobre mí</a>
          <a href="/blog" class="text-sm text-gray-600 hover:text-[#0A2540] transition-colors">Blog</a>
        </div>
        <div class="justify-self-end">
          <a href="/contacto" class="text-sm font-semibold text-white px-5 py-2.5 rounded-lg transition-colors hover:opacity-90" style="background-color: #0A2540;">
            Contacto
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer style="background-color: #0A2540;">
      <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm">
        <span class="text-white/60">© 2026 LRA Cloud Operations</span>
        <div class="flex gap-6">
          <a href="https://github.com/Liquenson" class="text-white/60 hover:text-white transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/liquenson-ruben-490961269/" class="text-white/60 hover:text-white transition-colors">LinkedIn</a>
        </div>
      </div>
    </footer>

  </body>
</html>
