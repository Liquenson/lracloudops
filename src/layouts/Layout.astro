---
import '../styles/global.css'
import ChatWidget from '../components/ChatWidget.astro'

interface Props {
  title: string
  description?: string
  lang?: string
}

const { title, description = 'LRA CloudOps', lang = 'en' } = Astro.props

const isES = lang === 'es'

const gaId = import.meta.env.PUBLIC_GA_ID || 'G-VVRS1XH4Z5'

// Explicit route map EN ↔ ES — translated slugs aren't a simple /es prefix
const routeMap: Record<string, string> = {
  '/': '/es/',
  '/projects': '/es/proyectos',
  '/projects/lra-ai-platform': '/es/proyectos/lra-ai-platform',
  '/projects/aws-devops-agent': '/es/proyectos/aws-devops-agent',
  '/projects/aws-terraform-devops': '/es/proyectos/aws-terraform-devops',
  '/projects/k8s-on-premise': '/es/proyectos/k8s-on-premise',
  '/services': '/es/servicios',
  '/pricing': '/es/precios',
  '/about': '/es/sobre-nosotros',
  '/contact': '/es/contacto',
  '/login': '/es/login',
  '/dashboard': '/es/dashboard',
  '/privacy': '/es/privacidad',
  '/terms': '/es/terminos',
  '/audit': '/es/auditoria',
  '/case-studies': '/es/casos-de-uso',
  '/open-source': '/es/open-source',
  '/payment-success': '/es/pago-exitoso',
  '/security': '/es/seguridad',
}

// Reverse map ES → EN
const reverseMap = Object.fromEntries(
  Object.entries(routeMap).map(([en, es]) => [es, en])
)

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'

const enUrl = isES
  ? reverseMap[currentPath] || reverseMap[currentPath + '/'] || '/'
  : currentPath
const esUrl = isES
  ? currentPath
  : routeMap[currentPath] || routeMap[currentPath + '/'] || '/es/'
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>

    <!-- Primary Meta Tags -->
    <meta name="description" content={description} />
    <meta name="author" content="Ruben Liquenson — LRA CloudOps" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / LinkedIn / WhatsApp / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="LRA CloudOps" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://lracloudops.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={isES
        ? 'LRA CloudOps — Automatización DevOps con agentes especializados'
        : 'LRA CloudOps — DevOps automation with specialized agents'}
    />
    <meta property="og:locale" content={isES ? 'es_ES' : 'en_US'} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://lracloudops.com/og-image.png" />
    <meta
      name="twitter:image:alt"
      content={isES
        ? 'LRA CloudOps — Automatización DevOps con agentes especializados'
        : 'LRA CloudOps — DevOps automation with specialized agents'}
    />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon-new.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <meta name="msapplication-TileImage" content="/favicon-192x192.png" />
    <meta name="msapplication-TileColor" content="#1A73E8" />
    <link rel="alternate" hreflang="en" href={new URL(enUrl, Astro.site)} />
    <link rel="alternate" hreflang="es" href={new URL(esUrl, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(enUrl, Astro.site)} />
    <link rel="dns-prefetch" href="https://github.com" />
    <link rel="preconnect" href="https://api.web3forms.com" />
    <link rel="dns-prefetch" href="https://lracloudops-webhook.liquenson-cloud.workers.dev" />
    <link rel="dns-prefetch" href="https://lracloudops-agent.liquenson-cloud.workers.dev" />

    <!-- Mobile optimization -->
    <meta name="theme-color" content="#1A73E8" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <script is:inline src="/js/lang-redirect.js"></script>

    <!-- Google Analytics GA4 -->
    <script async is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script is:inline defer src="/js/analytics.js" data-ga-id={gaId}></script>

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "LRA CloudOps",
      "url": "https://lracloudops.com",
      "logo": "https://lracloudops.com/lracloudops-icon.svg",
      "description": "Platform Engineering consultancy specializing in Infrastructure as Code, Kubernetes, GitOps and AI agents.",
      "founder": {
        "@type": "Person",
        "name": "Ruben Liquenson",
        "jobTitle": "Platform Engineer",
        "url": "https://www.linkedin.com/in/ruben-liquenson-490961269/"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Las Palmas de Gran Canaria",
        "addressRegion": "Canarias",
        "addressCountry": "ES"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@lracloudops.com",
        "contactType": "customer service"
      },
      "sameAs": [
        "https://github.com/lra-cloud-ops",
        "https://www.linkedin.com/in/ruben-liquenson-490961269/"
      ]
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <main id="main-content">
      <slot />
    </main>

    <ChatWidget />

    <script is:inline src="/js/img-fallback.js"></script>

    <script>
      import { initAnimations } from '../scripts/animations.ts'
      initAnimations()
    </script>
  </body>
</html>
