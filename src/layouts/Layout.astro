---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  image?: string
  lang?: string
  canonicalURL?: string
}

const {
  title,
  description,
  image = '/og-image.png',
  lang = 'en',
  canonicalURL = Astro.url.href,
} = Astro.props

const siteName = 'Ruben Liquenson'
const fullTitle = title.includes('Ruben') ? title : `${title} — ${siteName}`
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={Astro.site} />
    <link rel="alternate" hreflang="es" href={new URL('/es/', Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={Astro.site} />

    <!-- Schema.org Person -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Ruben Liquenson',
        jobTitle: 'DevOps Engineer & AWS Specialist',
        url: 'https://lracloudops.com',
        email: 'liquenson.cloud@gmail.com',
        sameAs: [
          'https://www.linkedin.com/in/rubenliquenson-490961269',
          'https://github.com/Liquenson',
          'https://github.com/lra-cloud-ops',
        ],
        knowsAbout: [
          'DevOps',
          'AWS',
          'Kubernetes',
          'Terraform',
          'GitOps',
          'ArgoCD',
        ],
      })}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <slot />
    <script>
      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible')
              observer.unobserve(e.target)
            }
          }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      )
      document
        .querySelectorAll('.fade-up')
        .forEach((el) => observer.observe(el))
    </script>
  </body>
</html>
