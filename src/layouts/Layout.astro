---
import '../styles/global.css'
import { getLangFromUrl } from '../i18n'
import AgentChat from '../components/AgentChat.astro'

interface Props {
  titulo: string
  descripcion: string
  keywords?: string
  schema?: Record<string, unknown> | null
  ogType?: 'website' | 'article'
  ogImage?: string
}

const {
  titulo,
  descripcion,
  keywords,
  schema = null,
  ogType = 'website',
  ogImage,
} = Astro.props
const currentPath = Astro.url.pathname
const lang = getLangFromUrl(Astro.url)
const canonicalURL = new URL(currentPath, 'https://lracloudops.com')
const finalOgImage = ogImage ?? 'https://lracloudops.com/og-image.png'

// Smart bilingual route mapping (handles slug differences like /services ↔ /es/servicios)
const _enToEs: Record<string, string> = {
  '/': '/es',
  '/services': '/es/servicios',
  '/about': '/es/nosotros',
  '/contact': '/es/contacto',
  '/pricing': '/es/pricing',
  '/projects': '/es/proyectos',
  '/blog': '/es/blog',
  '/resources': '/es/resources',
  '/open-source': '/es/open-source',
  '/security': '/es/security',
  '/why-lra': '/es/why-lra',
}
const _smartEsPath = currentPath.startsWith('/es')
  ? currentPath
  : (_enToEs[currentPath] ?? '/es' + currentPath)
const _smartEnPath = !currentPath.startsWith('/es')
  ? currentPath
  : (Object.entries(_enToEs).find(([, v]) => v === currentPath)?.[0] ??
    (currentPath === '/es' ? '/' : currentPath.slice(3)))
const enUrl = 'https://lracloudops.com' + _smartEnPath
const esUrl = 'https://lracloudops.com' + _smartEsPath
const currentLangLabel = lang === 'es' ? 'Español' : 'English'

const pathLabels: Record<string, string> = {
  services: 'Solutions',
  projects: 'Case Studies',
  about: 'About',
  contact: 'Contact',
  blog: 'Blog',
  'cloud-infrastructure': 'Cloud Infrastructure',
  'platform-engineering': 'Platform Engineering',
  'devops-automation': 'DevOps Automation',
  observability: 'Observability',
  pricing: 'Pricing',
  resources: 'Resources',
  solutions: 'Solutions',
  industries: 'Industries',
  'aws-modernization': 'AWS Modernization',
  'kubernetes-adoption': 'Kubernetes Adoption',
  'cicd-transformation': 'CI/CD Transformation',
  gitops: 'GitOps Implementation',
  healthcare: 'Healthcare',
  fintech: 'Fintech',
  saas: 'SaaS',
  'kubernetes-platforms': 'Kubernetes Platforms',
  'open-source': 'Open Source',
  es: 'ES',
  servicios: 'Soluciones',
  proyectos: 'Casos de uso',
  nosotros: 'Nosotros',
  contacto: 'Contacto',
}
const segments = currentPath.split('/').filter(Boolean)
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: 'https://lracloudops.com',
  },
  ...segments.map((seg, i) => {
    const url = 'https://lracloudops.com/' + segments.slice(0, i + 1).join('/')
    const name =
      i === segments.length - 1 && !pathLabels[seg]
        ? titulo
        : (pathLabels[seg] ?? seg)
    return { '@type': 'ListItem', position: i + 2, name, item: url }
  }),
]
const breadcrumbSchema =
  segments.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbItems,
      }
    : null

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://lracloudops.com/#organization',
  name: 'LRA Cloud Ops',
  url: 'https://lracloudops.com',
