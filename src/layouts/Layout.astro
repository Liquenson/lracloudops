---
import '../styles/global.css'
import ChatWidget from '../components/ChatWidget.astro'

interface Props {
  title: string
  description?: string
  lang?: string
}

const { title, description = 'LRA CloudOps', lang = 'en' } = Astro.props

const isES = lang === 'es'

// Explicit route map EN ↔ ES — translated slugs aren't a simple /es prefix
const routeMap: Record<string, string> = {
  '/': '/es/',
  '/projects': '/es/proyectos',
  '/projects/lra-ai-platform': '/es/proyectos/lra-ai-platform',
  '/projects/aws-devops-agent': '/es/proyectos/aws-devops-agent',
  '/projects/aws-terraform-devops': '/es/proyectos/aws-terraform-devops',
  '/projects/k8s-on-premise': '/es/proyectos/k8s-on-premise',
  '/services': '/es/servicios',
  '/pricing': '/es/precios',
  '/about': '/es/sobre-nosotros',
  '/contact': '/es/contacto',
  '/login': '/es/login',
  '/dashboard': '/es/dashboard',
}

// Reverse map ES → EN
const reverseMap = Object.fromEntries(
  Object.entries(routeMap).map(([en, es]) => [es, en])
)

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'

const enUrl = isES
  ? reverseMap[currentPath] || reverseMap[currentPath + '/'] || '/'
  : currentPath
const esUrl = isES
  ? currentPath
  : routeMap[currentPath] || routeMap[currentPath + '/'] || '/es/'
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Primary Meta Tags -->
    <meta name="description" content={description} />
    <meta name="author" content="Ruben Liquenson — LRA CloudOps" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / LinkedIn / WhatsApp / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="LRA CloudOps" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://lracloudops.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={isES
        ? 'LRA CloudOps — Automatización DevOps con agentes especializados'
        : 'LRA CloudOps — DevOps automation with specialized agents'}
    />
    <meta property="og:locale" content={isES ? 'es_ES' : 'en_US'} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://lracloudops.com/og-image.png" />
    <meta
      name="twitter:image:alt"
      content={isES
        ? 'LRA CloudOps — Automatización DevOps con agentes especializados'
        : 'LRA CloudOps — DevOps automation with specialized agents'}
    />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon-new.svg" />
    <link rel="apple-touch-icon" href="/favicon-new.png" />
    <link rel="alternate" hreflang="en" href={new URL(enUrl, Astro.site)} />
    <link rel="alternate" hreflang="es" href={new URL(esUrl, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={Astro.site} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://github.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;700;900&family=Red+Hat+Text:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Mobile optimization -->
    <meta name="theme-color" content="#1A73E8" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <script is:inline>
      ;(function () {
        const path = window.location.pathname
        if (path !== '/') return
        if (sessionStorage.getItem('lang-chosen')) return
        const lang = navigator.language || navigator.userLanguage || 'en'
        const isSpanish = lang.toLowerCase().startsWith('es')
        if (isSpanish) {
          sessionStorage.setItem('lang-chosen', 'es')
          window.location.replace('/es/')
        } else {
          sessionStorage.setItem('lang-chosen', 'en')
        }
      })()
    </script>
  </head>
  <body>
    <slot />

    <ChatWidget />

    <script>
      import { initAnimations } from '../scripts/animations.ts'
      initAnimations()
    </script>
  </body>
</html>
