---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  lang?: string
}

const { title, description = 'LRA CloudOps', lang = 'en' } = Astro.props

const isES = lang === 'es'

// Explicit route map EN ↔ ES — translated slugs aren't a simple /es prefix
const routeMap: Record<string, string> = {
  '/': '/es/',
  '/projects': '/es/proyectos',
  '/projects/lra-ai-platform': '/es/proyectos/lra-ai-platform',
  '/projects/aws-devops-agent': '/es/proyectos/aws-devops-agent',
  '/projects/aws-terraform-devops': '/es/proyectos/aws-terraform-devops',
  '/projects/k8s-on-premise': '/es/proyectos/k8s-on-premise',
  '/services': '/es/servicios',
  '/pricing': '/es/precios',
  '/about': '/es/sobre-nosotros',
  '/contact': '/es/contacto',
  '/login': '/es/login',
  '/dashboard': '/es/dashboard',
}

// Reverse map ES → EN
const reverseMap = Object.fromEntries(
  Object.entries(routeMap).map(([en, es]) => [es, en])
)

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'

const enUrl = isES
  ? reverseMap[currentPath] || reverseMap[currentPath + '/'] || '/'
  : currentPath
const esUrl = isES
  ? currentPath
  : routeMap[currentPath] || routeMap[currentPath + '/'] || '/es/'
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/png" href="/favicon-new.png" />
    <link rel="apple-touch-icon" href="/favicon-new.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="alternate" hreflang="en" href={new URL(enUrl, Astro.site)} />
    <link rel="alternate" hreflang="es" href={new URL(esUrl, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={Astro.site} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://github.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;700;900&family=Red+Hat+Text:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Mobile optimization -->
    <meta name="theme-color" content="#1A73E8" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Ruben Liquenson — LRA CloudOps" />
    <script is:inline>
      ;(function () {
        const path = window.location.pathname
        if (path !== '/') return
        if (sessionStorage.getItem('lang-chosen')) return
        const lang = navigator.language || navigator.userLanguage || 'en'
        const isSpanish = lang.toLowerCase().startsWith('es')
        if (isSpanish) {
          sessionStorage.setItem('lang-chosen', 'es')
          window.location.replace('/es/')
        } else {
          sessionStorage.setItem('lang-chosen', 'en')
        }
      })()
    </script>
  </head>
  <body>
    <slot />

    <div
      id="lang-switcher"
      style="position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999;"
    >
      <div style="position: relative; text-align: center;">
        <p
          style="font-family: 'Red Hat Text', sans-serif; font-size: 0.8125rem; color: #6B7280; font-weight: 500; margin-bottom: 0.5rem;"
        >
          {isES ? 'Cambiar idioma' : 'Change page language'}
        </p>

        <button
          id="lang-btn"
          type="button"
          style="display: inline-flex; align-items: center; gap: 0.5rem; background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 8px; padding: 0.5rem 1rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #111827; cursor: pointer; box-shadow: 0 1px 4px rgba(0,0,0,0.08); transition: border-color 150ms;"
          aria-expanded="false"
          aria-haspopup="true"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            style="color: #6B7280;"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path
              d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            ></path>
          </svg>
          <span>{isES ? 'Español' : 'English'}</span>
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            style="color: #6B7280;"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>

        <div
          id="lang-dropdown"
          style="display: none; position: absolute; bottom: calc(100% + 8px); right: 0; min-width: 160px; background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.10);"
          role="menu"
        >
          <a
            id="lang-link-en"
            href={enUrl}
            role="menuitem"
            style={`display: flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 500; text-decoration: none; ${!isES ? 'color: #0078D4; background: #EFF6FC; font-weight: 600;' : 'color: #111827;'}`}
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path
                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
              ></path>
            </svg>
            <span>English</span>
            {
              !isES && (
                <span
                  aria-hidden="true"
                  style="margin-left: auto; color: #0078D4;"
                >
                  ✓
                </span>
              )
            }
          </a>
          <a
            id="lang-link-es"
            href={esUrl}
            role="menuitem"
            style={`display: flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1rem; font-family: 'Red Hat Text', sans-serif; font-size: 0.875rem; font-weight: 500; text-decoration: none; ${isES ? 'color: #0078D4; background: #EFF6FC; font-weight: 600;' : 'color: #111827;'}`}
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path
                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
              ></path>
            </svg>
            <span>Español</span>
            {
              isES && (
                <span
                  aria-hidden="true"
                  style="margin-left: auto; color: #0078D4;"
                >
                  ✓
                </span>
              )
            }
          </a>
        </div>
      </div>
    </div>

    <script>
      const btn = document.getElementById('lang-btn')
      const dropdown = document.getElementById('lang-dropdown')
      const switcher = document.getElementById('lang-switcher')

      btn?.addEventListener('click', () => {
        const isOpen = dropdown?.style.display === 'block'
        if (dropdown) dropdown.style.display = isOpen ? 'none' : 'block'
        btn.setAttribute('aria-expanded', String(!isOpen))
      })

      document.addEventListener('click', (event) => {
        if (
          switcher &&
          event.target instanceof Node &&
          !switcher.contains(event.target)
        ) {
          if (dropdown) dropdown.style.display = 'none'
          btn?.setAttribute('aria-expanded', 'false')
        }
      })

      document.getElementById('lang-link-en')?.addEventListener('click', () => {
        sessionStorage.setItem('lang-chosen', 'en')
      })

      document.getElementById('lang-link-es')?.addEventListener('click', () => {
        sessionStorage.setItem('lang-chosen', 'es')
      })
    </script>

    <script>
      import { initAnimations } from '../scripts/animations.ts'
      initAnimations()
    </script>
  </body>
</html>
