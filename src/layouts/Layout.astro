---
import '../styles/global.css'

interface Props {
  titulo: string
  descripcion: string
  schema?: Record<string, unknown> | null
}

const { titulo, descripcion, schema = null } = Astro.props
const currentPath = Astro.url.pathname
const canonicalURL = new URL(currentPath, 'https://lracloudops.com')

// Auto-generate BreadcrumbList from the URL path
const pathLabels: Record<string, string> = {
  blog: 'Blog',
  projects: 'Projects',
  proyectos: 'Case Studies',
  servicios: 'Solutions',
  'sobre-nosotros': 'About',
  contacto: 'Contact',
  'case-studies': 'Case Studies',
  'cloud-infrastructure': 'Cloud Infrastructure',
  'platform-engineering': 'Platform Engineering',
  'devops-automation': 'DevOps Automation',
  observability: 'Observability',
}
const segments = currentPath.split('/').filter(Boolean)
const breadcrumbItems = [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lracloudops.com' },
  ...segments.map((seg, i) => {
    const url = 'https://lracloudops.com/' + segments.slice(0, i + 1).join('/')
    const isLastDynamic = i === segments.length - 1 && !pathLabels[seg]
    const name = isLastDynamic ? titulo : (pathLabels[seg] ?? seg)
    return { '@type': 'ListItem', position: i + 2, name, item: url }
  }),
]
const breadcrumbSchema = segments.length > 0
  ? { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: breadcrumbItems }
  : null

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://lracloudops.com/#organization',
  name: 'LRA Cloud Ops',
  url: 'https://lracloudops.com',
  logo: 'https://lracloudops.com/logo.svg',
  email: 'liquenson.cloud@gmail.com',
  foundingDate: '2024',
  description: 'Cloud infrastructure, Kubernetes platforms, DevOps automation and AWS consulting.',
  knowsAbout: ['Cloud Infrastructure', 'Platform Engineering', 'Kubernetes', 'Terraform', 'AWS', 'GitOps', 'DevOps', 'ArgoCD', 'CI/CD', 'SRE'],
  sameAs: [
    'https://www.linkedin.com/in/liquenson-ruben-490961269/',
    'https://github.com/Liquenson',
  ],
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://lracloudops.com/#website',
  url: 'https://lracloudops.com',
  name: 'LRA Cloud Ops',
  description: 'Cloud infrastructure, Kubernetes platforms and DevOps automation.',
  publisher: { '@id': 'https://lracloudops.com/#organization' },
  inLanguage: 'en-US',
}

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/servicios', label: 'Solutions' },
  { href: '/proyectos', label: 'Case Studies' },
  { href: '/sobre-nosotros', label: 'About' },
  { href: '/blog', label: 'Blog' },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cloud Infrastructure & Platform Engineering | LRA Cloud Ops</title>
    <meta name="description" content={descripcion} />
    <meta name="keywords" content="cloud infrastructure, platform engineering, DevOps consulting, AWS, Kubernetes, Terraform, GitOps, ArgoCD, Infrastructure as Code, SRE, CI/CD automation" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${titulo} | LRA Cloud Ops`} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="LRA Cloud Ops" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://lracloudops.com/og-image.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${titulo} | LRA Cloud Ops`} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content="https://lracloudops.com/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data — Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <!-- Structured Data — WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <!-- Structured Data — BreadcrumbList (auto-generated from path) -->
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
    <!-- Structured Data — Per-page schema (Article, Service, ItemList, etc.) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Fonts: Inter + IBM Plex Sans (enterprise pairing) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-white text-gray-900 antialiased">

    <!-- ── SKIP NAVIGATION (accessibility) ── -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded-lg focus:font-semibold">
      Skip to main content
    </a>

    <!-- ── STICKY NAVBAR ─────────────────────────────────────────────── -->
    <header
      id="site-header"
      class="sticky top-0 z-50 transition-all duration-300"
      style="background: rgba(255,255,255,0.97); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(15,23,42,0.06);"
    >
      <nav
        class="max-w-7xl mx-auto px-5 sm:px-6 h-[66px] flex items-center justify-between gap-4"
        aria-label="Main navigation"
      >

        <!-- Logo -->
        <a href="/" class="flex-shrink-0 z-50 flex items-center gap-2.5" aria-label="LRA Cloud Ops — Home">
          <img src="/logo.svg" alt="LRA Cloud Ops" class="h-[38px] w-auto" />
        </a>

        <!-- Desktop Nav -->
        <div class="hidden lg:flex items-center gap-0.5">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href)
            return (
              <a
                href={href}
                class={`relative text-sm font-medium px-3.5 py-2 rounded-lg transition-all duration-200 group ${
                  isActive
                    ? 'text-[#0F172A] font-semibold'
                    : 'text-[#64748B] hover:text-[#0F172A] hover:bg-gray-50'
                }`}
                aria-current={isActive ? 'page' : undefined}
              >
                {label}
                {isActive && (
                  <span class="absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 w-5 rounded-full" style="background: #2563EB;"></span>
                )}
              </a>
            )
          })}
        </div>

        <!-- Desktop CTA -->
        <div class="hidden lg:flex items-center gap-3 flex-shrink-0">
          <a
            href="https://github.com/Liquenson"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors"
            aria-label="GitHub profile"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>
          <a
            href="/contacto"
            class="text-sm font-semibold text-white px-5 py-2.5 rounded-xl transition-all duration-200 hover:-translate-y-px active:scale-[0.98]"
            style="background: #2563EB; box-shadow: 0 2px 8px rgba(37,99,235,0.3);"
          >
            Schedule Consultation
          </a>
        </div>

        <!-- Mobile Hamburger -->
        <button
          id="menu-btn"
          class="lg:hidden relative z-50 w-10 h-10 flex items-center justify-center rounded-xl hover:bg-gray-100/80 transition-colors"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-drawer"
        >
          <div class="w-5 h-4 flex flex-col justify-between">
            <span id="bar1" class="block h-0.5 bg-gray-800 rounded-full transition-all duration-300 origin-center"></span>
            <span id="bar2" class="block h-0.5 bg-gray-800 rounded-full transition-all duration-300"></span>
            <span id="bar3" class="block h-0.5 bg-gray-800 rounded-full transition-all duration-300 origin-center"></span>
          </div>
        </button>
      </nav>
    </header>

    <!-- Mobile Overlay -->
    <div
      id="mobile-overlay"
      class="fixed inset-0 z-40 lg:hidden pointer-events-none"
      style="background: rgba(11,18,32,0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); opacity: 0; transition: opacity 0.3s ease;"
      aria-hidden="true"
    ></div>

    <!-- Mobile Drawer -->
    <div
      id="mobile-drawer"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation menu"
      class="fixed top-0 right-0 bottom-0 z-40 w-72 lg:hidden flex flex-col"
      style="background: white; transform: translateX(100%); transition: transform 0.32s cubic-bezier(0.4,0,0.2,1); box-shadow: -12px 0 40px rgba(11,18,32,0.15);"
    >
      <div class="h-[64px] flex-shrink-0 border-b border-gray-100 flex items-center px-5">
        <span class="text-[10px] font-bold uppercase tracking-widest" style="color: #2563EB;">Navigation</span>
      </div>

      <nav class="flex-1 overflow-y-auto px-4 py-5">
        <div class="flex flex-col gap-0.5">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href)
            return (
              <a
                href={href}
                class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${
                  isActive
                    ? 'font-semibold'
                    : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
                }`}
                style={isActive ? 'background: #EFF6FF; color: #1D4ED8;' : ''}
                aria-current={isActive ? 'page' : undefined}
              >
                {isActive && (
                  <span class="w-1.5 h-4 rounded-full flex-shrink-0" style="background: #2563EB;"></span>
                )}
                <span class={isActive ? '' : 'ml-4'}>{label}</span>
              </a>
            )
          })}
        </div>
      </nav>

      <div class="flex-shrink-0 px-4 pb-6 pt-4 border-t border-gray-100">
        <a
          href="/contacto"
          class="flex items-center justify-center gap-2 w-full text-sm font-semibold text-white py-3.5 rounded-xl transition-all hover:opacity-90 mb-3"
          style="background: #2563EB; box-shadow: 0 4px 14px rgba(37,99,235,0.35);"
        >
          Schedule Consultation
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <div class="flex gap-2">
          <a
            href="https://github.com/Liquenson"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex items-center justify-center gap-1.5 text-xs font-medium text-gray-500 py-2.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/liquenson-ruben-490961269/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex items-center justify-center gap-1.5 text-xs font-medium text-gray-500 py-2.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- ── MAIN CONTENT ─────────────────────────────────────────────────── -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ── FOOTER ENTERPRISE ───────────────────────────────────────────── -->
    <footer style="background-color: #0B1220;" role="contentinfo">
      <div class="max-w-7xl mx-auto px-6 pt-16 pb-10">

        <!-- Footer Grid — 5 columns on desktop -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-10 mb-14">

          <!-- Brand col (spans 2 on lg) -->
          <div class="col-span-2 lg:col-span-2">
            <a href="/" class="inline-block mb-5" aria-label="LRA Cloud Ops — Home">
              <img
                src="/logo.svg"
                alt="LRA Cloud Ops"
                class="h-9 w-auto"
                style="filter: brightness(0) invert(1) opacity(0.9);"
              />
            </a>
            <p class="text-sm leading-relaxed mb-6 max-w-xs" style="color: rgba(148,163,184,0.8);">
              Cloud infrastructure, Kubernetes platforms and DevOps automation. Production AWS environments built as code.
            </p>
            <div class="flex gap-2.5 mb-6">
              <a
                href="https://github.com/Liquenson"
                target="_blank"
                rel="noopener noreferrer"
                class="w-9 h-9 flex items-center justify-center rounded-lg transition-all hover:scale-110 hover:bg-white/15"
                style="background: rgba(255,255,255,0.08);"
                aria-label="GitHub"
              >
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              </a>
              <a
                href="https://www.linkedin.com/in/liquenson-ruben-490961269/"
                target="_blank"
                rel="noopener noreferrer"
                class="w-9 h-9 flex items-center justify-center rounded-lg transition-all hover:scale-110 hover:bg-white/15"
                style="background: rgba(255,255,255,0.08);"
                aria-label="LinkedIn"
              >
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
            <div class="flex items-center gap-2 text-sm" style="color: rgba(16,185,129,0.9);">
              <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0" aria-hidden="true"></span>
              <span>Available for new projects</span>
            </div>
          </div>

          <!-- Solutions -->
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest mb-5 text-white">Solutions</h3>
            <ul class="space-y-3">
              {[
                { label: 'Cloud Infrastructure', href: '/cloud-infrastructure' },
                { label: 'Platform Engineering', href: '/platform-engineering' },
                { label: 'DevOps Automation', href: '/devops-automation' },
                { label: 'Observability', href: '/observability' },
              ].map(({ label, href }) => (
                <li>
                  <a
                    href={href}
                    class="text-sm transition-colors hover:text-white"
                    style="color: rgba(148,163,184,0.7);"
                  >{label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Resources -->
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest mb-5 text-white">Resources</h3>
            <ul class="space-y-3">
              {[
                { label: 'Blog', href: '/blog' },
                { label: 'Case Studies', href: '/case-studies' },
                { label: 'GitHub', href: 'https://github.com/Liquenson', external: true },
              ].map(({ label, href, external }) => (
                <li>
                  <a
                    href={href}
                    target={external ? '_blank' : undefined}
                    rel={external ? 'noopener noreferrer' : undefined}
                    class="text-sm transition-colors hover:text-white"
                    style="color: rgba(148,163,184,0.7);"
                  >{label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Company -->
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest mb-5 text-white">Company</h3>
            <ul class="space-y-3">
              {[
                { label: 'About', href: '/sobre-nosotros' },
                { label: 'Contact', href: '/contacto' },
              ].map(({ label, href }) => (
                <li>
                  <a
                    href={href}
                    class="text-sm transition-colors hover:text-white"
                    style="color: rgba(148,163,184,0.7);"
                  >{label}</a>
                </li>
              ))}
              <li class="pt-2">
                <a
                  href="/contacto"
                  class="inline-flex items-center gap-1.5 text-xs font-semibold text-white px-3.5 py-2 rounded-lg transition-all hover:opacity-90"
                  style="background: rgba(37,99,235,0.25); border: 1px solid rgba(37,99,235,0.4);"
                >
                  Book a Consultation
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Footer bottom -->
        <div
          class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-6"
          style="border-top: 1px solid rgba(255,255,255,0.06);"
        >
          <span class="text-xs" style="color: rgba(148,163,184,0.4);">
            © 2026 LRA Cloud Ops. All rights reserved.
          </span>
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-1.5 text-xs" style="color: rgba(148,163,184,0.4);">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block" aria-hidden="true"></span>
              Cloudflare Edge Network
            </div>
            <span style="color: rgba(255,255,255,0.05);" aria-hidden="true">|</span>
            <span class="text-xs font-mono" style="color: rgba(148,163,184,0.25);">v3.0</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- ── Scripts ──────────────────────────────────────────────────────── -->
    <script>
      const menuBtn   = document.getElementById('menu-btn')
      const drawer    = document.getElementById('mobile-drawer')
      const overlay   = document.getElementById('mobile-overlay')
      const bar1      = document.getElementById('bar1')
      const bar2      = document.getElementById('bar2')
      const bar3      = document.getElementById('bar3')
      let isOpen = false

      function openMenu() {
        isOpen = true
        drawer?.style && (drawer.style.transform = 'translateX(0)')
        if (overlay) { overlay.style.opacity = '1'; overlay.style.pointerEvents = 'auto' }
        document.body.style.overflow = 'hidden'
        if (bar1) bar1.style.transform = 'translateY(6px) rotate(45deg)'
        if (bar2) bar2.style.opacity = '0'
        if (bar3) bar3.style.transform = 'translateY(-6px) rotate(-45deg)'
        menuBtn?.setAttribute('aria-expanded', 'true')
      }

      function closeMenu() {
        isOpen = false
        drawer?.style && (drawer.style.transform = 'translateX(100%)')
        if (overlay) { overlay.style.opacity = '0'; overlay.style.pointerEvents = 'none' }
        document.body.style.overflow = ''
        if (bar1) bar1.style.transform = ''
        if (bar2) bar2.style.opacity = '1'
        if (bar3) bar3.style.transform = ''
        menuBtn?.setAttribute('aria-expanded', 'false')
      }

      menuBtn?.addEventListener('click', () => isOpen ? closeMenu() : openMenu())
      overlay?.addEventListener('click', closeMenu)
      document.querySelectorAll('#mobile-drawer a').forEach(l => l.addEventListener('click', closeMenu))
      document.addEventListener('keydown', e => { if (e.key === 'Escape' && isOpen) closeMenu() })

      // Navbar scroll shadow
      const header = document.getElementById('site-header')
      let scrolled = false
      window.addEventListener('scroll', () => {
        const s = window.scrollY > 10
        if (s !== scrolled) {
          scrolled = s
          if (header) {
            header.style.boxShadow = scrolled
              ? '0 1px 0 rgba(15,23,42,0.05), 0 4px 20px rgba(15,23,42,0.07)'
              : 'none'
          }
        }
      }, { passive: true })
    </script>

    <script>
      // Scroll-reveal IntersectionObserver
      const scrollObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible')
          }
        })
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' })

      document.querySelectorAll('.animate-fade-up, .animate-fade-left, .animate-fade, .line-draw')
        .forEach(el => scrollObserver.observe(el))
    </script>

    <script>
      // Animated counters
      function animateCounter(el: Element) {
        const target  = parseInt((el as HTMLElement).dataset.count || '0', 10)
        const suffix  = (el as HTMLElement).dataset.suffix || ''
        const duration = 1800
        const start   = performance.now()
        const step = (now: number) => {
          const progress = Math.min((now - start) / duration, 1)
          const eased    = 1 - Math.pow(1 - progress, 3)
          ;(el as HTMLElement).textContent = Math.round(eased * target) + suffix
          if (progress < 1) requestAnimationFrame(step)
        }
        requestAnimationFrame(step)
      }

      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateCounter(entry.target)
            counterObserver.unobserve(entry.target)
          }
        })
      }, { threshold: 0.5 })

      document.querySelectorAll('.counter-value').forEach(el => counterObserver.observe(el))
    </script>

  </body>
</html>
