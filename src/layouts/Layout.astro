---
import '../styles/global.css'

const { titulo, descripcion } = Astro.props
const currentPath = Astro.url.pathname

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/sobre-nosotros', label: 'Sobre nosotros' },
  { href: '/blog', label: 'Blog' },
]
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LRA Cloud Operations | {titulo}</title>
    <meta name="description" content={descripcion} />
    <meta name="keywords" content="DevOps, AWS, Kubernetes, Terraform, CI/CD, Platform Engineering, Cloud Architecture, Infrastructure as Code, ingenieros DevOps freelance" />
    <meta property="og:title" content={`LRA Cloud Operations | ${titulo}`} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content="https://lracloudops.com" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="LRA Cloud Operations" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`LRA Cloud Operations | ${titulo}`} />
    <meta name="twitter:description" content={descripcion} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "LRA Cloud Operations",
      "url": "https://lracloudops.com",
      "email": "hola@lracloudops.com",
      "description": "Equipo de ingenieros DevOps especializados en AWS, Kubernetes y Terraform",
      "sameAs": [
        "https://www.linkedin.com/in/liquenson-ruben-490961269/",
        "https://github.com/Liquenson"
      ]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-gray-900 antialiased">

    <!-- STICKY NAVBAR -->
    <header id="site-header" class="sticky top-0 z-50 transition-all duration-300" style="background: rgba(255,255,255,0.97); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(10,37,64,0.07);">
      <nav class="max-w-7xl mx-auto px-5 sm:px-6 h-[68px] flex items-center justify-between gap-4">

        <!-- Logo -->
        <a href="/" class="flex-shrink-0 z-50">
          <img src="/logo.svg" alt="LRA Cloud Operations" class="h-[42px] w-auto" />
        </a>

        <!-- Desktop Nav Links -->
        <div class="hidden lg:flex items-center gap-1">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href)
            return (
              <a
                href={href}
                class={`relative text-sm font-medium px-4 py-2.5 rounded-lg transition-all duration-200 group ${
                  isActive
                    ? 'text-[#0A2540] font-semibold'
                    : 'text-[#64748b] hover:text-[#0A2540]'
                }`}
              >
                {label}
                <span class={`absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 rounded-full transition-all duration-200 ${
                  isActive ? 'w-5 opacity-100' : 'w-0 opacity-0 group-hover:w-3 group-hover:opacity-50'
                }`} style="background: #1E6FFF;"></span>
              </a>
            )
          })}
        </div>

        <!-- Desktop Right -->
        <div class="hidden lg:flex items-center gap-3 flex-shrink-0">
          <a
            href="/contacto"
            class="text-sm font-semibold text-white px-5 py-2.5 rounded-xl transition-all duration-200 hover:-translate-y-px active:scale-[0.98]"
            style="background: linear-gradient(135deg, #1E6FFF 0%, #1452cc 100%); box-shadow: 0 2px 8px rgba(30,111,255,0.3), 0 1px 2px rgba(30,111,255,0.15);"
          >
            Contacto
          </a>
        </div>

        <!-- Mobile Hamburger -->
        <button
          id="menu-btn"
          class="lg:hidden relative z-50 w-10 h-10 flex items-center justify-center rounded-xl hover:bg-gray-100/80 transition-colors"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
        >
          <div class="w-5 h-4 flex flex-col justify-between">
            <span id="bar1" class="block h-0.5 bg-gray-800 rounded-full transition-all duration-300 origin-center"></span>
            <span id="bar2" class="block h-0.5 bg-gray-800 rounded-full transition-all duration-300"></span>
            <span id="bar3" class="block h-0.5 bg-gray-800 rounded-full transition-all duration-300 origin-center"></span>
          </div>
        </button>
      </nav>
    </header>

    <!-- Mobile: Backdrop Overlay -->
    <div
      id="mobile-overlay"
      class="fixed inset-0 z-40 lg:hidden pointer-events-none"
      style="background: rgba(10,37,64,0.4); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); opacity: 0; transition: opacity 0.3s ease;"
    ></div>

    <!-- Mobile: Drawer -->
    <div
      id="mobile-drawer"
      class="fixed top-0 right-0 bottom-0 z-40 w-72 lg:hidden flex flex-col"
      style="background: white; transform: translateX(100%); transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: -12px 0 40px rgba(10,37,64,0.12);"
    >
      <!-- Drawer top spacing (below header) -->
      <div class="h-[66px] flex-shrink-0 border-b border-gray-100 flex items-center px-5">
        <span class="text-xs font-semibold uppercase tracking-widest" style="color: #1E6FFF;">Menú</span>
      </div>

      <!-- Nav Links -->
      <nav class="flex-1 overflow-y-auto px-4 py-6">
        <div class="flex flex-col gap-1">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href)
            return (
              <a
                href={href}
                class={`flex items-center gap-3 px-4 py-3.5 rounded-xl text-sm font-medium transition-all ${
                  isActive
                    ? 'font-semibold'
                    : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
                }`}
                style={isActive ? `background: #EEF4FF; color: #0A2540;` : ''}
              >
                {isActive && (
                  <span class="w-1.5 h-5 rounded-full flex-shrink-0" style="background: #1E6FFF;"></span>
                )}
                <span class={isActive ? '' : 'ml-4'}>{label}</span>
              </a>
            )
          })}
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-100 my-4"></div>

        <!-- Extra links -->
        <div class="flex flex-col gap-1">
          <a href="/contacto" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Contacto
          </a>
        </div>
      </nav>

      <!-- Drawer Footer -->
      <div class="flex-shrink-0 px-4 pb-6 pt-4 border-t border-gray-100">
        <a
          href="/contacto"
          class="flex items-center justify-center gap-2 w-full text-sm font-semibold text-white py-3.5 rounded-xl transition-all hover:opacity-90 mb-4"
          style="background: linear-gradient(135deg, #1E6FFF 0%, #0A2540 100%);"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Agenda una consulta
        </a>
        <div class="flex gap-2">
          <a
            href="https://github.com/Liquenson"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex items-center justify-center gap-2 text-xs font-medium text-gray-500 py-2.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/liquenson-ruben-490961269/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex items-center justify-center gap-2 text-xs font-medium text-gray-500 py-2.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer style="background-color: #0A2540;">
      <div class="max-w-7xl mx-auto px-6 pt-16 pb-10">

        <!-- Footer Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">

          <!-- Brand -->
          <div class="col-span-2 md:col-span-1">
            <a href="/" class="inline-block mb-4">
              <img src="/logo.svg" alt="LRA Cloud Operations" class="h-9 w-auto" style="filter: brightness(0) invert(1) opacity(0.9);" />
            </a>
            <p class="text-sm leading-relaxed mb-5" style="color: rgba(147,184,255,0.75);">
              Infraestructura cloud. Automatización real.<br />Resultados medibles.
            </p>
            <div class="flex gap-2.5">
              <a href="https://github.com/Liquenson" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-lg transition-all hover:scale-110" style="background: rgba(255,255,255,0.08);">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              </a>
              <a href="https://www.linkedin.com/in/liquenson-ruben-490961269/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-lg transition-all hover:scale-110" style="background: rgba(255,255,255,0.08);">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Platform -->
          <div>
            <h4 class="text-sm font-semibold text-white mb-5">Plataforma</h4>
            <ul class="space-y-3">
              {[
                { href: '/', label: 'Inicio' },
                { href: '/servicios', label: 'Servicios' },
                { href: '/proyectos', label: 'Proyectos' },
                { href: '/blog', label: 'Blog técnico' },
                { href: '/contacto', label: 'Contacto' },
              ].map(({ href, label }) => (
                <li>
                  <a href={href} class="text-sm transition-colors" style="color: rgba(147,184,255,0.7);" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(147,184,255,0.7)'">{label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Services -->
          <div>
            <h4 class="text-sm font-semibold text-white mb-5">Servicios</h4>
            <ul class="space-y-3">
              {[
                'Cloud Architecture',
                'Infrastructure as Code',
                'Kubernetes & GitOps',
                'CI/CD Pipelines',
                'Observabilidad & SRE',
                'Linux & Automatización',
              ].map(label => (
                <li>
                  <a href="/servicios" class="text-sm transition-colors" style="color: rgba(147,184,255,0.7);" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(147,184,255,0.7)'">{label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="text-sm font-semibold text-white mb-5">Contacto</h4>
            <ul class="space-y-3">
              <li>
                <a href="mailto:hola@lracloudops.com" class="flex items-start gap-2.5 text-sm transition-colors" style="color: rgba(147,184,255,0.7);" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(147,184,255,0.7)'">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  hola@lracloudops.com
                </a>
              </li>
              <li class="mt-2">
                <span class="flex items-center gap-2 text-sm" style="color: rgba(63,185,80,0.9);">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
                  Disponibles para proyectos freelance
                </span>
              </li>
              <li class="mt-4">
                <a
                  href="/contacto"
                  class="inline-flex items-center gap-2 text-sm font-semibold text-white px-4 py-2.5 rounded-lg transition-all hover:opacity-90"
                  style="background: rgba(30,111,255,0.25); border: 1px solid rgba(30,111,255,0.4);"
                >
                  Agenda una consulta
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Footer Bottom -->
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-6" style="border-top: 1px solid rgba(255,255,255,0.06);">
          <span class="text-xs" style="color: rgba(147,184,255,0.4);">
            © 2026 LRA Cloud Operations. Todos los derechos reservados.
          </span>
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-1.5 text-xs" style="color: rgba(147,184,255,0.4);">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block animate-pulse"></span>
              Cloudflare Edge Network
            </div>
            <span style="color: rgba(255,255,255,0.06);">|</span>
            <span class="text-xs font-mono" style="color: rgba(147,184,255,0.25);">v2.0</span>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const menuBtn = document.getElementById('menu-btn')
      const drawer = document.getElementById('mobile-drawer')
      const overlay = document.getElementById('mobile-overlay')
      const bar1 = document.getElementById('bar1')
      const bar2 = document.getElementById('bar2')
      const bar3 = document.getElementById('bar3')
      let isOpen = false

      function openMenu() {
        isOpen = true
        if (drawer) drawer.style.transform = 'translateX(0)'
        if (overlay) {
          overlay.style.opacity = '1'
          overlay.style.pointerEvents = 'auto'
        }
        document.body.style.overflow = 'hidden'
        if (bar1) bar1.style.transform = 'translateY(6px) rotate(45deg)'
        if (bar2) bar2.style.opacity = '0'
        if (bar3) bar3.style.transform = 'translateY(-6px) rotate(-45deg)'
        menuBtn?.setAttribute('aria-expanded', 'true')
      }

      function closeMenu() {
        isOpen = false
        if (drawer) drawer.style.transform = 'translateX(100%)'
        if (overlay) {
          overlay.style.opacity = '0'
          overlay.style.pointerEvents = 'none'
        }
        document.body.style.overflow = ''
        if (bar1) bar1.style.transform = ''
        if (bar2) bar2.style.opacity = '1'
        if (bar3) bar3.style.transform = ''
        menuBtn?.setAttribute('aria-expanded', 'false')
      }

      menuBtn?.addEventListener('click', () => isOpen ? closeMenu() : openMenu())
      overlay?.addEventListener('click', closeMenu)

      document.querySelectorAll('#mobile-drawer a').forEach(link => {
        link.addEventListener('click', closeMenu)
      })

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) closeMenu()
      })

      // Navbar scroll shadow enhancement
      const header = document.getElementById('site-header')
      let scrolled = false
      window.addEventListener('scroll', () => {
        const isScrolled = window.scrollY > 10
        if (isScrolled !== scrolled) {
          scrolled = isScrolled
          if (header) {
            header.style.boxShadow = scrolled
              ? '0 1px 0 rgba(10,37,64,0.06), 0 4px 24px rgba(10,37,64,0.08)'
              : 'none'
          }
        }
      }, { passive: true })
    </script>

    <script>
      const scrollObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible')
          }
        })
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' })

      document.querySelectorAll('.animate-fade-up, .animate-fade-left, .animate-fade, .line-draw')
        .forEach(el => scrollObserver.observe(el))
    </script>

  </body>
</html>
