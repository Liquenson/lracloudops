---
import '../styles/global.css'

const { titulo, descripcion } = Astro.props
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titulo} | LRA Cloud Operations</title>
    <meta name="description" content={descripcion} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content="https://lracloudops.com" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-gray-900 antialiased">

    <header class="border-b border-gray-100 sticky top-0 bg-white z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="font-medium text-gray-900 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-teal-500 inline-block"></span>
          LRA Cloud Operations
        </a>
        <div class="flex items-center gap-8">
          <a href="/servicios" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Servicios</a>
          <a href="/blog" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Blog</a>
          <a href="/contacto" class="text-sm font-medium text-teal-600 border border-teal-600 px-4 py-1.5 rounded-md hover:bg-teal-50 transition-colors">Contactar</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-100 mt-24">
      <div class="max-w-5xl mx-auto px-6 py-8 flex justify-between items-center text-sm text-gray-400">
        <span>© 2026 LRA Cloud Operations</span>
        <div class="flex gap-6">
          <a href="https://github.com/Liquenson" class="hover:text-gray-600 transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/liquenson-ruben-490961269/" class="hover:text-gray-600 transition-colors">LinkedIn</a>
        </div>
      </div>
    </footer>

  </body>
</html>
